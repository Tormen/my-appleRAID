set -u  # Treat unset variables as errors (but NOT -e: we want to handle
        # errors ourselves and keep interactive flow alive).

# ----------------------------------------------------------------------
# Colors (only if stdout is a terminal)
# ----------------------------------------------------------------------
if [ -t 1 ]; then
    C_BOLD=$(printf '\033[1m')
    C_DIM=$(printf '\033[2m')
    C_RED=$(printf '\033[31m')
    C_GREEN=$(printf '\033[32m')
    C_YELLOW=$(printf '\033[33m')
    C_BLUE=$(printf '\033[34m')
    C_CYAN=$(printf '\033[36m')
    C_RESET=$(printf '\033[0m')
else
    C_BOLD=''
    C_DIM=''
    C_RED=''
    C_GREEN=''
    C_YELLOW=''
    C_BLUE=''
    C_CYAN=''
    C_RESET=''
fi

SCRIPT_NAME="$(basename "$0")"

# Version: bump in lockstep with the git tag.
# SCRIPT_COMMIT is baked into the file itself so deployed copies
# (e.g. on ada, which has no .git alongside the script) still print
# the commit they were built from. The companion 'stamp-version'
# subcommand updates SCRIPT_COMMIT to the current HEAD sha and
# amends - run it as the last step before deploying.
SCRIPT_VERSION="v7"
SCRIPT_COMMIT="d5e7174"
SCRIPT_COPYRIGHT="Copyright (C) 2026 Tormen <tormen@mail.ch>"
SCRIPT_LICENSE_SHORT="GPL-3.0-or-later (copyleft)"
SCRIPT_LICENSE_URL="https://www.gnu.org/licenses/gpl-3.0.html"

# Augment PATH for the launchd context.
# launchd starts daemons with a minimal PATH (/usr/bin:/bin:/usr/sbin:/sbin)
# that excludes both Homebrew prefixes - which means smartctl, msmtp,
# and any other Homebrew-installed tool would be invisible to the
# health daemon even when present on the box. Append both Homebrew
# bin dirs (no-op when already in PATH or when the dir doesn't exist).
for _hbprefix in /opt/homebrew/bin /usr/local/bin; do
    case ":${PATH:-}:" in
        *":$_hbprefix:"*) ;;
        *) [ -d "$_hbprefix" ] && PATH="${PATH:-}${PATH:+:}$_hbprefix" ;;
    esac
done
export PATH
unset _hbprefix

# ----------------------------------------------------------------------
# Global verbosity flags.
# Set by parse_global_flags(), which is called both at the top of main()
# and by individual subcommands that want to accept these flags in any
# position (before or after the subcommand name).
#
# VERBOSE=1  -> LOG_LEVEL=debug + subcommand-specific extra detail
# DEBUG=1    -> everything VERBOSE does + shell tracing (set -x) +
#               `run` echoes every subprocess invocation at debug level
#
# If both are passed, DEBUG wins.
# ----------------------------------------------------------------------
VERBOSE=0
DEBUG=0

# Parse -V/--verbose and -D/--debug from an argv list. Because this
# function has to run in a $(...) subshell to feed its output back to
# the caller (variable assignments inside a subshell don't escape),
# we emit a snippet of shell code that the caller evaluates via `eval`.
# That snippet sets VERBOSE/DEBUG/LOG_LEVEL and positional params in
# the caller's own shell.
#
# IMPORTANT: the emitted snippet only RAISES the verbosity level. If
# the caller's VERBOSE or DEBUG is already set from a prior parse
# (e.g. main() parsed '-V' and then dispatched to a subcommand which
# also re-parses its own argv), this re-parse must not clobber the
# earlier state back to zero. We therefore read the current values of
# VERBOSE/DEBUG at eval time and only turn them on, never off.
#
# Idiomatic use:
#     eval "$(parse_global_flags "$@")"
parse_global_flags() {
    _v=0; _d=0
    _args=""
    for _arg in "$@"; do
        case "$_arg" in
            -V|--verbose) _v=1 ;;
            -D|--debug)   _d=1; _v=1 ;;
            *)
                # Shell-safe single-quote: wrap, escape any embedded "'"
                # by closing the quote, emitting \' , then re-opening.
                _q=$(printf "%s" "$_arg" | sed "s/'/'\\\\''/g")
                _args="$_args '$_q'"
                ;;
        esac
    done

    # Emit code that ORs in the new flag values rather than replacing
    # them. Using arithmetic evaluation: any prior 1 stays 1.
    # shellcheck disable=SC2016  # arithmetic intentionally literal;
                                 # the caller's eval expands it.
    printf 'VERBOSE=$((VERBOSE | %d)); DEBUG=$((DEBUG | %d));' "$_v" "$_d"
    # LOG_LEVEL: only escalate if we actually saw a flag this call
    # (otherwise leave caller's choice untouched).
    if [ "$_d" = "1" ] || [ "$_v" = "1" ]; then
        printf ' LOG_LEVEL=debug;'
    fi
    printf ' set --%s' "$_args"
}

# ----------------------------------------------------------------------
# Logging helpers
# ----------------------------------------------------------------------
info()    { printf '%s[INFO]%s %s\n'  "${C_BLUE}"   "${C_RESET}" "$*"; }
ok()      { printf '%s[ OK ]%s %s\n'  "${C_GREEN}"  "${C_RESET}" "$*"; }
warn()    { printf '%s[WARN]%s %s\n'  "${C_YELLOW}" "${C_RESET}" "$*" >&2; }
errmsg()     { printf '%s[FAIL]%s %s\n'  "${C_RED}"    "${C_RESET}" "$*" >&2; }
step()    { printf '\n%s=== %s ===%s\n' "${C_BOLD}${C_CYAN}" "$*" "${C_RESET}"; }
explain() { printf '%s%s%s\n' "${C_DIM}" "$*" "${C_RESET}"; }

# Print a command (with optional sudo) in bold, then execute it.
# Use: run <cmd> <arg1> <arg2> ...
run() {
    printf '%s$ %s%s\n' "${C_BOLD}" "$*" "${C_RESET}"
    "$@"
}

# Print a command without running it (for "dry" illustrations).
show() {
    printf '%s$ %s%s\n' "${C_DIM}" "$*" "${C_RESET}"
}

# Ask yes/no (default NO). Returns 0 on yes, 1 on no.
confirm() {
    prompt="$1"
    printf '%s%s%s (yes/no) ' "${C_YELLOW}" "$prompt" "${C_RESET}"
    read -r answer || return 1
    [ "$answer" = "yes" ] || [ "$answer" = "y" ] || [ "$answer" = "YES" ]
}

# Press-enter-to-continue gate.
pause() {
    printf '%sPress Enter to continue...%s ' "${C_DIM}" "${C_RESET}"
    read -r _dummy || true
}

die() {
    errmsg "$*"
    exit 1
}

# ----------------------------------------------------------------------
# err - hard-fail with a UNIQUE numeric error code so post-mortem
# debugging can grep the source for the exact origin of any error
# the user sees in the terminal. Use this for any newly-added
# failure path. The 'errmsg' helper above is the non-exiting
# message-only variant, kept for the existing log-style call sites
# whose flow continues past the message.
#
# Usage:   err <code> [<msg>] [<exitCode>]
# Output:  "ERROR <code> [<exitCode>]: <msg>" on stderr, then exit.
#          (no message form: "ERROR <code> [<exitCode>]")
#
# Idiomatic call site:
#
#       command || err 022 "optional message"
#
# Error-code registry (keep in sync with the call sites; grep for
# 'err 0' / 'err [0-9]'). When adding a new err call site, take the
# NEXT unused 3-digit number and bump _ERR_HIGHEST below.
#
#   010   STATE_DIR not writable AND fallback under TMPDIR also failed
#   011   LOG_FILE parent dir not writable (reserved; soft-fallback)
#   012   smart-dtype-cache: mktemp for atomic rewrite failed
#   013   smart-dtype-cache: awk rewrite OR write of cache row failed
#   014   install-daemon: writing the LaunchDaemon plist failed
#   015   install-daemon: chown root:wheel of plist failed
#   016   install-daemon: chmod 644 of plist failed
#   017   uninstall-daemon: rm of LaunchDaemon plist failed
#   018   state-DB: mktemp for state-put atomic rewrite failed
#   019   state-DB: awk rewrite during state-put failed
#   020   state-DB: append of new row during state-put failed
#   021   state-DB: atomic rename during state-put failed
#   022   state-DB: awk rewrite during state-delete failed
#   023   state-DB: atomic rename during state-delete failed
#
# _ERR_HIGHEST=023
# ----------------------------------------------------------------------
err() {
    _ec_code="$1"
    _ec_msg="${2:-}"
    _ec_exit="${3:-1}"
    if [ -n "$_ec_msg" ]; then
        printf '\n%sERROR %s [%s]: %s%s\n' \
            "${C_RED}" "$_ec_code" "$_ec_exit" "$_ec_msg" "${C_RESET}" >&2
    else
        printf '\n%sERROR %s [%s]%s\n' \
            "${C_RED}" "$_ec_code" "$_ec_exit" "${C_RESET}" >&2
    fi
    exit "$_ec_exit"
}

# ----------------------------------------------------------------------
# State-dir + log-file writability gate
# ----------------------------------------------------------------------
# When the daemon runs (root via launchd), STATE_DIR=/var/db/my-appleRAID
# and LOG_FILE=/var/log/.../my-appleRAID.log are owned by root and
# fully writable. When a NON-root user runs the script for read-only
# commands (e.g. 'my-appleRAID smart disk7') those paths are NOT
# writable by them, and unguarded redirects produced cascades of
# 'Permission denied' / 'mkstemp failed' / 'awk: can't open' spam.
#
# Solution: detect non-writability at startup and fall back to a
# user-private path under TMPDIR. The daemon path is unchanged
# (root can write the canonical paths). Both functions log a single
# warning when the fallback kicks in, so the user knows what happened.

# Make STATE_DIR a writable directory, falling back to a user-private
# tmp dir when the configured value isn't writable by the current uid.
#
# We remember the FALLBACK TARGET in $_STATE_DIR_FALLBACK so this
# function is idempotent across repeated calls AND across cfg_load
# invocations (cfg_set_defaults unconditionally resets STATE_DIR to
# the system default; without the saved-target re-apply step a
# subsequent cfg_load would silently put STATE_DIR back to the
# unwritable system path while the sentinel-style early-return
# prevented re-detection).
_STATE_DIR_FALLBACK=""
_ensure_state_dir_writable() {
    [ -n "${STATE_DIR:-}" ] || STATE_DIR="/var/db/my-appleRAID"
    # If we already decided on a fallback path, re-apply it silently.
    # Handles the cfg_set_defaults-reset-after-fallback case.
    if [ -n "$_STATE_DIR_FALLBACK" ]; then
        STATE_DIR="$_STATE_DIR_FALLBACK"
        return 0
    fi
    # Already writable: done.
    if [ -d "$STATE_DIR" ] && [ -w "$STATE_DIR" ]; then
        return 0
    fi
    # Doesn't exist yet but we can create it.
    if [ ! -d "$STATE_DIR" ] \
       && mkdir -p "$STATE_DIR" 2>/dev/null \
       && [ -w "$STATE_DIR" ]; then
        return 0
    fi
    # Not writable. Fall back to user-private location.
    _fb="${TMPDIR:-/tmp}/my-appleRAID-$(id -u 2>/dev/null || echo nobody)"
    if [ ! -d "$_fb" ] && ! mkdir -p "$_fb" 2>/dev/null; then
        err 010 "Cannot write to STATE_DIR='$STATE_DIR' AND fallback '$_fb' creation failed"
    fi
    if [ ! -w "$_fb" ]; then
        err 010 "Fallback state dir '$_fb' is not writable"
    fi
    log_warn "STATE_DIR='$STATE_DIR' not writable by uid=$(id -u 2>/dev/null); using fallback: $_fb"
    STATE_DIR="$_fb"
    _STATE_DIR_FALLBACK="$_fb"
    return 0
}

# Decide once whether LOG_FILE can be appended to. If it can't, NULL
# the variable so log_write skips the file-append branch silently.
# Avoids cascading 'cannot create <path>: Permission denied' messages
# from the shell for every log line.
#
# Tri-state: $_LOG_FILE_DECIDED in {"", "ok", "skip"}.
#   ""    = not yet decided
#   "ok"  = LOG_FILE is the canonical writable path
#   "skip"= file logging disabled for this run (LOG_FILE re-NULLed)
# This makes the function idempotent across cfg_load calls
# (cfg_set_defaults resets LOG_FILE to the system default; without
# the saved-decision re-apply step a sentinel-style early-return
# would let LOG_FILE come back as the unwritable canonical path,
# re-triggering the redirect-open errors log_write tries to suppress).
_LOG_FILE_DECIDED=""
_ensure_log_file_writable() {
    if [ "$_LOG_FILE_DECIDED" = "skip" ]; then
        LOG_FILE=""
        return 0
    fi
    [ "$_LOG_FILE_DECIDED" = "ok" ] && return 0
    [ -n "${LOG_FILE:-}" ] || { _LOG_FILE_DECIDED=ok; return 0; }
    _ld=$(dirname "$LOG_FILE")
    # If the log file already exists, we can append iff it's writable.
    if [ -f "$LOG_FILE" ] && [ -w "$LOG_FILE" ]; then
        _LOG_FILE_DECIDED=ok
        return 0
    fi
    # If parent dir exists and is writable, file can be created.
    if [ -d "$_ld" ] && [ -w "$_ld" ]; then
        _LOG_FILE_DECIDED=ok
        return 0
    fi
    # Try to create the parent dir (only if path looks user-private).
    case "$_ld" in
        /var/*|/etc/*|/usr/*) ;; # don't create system paths from here
        *)
            if mkdir -p "$_ld" 2>/dev/null && [ -w "$_ld" ]; then
                _LOG_FILE_DECIDED=ok
                return 0
            fi
            ;;
    esac
    # Not writable. Disable file logging for this run and warn once.
    log_warn "LOG_FILE='$LOG_FILE' not writable by uid=$(id -u 2>/dev/null); file logging disabled for this run (stderr still active)"
    LOG_FILE=""
    _LOG_FILE_DECIDED=skip
    return 0
}

# ----------------------------------------------------------------------
# Preflight
# ----------------------------------------------------------------------
preflight() {
    # macOS check
    if [ "$(uname)" != "Darwin" ]; then
        die "This script requires macOS (uname reports: $(uname))"
    fi

    # Tool check
    for tool in diskutil dd awk grep plutil; do
        if ! command -v "$tool" >/dev/null 2>&1; then
            die "Required tool not found: $tool"
        fi
    done
}

# ----------------------------------------------------------------------
# Disk helpers
# ----------------------------------------------------------------------

# Resolve a user-supplied number (e.g. "3") or name (e.g. "disk3" or
# "/dev/disk3") into a canonical device path "/dev/diskN".
resolve_disk() {
    input="$1"
    case "$input" in
        # /dev/diskNsM (a partition) -> walk up to the whole disk.
        /dev/disk[0-9]*s[0-9]*)
            base=$(printf '%s' "$input" | sed 's|^/dev/||; s/s[0-9]*$//')
            echo "/dev/$base"
            ;;
        /dev/disk[0-9]*) echo "$input" ;;
        disk[0-9]*s[0-9]*)
            base=$(printf '%s' "$input" | sed 's/s[0-9]*$//')
            echo "/dev/$base"
            ;;
        disk[0-9]*)      echo "/dev/$input" ;;
        [0-9]*)          echo "/dev/disk$input" ;;
        # Anything else starting with '/' is treated as a mount path
        # (e.g. '/Volumes/backup', '/' for the boot volume, ...).
        # Walk diskutil's hierarchy to the underlying physical disk:
        #
        #   /Volumes/foo  -> diskNs1            (the volume)
        #                 -> diskN              (Part of Whole: synthesized
        #                                        APFS container, virtual)
        #                 -> APFS Physical Store: diskM
        #                 -> diskM              (the AppleRAID virtual
        #                                        device, OR a real
        #                                        physical disk)
        #
        # If after this walk the result is still virtual (e.g. an
        # AppleRAID-backed APFS where the physical store IS the
        # AppleRAID virtual device), we return that. Caller's
        # assert_safe_target / assert_whole_disk will then fail with
        # a clear 'VIRTUAL device' message - the user has to specify
        # a specific physical member instead.
        /*)
            di=$(diskutil info "$input" 2>/dev/null) || return 1
            [ -n "$di" ] || return 1
            parent=$(printf '%s\n' "$di" \
                | awk -F': +' '/Part of Whole:/ {print $2; exit}' \
                | sed 's/[[:space:]]*$//')
            [ -n "$parent" ] || return 1
            # Second hop: if the parent is virtual AND we see an APFS
            # Physical Store on the original (or parent) info, follow it.
            di2=$(diskutil info "/dev/$parent" 2>/dev/null)
            virt2=$(printf '%s\n' "$di2" \
                | awk -F': +' '/Virtual:/ {print $2; exit}' \
                | sed 's/[[:space:]]*$//')
            if [ "$virt2" = "Yes" ]; then
                phys=$(printf '%s\n' "$di" \
                    | awk -F': +' '/APFS Physical Store/ {print $2; exit}' \
                    | sed 's/[[:space:]]*$//')
                if [ -z "$phys" ]; then
                    phys=$(printf '%s\n' "$di2" \
                        | awk -F': +' '/APFS Physical Store/ {print $2; exit}' \
                        | sed 's/[[:space:]]*$//')
                fi
                if [ -n "$phys" ]; then
                    # phys may be 'diskN' or 'diskNsM'; drop a partition
                    # suffix if present.
                    parent=$(printf '%s' "$phys" | sed 's/s[0-9]*$//')
                fi
            fi
            echo "/dev/$parent"
            ;;
        *) return 1 ;;
    esac
}

# Confirm device exists and is a whole disk (not a partition).
assert_whole_disk() {
    dev="$1"
    if ! diskutil info "$dev" >/dev/null 2>&1; then
        die "Device not found: $dev"
    fi
    # Whole disks have 'Whole: Yes' in diskutil info.
    whole=$(diskutil info "$dev" | awk -F': *' '/Whole:/ {print $2; exit}')
    if [ "$whole" != "Yes" ]; then
        die "$dev is not a whole disk (likely a partition). Pass the parent disk."
    fi
}

# Reject devices that should never be wiped or used as a RAID member:
#   - internal system disks (prevent catastrophic mistakes)
#   - virtual disks (AppleRAID virtual device, APFS synthesized)
#   - disks currently acting as a RAID member for some existing set
assert_safe_target() {
    dev="$1"
    short="${dev#/dev/}"

    # Check Virtual flag
    virt=$(diskutil info "$dev" 2>/dev/null | awk -F': *' '/Virtual:/ {print $2; exit}')
    if [ "$virt" = "Yes" ]; then
        die "$dev is a VIRTUAL device (RAID/APFS container). Refusing to use as a target."
    fi

    # Check Internal flag - refuse unless user types an extra 'yes-internal'
    internal=$(diskutil info "$dev" 2>/dev/null | awk -F': *' '/Internal:/ {print $2; exit}')
    if [ "$internal" = "Yes" ]; then
        warn "$dev is an INTERNAL disk!"
        warn "This is most likely your system drive. Using it as a RAID target will DESTROY macOS."
        confirm "Type 'yes' only if you are ABSOLUTELY certain this is the right disk" \
            || die "Aborted - internal disk safety check."
    fi

    # Check if this disk is already a RAID member of any existing set.
    # diskutil appleRAID list reports member DevNodes like 'disk2s2' - we match disk2.
    if diskutil appleRAID list 2>/dev/null \
         | awk '/^[0-9-]+[ \t]+disk/ {print $2}' \
         | sed 's/s[0-9]*$//' \
         | grep -qx "$short"; then
        # Look up the set name for the diagnostic.
        _set_name=$(diskutil appleRAID list 2>/dev/null | awk -v d="$short" '
            /^Name:/      { sub(/^Name:[[:space:]]+/, ""); n = $0; sub(/[[:space:]]+$/, "", n) }
            /^[0-9-]+[[:space:]]+disk[0-9]+/ {
                k = split($0, p, /[[:space:]]+/)
                j = 0
                for (i = 1; i <= k; i++) if (p[i] != "") { j++; if (j == 2) bsd = p[i] }
                base = bsd; sub(/s[0-9]+$/, "", base)
                if (base == d) { print n; exit }
            }
        ')
        errmsg "$dev is currently a member of an existing AppleRAID set${_set_name:+ '$_set_name'}."
        explain "Two ways to proceed:"
        explain "  - Destroy the set first:  $SCRIPT_NAME destroy${_set_name:+ '$_set_name'}"
        explain "  - Re-run 'create' with --force, which will release just the target"
        explain "    disk(s) from their set and keep the set alive (Degraded with the"
        explain "    remaining members), or destroy the set only if all of its members"
        explain "    are among the targets. After a confirmation prompt:"
        explain "      $SCRIPT_NAME create <name> <N1> <N2> --force"
        die "Aborted - target disk in use by another set."
    fi
}

# Free target disks from any AppleRAID set that currently claims them.
# Called by 'cmd_create' when --force is passed.
#
# Two cases per set the target disks belong to:
#
#   - Set has OTHER members that are NOT being targeted: just REMOVE
#     the target disk(s) via 'diskutil appleRAID remove'. The set stays
#     alive (Degraded with the remaining members) - their data is
#     preserved. Less destructive.
#
#   - All members of the set are target disks (no survivors): DELETE
#     the entire set via 'diskutil appleRAID delete'. There's no
#     remaining member to keep the set alive, so 'remove' would just
#     end up empty. Same end result, cleaner.
#
# Both paths are still destructive on the released disks themselves
# (their Apple_RAID partition is freed; data on the released-disk side
# of the mirror is lost). The confirmation prompt makes that explicit.
release_disks_from_existing_raids() {
    raid_list_text=$(diskutil appleRAID list 2>/dev/null) || return 0
    [ -n "$raid_list_text" ] || return 0

    # For each target disk, find the (set-uuid, set-name, member-uuid)
    # tuple identifying its slot in the set. Build a newline-separated
    # list of "dev|set_uuid|set_name|member_uuid".
    targets_in_raids=""
    for _dev in "$@"; do
        _short="${_dev#/dev/}"
        _hit=$(printf '%s\n' "$raid_list_text" | awk -v d="$_short" '
            /^Name:/         { sub(/^Name:[[:space:]]+/, ""); name = $0; sub(/[[:space:]]+$/, "", name) }
            /^Unique ID:/    { sub(/^Unique ID:[[:space:]]+/, ""); uuid = $0; sub(/[[:space:]]+$/, "", uuid) }
            /^[0-9-]+[[:space:]]+disk[0-9]+/ {
                k = split($0, p, /[[:space:]]+/)
                j = 0
                for (i = 1; i <= k; i++) if (p[i] != "") {
                    j++
                    if (j == 2) bsd   = p[i]
                    if (j == 3) muuid = p[i]
                }
                base = bsd; sub(/s[0-9]+$/, "", base)
                if (base == d) { printf "%s|%s|%s\n", uuid, name, muuid; exit }
            }
        ')
        if [ -n "$_hit" ]; then
            targets_in_raids="${targets_in_raids}${_dev}|${_hit}
"
        fi
    done
    [ -n "$targets_in_raids" ] || return 0

    # How many members each affected set has TOTAL, so we can decide
    # delete-vs-remove per set.
    set_total_count=$(printf '%s\n' "$raid_list_text" | awk '
        /^Unique ID:/ { sub(/^Unique ID:[[:space:]]+/, ""); uuid = $0; sub(/[[:space:]]+$/, "", uuid); cnt[uuid] = 0 }
        /^[0-9-]+[[:space:]]+disk[0-9]+/ { if (uuid != "") cnt[uuid]++ }
        END { for (u in cnt) print cnt[u] " " u }
    ')

    # How many of each set's members are target disks.
    set_target_count=$(printf '%s\n' "$targets_in_raids" \
        | awk -F'|' 'NF>0 {print $2}' | sort | uniq -c \
        | awk '{print $1, $2}')

    # Classify per row: remove vs delete.
    members_to_remove=""
    sets_to_delete=""
    while IFS='|' read -r _dev _suuid _sname _muuid; do
        [ -n "$_dev" ] || continue
        _tcount=$(printf '%s\n' "$set_target_count" | awk -v u="$_suuid" '$2==u {print $1; exit}')
        _ncount=$(printf '%s\n' "$set_total_count"  | awk -v u="$_suuid" '$2==u {print $1; exit}')
        if [ -n "$_tcount" ] && [ -n "$_ncount" ] \
           && [ "$_tcount" -ge "$_ncount" ] 2>/dev/null; then
            # No survivors will remain - delete the set.
            _entry="${_suuid}|${_sname}"
            if ! printf '%s' "$sets_to_delete" | grep -qxF "$_entry"; then
                sets_to_delete="${sets_to_delete}${_entry}
"
            fi
        else
            # Survivors remain - remove just this member.
            members_to_remove="${members_to_remove}${_dev}|${_suuid}|${_sname}|${_muuid}
"
        fi
    done <<EOF
$targets_in_raids
EOF

    # Plan + confirm.
    warn "--force: existing AppleRAID configuration will be modified:"
    if [ -n "$members_to_remove" ]; then
        warn "  Disks to be REMOVED from their set (set stays alive, becomes Degraded):"
        while IFS='|' read -r _d _u _n _m; do
            [ -n "$_d" ] || continue
            warn "    - $_d  (member $_m of set '$_n')"
        done <<EOF
$members_to_remove
EOF
    fi
    if [ -n "$sets_to_delete" ]; then
        warn "  Sets to be DESTROYED entirely (all members are among the targets):"
        while IFS='|' read -r _u _n; do
            [ -n "$_u" ] || continue
            warn "    - '$_n' ($_u)"
        done <<EOF
$sets_to_delete
EOF
    fi
    echo
    explain "Data on the released disks themselves will be lost; data on any"
    explain "surviving members of degraded-but-kept sets is PRESERVED."
    confirm "PROCEED?" || die "Aborted."

    # Execute: removes first, then deletes.
    while IFS='|' read -r _d _u _n _m; do
        [ -n "$_d" ] || continue
        step "Removing $_d (member $_m) from set '$_n'"
        run sudo diskutil appleRAID remove "$_m" "$_u" \
            || die "Failed to remove $_d from '$_n' - cannot proceed."
        ok "$_d released; set '$_n' is now Degraded but alive."
    done <<EOF
$members_to_remove
EOF

    while IFS='|' read -r _u _n; do
        [ -n "$_u" ] || continue
        step "Destroying set '$_n' ($_u) - no surviving members"
        run sudo diskutil appleRAID delete "$_u" \
            || die "Failed to delete '$_n' - cannot proceed."
        ok "Set '$_n' destroyed."
    done <<EOF
$sets_to_delete
EOF
}

# Print a one-line summary for a disk.
describe_disk() {
    dev="$1"
    size=$(diskutil info "$dev" 2>/dev/null | awk -F': *' '/Disk Size:/ {print $2; exit}')
    proto=$(diskutil info "$dev" 2>/dev/null | awk -F': *' '/Protocol:/ {print $2; exit}')
    model=$(diskutil info "$dev" 2>/dev/null | awk -F': *' '/Device \/ Media Name:/ {print $2; exit}')
    printf '  %s  size=%s  proto=%s  model=%s\n' "$dev" "${size:-?}" "${proto:-?}" "${model:-?}"
}

# Get disk size in bytes.
disk_size_bytes() {
    dev="$1"
    diskutil info "$dev" 2>/dev/null | awk -F'[()]' '/Disk Size/ {print $2; exit}' | awk '{print $1}'
}

# ----------------------------------------------------------------------
# RAID helpers
# ----------------------------------------------------------------------

# List all AppleRAID set UUIDs.
raid_list_uuids() {
    diskutil appleRAID list 2>/dev/null | awk '/^Unique ID:/ {print $3}'
}

# Given a RAID set UUID, return its virtual device node (e.g. "disk4").
raid_uuid_to_device() {
    uuid="$1"
    diskutil appleRAID list 2>/dev/null | awk -F': +' -v u="$uuid" '
        /^Unique ID:/   { cur = $2; sub(/ +$/, "", cur) }
        /^Device Node:/ { dev = $2; sub(/ +$/, "", dev); if (cur == u) { print dev; exit } }
    '
}

# Given a RAID set name, return its UUID.
# Uses ': *' separator + trim to handle names with spaces.
raid_name_to_uuid() {
    name="$1"
    diskutil appleRAID list 2>/dev/null | awk -F': +' -v n="$name" '
        /^Name:/       { cur = $2; sub(/ +$/, "", cur) }
        /^Unique ID:/  { uuid = $2; sub(/ +$/, "", uuid); if (cur == n) { print uuid; exit } }
    '
}

# Read the AppleRAID `Rebuild` (AutoRebuild) flag for a set, via ioreg.
# Returns "1" (automatic) or "0" (manual). Empty string if the set isn't
# in ioreg yet (extremely rare; only during a brief window right after
# create).
#
# `diskutil appleRAID list` does NOT expose this field at any output
# level (verified empirically). ioreg is the only userspace read path.
# Each set appears twice in `ioreg -arc AppleRAIDSet` (once for the
# AppleRAIDSet object, once for the synthesized IOMedia child); we
# dedupe on AppleRAID-SetUUID.
raid_ar_get() {
    uuid="$1"
    [ -n "$uuid" ] || return 0
    ioreg -arc AppleRAIDSet 2>/dev/null | python3 -c '
import sys, plistlib
d = plistlib.loads(sys.stdin.buffer.read())
target = sys.argv[1]
seen = set()
for e in d:
    u = e.get("AppleRAID-SetUUID")
    if u != target or u in seen: continue
    seen.add(u)
    print(1 if e.get("AppleRAID-AutoRebuild") else 0)
    break
' "$uuid" 2>/dev/null
}

# Read the AppleRAID `SetTimeout` (seconds) for a set, via ioreg.
# Empty string if not found. Same source-of-truth caveats as raid_ar_get.
raid_st_get() {
    uuid="$1"
    [ -n "$uuid" ] || return 0
    ioreg -arc AppleRAIDSet 2>/dev/null | python3 -c '
import sys, plistlib
d = plistlib.loads(sys.stdin.buffer.read())
target = sys.argv[1]
seen = set()
for e in d:
    u = e.get("AppleRAID-SetUUID")
    if u != target or u in seen: continue
    seen.add(u)
    v = e.get("AppleRAID-SetTimeout")
    if v is not None: print(v)
    break
' "$uuid" 2>/dev/null
}

# Apply the DEFAULT_AUTO_REBUILD config policy to a single set:
#   DEFAULT_AUTO_REBUILD=""    : skip (no enforcement)
#   DEFAULT_AUTO_REBUILD=0|1   : ensure AR matches; only call diskutil
#                                 update if there's a drift (AppleRAID
#                                 returns -69848 for no-op writes on
#                                 freshly-created mirrors, so always
#                                 read-current-first).
# Logs at info level when a change is made; silent when already in sync.
# Returns 0 on success or no-op, 1 on update failure.
# Per-set override file. Written by 'autorebuild <set> on|off' to
# record an explicit user choice that the daemon's enforcement must
# respect. Cleared by 'autorebuild <set> reset' (or by the user
# manually rm-ing the file).
ar_override_file() { echo "${STATE_DIR}/ar-override-$1"; }

enforce_default_ar_for_uuid() {
    uuid="$1"
    [ -n "$uuid" ] || return 0
    target="${DEFAULT_AUTO_REBUILD-1}"
    [ -z "$target" ] && return 0   # enforcement disabled
    case "$target" in
        0|1) ;;
        *)
            log_warn "DEFAULT_AUTO_REBUILD=$target is not 0/1/empty; skipping enforcement on $uuid"
            return 0
            ;;
    esac
    # User-explicit override: if 'autorebuild <set> on|off' wrote an
    # override file for this set, respect it - the daemon must NOT
    # silently revert what the user explicitly chose. The user can
    # remove the override with 'autorebuild <set> reset'.
    _ovr_file=$(ar_override_file "$uuid")
    if [ -f "$_ovr_file" ]; then
        log_debug "  $uuid: skipping enforcement - per-set override in effect (run 'autorebuild $uuid reset' to clear)"
        return 0
    fi
    current=$(raid_ar_get "$uuid")
    if [ "$current" = "$target" ]; then
        log_debug "  $uuid: AutoRebuild already $target (no change)"
        return 0
    fi

    # Skip enforcement when flipping AR=0 would abort an in-flight or
    # pending rebuild. Specifically:
    #
    #   - 'diskutil appleRAID repairMirror' adds the new disk as a hot
    #     SPARE; the kernel only promotes that Spare to a Rebuilding
    #     member while AutoRebuild=1. If we flip back to 0 before the
    #     promotion completes, the Spare freezes and the mirror stays
    #     incomplete forever (empirically observed on 'weg' rebuild).
    #
    #   - A member already in 'Rebuilding' state means a rebuild is
    #     actively running; AutoRebuild gates STARTING new ones, not
    #     finishing ones already in progress, but flipping mid-flight
    #     gives the kernel one more reason to be confused.
    #
    # When we want to flip AR=0 (target=0) and any member is in such a
    # state, log the reason and leave the current AR alone. The next
    # health pass will re-evaluate; once the rebuild finishes and all
    # members are Online, enforcement will then succeed normally.
    if [ "$target" = "0" ]; then
        members_status=$(diskutil appleRAID list "$uuid" 2>/dev/null \
            | awk '/^[0-9-][[:space:]]+disk/ {
                # Status occupies columns 4..N-1 (size is last); collect
                # every word from $4 onward except $NF.
                s = ""
                for (i = 4; i < NF; i++) s = (s ? s " " : "") $i
                print s
            }')
        _has_in_flight=$(echo "$members_status" | awk '
            /Rebuild|Spare|Stale|[0-9]+%/ { print "yes"; exit }
        ')
        if [ "$_has_in_flight" = "yes" ]; then
            log_info "  $uuid: AR=$current; skipping flip to 0 (Spare/Rebuilding member present - flipping now would abort the rebuild)"
            return 0
        fi
    fi

    log_info "Enforcing AutoRebuild=$target on $uuid (was: ${current:-<unknown>})"
    if sudo diskutil appleRAID update AutoRebuild "$target" "$uuid" >/dev/null 2>&1; then
        return 0
    fi
    log_warn "Failed to set AutoRebuild=$target on $uuid"
    return 1
}

# Given a virtual device ("disk4" or "/dev/disk4"), return its RAID UUID.
raid_device_to_uuid() {
    dev="$1"
    # Strip /dev/ if present.
    short="${dev#/dev/}"
    diskutil appleRAID list 2>/dev/null | awk -F': +' -v d="$short" '
        /^Unique ID:/   { uuid = $2; sub(/ +$/, "", uuid) }
        /^Device Node:/ { devn = $2; sub(/ +$/, "", devn); if (devn == d) { print uuid; exit } }
    '
}

# Given a RAID virtual device (e.g. "disk10"), emit one line per mounted
# volume backed by that RAID: <diskNsN>|<volume-name>|<mount-point>
# Matches both direct HFS+/exFAT on RAID (Part of Whole == raid_dev) and
# APFS-on-RAID (APFS Physical Store == raid_dev).
list_volumes_on_raid() {
    raid_dev="$1"
    [ -n "$raid_dev" ] || return 0
    mount | awk '{print $1}' | while IFS= read -r vol; do
        case "$vol" in
            /dev/disk*) ;;
            *) continue ;;
        esac
        vol_short="${vol#/dev/}"
        dinfo=$(diskutil info "$vol" 2>/dev/null) || continue
        ps=$(printf '%s\n' "$dinfo" | awk -F': *' '/^ *APFS Physical Store/ {print $2; exit}' | awk '{print $1}')
        pow=$(printf '%s\n' "$dinfo" | awk -F': *' '/^ *Part of Whole:/ {print $2; exit}')
        match=no
        [ "$ps" = "$raid_dev" ] && match=yes
        [ "$pow" = "$raid_dev" ] && match=yes
        [ "$match" = "yes" ] || continue
        vname=$(printf '%s\n' "$dinfo" | awk -F': *' '/^ *Volume Name:/ {print $2; exit}')
        mp=$(printf '%s\n' "$dinfo" | awk -F': *' '/^ *Mount Point:/ {print $2; exit}')
        printf '%s|%s|%s\n' "$vol_short" "$vname" "$mp"
    done
}

# Get status of a RAID set by UUID.
raid_status() {
    uuid="$1"
    diskutil appleRAID list 2>/dev/null | awk -F': +' -v u="$uuid" '
        /^Unique ID:/ { cur = $2; sub(/ +$/, "", cur) }
        /^Status:/    { st  = $2; sub(/ +$/, "", st);  if (cur == u) { print st; exit } }
    '
}

# Count RAID sets.
raid_count() {
    raid_list_uuids | grep -c . || true
}

# Pick a RAID set interactively (or return the only one, or fail).
# Sets global variable SELECTED_UUID.
#
# Optional first argument: 'prefer-degraded'. When passed, and there is
# exactly ONE Degraded/Failed set among multiple, that set is offered
# as the default - pressing Enter at the prompt accepts it. Used by
# cmd_repair so the operator doesn't have to retype 'weg' when there's
# only one obvious thing to repair.
pick_raid_set() {
    _prefer_degraded=0
    case "${1:-}" in
        prefer-degraded|prefer_degraded) _prefer_degraded=1 ;;
    esac

    n=$(raid_count)
    if [ "$n" -eq 0 ]; then
        die "No AppleRAID sets found."
    fi
    if [ "$n" -eq 1 ]; then
        SELECTED_UUID=$(raid_list_uuids | head -1)
        info "Only one RAID set found; auto-selecting: $SELECTED_UUID"
        return 0
    fi

    # If asked to prefer a Degraded/Failed set, find them now so we
    # can offer a default at the prompt.
    _suggested_uuid=""
    _suggested_name=""
    _suggested_state=""
    if [ "$_prefer_degraded" = "1" ]; then
        _broken=$(for _u in $(raid_list_uuids); do
            _st=$(raid_status "$_u")
            case "$_st" in
                Degraded|Failed) printf '%s|%s\n' "$_u" "$_st" ;;
            esac
        done)
        _broken_count=$(printf '%s\n' "$_broken" | awk 'NF>0' | wc -l | tr -d ' ')
        if [ "$_broken_count" = "1" ]; then
            _suggested_uuid=$(printf '%s\n' "$_broken" | awk -F'|' 'NF>0 {print $1; exit}')
            _suggested_state=$(printf '%s\n' "$_broken" | awk -F'|' 'NF>0 {print $2; exit}')
            _suggested_name=$(diskutil appleRAID list 2>/dev/null | awk -F': +' -v u="$_suggested_uuid" '
                /^Name:/       { cur  = $2; sub(/ +$/, "", cur) }
                /^Unique ID:/  { uid  = $2; sub(/ +$/, "", uid); if (uid == u) { print cur; exit } }
            ')
        fi
    fi

    # Multiple: show the compact 'list' summary as the menu (one line per
    # set, instead of the verbose multi-page 'diskutil appleRAID list'
    # dump). Same view the user is used to from 'my-appleRAID list'.
    step "Multiple RAID sets found - please pick one"
    cmd_list
    echo
    if [ -n "$_suggested_uuid" ]; then
        printf "Enter RAID set name or UUID [Enter for '%s' (the only %s set)]: " \
            "${_suggested_name:-$_suggested_uuid}" "$_suggested_state"
    else
        printf 'Enter RAID set name or UUID: '
    fi
    read -r choice
    if [ -z "$choice" ]; then
        if [ -n "$_suggested_uuid" ]; then
            SELECTED_UUID="$_suggested_uuid"
            info "Using suggested: ${_suggested_name:-$_suggested_uuid} ($_suggested_state)"
            return 0
        fi
        die "No selection made."
    fi
    # Try as UUID first, then as name.
    for u in $(raid_list_uuids); do
        if [ "$u" = "$choice" ]; then
            SELECTED_UUID="$u"
            return 0
        fi
    done
    u=$(raid_name_to_uuid "$choice")
    if [ -n "$u" ]; then
        SELECTED_UUID="$u"
        return 0
    fi
    die "No RAID set matches '$choice'."
}

# ======================================================================
# Configuration, state, alerting, and health-monitoring machinery
# ----------------------------------------------------------------------
# The functions below are only used by `appleRAID health`, `create-config`,
# `install-daemon`, `uninstall-daemon`, `show-config`, and `test-alerts`.
# They are deliberately grouped together so that the management-only
# portion of the script above remains self-contained and simple.
# ======================================================================

# ----------------------------------------------------------------------
# Default values for every config key.
# Each is also documented in the template written by create-config.
# When a config file is loaded, values it sets OVERRIDE these defaults;
# values it omits remain at the defaults below.
# ----------------------------------------------------------------------
cfg_set_defaults() {
    # --- RAID monitoring ---
    MONITOR_SETS="all"                     # "all"|"auto" (synonyms) or comma-list of names/UUIDs
    MONITOR_SETS_EXCLUDE=""                # Comma-list subtracted from MONITOR_SETS
    REQUIRED_SETS="all"                    # "all"=snapshot | comma-list | "" (disabled)
    ALERT_ON_MISSING_SET=yes               # master switch for set-presence alerts
    MISSING_SET_SEVERITY=crit              # warn|crit
    MISSING_SET_GRACE_PERIOD=5m            # debounce transient disappearance

    # --- Disk monitoring ---
    MONITOR_DISKS="auto"                   # "auto"=RAID members | "all"=every phys disk | comma-list
    MONITOR_DISKS_EXCLUDE=""               # Comma-list subtracted from MONITOR_DISKS
    REQUIRED_DISKS="all"                   # "all"=snapshot | comma-list | "" (disabled)
    ALERT_ON_MISSING_DISK=yes              # master switch for disk-presence alerts
    MISSING_DISK_SEVERITY=crit             # warn|crit
    MISSING_DISK_GRACE_PERIOD=5m           # debounce transient disappearance

    # --- Optional disk sets (SETs of GROUPs of DISKs) ---
    # Built for ROTATING EXTRA BACKUP DISK SETS (off-site rotation),
    # supporting multiple independent rotation pools in parallel.
    # Multi-line list: "Set/Group = disk1, disk2, ..." per line.
    #   (a) Per group: if any member is present, ALL must be (no partial).
    #   (b) Per set:   at least ONE group in the set must be fully present.
    # Bare names without '/' are auto-promoted into a 'default' set
    # (backwards compat with the v6 single-set layout).
    # Members of optional groups are EXCLUDED from REQUIRED_DISKS resolution
    # so a swapped-out rotation disk does not also fire a disk-missing alert.
    OPTIONAL_DISK_SETS=""
    ALERT_ON_OPTIONAL_DISK_SETS=yes
    OPTIONAL_DISK_SET_SEVERITY=crit
    OPTIONAL_DISK_SET_GRACE_PERIOD=5m

    # --- Auto-baseline (keeps REQUIRED_*=all in sync with reality) ---
    AUTO_BASELINE_FOR_SETS_ON_CREATE=yes   # `appleRAID create` adds set to baseline
    AUTO_BASELINE_FOR_SETS_ON_DESTROY=yes  # `appleRAID destroy` removes set from baseline
    AUTO_BASELINE_FOR_SETS_ON_HEALTH=yes   # health poll auto-adds new sets observed
    AUTO_BASELINE_FOR_DISKS_ON_HEALTH=yes  # health poll auto-adds new disks observed
    AUTO_BASELINE_GRACE_PERIOD=24h         # item must be present this long before ON_HEALTH adds it
    # Thresholds
    TEMP_WARN_C=50
    TEMP_CRIT_C=58
    SMART_CHECK_ENABLED=yes                # yes/no: run smartctl -H / -A
    # AppleRAID AutoRebuild enforcement.
    #   0   (default) enforce AutoRebuild=0 on every set during create / health
    #       / list. Returning members stay 'Failed' until you manually
    #       run 'repair' - i.e. you get a HARD ALERT (the set stays
    #       Degraded with a Failed member visibly until you act).
    #   1   force AutoRebuild=1 on every set the script touches. Returning
    #       members auto-rebuild silently (full block-by-block rebuild,
    #       hours per TB). The health daemon still emails on each
    #       transition (Degraded onset / Rebuilding start / progress /
    #       resolution), so you don't lose visibility - but the set
    #       quietly self-heals if you don't act.
    #   ""  empty = no enforcement; the script reads/displays
    #       AutoRebuild but never writes it. Manage manually via
    #       'autorebuild on|off'.
    DEFAULT_AUTO_REBUILD=0
    # How often (seconds) the health daemon re-emails about an ongoing
    # rebuild. Default 21600s = 6h = 4 emails per day. Other problem
    # categories use the generic EMAIL_INTERVAL (default 4h).
    REBUILD_EMAIL_INTERVAL=21600
    # Alarm
    ALARM_SOUND="/System/Library/Sounds/Basso.aiff"
    ALARM_VOLUME=0.8                       # 0.0 - 1.0
    ALARM_VOLUME_MODE=boost                # boost|cap|set
    ALARM_INTERVAL=60
    ALARM_ENABLED=yes
    # Email
    EMAIL_TO=""                            # empty disables email
    EMAIL_FROM="my-appleRAID@$(hostname)"
    EMAIL_SENDER="msmtp"                   # bare name; resolved via PATH (which
                                           # the top-of-script PATH block extends to
                                           # include Homebrew prefixes). Override with
                                           # an absolute path if you prefer.
    EMAIL_INTERVAL=14400                   # 4 hours
    # SMART polling & self-tests
    SMART_POLL_INTERVAL=86400              # 1 day
    SELFTEST_SHORT_SCHEDULE="daily"        # never|daily|weekly  (~2 min per drive)
    SELFTEST_LONG_SCHEDULE="weekly"        # never|daily|weekly  (hours; scales with disk size)
    SELFTEST_HOUR=3                        # 0-23, when scheduled tests kick off
    # State / logging
    STATE_DIR="/var/db/my-appleRAID"
    LOG_FILE="/var/log/my-appleRAID.log"
    LOG_LEVEL=info                         # error|warn|info|debug
    # LaunchDaemon installation target (used by install-daemon).
    # LAUNCHD_LABEL is derived from LAUNCHD_PLIST at load time - do not set manually.
    LAUNCHD_PLIST="/Library/LaunchDaemons/eu.no-panic.my-appleRAID_health.plist"
    LAUNCHD_STDOUT_LOG="/var/log/my-appleRAID.launchd.out"
    LAUNCHD_STDERR_LOG="/var/log/my-appleRAID.launchd.err"
    LAUNCHD_INTERVAL=60
}

# Path of the config file actually used by this run (for show-config).
LOADED_CONFIG=""

# ----------------------------------------------------------------------
# Load config: try each search-path location, source the first that exists.
# Silent on success; prints [INFO] line if nothing found (defaults used).
# ----------------------------------------------------------------------
cfg_load() {
    cfg_set_defaults
    # Candidate search path, in priority order.
    for candidate in \
        "${MY_APPLERAID_CONFIG:-}" \
        "/LINKS/default/my-appleRAID.conf" \
        "${HOME:-/}/.my-appleRAID.conf" \
        "/usr/local/etc/my-appleRAID.conf" \
        "/etc/my-appleRAID.conf"
    do
        [ -n "$candidate" ] || continue
        if [ -r "$candidate" ]; then
            # shellcheck disable=SC1090
            . "$candidate"
            LOADED_CONFIG="$candidate"
            break
        fi
    done
    [ -n "$LOADED_CONFIG" ] || LOADED_CONFIG="(none - defaults in use)"

    # Derive LAUNCHD_LABEL from LAUNCHD_PLIST: strip directory + ".plist".
    # Doing this after sourcing the config file means the user only needs
    # to set LAUNCHD_PLIST; the label stays in sync automatically.
    if [ -n "${LAUNCHD_PLIST:-}" ]; then
        _tmp="${LAUNCHD_PLIST##*/}"     # basename
        LAUNCHD_LABEL="${_tmp%.plist}"  # strip extension
    fi

    # Verify LOG_FILE + STATE_DIR are writable for the running uid;
    # fall back / NULL respectively if not. Done once here so that any
    # subsequent subshell ($(...) / pipeline) forked off the main shell
    # INHERITS the corrected paths, instead of independently rerunning
    # the checks (and re-printing the same warnings) per subshell.
    # Sentinel inside each function keeps it idempotent in case
    # cfg_load is invoked more than once per run.
    _ensure_log_file_writable
    _ensure_state_dir_writable

    # Normalize duration-valued config keys: accept either a bare number
    # (seconds) or a suffix like 30s / 5m / 2h / 1d / 1w. Done once at
    # load time so the rest of the script can treat these as plain ints.
    ALARM_INTERVAL=$(parse_duration "$ALARM_INTERVAL" "ALARM_INTERVAL")
    EMAIL_INTERVAL=$(parse_duration "$EMAIL_INTERVAL" "EMAIL_INTERVAL")
    REBUILD_EMAIL_INTERVAL=$(parse_duration "${REBUILD_EMAIL_INTERVAL:-21600}" "REBUILD_EMAIL_INTERVAL")
    SMART_POLL_INTERVAL=$(parse_duration "$SMART_POLL_INTERVAL" "SMART_POLL_INTERVAL")
    LAUNCHD_INTERVAL=$(parse_duration "$LAUNCHD_INTERVAL" "LAUNCHD_INTERVAL")
    MISSING_SET_GRACE_PERIOD=$(parse_duration "$MISSING_SET_GRACE_PERIOD" "MISSING_SET_GRACE_PERIOD")
    MISSING_DISK_GRACE_PERIOD=$(parse_duration "$MISSING_DISK_GRACE_PERIOD" "MISSING_DISK_GRACE_PERIOD")
    OPTIONAL_DISK_SET_GRACE_PERIOD=$(parse_duration "${OPTIONAL_DISK_SET_GRACE_PERIOD:-300}" "OPTIONAL_DISK_SET_GRACE_PERIOD")
    AUTO_BASELINE_GRACE_PERIOD=$(parse_duration "$AUTO_BASELINE_GRACE_PERIOD" "AUTO_BASELINE_GRACE_PERIOD")
    return 0
}

# ----------------------------------------------------------------------
# Duration parser.
# Converts a human-readable duration to seconds. Accepts:
#   <n>          -> n seconds (bare number, backwards-compatible)
#   <n>s         -> n seconds
#   <n>m         -> n minutes
#   <n>h         -> n hours
#   <n>d         -> n days
#   <n>w         -> n weeks
# The suffix is case-insensitive. Invalid input emits a warning and
# falls back to the default shown (so a typo doesn't make the daemon
# silently stop monitoring).
# Args: value, keyname (for error messages)
# ----------------------------------------------------------------------
parse_duration() {
    v="$1"; k="${2:-duration}"
    # Strip whitespace.
    v=$(printf '%s' "$v" | sed 's/[[:space:]]//g')
    [ -n "$v" ] || { echo 0; return; }

    # Lowercase the suffix only (portable: tr everywhere).
    suf=$(printf '%s' "$v" | sed 's/^[0-9]*//' | tr '[:upper:]' '[:lower:]')
    num=$(printf '%s' "$v" | sed 's/[^0-9].*$//')

    # Bare number = seconds.
    if [ -z "$suf" ]; then
        # Validate that it's digits only.
        case "$v" in
            ''|*[!0-9]*)
                log_warn "Invalid duration for $k: '$v' (expected e.g. 60, 5m, 2h, 1d, 1w). Using 0."
                echo 0
                return
                ;;
        esac
        echo "$v"
        return
    fi

    # Require a numeric portion.
    case "$num" in
        ''|*[!0-9]*)
            log_warn "Invalid duration for $k: '$v' (missing number). Using 0."
            echo 0
            return
            ;;
    esac

    case "$suf" in
        s)    echo "$num" ;;
        m)    echo "$(( num * 60 ))" ;;
        h)    echo "$(( num * 3600 ))" ;;
        d)    echo "$(( num * 86400 ))" ;;
        w)    echo "$(( num * 604800 ))" ;;
        *)
            log_warn "Invalid duration suffix for $k: '$suf' in '$v'. Expected s|m|h|d|w. Using $num as seconds."
            echo "$num"
            ;;
    esac
}

# ----------------------------------------------------------------------
# Logging (respects LOG_LEVEL and writes to LOG_FILE if set).
# Usage: log_<level> "message..."
# Levels: error(1) warn(2) info(3) debug(4). Lower = more severe.
# ----------------------------------------------------------------------
log_level_num() {
    case "$1" in
        error) echo 1 ;;
        warn)  echo 2 ;;
        info)  echo 3 ;;
        debug) echo 4 ;;
        *)     echo 3 ;;
    esac
}

log_write() {
    lvl="$1"; shift
    msg="$*"
    cur=$(log_level_num "${LOG_LEVEL:-info}")
    this=$(log_level_num "$lvl")
    [ "$this" -le "$cur" ] || return 0
    ts=$(date '+%Y-%m-%d %H:%M:%S')
    line=$(printf '%s [%s] %s' "$ts" "$lvl" "$msg")
    # Always echo to stderr so launchd stderr log catches it.
    printf '%s\n' "$line" >&2
    # File-append branch. Wrapped in a subshell whose entire stderr is
    # redirected so a redirect-open failure ('cannot create ...') from
    # the shell itself is also suppressed (a plain '>>... 2>/dev/null'
    # only suppresses the printf's stderr; the open-failure message is
    # produced by dash itself BEFORE the printf runs and bypasses that
    # redirect). _ensure_log_file_writable ought to have NULLed
    # LOG_FILE already in the unwritable case, but the subshell guard
    # is belt-and-braces.
    if [ -n "${LOG_FILE:-}" ]; then
        ( printf '%s\n' "$line" >> "$LOG_FILE" ) 2>/dev/null || true
    fi
}
log_error() { log_write error "$@"; }
log_warn()  { log_write warn  "$@"; }
log_info()  { log_write info  "$@"; }
log_debug() { log_write debug "$@"; }

# ----------------------------------------------------------------------
# State file (flat pipe-separated, with commented header + explanation).
# One line per current problem. When a problem clears, its line is removed.
#
# Layout:
#   hash|severity|first_seen|last_alarm|last_email|summary
#
# hash       - SHA1 of "kind|target|detail". Identifies a unique problem
#              across runs so we don't re-alert for an already-known issue.
# severity   - warn|crit
# first_seen - ISO8601 timestamp when the problem was first observed.
# last_alarm - ISO8601 timestamp of last alarm playback.
# last_email - ISO8601 timestamp of last email sent (or "-" if never).
# summary    - human-readable one-liner.
# ----------------------------------------------------------------------
STATE_FILE=""    # set by state_init based on STATE_DIR

state_init() {
    # _ensure_state_dir_writable may rewrite STATE_DIR to a user-
    # private fallback if the canonical path isn't writable - run it
    # FIRST so STATE_FILE picks up the corrected path.
    _ensure_state_dir_writable
    STATE_FILE="${STATE_DIR}/state.db"
    if [ ! -f "$STATE_FILE" ]; then
        {
            echo "# appleRAID state file - DO NOT EDIT BY HAND"
            echo "# One line per active problem. Format:"
            echo "#   hash|severity|first_seen|last_alarm|last_email|summary"
            echo "# Lines starting with '#' are ignored."
        } > "$STATE_FILE" 2>/dev/null \
            || err 010 "Cannot create state file: $STATE_FILE"
    fi
}

# Return a stable hash for a problem.
# Args: kind (raid|smart|temp|selftest), target (set/disk name), detail (what's wrong)
problem_hash() {
    printf '%s|%s|%s' "$1" "$2" "$3" | shasum | awk '{print $1}'
}

# Look up a problem by hash. Prints the matching line or empty.
state_get() {
    h="$1"
    [ -f "$STATE_FILE" ] || return 0
    awk -F'|' -v h="$h" '
        /^#/ { next }
        $1 == h { print; exit }
    ' "$STATE_FILE"
}

# Upsert a problem: write or replace the line for a given hash.
# Args: hash, severity, first_seen, last_alarm, last_email, summary
state_put() {
    h="$1"; sev="$2"; first="$3"; alarm="$4"; email="$5"; summary="$6"
    tmp=$(mktemp "${STATE_FILE}.XXXXXX") \
        || err 018 "mktemp for state-DB rewrite failed at ${STATE_FILE}.XXXXXX"
    awk -F'|' -v h="$h" '
        /^#/ { print; next }
        $1 != h { print }
    ' "$STATE_FILE" > "$tmp" \
        || err 019 "awk rewrite of state-DB failed (writing to $tmp)"
    printf '%s|%s|%s|%s|%s|%s\n' "$h" "$sev" "$first" "$alarm" "$email" "$summary" >> "$tmp" \
        || err 020 "appending new state-DB row failed (to $tmp)"
    mv "$tmp" "$STATE_FILE" \
        || err 021 "atomic rename of state-DB failed: $tmp -> $STATE_FILE"
}

# Remove a problem by hash.
state_delete() {
    h="$1"
    [ -f "$STATE_FILE" ] || return 0
    tmp=$(mktemp "${STATE_FILE}.XXXXXX") || return 1
    awk -F'|' -v h="$h" '
        /^#/ { print; next }
        $1 != h { print }
    ' "$STATE_FILE" > "$tmp" \
        || err 022 "awk rewrite of state-DB during delete failed (writing to $tmp)"
    mv "$tmp" "$STATE_FILE" \
        || err 023 "atomic rename of state-DB during delete failed: $tmp -> $STATE_FILE"
}

# List all current problem hashes (one per line).
state_list_hashes() {
    [ -f "$STATE_FILE" ] || return 0
    awk -F'|' '/^#/{next} NF>=1 && $1!="" {print $1}' "$STATE_FILE"
}

# Get field N (1-based) from the state line for a given hash.
state_field() {
    h="$1"; n="$2"
    line=$(state_get "$h")
    [ -n "$line" ] || return 0
    echo "$line" | awk -F'|' -v n="$n" '{print $n}'
}

# Seconds between two ISO8601 timestamps (macOS date parsing).
# Args: earlier, later  (either may be "-" meaning "infinity ago")
seconds_between() {
    a="$1"; b="$2"
    [ "$a" = "-" ] && { echo 999999999; return 0; }
    # macOS date -j -f parsing
    ta=$(date -j -f "%Y-%m-%dT%H:%M:%S%z" "$a" +%s 2>/dev/null)
    tb=$(date -j -f "%Y-%m-%dT%H:%M:%S%z" "$b" +%s 2>/dev/null)
    if [ -z "$ta" ] || [ -z "$tb" ]; then
        echo 0
    else
        echo $(( tb - ta ))
    fi
}

now_iso() {
    # ISO8601 with numeric timezone offset (macOS date -j compatible).
    date '+%Y-%m-%dT%H:%M:%S%z'
}

# ----------------------------------------------------------------------
# Grace-period tracking for missing sets/disks.
# When a required item first disappears, we record a "pending" file
# rather than firing an alert immediately. On subsequent runs we check
# if it's still missing AND has been missing long enough. If it comes
# back before the grace expires, we drop the pending file silently.
#
# State dir layout for pending files:
#   $STATE_DIR/pending-set-<name>    timestamp when set first seen missing
#   $STATE_DIR/pending-disk-<name>   timestamp when disk first seen missing
# ----------------------------------------------------------------------

# Mark item as pending-missing if not already pending. Returns 0 if grace
# has expired (caller should alert) or 1 if still within grace period.
# Args: kind (set|disk), name, grace_sec
grace_check() {
    kind="$1"; name="$2"; grace="$3"
    f="${STATE_DIR}/pending-${kind}-${name}"
    if [ ! -f "$f" ]; then
        # First disappearance in this run; start the clock.
        date +%s > "$f"
        log_debug "Started grace timer for ${kind} ${name} (${grace}s)"
        return 1
    fi
    first=$(cat "$f" 2>/dev/null)
    [ -n "$first" ] || { date +%s > "$f"; return 1; }
    now=$(date +%s)
    elapsed=$(( now - first ))
    if [ "$elapsed" -ge "$grace" ]; then
        return 0
    fi
    log_debug "${kind} ${name} missing for ${elapsed}s (grace ${grace}s); not alerting yet"
    return 1
}

# Clear any pending grace entry for this item (called when it reappears).
# Args: kind, name
grace_clear() {
    rm -f "${STATE_DIR}/pending-$1-$2" 2>/dev/null || true
}

# ----------------------------------------------------------------------
# Auto-baseline presence tracking. Mirror of grace_check, but for the
# opposite event: "has this item been consistently PRESENT long enough
# to auto-add to the baseline?"
#
# Sentinel files: $STATE_DIR/seen-<kind>-<name>  (timestamp of first sighting)
#
# Returns 0 if the item has been present long enough (caller should
# add to baseline) or 1 if still in the grace window.
# Args: kind (set|disk), name, grace_sec
# ----------------------------------------------------------------------
auto_baseline_check() {
    kind="$1"; name="$2"; grace="$3"
    f="${STATE_DIR}/seen-${kind}-${name}"
    if [ ! -f "$f" ]; then
        date +%s > "$f"
        log_debug "Started auto-baseline timer for ${kind} ${name} (${grace}s)"
        return 1
    fi
    first=$(cat "$f" 2>/dev/null)
    [ -n "$first" ] || { date +%s > "$f"; return 1; }
    now=$(date +%s)
    elapsed=$(( now - first ))
    if [ "$elapsed" -ge "$grace" ]; then
        return 0
    fi
    log_debug "${kind} ${name} present for ${elapsed}s (grace ${grace}s); not auto-baselining yet"
    return 1
}

# Clear the auto-baseline seen-timer for an item (called once it has
# been added to the baseline, so the timer doesn't linger).
auto_baseline_clear() {
    rm -f "${STATE_DIR}/seen-$1-$2" 2>/dev/null || true
}

# ----------------------------------------------------------------------
# Baseline files: the snapshot of "what should exist" for REQUIRED_*=all.
#
#   $STATE_DIR/baseline-sets    one RAID set name per line
#   $STATE_DIR/baseline-disks   one stable disk SERIAL per line, with
#                               the /dev/diskN node + model in a trailing
#                               '#' comment. The serial is the matchable
#                               identifier; the comment is a human hint
#                               (and stale once the disk gets a new node
#                               number on the next reboot/replug).
#
# Why serials, not disk-node names: macOS assigns /dev/diskN at attach
# time, and the number shuffles freely across reboots, USB hub swaps,
# and replug order. Tracking by serial keeps "the same physical disk"
# the same identity regardless of which slot it lands in.
#
# Written by 'appleRAID baseline'. If a baseline file doesn't exist
# when REQUIRED_*=all is active, the 'health' command auto-creates it
# from current state on first run and logs that it did.
# ----------------------------------------------------------------------
baseline_sets_file()  { echo "${STATE_DIR}/baseline-sets";  }
baseline_disks_file() { echo "${STATE_DIR}/baseline-disks"; }

baseline_read_sets() {
    f=$(baseline_sets_file)
    [ -f "$f" ] || return 0
    awk 'NF>0 && !/^#/ {print}' "$f"
}

# Read the disk baseline. Returns one serial per line (the first
# whitespace-separated token of each non-comment line). Lines whose
# first token still looks like a /dev/diskN node are flagged as a
# legacy baseline that needs re-baselining via 'appleRAID baseline
# --disks'.
baseline_read_disks() {
    f=$(baseline_disks_file)
    [ -f "$f" ] || return 0
    awk 'NF>0 && !/^#/ { print $1 }' "$f"
}

# True if the baseline file appears to be in any pre-tagged format
# (legacy disk-node names like "disk2", or earlier serial-only entries
# without a SN:/USB:/VOL: tag). Used to nudge the user to rebaseline
# after the upgrade that switched to tagged stable identifiers.
baseline_disks_is_legacy() {
    f=$(baseline_disks_file)
    [ -f "$f" ] || return 1
    first=$(awk 'NF>0 && !/^#/ { print $1; exit }' "$f")
    [ -n "$first" ] || return 1
    case "$first" in
        SN:*|PART:*|USB:*|VOL:*) return 1 ;;
        *)                       return 0 ;;
    esac
}

# Write the currently-existing RAID set *names* to the baseline file.
baseline_write_sets() {
    f=$(baseline_sets_file)
    {
        echo "# appleRAID baseline: RAID sets expected to exist."
        echo "# Written: $(now_iso)"
        echo "# Update with: appleRAID baseline --sets"
        diskutil appleRAID list 2>/dev/null | awk -F': +' '
            /^Name:/ { n=$2; sub(/ +$/,"",n); if (n!="") print n }
        '
    } > "$f"
}

# Pick the best stable identifier for a physical disk, tagged with its
# source so we know how to match it back later. Tags, in priority order:
#
#   SN:<serial>             ATA/SATA/NVMe IDENTIFY serial number.
#                           Strongest: stable across reboots, replugs,
#                           hub swaps, AND reformats - the serial is
#                           baked into the drive firmware.
#   PART:<gpt-uuid>         GPT partition entry GUID of the disk's main
#                           data partition (first non-EFI, non-Apple_Boot
#                           partition). Baked into the partition table
#                           on disk, so it travels with the disk across
#                           reboots, replugs, and hub swaps. Lost only
#                           on a full reformat (partition table rewrite).
#                           Used when SN is unavailable - typically
#                           USB-SAT bridges that don't pass IDENTIFY
#                           through.
#   USB:<srl>:<bytes>       Bridge serial PLUS size-in-bytes. Used only
#                           if the disk has no GPT data partition (raw,
#                           wiped, or non-GPT scheme). Stable across
#                           replug; ambiguous if two identically-sized
#                           disks share the same multi-bay enclosure.
#   VOL:<uuid>              Volume UUID of the first mounted partition.
#                           Last resort - lost on volume recreation
#                           even when the GPT survives.
#
# Empty output means the disk has no stable identifier and cannot be
# baselined; the caller should skip it with a warning.
# ----------------------------------------------------------------------
# bsd -> tagged-id cache (process-wide, file-backed).
#
# Computing a stable id for a disk hits disk_serial (smartctl), then
# diskutil for GPT GUID, then `system_profiler SPUSBDataType`. The
# last one is the slow one - hundreds of ms per call. cmd_baseline
# previously called disk_baseline_id once per attached disk inside
# baseline_write_disks AND once per (set, group, member) inside the
# optsets-section renderer (via optional_spec_to_bsd ->
# disk_for_baseline_id, which itself walks every attached disk
# calling disk_baseline_id). With ~10 disks and ~5 optset specs that
# is ~50 system_profiler invocations per `baseline` run.
#
# Solution: populate a file-backed cache once per process. The file
# is plain "<bsd>|<id-or-__NONE__>" lines, so subshell-spawned
# pipelines (e.g. `... | while read`) can read it too - in-memory
# variables would be lost across the pipe. cmd_baseline,
# cmd_baseline_optsets, cmd_disks, and cmd_health all populate the
# cache early; trap removes the file on exit.
# ----------------------------------------------------------------------
_DISKID_CACHE_FILE=""

# Build the cache for every currently-attached physical disk. Idempotent:
# returns immediately if the cache already exists.
_diskid_cache_init() {
    if [ -n "${_DISKID_CACHE_FILE:-}" ] && [ -f "$_DISKID_CACHE_FILE" ]; then
        return 0
    fi
    [ -n "${STATE_DIR:-}" ] || return 1
    _DISKID_CACHE_FILE=$(mktemp "$STATE_DIR/.diskid-cache.XXXXXX" 2>/dev/null) \
        || { _DISKID_CACHE_FILE=""; return 1; }
    list_all_physical_disks | while IFS= read -r _d; do
        [ -n "$_d" ] || continue
        _id=$(_disk_baseline_id_uncached "$_d" 2>/dev/null)
        printf '%s|%s\n' "$_d" "${_id:-__NONE__}" >> "$_DISKID_CACHE_FILE"
    done
}

_diskid_cache_clear() {
    [ -n "${_DISKID_CACHE_FILE:-}" ] || return 0
    rm -f "$_DISKID_CACHE_FILE" 2>/dev/null || true
    _DISKID_CACHE_FILE=""
}

# Public-facing disk_baseline_id: cache check, fall through to the
# uncached implementation. Caches the result for next time.
disk_baseline_id() {
    bsd="${1#/dev/}"
    [ -n "$bsd" ] || return 1
    if [ -n "${_DISKID_CACHE_FILE:-}" ] && [ -f "$_DISKID_CACHE_FILE" ]; then
        _hit=$(awk -F'|' -v b="$bsd" '$1==b {print $2; exit}' "$_DISKID_CACHE_FILE")
        case "$_hit" in
            "")        ;;  # not in cache, fall through
            __NONE__)  return 1 ;;
            *)         echo "$_hit"; return 0 ;;
        esac
    fi
    _id=$(_disk_baseline_id_uncached "$bsd")
    _rc=$?
    # Memoize for next time (best-effort: any failure is silently ignored).
    if [ -n "${_DISKID_CACHE_FILE:-}" ] && [ -f "$_DISKID_CACHE_FILE" ]; then
        printf '%s|%s\n' "$bsd" "${_id:-__NONE__}" >> "$_DISKID_CACHE_FILE"
    fi
    [ -n "$_id" ] && echo "$_id"
    return $_rc
}

# Original implementation, renamed. Kept as an internal entry point
# for the cache initializer (which populates the cache by walking
# every disk) and as a fallback when cache hasn't been initialized.
_disk_baseline_id_uncached() {
    bsd="${1#/dev/}"
    [ -n "$bsd" ] || return 1

    # 1. ATA/NVMe serial via the existing disk_serial helper.
    s=$(disk_serial "$bsd" 2>/dev/null)
    if [ -n "$s" ]; then
        echo "SN:$s"
        return 0
    fi

    # 2. GPT partition entry GUID of the disk's main data partition.
    #    The GUID is baked into the partition table at format time and
    #    travels with the disk regardless of which port it lands on.
    #    We pick the first partition that isn't a macOS-template EFI
    #    or Apple_Boot, and isn't the whole-disk "scheme" pseudo-entry.
    main_part=$(diskutil list "/dev/$bsd" 2>/dev/null | awk '
        NR > 2 && /^[[:space:]]+[0-9]+:/ {
            ident = $NF
            ptype = $2
            if (ptype == "EFI") next
            if (ptype ~ /^Apple_Boot/) next
            if (ptype ~ /partition_scheme$/) next
            if (ident ~ /^disk[0-9]+s[0-9]+$/) {
                print ident
                exit
            }
        }
    ')
    if [ -n "$main_part" ]; then
        s=$(diskutil info "/dev/$main_part" 2>/dev/null \
            | awk -F': +' '/Disk \/ Partition UUID:/ {print $2; exit}' \
            | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        if [ -n "$s" ]; then
            echo "PART:$s"
            return 0
        fi
    fi

    # 3. USB bridge serial + size-in-bytes. system_profiler SPUSBDataType
    #    groups disks under their bridge, with the bridge's "Serial
    #    Number" appearing above the BSD Name(s) it owns. Take the most
    #    recent non-trivial "Serial Number:" line that precedes "BSD
    #    Name: <bsd>". Size is appended so two different disks in the
    #    same multi-bay enclosure don't collide on the same USB id.
    s=$(system_profiler SPUSBDataType 2>/dev/null | awk -v target="$bsd" '
        /Serial Number:/ {
            line = $0
            sub(/^[[:space:]]*Serial Number:[[:space:]]*/, "", line)
            sub(/[[:space:]]+$/, "", line)
            # Skip obvious placeholder values that hubs report.
            if (line ~ /^0+$/ || line == "") next
            recent = line
        }
        /BSD Name:/ {
            line = $0
            sub(/^[[:space:]]*BSD Name:[[:space:]]*/, "", line)
            sub(/[[:space:]]+$/, "", line)
            if (line == target && recent != "") {
                print recent
                exit
            }
        }
    ')
    if [ -n "$s" ]; then
        bytes=$(disk_size_bytes "/dev/$bsd" 2>/dev/null)
        if [ -n "$bytes" ]; then
            echo "USB:$s:$bytes"
        else
            # Size unreadable - emit unsuffixed (will collide with
            # any same-bridge sibling but better than nothing).
            echo "USB:$s"
        fi
        return 0
    fi

    # 3. Volume UUID of any mounted partition on this disk.
    s=$(diskutil info "/dev/${bsd}s1" 2>/dev/null \
        | awk -F': +' '/Volume UUID:/ {print $2; exit}' \
        | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    if [ -z "$s" ]; then
        s=$(diskutil info "/dev/${bsd}s2" 2>/dev/null \
            | awk -F': +' '/Volume UUID:/ {print $2; exit}' \
            | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    fi
    if [ -n "$s" ]; then
        echo "VOL:$s"
        return 0
    fi

    return 1
}

# Write the currently-attached physical disks to the baseline file,
# keyed by their best stable identifier. Format per non-comment line:
#
#   <tagged-id>    # <bsd-at-baseline>  <model>
#
# tagged-id is one of  SN:<serial> | USB:<bridge-serial> | VOL:<uuid>
# (see disk_baseline_id). Disks for which none of those is discoverable
# are skipped with a warning.
baseline_write_disks() {
    f=$(baseline_disks_file)
    {
        echo "# appleRAID baseline: disks expected to be attached."
        echo "# Written: $(now_iso)"
        echo "# Update with: appleRAID baseline --disks"
        echo "#"
        echo "# Format: <tagged-id>  # <bsd-at-baseline>  <size>  <model>"
        echo "# The tagged-id is the stable identifier we match against."
        echo "# Tags:"
        echo "#   SN:                ATA/NVMe IDENTIFY serial. Preferred, fully stable."
        echo "#   PART:              GPT partition entry GUID of the disk's main data"
        echo "#                      partition (first non-EFI, non-Apple_Boot). Baked"
        echo "#                      into the partition table on disk; survives reboot,"
        echo "#                      replug, hub swap. Lost only on full reformat."
        echo "#   USB:<srl>:<bytes>  USB bridge serial + disk size in bytes. Used only"
        echo "#                      when neither SN nor PART is available (raw or"
        echo "#                      non-GPT disks behind a USB bridge). Size is"
        echo "#                      appended so two disks in a multi-bay enclosure"
        echo "#                      don't collide on the same bridge serial."
        echo "#   VOL:               Volume UUID of first partition. Last resort,"
        echo "#                      stable per-filesystem, lost on volume recreation."
        echo "# The bsd (/dev/diskN node), size, and model in the comment"
        echo "# are human hints. The bsd may shuffle on replug; size and"
        echo "# model are intrinsic to the disk and stay stable."
        # Pre-compute the set of optset specs so the per-disk filter
        # below is O(1) instead of re-running awk N times.
        _optspecs=""
        if [ -n "${OPTIONAL_DISK_SETS:-}" ]; then
            _optspecs=$(optional_sets_all_specs)
        fi
        list_all_physical_disks | while IFS= read -r d; do
            [ -n "$d" ] || continue
            id=$(disk_baseline_id "$d" 2>/dev/null)
            model=$(diskutil info "/dev/$d" 2>/dev/null \
                | awk -F': +' '/Device \/ Media Name:/ {print $2; exit}' \
                | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
            size=$(diskutil info "/dev/$d" 2>/dev/null \
                | awk -F': +' '/Disk Size:/ {print $2; exit}' \
                | awk '{print $1, $2}' \
                | sed 's/[[:space:]]*$//')
            if [ -z "$id" ]; then
                log_warn "Skipping $d in baseline: no stable identifier discoverable (size: ${size:-unknown}, model: ${model:-unknown})"
                continue
            fi
            # Skip if this id is governed by an optset: it's checked by
            # the rotation rules (a)+(b), not the plain baseline-disks
            # presence check. Listing it in both places is at best
            # redundant and at worst confusing in 'baseline --show'.
            if [ -n "$_optspecs" ] && printf '%s\n' "$_optspecs" | grep -qxF "$id"; then
                log_debug "Skipping $d ($id) in baseline: member of OPTIONAL_DISK_SETS"
                continue
            fi
            printf '%-24s # %-7s %-9s %s\n' "$id" "$d" "${size:-?}" "${model:-?}"
        done
    } > "$f"
}

# Map a tagged baseline id back to the currently-attached /dev/diskN
# node, or empty if no current disk matches. Used by the presence
# check.
disk_for_baseline_id() {
    target="$1"
    [ -n "$target" ] || return 1
    # Cache fast-path: read the bsd column for the row whose tagged-id
    # matches the target. ~1ms vs ~hundreds of ms for the slow path.
    if [ -n "${_DISKID_CACHE_FILE:-}" ] && [ -f "$_DISKID_CACHE_FILE" ]; then
        _hit=$(awk -F'|' -v t="$target" '$2==t {print $1; exit}' "$_DISKID_CACHE_FILE")
        if [ -n "$_hit" ]; then
            echo "$_hit"
            return 0
        fi
        return 1
    fi
    # Slow path: cache uninitialized. Walk all disks and compute their
    # ids one at a time. disk_baseline_id will memoize each, so a
    # subsequent call is fast even without explicit init.
    list_all_physical_disks | while IFS= read -r d; do
        [ -n "$d" ] || continue
        cur=$(disk_baseline_id "$d" 2>/dev/null)
        if [ "$cur" = "$target" ]; then
            echo "$d"
            return 0
        fi
    done
}

# ----------------------------------------------------------------------
# Alerting: sound + email.
# alert_sound plays ALARM_SOUND using afplay, respecting ALARM_VOLUME_MODE.
# ----------------------------------------------------------------------

# Get current system output volume as a 0.0-1.0 float.
# macOS 'osascript' reports 0-100, so we divide.
sys_volume_get() {
    out=$(osascript -e 'output volume of (get volume settings)' 2>/dev/null)
    [ -n "$out" ] || { echo "0.5"; return; }
    # 'missing value' = muted or inaccessible; treat as 0
    case "$out" in missing*) echo "0.0"; return ;; esac
    awk -v v="$out" 'BEGIN { printf "%.2f", v / 100 }'
}

sys_volume_set() {
    # Arg: float 0.0-1.0
    v="$1"
    pct=$(awk -v v="$v" 'BEGIN { printf "%d", v * 100 }')
    osascript -e "set volume output volume $pct" 2>/dev/null || true
}

alert_sound() {
    [ "${ALARM_ENABLED:-yes}" = "yes" ] || return 0
    [ -n "${ALARM_SOUND:-}" ] || return 0
    [ -r "${ALARM_SOUND}" ] || { log_warn "Alarm sound not readable: $ALARM_SOUND"; return 0; }
    command -v afplay >/dev/null 2>&1 || { log_warn "afplay not found"; return 0; }

    saved=$(sys_volume_get)
    target="${ALARM_VOLUME:-0.8}"

    case "${ALARM_VOLUME_MODE:-boost}" in
        set)
            sys_volume_set "$target"
            ;;
        cap)
            # If current > target, reduce to target; else leave alone.
            awk -v s="$saved" -v t="$target" 'BEGIN { exit (s > t) ? 0 : 1 }' \
                && sys_volume_set "$target"
            ;;
        boost)
            # If current < target, raise to target; else leave alone.
            awk -v s="$saved" -v t="$target" 'BEGIN { exit (s < t) ? 0 : 1 }' \
                && sys_volume_set "$target"
            ;;
        *)
            log_warn "Unknown ALARM_VOLUME_MODE: $ALARM_VOLUME_MODE"
            ;;
    esac

    afplay "$ALARM_SOUND" 2>/dev/null || true

    # Restore previous volume (only if we changed it).
    case "${ALARM_VOLUME_MODE:-boost}" in
        set|cap|boost) sys_volume_set "$saved" ;;
    esac
}

alert_email() {
    # Args: subject, body
    subject="$1"; body="$2"
    [ -n "${EMAIL_TO:-}" ] || { log_debug "Email disabled (no EMAIL_TO)"; return 0; }
    [ -n "${EMAIL_SENDER:-}" ] || { log_debug "Email disabled (no EMAIL_SENDER)"; return 0; }

    # Resolve the sender. Accept either an absolute path or a bare name
    # (e.g. "msmtp"); for the latter we look it up via PATH, which now
    # includes both Homebrew prefixes (see top-of-script PATH block).
    case "$EMAIL_SENDER" in
        /*) sender_exec="$EMAIL_SENDER" ;;
        *)  sender_exec=$(command -v "$EMAIL_SENDER" 2>/dev/null) ;;
    esac
    [ -n "$sender_exec" ] && [ -x "$sender_exec" ] \
        || { log_warn "Email sender not found or not executable: '$EMAIL_SENDER'"; return 0; }

    {
        printf 'From: %s\n' "${EMAIL_FROM}"
        printf 'To: %s\n'   "${EMAIL_TO}"
        printf 'Subject: %s\n' "$subject"
        printf 'Content-Type: text/plain; charset=utf-8\n'
        printf '\n'
        printf '%s\n' "$body"
    } | "$sender_exec" "$EMAIL_TO" 2>/dev/null \
        || log_warn "Email send failed (check msmtp config and '$sender_exec --debug')"
}

# ----------------------------------------------------------------------
# Problem handler: given a detected problem, decide whether to alert.
# Args: kind, target, detail, severity, summary
# severity: warn|crit. Only crit triggers alarm sound; warn logs+emails only.
# ----------------------------------------------------------------------
handle_problem() {
    kind="$1"; target="$2"; detail="$3"; sev="$4"; summary="$5"
    h=$(problem_hash "$kind" "$target" "$detail")
    now=$(now_iso)
    existing=$(state_get "$h")

    if [ -z "$existing" ]; then
        # NEW problem
        log_error "NEW $sev: $summary"
        [ -n "${HEALTH_RUN_LOG:-}" ] && \
            printf 'new|%s|%s\n' "$sev" "$summary" >> "$HEALTH_RUN_LOG"
        [ "$sev" = "crit" ] && alert_sound
        alert_email "[appleRAID/$sev] $summary" \
            "New problem detected at $now

Kind:     $kind
Target:   $target
Detail:   $detail
Severity: $sev

$(diskutil appleRAID list 2>/dev/null)
"
        state_put "$h" "$sev" "$now" "$now" "$now" "$summary"
    else
        # ONGOING problem - apply rate limits
        [ -n "${HEALTH_RUN_LOG:-}" ] && \
            printf 'ongoing|%s|%s\n' "$sev" "$summary" >> "$HEALTH_RUN_LOG"
        first=$(echo  "$existing" | awk -F'|' '{print $3}')
        la=$(echo     "$existing" | awk -F'|' '{print $4}')
        le=$(echo     "$existing" | awk -F'|' '{print $5}')
        since_alarm=$(seconds_between "$la" "$now")
        since_email=$(seconds_between "$le" "$now")

        new_la="$la"
        new_le="$le"

        if [ "$sev" = "crit" ] && [ "${since_alarm:-0}" -ge "${ALARM_INTERVAL:-60}" ]; then
            alert_sound
            new_la="$now"
        fi

        # Rebuilds get their own re-email cadence (REBUILD_EMAIL_INTERVAL,
        # default 6h) since they last many hours and EMAIL_INTERVAL's
        # 4h default would generate too many recurring emails over a
        # multi-day rebuild. Falls back to EMAIL_INTERVAL for everything
        # else.
        case "$kind/$detail" in
            raid-member/rebuilding) email_interval="${REBUILD_EMAIL_INTERVAL:-21600}" ;;
            *)                      email_interval="${EMAIL_INTERVAL:-14400}" ;;
        esac

        if [ "${since_email:-0}" -ge "$email_interval" ]; then
            alert_email "[appleRAID/$sev] (recurring) $summary" \
                "Problem still present (first seen: $first)

Kind:     $kind
Target:   $target
Detail:   $detail
Severity: $sev

$(diskutil appleRAID list 2>/dev/null)
"
            new_le="$now"
        fi

        state_put "$h" "$sev" "$first" "$new_la" "$new_le" "$summary"
    fi
}

# Called when a previously-known problem hash was not seen this run.
# That doesn't automatically mean the problem is resolved: the hash
# might be a stale entry from an older code path that generated
# different hashes for the same condition (e.g. before the SN:/PART:/
# USB:/VOL: tagging landed). For "disk-missing" / "set-missing" alerts
# we can verify cheaply: parse the subject out of the saved summary
# text and re-check it. If the underlying entity is genuinely back
# we emit RESOLVED + email + delete; if it is still missing we treat
# the state-DB entry as orphan and prune silently with a STALE log
# line, so the user does not get a false "all clear".
#
# The summary text shapes we recognize (must stay in sync with the
# alert sites in check_disk_presence / check_set_presence):
#
#   Expected disk with id '<id>' is NOT attached
#   Expected disk /dev/<bsd-or-leftover> is NOT attached
#   Required RAID set '<name>' is NOT present in diskutil appleRAID list
#
# Anything we can't classify gets the previous behavior (announce
# resolved + email).
handle_resolved() {
    h="$1"
    line=$(state_get "$h")
    [ -n "$line" ] || return 0
    summary=$(echo "$line" | awk -F'|' '{print $6}')

    still_missing=0

    # disk-missing, tagged-id form.
    case "$summary" in
        "Expected disk with id '"*)
            sub=${summary#Expected disk with id \'}
            sub=${sub%%\'*}
            if [ -n "$sub" ]; then
                if ! cur=$(disk_for_baseline_id "$sub") || [ -z "$cur" ]; then
                    still_missing=1
                fi
            fi
            ;;
    esac

    # disk-missing, bare /dev/<x> form. Try both interpretations: a
    # real bsd-name (transient) AND a legacy buggy form where a tagged
    # id was concatenated after /dev/ by an older code path.
    case "$summary" in
        "Expected disk /dev/"*)
            sub=${summary#Expected disk /dev/}
            sub=${sub% is NOT attached}
            case "$sub" in
                SN:*|PART:*|USB:*|VOL:*)
                    if ! cur=$(disk_for_baseline_id "$sub") || [ -z "$cur" ]; then
                        still_missing=1
                    fi
                    ;;
                *)
                    diskutil info "/dev/$sub" >/dev/null 2>&1 \
                        || still_missing=1
                    ;;
            esac
            ;;
    esac

    # set-missing.
    case "$summary" in
        "Required RAID set '"*)
            sub=${summary#Required RAID set \'}
            sub=${sub%%\'*}
            if [ -n "$sub" ]; then
                present=$(diskutil appleRAID list 2>/dev/null \
                    | awk -F': +' '/^Name:/ { n=$2; sub(/ +$/,"",n); print n }')
                echo "$present" | grep -qxF "$sub" || still_missing=1
            fi
            ;;
    esac

    if [ "$still_missing" = "1" ]; then
        # Orphan / legacy entry: do NOT emit a misleading "RESOLVED"
        # alert email. Just prune the state row so it stops haunting
        # us, but log loudly so the user sees what happened. The
        # current-pass check_*_presence will have already created a
        # fresh, correctly-keyed alert for the underlying condition.
        log_warn "STALE STATE entry pruned (underlying problem still present, alert is being re-fired with the current hash format): $summary"
        [ -n "${HEALTH_RUN_LOG:-}" ] && \
            printf 'stale||%s\n' "$summary" >> "$HEALTH_RUN_LOG"
        state_delete "$h"
        return 0
    fi

    log_info "RESOLVED: $summary"
    [ -n "${HEALTH_RUN_LOG:-}" ] && \
        printf 'resolved||%s\n' "$summary" >> "$HEALTH_RUN_LOG"
    alert_email "[appleRAID/OK] Resolved: $summary" \
        "The following problem is no longer present:

$summary

Cleared at: $(now_iso)
"
    state_delete "$h"
}

# ----------------------------------------------------------------------
# RAID health check
# ----------------------------------------------------------------------

# Returns the list of RAID UUIDs to monitor, based on MONITOR_SETS
# and MONITOR_SETS_EXCLUDE. Accepts "all" and "auto" as synonyms.
resolve_monitored_sets() {
    # Build base UUID list.
    base_uuids=""
    case "${MONITOR_SETS:-all}" in
        all|ALL|auto|AUTO|"")
            base_uuids=$(raid_list_uuids)
            ;;
        *)
            for item in $(echo "$MONITOR_SETS" | tr ',' ' '); do
                found=""
                for u in $(raid_list_uuids); do
                    if [ "$u" = "$item" ]; then
                        found="$u"
                        break
                    fi
                done
                [ -z "$found" ] && found=$(raid_name_to_uuid "$item")
                [ -n "$found" ] && base_uuids="$base_uuids
$found"
            done
            ;;
    esac

    # Build exclusion UUID list (by name or UUID).
    exclude_uuids=""
    if [ -n "${MONITOR_SETS_EXCLUDE:-}" ]; then
        for item in $(echo "$MONITOR_SETS_EXCLUDE" | tr ',' ' '); do
            found=""
            for u in $(raid_list_uuids); do
                [ "$u" = "$item" ] && found="$u" && break
            done
            [ -z "$found" ] && found=$(raid_name_to_uuid "$item")
            [ -n "$found" ] && exclude_uuids="$exclude_uuids
$found"
        done
    fi

    # Subtract + dedupe.
    echo "$base_uuids" | awk 'NF>0' | while read -r u; do
        if ! echo "$exclude_uuids" | grep -qxF "$u"; then
            echo "$u"
        fi
    done | awk '!seen[$0]++'
}

# Produces newline-separated list of problem-hashes seen THIS run.
# Used to detect resolved problems (anything in state but not in this list).
SEEN_HASHES_FILE=""

seen_init() {
    SEEN_HASHES_FILE=$(mktemp "${STATE_DIR}/seen.XXXXXX") || die "mktemp failed"
}

seen_cleanup() {
    [ -n "$SEEN_HASHES_FILE" ] && rm -f "$SEEN_HASHES_FILE"
}

seen_add() {
    echo "$1" >> "$SEEN_HASHES_FILE"
}

seen_has() {
    h="$1"
    [ -f "$SEEN_HASHES_FILE" ] || return 1
    grep -qxF "$h" "$SEEN_HASHES_FILE"
}

check_raid_sets() {
    uuids=$(resolve_monitored_sets)
    if [ -z "$uuids" ]; then
        log_warn "No RAID sets match MONITOR_SETS='$MONITOR_SETS'"
        return 0
    fi

    for u in $uuids; do
        name=$(diskutil appleRAID list | awk -F': +' -v u="$u" '
            /^Name:/      { cur = $2; sub(/ +$/, "", cur) }
            /^Unique ID:/ { uuid = $2; sub(/ +$/, "", uuid); if (uuid == u) { print cur; exit } }
        ')
        [ -n "$name" ] || name="$u"
        st=$(raid_status "$u")

        # Overall set status
        case "$st" in
            Online)
                log_debug "RAID $name: Online"
                ;;
            Degraded)
                h=$(problem_hash "raid-status" "$name" "Degraded")
                seen_add "$h"
                handle_problem "raid-status" "$name" "Degraded" "crit" \
                    "RAID set '$name' is DEGRADED"
                ;;
            *)
                h=$(problem_hash "raid-status" "$name" "$st")
                seen_add "$h"
                handle_problem "raid-status" "$name" "$st" "crit" \
                    "RAID set '$name' status: $st"
                ;;
        esac

        # Per-member check (captures Rebuilding/Missing even when set=Online)
        #
        # Member rows look like:
        #
        #   #  DevNode    UUID                                Status     Size
        #   0  disk7s2    9CA16373-...                        Online     10000382492672
        #   1  disk21s2   C03A47B3-...                        21% (Rebuilding)10000382492672
        #
        # Two parsing hazards:
        #   1) The Status column is multi-word during a rebuild
        #      ("21% (Rebuilding)").
        #   2) For the rebuilding member, diskutil sometimes (always?)
        #      glues the byte-size onto "(Rebuilding)" with no
        #      whitespace - "(Rebuilding)10000382492672" - so naive
        #      'i < NF' parsing drops the "(Rebuilding)" entirely and
        #      memstat becomes just "21%". That alone is fatal: the
        #      case-glob *[Rr]ebuilding* misses, the row falls through
        #      to the crit catch-all, and the percentage ends up in the
        #      problem-hash 'detail' - so every tick (1%->2%->3%...)
        #      generates NEW+RESOLVED email pairs forever.
        #
        # We cover both: include $NF in the joined status, then strip
        # the trailing-digit run that's the size (whether spaced or
        # glued). That gives us the full "21% (Rebuilding)" string.
        diskutil appleRAID list "$u" 2>/dev/null | awk '
            /^[0-9-]+[ \t]+disk[0-9]+/ {
                devnode = $2
                status = ""
                for (i = 4; i <= NF; i++) {
                    status = (status == "" ? $i : status " " $i)
                }
                # Strip the trailing byte-size, with or without leading
                # whitespace (the Rebuilding case glues it to the
                # parenthesized status word).
                sub(/[ \t]*[0-9]+$/, "", status)
                # Trim trailing whitespace.
                sub(/[ \t]+$/, "", status)
                print devnode "|" status
            }
        ' | while IFS='|' read -r devnode memstat; do
            [ -n "$devnode" ] || continue
            case "$memstat" in
                Online)
                    log_debug "  $devnode: Online"
                    ;;
                *[Rr]ebuilding*|*%*)
                    # Stable hash: 'rebuilding' regardless of percentage.
                    # Without the *%* alternative, a memstat of bare
                    # "21%" (parsed before the awk fix above) would have
                    # missed this case and gone to the crit catch-all,
                    # producing one NEW+RESOLVED email pair per tick.
                    h=$(problem_hash "raid-member" "$name/$devnode" "rebuilding")
                    seen_add "$h"
                    handle_problem "raid-member" "$name/$devnode" "rebuilding" "warn" \
                        "RAID $name member $devnode is rebuilding ($memstat)"
                    ;;
                *)
                    h=$(problem_hash "raid-member" "$name/$devnode" "$memstat")
                    seen_add "$h"
                    handle_problem "raid-member" "$name/$devnode" "$memstat" "crit" \
                        "RAID $name member $devnode status: $memstat"
                    ;;
            esac
        done
    done
}

# ----------------------------------------------------------------------
# SMART health check. Runs at most once per SMART_POLL_INTERVAL.
# Uses a sentinel file ($STATE_DIR/last-smart) to rate-limit across runs.
# ----------------------------------------------------------------------

smart_last_run_file() { echo "${STATE_DIR}/last-smart"; }

# Global flag: set to 1 when smartctl is not installed / not in PATH.
# cmd_health inspects this at the end and emits a prominent warning.
# Missing smartctl is a SILENT FAILURE MODE - the daemon would happily
# claim "no problems" while never actually checking SMART - so we make
# this extremely visible.
SMART_UNAVAILABLE=0

smart_should_run() {
    [ "${SMART_CHECK_ENABLED:-yes}" = "yes" ] || return 1
    if ! command -v smartctl >/dev/null 2>&1; then
        # Escalated from log_debug to log_warn: this is a silent failure
        # mode where the daemon would keep running without ever checking
        # SMART. Surface it every run so it can't go unnoticed.
        SMART_UNAVAILABLE=1
        log_warn "smartctl NOT FOUND - SMART checks are completely disabled"
        log_warn "  Install with:   brew install smartmontools"
        log_warn "  Or set SMART_CHECK_ENABLED=no to silence this warning."
        return 1
    fi
    f=$(smart_last_run_file)
    if [ ! -f "$f" ]; then return 0; fi
    last=$(cat "$f" 2>/dev/null)
    now=$(date +%s)
    diff=$(( now - ${last:-0} ))
    [ "$diff" -ge "${SMART_POLL_INTERVAL:-86400}" ]
}

smart_mark_ran() {
    date +%s > "$(smart_last_run_file)" 2>/dev/null || true
}

# Normalize a single disk spec ("3", "disk3", "/dev/disk3", "disk3s2") to
# the bare whole-disk identifier ("disk3"). Returns empty if it can't parse.
normalize_disk_id() {
    raw="$1"
    # Strip leading/trailing whitespace and /dev/ prefix.
    raw=$(printf '%s' "$raw" | sed 's|^[[:space:]]*||; s|[[:space:]]*$||; s|^/dev/||')
    case "$raw" in
        disk[0-9]*)
            # Strip any partition suffix (sNN).
            echo "$raw" | sed 's/s[0-9]*$//'
            ;;
        [0-9]*)
            echo "disk$raw"
            ;;
        "")
            : # silently skip blanks
            ;;
        *)
            log_warn "Ignoring unparseable disk spec: '$raw'"
            ;;
    esac
}

# List every whole physical disk currently attached (no virtual RAID/APFS).
# Used for MONITOR_DISKS="all".
list_all_physical_disks() {
    # 'diskutil list' shows a header line per disk; we want ones marked
    # "(internal, physical)" or "(external, physical)" - NOT "virtual" or
    # "synthesized".
    diskutil list 2>/dev/null \
        | awk -F'[ (]' '/^\/dev\/disk[0-9]+ \((internal|external), physical\):/ {
            # $1="/dev/diskN" -> strip /dev/
            sub(/^\/dev\//, "", $1)
            print $1
        }'
}

# ----------------------------------------------------------------------
# Optional disk SETs of GROUPs.
#
# Three-level structure:
#
#   DISK          one physical disk, identified by stable id (SN:/PART:/
#                 USB:/VOL:) or bare disk-node name.
#   GROUP         named bundle of disks. Rule (a): if ANY member is
#                 present, ALL members must be present (no partial group).
#   SET           named collection of GROUPs (a "rotation"). Rule (b):
#                 within the set, AT LEAST ONE group must be fully
#                 present at any time.
#
# Multiple SETs can coexist; rules (a) and (b) are checked per-set
# independently. Typical use: one SET per rotation pool (off-site
# rotation pair vs. weekly archive vs. ...).
#
# Config: OPTIONAL_DISK_SETS is a multi-line string. Each non-empty,
# non-comment line has the form:
#
#     <set>/<group> = <disk-spec>, <disk-spec>, ...
#
# Backwards-compatibility: a line with no '/' (legacy v6 form
# "<name> = ...") is auto-promoted to "default/<name>", so the SET
# named 'default' holds all such legacy groups. v6 semantics are
# preserved exactly: rule (b) "across the whole list" was a single
# implicit set.
#
# A <disk-spec> may be a tagged baseline id (SN:..., PART:..., USB:...,
# VOL:...) OR a bare disk-node form (disk7, /dev/disk7, 7). Tagged ids
# are STRONGLY preferred for rotation use cases since the bsd shuffles
# across replug/reboot.
#
# Members of any optional GROUP (in any SET) are EXCLUDED from
# REQUIRED_DISKS resolution so a swapped-out rotation disk does not
# also fire a disk-missing alert.
# ----------------------------------------------------------------------

# Emit "set|group|spec" lines for every (set, group, member) tuple
# defined in OPTIONAL_DISK_SETS. Skips blanks/'#' comments. Trims
# whitespace. Auto-promotes legacy bare-name lines into the 'default'
# set.
optional_sets_iter() {
    [ -n "${OPTIONAL_DISK_SETS:-}" ] || return 0
    printf '%s\n' "$OPTIONAL_DISK_SETS" | while IFS= read -r _line; do
        _line=$(printf '%s' "$_line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        case "$_line" in
            ''|'#'*) continue ;;
        esac
        case "$_line" in
            *=*) ;;
            *) log_warn "OPTIONAL_DISK_SETS: ignoring malformed line (no '='): $_line"; continue ;;
        esac
        _path=$(printf '%s' "$_line" | sed 's/=.*//' | sed 's/[[:space:]]*$//')
        _rest=$(printf '%s' "$_line" | sed 's/^[^=]*=//')
        [ -n "$_path" ] || continue
        # Split set/group. Bare name = default set, name as group.
        case "$_path" in
            */*)
                _setn=$(printf '%s' "$_path" | sed 's|/.*||' | sed 's/[[:space:]]*$//')
                _grpn=$(printf '%s' "$_path" | sed 's|^[^/]*/||' | sed 's/^[[:space:]]*//')
                ;;
            *)
                _setn="default"
                _grpn="$_path"
                ;;
        esac
        case "$_setn" in *'|'*|*' '*) log_warn "OPTIONAL_DISK_SETS: bad set name (space/'|') in: $_line"; continue ;; esac
        case "$_grpn" in *'|'*|*' '*) log_warn "OPTIONAL_DISK_SETS: bad group name (space/'|') in: $_line"; continue ;; esac
        [ -n "$_setn" ] && [ -n "$_grpn" ] || continue
        printf '%s\n' "$_rest" | tr ',' '\n' | while IFS= read -r _spec; do
            _spec=$(printf '%s' "$_spec" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
            [ -n "$_spec" ] || continue
            printf '%s|%s|%s\n' "$_setn" "$_grpn" "$_spec"
        done
    done
}

# Distinct SET names, in declaration order.
optional_sets_set_names() {
    optional_sets_iter | awk -F'|' 'NF>0 && !seen[$1]++ {print $1}'
}

# Distinct GROUP names within a given SET, in declaration order.
optional_sets_groups_in() {
    _s="$1"
    optional_sets_iter | awk -F'|' -v s="$_s" '$1==s && !seen[$2]++ {print $2}'
}

# Disks in (set, group), one spec per line.
optional_set_group_members() {
    _s="$1"; _g="$2"
    optional_sets_iter | awk -F'|' -v s="$_s" -v g="$_g" '$1==s && $2==g {print $3}'
}

# Every spec across every (set, group), deduplicated. Used to filter
# REQUIRED_DISKS resolution.
optional_sets_all_specs() {
    optional_sets_iter | awk -F'|' '{print $3}' | awk 'NF>0 && !seen[$0]++'
}

# Resolve a single spec to the currently-attached bsd, or empty if not
# present. Accepts tagged baseline ids and bare disk-node forms.
optional_spec_to_bsd() {
    _s="$1"
    [ -n "$_s" ] || return 0
    case "$_s" in
        SN:*|PART:*|USB:*|VOL:*)
            disk_for_baseline_id "$_s"
            ;;
        *)
            _b=$(normalize_disk_id "$_s")
            if [ -n "$_b" ] && diskutil info "/dev/$_b" >/dev/null 2>&1; then
                echo "$_b"
            fi
            ;;
    esac
}

# Given a bsd, return "set/group" if the disk is a member of any
# (set, group); empty otherwise. First match wins (a disk should not
# be in two groups).
optional_set_for_bsd() {
    _b="${1#/dev/}"
    [ -n "$_b" ] || return 0
    [ -n "${OPTIONAL_DISK_SETS:-}" ] || return 0
    _id=$(disk_baseline_id "$_b" 2>/dev/null)
    optional_sets_iter | while IFS='|' read -r _setn _grpn _spec; do
        [ -n "$_setn" ] || continue
        case "$_spec" in
            SN:*|PART:*|USB:*|VOL:*)
                if [ -n "$_id" ] && [ "$_spec" = "$_id" ]; then
                    printf '%s/%s\n' "$_setn" "$_grpn"; return 0
                fi
                ;;
            *)
                _nb=$(normalize_disk_id "$_spec")
                if [ -n "$_nb" ] && [ "$_nb" = "$_b" ]; then
                    printf '%s/%s\n' "$_setn" "$_grpn"; return 0
                fi
                ;;
        esac
    done
}

# Build the expected disk list WITHOUT presence validation.
# This is the union of (base list from MONITOR_DISKS) + MONITOR_EXTRA_DISKS,
# normalized and deduplicated. Used by both the SMART pipeline (which
# then filters down to present disks) and the presence check (which
# diffs this list against what's actually attached).
#
# Two entry forms are accepted in REQUIRED_DISKS comma-lists:
#   * disk-node form: "3", "disk3", "/dev/disk3" - normalized to "disk3"
#     and matched against the current attach order. TRANSIENT - the
#     same physical disk may appear at a different node after reboot.
#   * serial form: anything else - passed through verbatim and matched
#     against attached disks' SMART/system_profiler serial numbers.
#     STABLE across reboots and replugs.
#
# 'all' mode reads the baseline file, which is now serial-keyed.
resolve_required_disks() {
    _raw=$(
        case "${REQUIRED_DISKS:-}" in
            ""|none|NONE)
                ;;
            all|ALL)
                f=$(baseline_disks_file)
                if [ ! -f "$f" ]; then
                    log_info "No disk baseline yet; creating from current state"
                    baseline_write_disks
                fi
                if baseline_disks_is_legacy 2>/dev/null; then
                    log_warn "baseline-disks is in legacy disk-node format (e.g. 'disk2')."
                    log_warn "Disk-node names are TRANSIENT and shuffle across reboots/replugs."
                    log_warn "Re-run 'my-appleRAID baseline --disks' to switch to stable serials."
                fi
                baseline_read_disks
                ;;
            *)
                echo "$REQUIRED_DISKS" | tr ',' '\n' | while read -r spec; do
                    spec=$(printf '%s' "$spec" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
                    [ -n "$spec" ] || continue
                    case "$spec" in
                        disk[0-9]*|/dev/disk[0-9]*|[0-9]*)
                            normalize_disk_id "$spec"
                            ;;
                        *)
                            # Treated as a serial number by check_disk_presence.
                            echo "$spec"
                            ;;
                    esac
                done
                ;;
        esac
    )
    # Subtract any disk that is a member of an optional disk set:
    # presence of those is governed by check_optional_disk_sets, not the
    # plain disk-missing alert. Match on verbatim spec equality (covers
    # tagged baseline ids when both sides use SN:/PART:/USB:/VOL: form).
    _optspecs=$(optional_sets_all_specs)
    if [ -z "$_optspecs" ]; then
        printf '%s\n' "$_raw" | awk 'NF>0'
        return 0
    fi
    printf '%s\n' "$_raw" | awk 'NF>0' | while IFS= read -r _r; do
        if printf '%s\n' "$_optspecs" | grep -qxF "$_r"; then
            log_debug "  required disk '$_r' suppressed (member of an optional disk set)"
            continue
        fi
        echo "$_r"
    done
}

# Resolve REQUIRED_SETS into a concrete list of set NAMES (not UUIDs).
# Names are more stable across recreations than UUIDs.
resolve_required_sets() {
    case "${REQUIRED_SETS:-}" in
        ""|none|NONE)
            return 0
            ;;
        all|ALL)
            f=$(baseline_sets_file)
            if [ ! -f "$f" ]; then
                log_info "No set baseline yet; creating from current state"
                baseline_write_sets
            fi
            baseline_read_sets
            ;;
        *)
            echo "$REQUIRED_SETS" | tr ',' '\n' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | awk 'NF>0'
            ;;
    esac
}

# Build the full SMART-monitoring scope: MONITOR_DISKS base minus
# MONITOR_DISKS_EXCLUDE, plus any explicit REQUIRED_DISKS entries
# (required disks are always SMART-checked when present, even if they
# would otherwise be excluded).
resolve_expected_disks() {
    # --- Base list from MONITOR_DISKS ---
    base=""
    case "${MONITOR_DISKS:-auto}" in
        auto|AUTO|"")
            uuids=$(resolve_monitored_sets)
            for u in $uuids; do
                base="$base
$(diskutil appleRAID list "$u" 2>/dev/null \
                    | awk '/^[0-9]+[ \t]+disk/ {print $2}' \
                    | sed 's/s[0-9]*$//')"
            done
            ;;
        all|ALL)
            base=$(list_all_physical_disks)
            ;;
        *)
            base=$(echo "$MONITOR_DISKS" | tr ',' '\n' | while read -r spec; do
                normalize_disk_id "$spec"
            done)
            ;;
    esac

    # --- Subtract MONITOR_DISKS_EXCLUDE ---
    exclude=""
    if [ -n "${MONITOR_DISKS_EXCLUDE:-}" ]; then
        exclude=$(echo "$MONITOR_DISKS_EXCLUDE" | tr ',' '\n' | while read -r spec; do
            normalize_disk_id "$spec"
        done)
    fi
    base=$(echo "$base" | awk 'NF>0' | while read -r d; do
        if ! echo "$exclude" | grep -qxF "$d"; then
            echo "$d"
        fi
    done)

    # --- Merge REQUIRED_DISKS (present ones get SMART-checked too) ---
    # Only explicit-list REQUIRED_DISKS merge here; "all" mode already
    # derives from system state, and merging that back would be tautological.
    required=""
    case "${REQUIRED_DISKS:-}" in
        ""|none|NONE|all|ALL) ;;
        *)
            required=$(echo "$REQUIRED_DISKS" | tr ',' '\n' | while read -r spec; do
                normalize_disk_id "$spec"
            done)
            ;;
    esac

    printf '%s\n%s\n' "$base" "$required" | awk 'NF>0 && !seen[$0]++'
}

# Resolve list of physical disks to SMART-check. Returns only disks that
# are CURRENTLY PRESENT on the system. Missing disks are silently skipped
# here; the presence check (check_disk_presence) is the designated place
# to alert about them.
resolve_monitored_disks() {
    resolve_expected_disks | while read -r d; do
        [ -n "$d" ] || continue
        if diskutil info "/dev/$d" >/dev/null 2>&1; then
            echo "$d"
        fi
    done
}

# Presence check for disks. Fires alerts when a disk in REQUIRED_DISKS is
# not currently attached. Uses a grace period to debounce transient
# disappearances (Thunderbolt enclosure waking, USB re-enumeration).
#
# Config:
#   ALERT_ON_MISSING_DISK    yes|no           master switch
#   REQUIRED_DISKS           all|list|""      scope (see resolve_required_disks)
#   MISSING_DISK_SEVERITY    warn|crit
#   MISSING_DISK_GRACE_PERIOD   duration         seconds missing before alerting
check_disk_presence() {
    if [ "${ALERT_ON_MISSING_DISK:-no}" != "yes" ]; then
        log_debug "Disk presence check skipped: ALERT_ON_MISSING_DISK=${ALERT_ON_MISSING_DISK:-no}"
        return 0
    fi

    sev="${MISSING_DISK_SEVERITY:-crit}"
    case "$sev" in
        warn|crit) ;;
        *) log_warn "Invalid MISSING_DISK_SEVERITY='$sev'; using 'crit'"; sev=crit ;;
    esac

    grace="${MISSING_DISK_GRACE_PERIOD:-300}"
    required=$(resolve_required_disks)
    if [ -z "$required" ]; then
        log_debug "Disk presence check skipped: REQUIRED_DISKS resolves to empty"
        return 0
    fi
    log_debug "Disk presence: $(echo "$required" | wc -l | tr -d ' ') required entries, grace=${grace}s, severity=$sev"

    # Each required entry is either:
    #   - A tagged baseline id (SN:..., PART:..., USB:..., VOL:...) -
    #     resolved via disk_for_baseline_id, which scans currently-
    #     attached disks for one with that identifier.
    #   - A bare disk-node name (disk2, disk3 - from explicit comma-list
    #     REQUIRED_DISKS) - looked up via diskutil info /dev/<name>.
    # Bare disk-node entries are TRANSIENT and may match a different
    # physical disk after replug; they exist here for backward
    # compatibility with explicit user lists.
    echo "$required" | awk 'NF>0 && !seen[$0]++' | while read -r r; do
        [ -n "$r" ] || continue
        case "$r" in
            SN:*|PART:*|USB:*|VOL:*)
                cur=$(disk_for_baseline_id "$r")
                if [ -n "$cur" ]; then
                    log_debug "  $r -> /dev/$cur (present)"
                    grace_clear "disk" "$r"
                else
                    log_debug "  $r -> NOT attached"
                    if grace_check "disk" "$r" "$grace"; then
                        h=$(problem_hash "disk-missing" "$r" "not-present")
                        seen_add "$h"
                        handle_problem "disk-missing" "$r" "not-present" "$sev" \
                            "Expected disk with id '$r' is NOT attached"
                    fi
                fi
                ;;
            *)
                if diskutil info "/dev/$r" >/dev/null 2>&1; then
                    log_debug "  /dev/$r: present (note: bare-node form is transient)"
                    grace_clear "disk" "$r"
                else
                    log_debug "  /dev/$r: NOT attached"
                    if grace_check "disk" "$r" "$grace"; then
                        h=$(problem_hash "disk-missing" "$r" "not-present")
                        seen_add "$h"
                        handle_problem "disk-missing" "$r" "not-present" "$sev" \
                            "Expected disk /dev/$r is NOT attached"
                    fi
                fi
                ;;
        esac
    done
}

# Presence check for OPTIONAL_DISK_SETS (SETs of GROUPs of DISKs).
#
# For each (set, group):
#   present == total       -> OK; group is "fully present"
#   0 < present < total    -> PARTIAL: rule (a) violated for that group;
#                             alert with severity OPTIONAL_DISK_SET_SEVERITY
#   present == 0           -> group fully absent; fine on its own
#
# Then per SET, rule (b): at least ONE of the set's groups must be
# fully present. If no group in the set is fully present, alert.
#
# Both alert types are debounced by OPTIONAL_DISK_SET_GRACE_PERIOD so
# transient hub re-enumeration on swap-out does not fire instantly.
check_optional_disk_sets() {
    [ -n "${OPTIONAL_DISK_SETS:-}" ] || {
        log_debug "Optional disk sets check skipped: OPTIONAL_DISK_SETS empty"
        return 0
    }
    if [ "${ALERT_ON_OPTIONAL_DISK_SETS:-yes}" != "yes" ]; then
        log_debug "Optional disk sets check skipped: ALERT_ON_OPTIONAL_DISK_SETS=${ALERT_ON_OPTIONAL_DISK_SETS:-yes}"
        return 0
    fi

    sev="${OPTIONAL_DISK_SET_SEVERITY:-crit}"
    case "$sev" in
        warn|crit) ;;
        *) log_warn "Invalid OPTIONAL_DISK_SET_SEVERITY='$sev'; using 'crit'"; sev=crit ;;
    esac
    grace="${OPTIONAL_DISK_SET_GRACE_PERIOD:-300}"

    _sets=$(optional_sets_set_names)
    [ -n "$_sets" ] || return 0

    for _setn in $_sets; do
        _groups=$(optional_sets_groups_in "$_setn")
        [ -n "$_groups" ] || continue

        _any_full=0
        _full_groups=""
        for _grpn in $_groups; do
            _members=$(optional_set_group_members "$_setn" "$_grpn")
            _total=$(printf '%s\n' "$_members" | awk 'NF>0' | wc -l | tr -d ' ')
            [ "$_total" -gt 0 ] || continue

            _resolved=$(printf '%s\n' "$_members" | while IFS= read -r _spec; do
                [ -n "$_spec" ] || continue
                _bsd=$(optional_spec_to_bsd "$_spec")
                if [ -n "$_bsd" ]; then
                    printf 'PRESENT %s %s\n' "$_spec" "$_bsd"
                else
                    printf 'MISSING %s\n' "$_spec"
                fi
            done)
            _present=$(printf '%s\n' "$_resolved" | awk '$1=="PRESENT"' | wc -l | tr -d ' ')
            _missing=$(printf '%s\n' "$_resolved" | awk '$1=="MISSING" {print $2}' | paste -sd, -)

            log_debug "  optional ${_setn}/${_grpn}: $_present/$_total present"

            # Slash in the tag would land as a path separator in
            # pending-optset-partial-<tag>; flatten to underscore.
            _gracetag="${_setn}__${_grpn}"
            if [ "$_present" = "$_total" ]; then
                grace_clear "optset-partial" "$_gracetag"
                _any_full=1
                _full_groups="$_full_groups $_grpn"
            elif [ "$_present" -gt 0 ]; then
                if grace_check "optset-partial" "$_gracetag" "$grace"; then
                    h=$(problem_hash "optset-partial" "$_gracetag" "${_present}of${_total}")
                    seen_add "$h"
                    handle_problem "optset-partial" "$_gracetag" "${_present}of${_total}" "$sev" \
                        "Optional set '$_setn' group '$_grpn' is partially present ($_present of $_total); missing: ${_missing:-?}"
                fi
            else
                grace_clear "optset-partial" "$_gracetag"
            fi
        done

        # Rule (b) per-set.
        if [ "$_any_full" = "1" ]; then
            grace_clear "optset-none-full" "$_setn"
            log_debug "  optional set '$_setn' rule (b) OK; fully present:$_full_groups"
        else
            if grace_check "optset-none-full" "$_setn" "$grace"; then
                h=$(problem_hash "optset-none-full" "$_setn" "no-group-fully-present")
                seen_add "$h"
                _gnames=$(printf '%s' "$_groups" | tr '\n' ',' | sed 's/,$//;s/,/, /g')
                handle_problem "optset-none-full" "$_setn" "no-group-fully-present" "$sev" \
                    "Optional set '$_setn': no group is fully present (defined groups: ${_gnames})"
            fi
        fi
    done
}

# Presence check for RAID sets. Fires alerts when a set in REQUIRED_SETS
# is not currently present in 'diskutil appleRAID list'. Degraded/Failed
# sets ARE present (and caught separately by check_raid_sets), so this
# function specifically targets the "set disappeared entirely" case.
#
# Config:
#   ALERT_ON_MISSING_SET     yes|no           master switch
#   REQUIRED_SETS            all|list|""      scope (see resolve_required_sets)
#   MISSING_SET_SEVERITY     warn|crit
#   MISSING_SET_GRACE_PERIOD    duration         seconds missing before alerting
check_set_presence() {
    if [ "${ALERT_ON_MISSING_SET:-no}" != "yes" ]; then
        log_debug "Set presence check skipped: ALERT_ON_MISSING_SET=${ALERT_ON_MISSING_SET:-no}"
        return 0
    fi

    sev="${MISSING_SET_SEVERITY:-crit}"
    case "$sev" in
        warn|crit) ;;
        *) log_warn "Invalid MISSING_SET_SEVERITY='$sev'; using 'crit'"; sev=crit ;;
    esac

    grace="${MISSING_SET_GRACE_PERIOD:-300}"
    required=$(resolve_required_sets)
    if [ -z "$required" ]; then
        log_debug "Set presence check skipped: REQUIRED_SETS resolves to empty"
        return 0
    fi
    log_debug "Set presence: $(echo "$required" | wc -l | tr -d ' ') required, grace=${grace}s, severity=$sev"

    # Build a list of currently-present set names for fast lookup.
    present_names=$(diskutil appleRAID list 2>/dev/null | awk -F': +' '
        /^Name:/ { n=$2; sub(/ +$/,"",n); if (n!="") print n }
    ')

    echo "$required" | awk 'NF>0 && !seen[$0]++' | while read -r name; do
        [ -n "$name" ] || continue
        if echo "$present_names" | grep -qxF "$name"; then
            log_debug "  set '$name': present"
            grace_clear "set" "$name"
        else
            log_debug "  set '$name': NOT present"
            if grace_check "set" "$name" "$grace"; then
                h=$(problem_hash "set-missing" "$name" "not-present")
                seen_add "$h"
                handle_problem "set-missing" "$name" "not-present" "$sev" \
                    "Required RAID set '$name' is NOT present in diskutil appleRAID list"
            fi
        fi
    done
}

# Auto-baseline: when enabled, extend the baseline to include sets that
# have been consistently observed for at least AUTO_BASELINE_GRACE_PERIOD.
# Only runs if REQUIRED_SETS=all (otherwise the baseline file isn't
# authoritative - the user is managing an explicit list manually).
check_auto_baseline_sets() {
    if [ "${AUTO_BASELINE_FOR_SETS_ON_HEALTH:-no}" != "yes" ]; then
        log_debug "Auto-baseline sets skipped: AUTO_BASELINE_FOR_SETS_ON_HEALTH=${AUTO_BASELINE_FOR_SETS_ON_HEALTH:-no}"
        return 0
    fi
    case "${REQUIRED_SETS:-}" in
        all|ALL) ;;
        *) log_debug "Auto-baseline sets skipped: REQUIRED_SETS='${REQUIRED_SETS:-}' (not 'all')"; return 0 ;;
    esac
    if [ "${ALERT_ON_MISSING_SET:-no}" != "yes" ]; then
        log_debug "Auto-baseline sets skipped: ALERT_ON_MISSING_SET=${ALERT_ON_MISSING_SET:-no}"
        return 0
    fi

    grace="${AUTO_BASELINE_GRACE_PERIOD:-86400}"
    # Current baseline for lookup.
    current=$(baseline_read_sets 2>/dev/null)
    # Present set names.
    present=$(diskutil appleRAID list 2>/dev/null | awk -F': +' '
        /^Name:/ { n=$2; sub(/ +$/,"",n); if (n!="") print n }
    ')
    log_debug "Auto-baseline sets: present=$(echo "$present" | wc -l | tr -d ' '), baselined=$(echo "$current" | wc -l | tr -d ' '), grace=${grace}s"

    echo "$present" | awk 'NF>0 && !seen[$0]++' | while read -r name; do
        [ -n "$name" ] || continue
        if echo "$current" | grep -qxF "$name"; then
            log_debug "  set '$name': already in baseline"
            auto_baseline_clear "set" "$name"
        else
            log_debug "  set '$name': new (waiting for ${grace}s of continuous presence)"
            if auto_baseline_check "set" "$name" "$grace"; then
                log_info "Auto-baselining new RAID set: $name (present >= ${grace}s)"
                baseline_write_sets
                auto_baseline_clear "set" "$name"
            fi
        fi
    done
    # NOTE: we intentionally do NOT auto-remove sets that have been
    # missing-and-grace-expired. Auto-removal of persistent items is
    # riskier than auto-adding of long-present ones - the user can
    # always force a refresh with 'appleRAID baseline --sets'. The
    # AUTO_BASELINE_FOR_SETS_ON_DESTROY path handles the clean case
    # where the user deliberately destroyed a set.
    return 0
}

# Auto-baseline for disks: same logic as sets, but for physical disk
# identifiers.
check_auto_baseline_disks() {
    if [ "${AUTO_BASELINE_FOR_DISKS_ON_HEALTH:-no}" != "yes" ]; then
        log_debug "Auto-baseline disks skipped: AUTO_BASELINE_FOR_DISKS_ON_HEALTH=${AUTO_BASELINE_FOR_DISKS_ON_HEALTH:-no}"
        return 0
    fi
    case "${REQUIRED_DISKS:-}" in
        all|ALL) ;;
        *) log_debug "Auto-baseline disks skipped: REQUIRED_DISKS='${REQUIRED_DISKS:-}' (not 'all')"; return 0 ;;
    esac
    if [ "${ALERT_ON_MISSING_DISK:-no}" != "yes" ]; then
        log_debug "Auto-baseline disks skipped: ALERT_ON_MISSING_DISK=${ALERT_ON_MISSING_DISK:-no}"
        return 0
    fi

    grace="${AUTO_BASELINE_GRACE_PERIOD:-86400}"
    current=$(baseline_read_disks 2>/dev/null)
    log_debug "Auto-baseline disks: baselined=$(echo "$current" | wc -l | tr -d ' '), grace=${grace}s"

    # Compare by tagged baseline id, not by /dev/diskN node, so a disk
    # whose number changed (replug, hub swap) does not get spuriously
    # auto-baselined as "new".
    list_all_physical_disks | while IFS= read -r d; do
        [ -n "$d" ] || continue
        id=$(disk_baseline_id "$d" 2>/dev/null)
        if [ -z "$id" ]; then
            log_debug "  /dev/$d: skip (no stable identifier discoverable)"
            continue
        fi
        if echo "$current" | grep -qxF "$id"; then
            log_debug "  /dev/$d ($id): already in baseline"
            auto_baseline_clear "disk" "$id"
        else
            log_debug "  /dev/$d ($id): new (waiting for ${grace}s of continuous presence)"
            if auto_baseline_check "disk" "$id" "$grace"; then
                log_info "Auto-baselining new disk: $d ($id, present >= ${grace}s)"
                baseline_write_disks
                auto_baseline_clear "disk" "$id"
            fi
        fi
    done
    return 0
}

check_smart() {
    if ! smart_should_run; then
        f=$(smart_last_run_file)
        if [ -f "$f" ]; then
            last=$(cat "$f" 2>/dev/null)
            now=$(date +%s)
            age=$((now - ${last:-0}))
            log_debug "SMART check skipped: last ran ${age}s ago, interval=${SMART_POLL_INTERVAL}s"
        else
            log_debug "SMART check skipped: SMART_CHECK_ENABLED=${SMART_CHECK_ENABLED:-yes} or smartctl missing"
        fi
        return 0
    fi
    log_info "Running SMART check (runs every ${SMART_POLL_INTERVAL}s)"
    disks=$(resolve_monitored_disks)
    if [ -z "$disks" ]; then
        log_warn "No disks resolved for SMART check"
        return 0
    fi
    log_debug "SMART scope: $(echo "$disks" | wc -w | tr -d ' ') disk(s): $(echo "$disks" | tr '\n' ' ')"

    for d in $disks; do
        dev="/dev/$d"
        [ -e "$dev" ] || { log_warn "Skipping $dev (not present)"; continue; }

        # Determine and cache the correct `smartctl -d` type for this
        # disk. Some USB/Thunderbolt bridges need an explicit -d; the
        # cache avoids re-probing on every run.
        sc=$(smart_cmd "$d")
        if [ "$sc" = "smartctl" ] && [ "$(smart_dtype_for "$d")" = "" ]; then
            log_debug "  $d: no SMART support; skipping"
            continue
        fi
        log_debug "  $d: probing via '$sc'"

        # Overall health (PASSED/FAILED)
        health=$($sc -H "$dev" 2>/dev/null | awk -F': *' \
            '/SMART overall-health/ {print $2; exit}
             /SMART Health Status/   {print $2; exit}')
        health=$(echo "$health" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        log_debug "    health: ${health:-<unknown>}"

        if [ -n "$health" ] && [ "$health" != "PASSED" ] && [ "$health" != "OK" ]; then
            h=$(problem_hash "smart-health" "$d" "$health")
            seen_add "$h"
            handle_problem "smart-health" "$d" "$health" "crit" \
                "SMART overall health for $d: $health"
        fi

        # Temperature (attribute 194 or 190)
        temp=$($sc -A "$dev" 2>/dev/null | awk '
            /^[[:space:]]*(194|190)[[:space:]]+Temperature/ { print $10; exit }
        ')
        if [ -n "$temp" ]; then
            log_debug "Disk $d temperature: ${temp}C"
            if [ "$temp" -ge "${TEMP_CRIT_C:-58}" ] 2>/dev/null; then
                h=$(problem_hash "smart-temp" "$d" "critical")
                seen_add "$h"
                handle_problem "smart-temp" "$d" "critical" "crit" \
                    "Disk $d temperature ${temp}C >= CRIT ${TEMP_CRIT_C}C"
            elif [ "$temp" -ge "${TEMP_WARN_C:-50}" ] 2>/dev/null; then
                h=$(problem_hash "smart-temp" "$d" "warn")
                seen_add "$h"
                handle_problem "smart-temp" "$d" "warn" "warn" \
                    "Disk $d temperature ${temp}C >= WARN ${TEMP_WARN_C}C"
            fi
        fi

        # "Killer" attributes: any non-zero raw value warrants attention.
        # Reallocated_Sector_Ct (5), Current_Pending_Sector (197),
        # Offline_Uncorrectable (198), UDMA_CRC_Error_Count (199)
        $sc -A "$dev" 2>/dev/null | awk '
            /^[[:space:]]*(5|197|198|199)[[:space:]]/ {
                id=$1; name=$2; raw=$10
                # raw may be "0" or "0/0" etc.; take first numeric token
                if (raw+0 > 0) printf "%s|%s|%s\n", id, name, raw
            }
        ' | while IFS='|' read -r aid aname araw; do
            [ -n "$aid" ] || continue
            h=$(problem_hash "smart-attr" "$d" "$aid")
            seen_add "$h"
            handle_problem "smart-attr" "$d" "$aid" "warn" \
                "Disk $d attribute $aname ($aid) = $araw (non-zero)"
        done
    done
    smart_mark_ran
}

# ----------------------------------------------------------------------
# SMART self-tests (short/long), scheduled daily or weekly at SELFTEST_HOUR.
# Uses a per-disk sentinel file to avoid re-running within the same window.
# ----------------------------------------------------------------------
selftest_should_run() {
    schedule="$1"     # daily|weekly|never
    sentinel="$2"
    case "$schedule" in
        never|"") return 1 ;;
    esac
    h=$(date '+%H')
    # Only run during the scheduled hour (avoids mid-day surprises).
    [ "$h" = "$(printf '%02d' "${SELFTEST_HOUR:-3}")" ] || return 1
    # Don't re-run within window.
    if [ -f "$sentinel" ]; then
        last_day=$(stat -f '%Sm' -t '%Y-%m-%d' "$sentinel" 2>/dev/null)
        today=$(date '+%Y-%m-%d')
        case "$schedule" in
            daily)
                [ "$last_day" != "$today" ] || return 1
                ;;
            weekly)
                last_epoch=$(stat -f '%m' "$sentinel" 2>/dev/null || echo 0)
                now_epoch=$(date +%s)
                [ $(( now_epoch - last_epoch )) -ge 604800 ] || return 1
                ;;
        esac
    fi
    return 0
}

run_selftests() {
    if ! command -v smartctl >/dev/null 2>&1; then
        # Already reported by smart_should_run - don't double-log, just
        # ensure the flag is set in case SMART_CHECK_ENABLED=no but we
        # still got here somehow.
        SMART_UNAVAILABLE=1
        log_debug "Self-tests skipped: smartctl not in PATH"
        return 0
    fi
    log_debug "Self-tests: short=${SELFTEST_SHORT_SCHEDULE:-daily}, long=${SELFTEST_LONG_SCHEDULE:-weekly}, hour=$(printf '%02d' "${SELFTEST_HOUR:-3}"), now=$(date '+%H'):00"
    for d in $(resolve_monitored_disks); do
        dev="/dev/$d"
        [ -e "$dev" ] || continue

        sc=$(smart_cmd "$d")
        short_sentinel="${STATE_DIR}/selftest-short-${d}"
        long_sentinel="${STATE_DIR}/selftest-long-${d}"

        if selftest_should_run "${SELFTEST_SHORT_SCHEDULE:-never}" "$short_sentinel"; then
            log_info "Starting SHORT self-test on $d"
            $sc -t short "$dev" >/dev/null 2>&1 && touch "$short_sentinel"
        else
            log_debug "  $d: short self-test not due (schedule=${SELFTEST_SHORT_SCHEDULE:-never})"
        fi
        if selftest_should_run "${SELFTEST_LONG_SCHEDULE:-daily}" "$long_sentinel"; then
            log_info "Starting LONG self-test on $d (runs in background, ~1.4 h per 1 TB at sustained ~200 MB/s)"
            $sc -t long "$dev" >/dev/null 2>&1 && touch "$long_sentinel"
        else
            log_debug "  $d: long self-test not due (schedule=${SELFTEST_LONG_SCHEDULE:-weekly})"
        fi
    done
}

# ----------------------------------------------------------------------
# The `health` subcommand itself.
# ----------------------------------------------------------------------
cmd_health() {
    # Accept global -V/-D after the subcommand name.
    eval "$(parse_global_flags "$@")"

    # --disk drill-down mode: short-circuit the daemon pipeline and
    # call _smart_drilldown_one for one specific physical disk. This
    # is the on-demand counterpart to the recurring monitoring pass,
    # and is also exposed as the standalone `smart` subcommand.
    drill_disk=""
    drill_mode=0
    _hpos=""
    for a in "$@"; do
        if [ "$_hpos" = "--disk" ]; then
            drill_disk="$a"; _hpos=""
            continue
        fi
        case "$a" in
            --disk)   drill_mode=1; _hpos="--disk" ;;
            --disk=*) drill_mode=1; drill_disk="${a#--disk=}" ;;
        esac
    done
    if [ "$drill_mode" = "1" ]; then
        if [ -z "$drill_disk" ]; then
            drill_disk=$(pick_physical_disk_interactively "inspect (SMART)") || return 1
        fi
        ddev=$(resolve_disk "$drill_disk") || die "Invalid disk spec: $drill_disk"
        assert_whole_disk "$ddev"
        _smart_drilldown_one "${ddev#/dev/}"
        return 0
    fi

    cfg_load
    # cfg_load sources the config file which resets LOG_LEVEL back to
    # whatever the user has there (default "info"). If -V/-D was passed
    # on the CLI, re-escalate now so debug logging wins over the config.
    if [ "$VERBOSE" = "1" ] || [ "$DEBUG" = "1" ]; then
        LOG_LEVEL=debug
    fi
    state_init
    seen_init

    # Per-run event log. handle_problem and handle_resolved append to
    # this file (via the HEALTH_RUN_LOG env var) so the end-of-run
    # SUMMARY block can count what happened this pass without re-
    # parsing the state DB. Cleaned up by the trap below.
    HEALTH_RUN_LOG=$(mktemp -t my-appleRAID-runlog.XXXXXX) || HEALTH_RUN_LOG=""
    export HEALTH_RUN_LOG

    # Trap so we always clean up the temp seen-file + run-log.
    # Health iterates monitored disks, optsets, and presence checks -
    # all of which call disk_baseline_id / disk_for_baseline_id. Cache
    # once up front, clean up via the same trap as the rest.
    _diskid_cache_init
    trap 'seen_cleanup; _diskid_cache_clear; [ -n "$HEALTH_RUN_LOG" ] && rm -f "$HEALTH_RUN_LOG"' EXIT INT TERM

    dry=0
    force=0
    for a in "$@"; do
        case "$a" in
            --dry-run) dry=1 ;;
            --once)    force=1 ;;
            # Legacy lowercase -v accepted as alias for -V.
            -v)        VERBOSE=1; LOG_LEVEL=debug ;;
        esac
    done

    if [ "$dry" = "1" ]; then
        log_info "DRY RUN - no alarms/emails will be sent"
        # Override alert functions to no-op
        alert_sound() { log_info "(dry) would play alarm: $ALARM_SOUND"; }
        alert_email() { log_info "(dry) would email: $1"; }
    fi
    if [ "$force" = "1" ]; then
        ALARM_INTERVAL=0
        EMAIL_INTERVAL=0
    fi

    log_debug "Config loaded from: $LOADED_CONFIG"
    log_debug "Monitoring sets: $MONITOR_SETS"

    # Step-by-step narration when run interactively with -V / -D (or -v).
    # The launchd daemon path runs without these flags so its log stays
    # quiet; only the human-invoked `health -V` walks through each check.
    _verbose_health=0
    if [ "$VERBOSE" = "1" ] || [ "$DEBUG" = "1" ]; then
        _verbose_health=1
    fi

    [ "$_verbose_health" = "1" ] && step "Health pass starting"
    if [ "$_verbose_health" = "1" ]; then
        info "Config file:    ${LOADED_CONFIG:-<none>}"
        info "State dir:      ${STATE_DIR:-<none>}"
        info "Log file:       ${LOG_FILE:-<stderr only>}"
        info "Email enabled:  $([ -n "${EMAIL_TO:-}" ] && echo "yes -> $EMAIL_TO" || echo "no (EMAIL_TO empty)")"
        info "Alarm enabled:  ${ALARM_ENABLED:-yes}"
        info "Dry run:        $([ "$dry" = "1" ] && echo "yes" || echo "no")"
        info "Force (--once): $([ "$force" = "1" ] && echo "yes (rate limits bypassed)" || echo "no")"
        echo
    fi

    [ "$_verbose_health" = "1" ] && step "Check 1/9: RAID set state (Online / Degraded / Rebuilding / Failed)"
    check_raid_sets

    # Enforce DEFAULT_AUTO_REBUILD policy on every monitored set.
    # Skipped if config is empty. Silent when no drift; logs an info
    # line when it actually flips a set's AutoRebuild.
    if [ -n "${DEFAULT_AUTO_REBUILD:-}" ]; then
        [ "$_verbose_health" = "1" ] && step "Check 2/9: Enforce DEFAULT_AUTO_REBUILD=$DEFAULT_AUTO_REBUILD on every monitored set"
        for u in $(resolve_monitored_sets 2>/dev/null); do
            enforce_default_ar_for_uuid "$u" || true
        done
    else
        [ "$_verbose_health" = "1" ] && step "Check 2/9: AutoRebuild enforcement DISABLED (DEFAULT_AUTO_REBUILD is empty)"
    fi

    [ "$_verbose_health" = "1" ] && step "Check 3/9: Auto-baseline sets (add long-present sets to baseline)"
    check_auto_baseline_sets
    [ "$_verbose_health" = "1" ] && step "Check 4/9: Auto-baseline disks (add long-present disks to baseline)"
    check_auto_baseline_disks
    [ "$_verbose_health" = "1" ] && step "Check 5/9: RAID set presence (every set in REQUIRED_SETS still present?)"
    check_set_presence
    [ "$_verbose_health" = "1" ] && step "Check 6/9: Disk presence (every disk in REQUIRED_DISKS still attached?)"
    check_disk_presence
    [ "$_verbose_health" = "1" ] && step "Check 7/9: Optional disk sets (rule a: full-or-empty per group; rule b: at least one group fully present)"
    check_optional_disk_sets
    [ "$_verbose_health" = "1" ] && step "Check 8/9: SMART attributes + temperature (rate-limited by SMART_POLL_INTERVAL)"
    check_smart
    [ "$_verbose_health" = "1" ] && step "Check 9/9: Scheduled SMART self-tests (short / long per SELFTEST_*_SCHEDULE)"
    run_selftests

    # Detect resolved problems: anything in state file not seen this run.
    for h in $(state_list_hashes); do
        if ! seen_has "$h"; then
            handle_resolved "$h"
        fi
    done

    # Exit code reflects worst severity still present.
    worst=0
    crit_count=0
    warn_count=0
    for h in $(state_list_hashes); do
        sev=$(state_field "$h" 2)
        case "$sev" in
            crit) worst=2; crit_count=$((crit_count + 1)) ;;
            warn) [ "$worst" -lt 1 ] && worst=1; warn_count=$((warn_count + 1)) ;;
        esac
    done
    log_debug "Health check complete. Exit=$worst"

    # End-of-run SUMMARY. Shown only in -V/-D mode. The non-verbose
    # path (incl. the launchd daemon) is intentionally silent on
    # stdout: real alerts go via the structured logger (LOG_FILE,
    # log_warn/error -> stderr) and the email/alarm side effects.
    # The exit code still reflects worst-severity for scripted
    # callers. The smartctl-missing banner below is unconditional
    # because that's a silent-failure-mode alert that must never
    # be hidden by quiet mode.
    if [ "$_verbose_health" = "1" ]; then
        new_crit=0; new_warn=0; ongoing=0; resolved_n=0; stale_n=0
        if [ -n "${HEALTH_RUN_LOG:-}" ] && [ -r "$HEALTH_RUN_LOG" ]; then
            new_crit=$(awk -F'|' '$1=="new"      && $2=="crit"' "$HEALTH_RUN_LOG" | wc -l | tr -d ' ')
            new_warn=$(awk -F'|' '$1=="new"      && $2=="warn"' "$HEALTH_RUN_LOG" | wc -l | tr -d ' ')
            ongoing=$( awk -F'|' '$1=="ongoing"'                "$HEALTH_RUN_LOG" | wc -l | tr -d ' ')
            resolved_n=$(awk -F'|' '$1=="resolved"'             "$HEALTH_RUN_LOG" | wc -l | tr -d ' ')
            stale_n=$(awk -F'|' '$1=="stale"'                   "$HEALTH_RUN_LOG" | wc -l | tr -d ' ')
        fi
        case "$worst" in
            0) _exit_label="OK (no problems)" ;;
            1) _exit_label="WARN (warn-level problems present)" ;;
            2) _exit_label="CRIT (crit-level problems present)" ;;
            *) _exit_label="?" ;;
        esac
        echo
        step "SUMMARY"
        info "  Currently open problems:     $((crit_count + warn_count))  (crit=$crit_count, warn=$warn_count)"
        info "  New this run:                $((new_crit + new_warn))  (crit=$new_crit, warn=$new_warn)"
        info "  Ongoing this run:            $ongoing  (already known, rate-limit applied)"
        info "  Resolved this run:           $resolved_n  (sent 'all clear' email + cleared state)"
        if [ "$stale_n" -gt 0 ]; then
            info "  Stale state pruned:          $stale_n  (legacy hashes; underlying issue re-fired with current keys)"
        fi
        info "  Exit code:                   $worst  ($_exit_label)"
        info "    0 = clean, 1 = warn-level open, 2 = crit-level open."
        if [ "$crit_count" -gt 0 ] || [ "$warn_count" -gt 0 ]; then
            echo
            info "  Open problems:"
            for h in $(state_list_hashes); do
                sev=$(state_field "$h" 2)
                sum=$(state_field "$h" 6)
                printf '    [%s] %s\n' "$sev" "$sum"
            done
        fi
        echo
    fi

    # --- Prominent end-of-run SMART-missing warning ---
    # If smartctl was discovered missing during this run, emit a visible
    # banner. This goes to stderr (so launchd captures it in
    # LAUNCHD_STDERR_LOG) and also through the structured logger at warn
    # level (so it ends up in LOG_FILE and any mail digest).
    #
    # Rationale: smartctl-missing is the single most dangerous silent
    # failure mode for this daemon. Without it, temperature, reallocated
    # sectors, pending sectors, UDMA errors, and overall health are ALL
    # uninspected. The daemon would keep reporting "Online" while a
    # drive quietly fails. Make it impossible to miss.
    if [ "${SMART_UNAVAILABLE:-0}" = "1" ]; then
        {
            echo
            echo "================================================================"
            echo "  WARNING: smartctl IS NOT INSTALLED"
            echo "================================================================"
            echo "  SMART monitoring is COMPLETELY DISABLED."
            echo "  The daemon is NOT checking:"
            echo "    - Drive temperature"
            echo "    - Reallocated / pending / uncorrectable sectors"
            echo "    - UDMA CRC errors"
            echo "    - Overall drive health (PASSED/FAILED)"
            echo "    - SMART self-tests"
            echo
            echo "  Only RAID set/member presence is being monitored."
            echo "  A failing drive may go unnoticed until it causes RAID"
            echo "  degradation or data loss."
            echo
            echo "  FIX:   brew install smartmontools"
            echo "  Or:    set SMART_CHECK_ENABLED=no in the config to"
            echo "         silence this warning if you truly do not want"
            echo "         SMART monitoring."
            echo "================================================================"
        } >&2
        # Elevate exit code so scripts/monitoring that check \$? see this
        # is not a clean run. Promote to at least warn (1).
        [ "$worst" -lt 1 ] && worst=1
    fi

    seen_cleanup
    trap - EXIT INT TERM
    return $worst
}

# ----------------------------------------------------------------------
# `show-config` - dump effective config and which file it came from.
# ----------------------------------------------------------------------
cmd_show_config() {
    cfg_load

    # Refuse to display if no config file was actually loaded. Showing
    # built-in defaults as "the config" is misleading - the user ran
    # show-config precisely because they want to see THEIR config. If
    # it's not there, tell them how to fix that rather than confirming
    # a state that doesn't exist.
    case "$LOADED_CONFIG" in
        *"(none"*|"")
            errmsg "No config file found on the search path."
            echo
            info "Searched locations (first readable wins):"
            info "  \$MY_APPLERAID_CONFIG              (env var, for testing)"
            info "  /LINKS/default/my-appleRAID.conf"
            info "  \$HOME/.my-appleRAID.conf"
            info "  /usr/local/etc/my-appleRAID.conf"
            info "  /etc/my-appleRAID.conf"
            echo
            info "To create an annotated default config at one of these paths:"
            info "  $SCRIPT_NAME create-config /LINKS/default/my-appleRAID.conf"
            info "Or for a per-user file:"
            info "  $SCRIPT_NAME create-config ~/.my-appleRAID.conf"
            echo
            info "Then re-run:  $SCRIPT_NAME show-config"
            exit 1
            ;;
    esac

    step "Effective configuration"
    info "Config file loaded: $LOADED_CONFIG"
    echo
    # Print every known key in a stable order. For duration-valued keys
    # (*_INTERVAL, *_PERIOD), also show the normalized value in a
    # human-readable form so "86400" is annotated as "1d" for easier
    # verification.
    for k in \
        MONITOR_SETS MONITOR_SETS_EXCLUDE \
        REQUIRED_SETS ALERT_ON_MISSING_SET MISSING_SET_SEVERITY MISSING_SET_GRACE_PERIOD \
        MONITOR_DISKS MONITOR_DISKS_EXCLUDE \
        REQUIRED_DISKS ALERT_ON_MISSING_DISK MISSING_DISK_SEVERITY MISSING_DISK_GRACE_PERIOD \
        OPTIONAL_DISK_SETS ALERT_ON_OPTIONAL_DISK_SETS OPTIONAL_DISK_SET_SEVERITY OPTIONAL_DISK_SET_GRACE_PERIOD \
        AUTO_BASELINE_FOR_SETS_ON_CREATE AUTO_BASELINE_FOR_SETS_ON_DESTROY \
        AUTO_BASELINE_FOR_SETS_ON_HEALTH AUTO_BASELINE_FOR_DISKS_ON_HEALTH \
        AUTO_BASELINE_GRACE_PERIOD \
        TEMP_WARN_C TEMP_CRIT_C SMART_CHECK_ENABLED \
        DEFAULT_AUTO_REBUILD REBUILD_EMAIL_INTERVAL \
        ALARM_SOUND ALARM_VOLUME ALARM_VOLUME_MODE ALARM_INTERVAL ALARM_ENABLED \
        EMAIL_TO EMAIL_FROM EMAIL_SENDER EMAIL_INTERVAL \
        SMART_POLL_INTERVAL SELFTEST_SHORT_SCHEDULE SELFTEST_LONG_SCHEDULE SELFTEST_HOUR \
        STATE_DIR LOG_FILE LOG_LEVEL \
        LAUNCHD_PLIST LAUNCHD_STDOUT_LOG LAUNCHD_STDERR_LOG LAUNCHD_INTERVAL
    do
        eval "v=\${$k}"
        # Annotate duration-valued keys (_INTERVAL or _PERIOD suffix).
        case "$k" in
            *_INTERVAL|*_PERIOD)
                case "$v" in
                    ''|*[!0-9]*) printf '  %-28s = %s\n' "$k" "$v" ;;
                    *)           printf '  %-28s = %s  (%s)\n' "$k" "$v" "$(format_duration "$v")" ;;
                esac
                ;;
            *) printf '  %-28s = %s\n' "$k" "$v" ;;
        esac
    done

    # Derived values (not user-settable).
    echo
    printf '%sDerived:%s\n' "${C_DIM}" "${C_RESET}"
    printf '  %-28s = %s  (from LAUNCHD_PLIST filename)\n' "LAUNCHD_LABEL" "${LAUNCHD_LABEL:-<unset>}"
}

# Format an integer number of seconds as the most natural human-readable
# duration string. Exact multiples round trip cleanly: 86400 -> "1d",
# 3600 -> "1h", 300 -> "5m", etc. Non-exact values fall back to "N s".
format_duration() {
    s="$1"
    case "$s" in
        ''|*[!0-9]*) echo "?"; return ;;
    esac
    [ "$s" -eq 0 ] 2>/dev/null && { echo "0s"; return; }
    if [ $(( s % 604800 )) -eq 0 ] && [ "$s" -ge 604800 ]; then
        echo "$(( s / 604800 ))w"
    elif [ $(( s % 86400 )) -eq 0 ] && [ "$s" -ge 86400 ]; then
        echo "$(( s / 86400 ))d"
    elif [ $(( s % 3600 )) -eq 0 ] && [ "$s" -ge 3600 ]; then
        echo "$(( s / 3600 ))h"
    elif [ $(( s % 60 )) -eq 0 ] && [ "$s" -ge 60 ]; then
        echo "$(( s / 60 ))m"
    else
        echo "${s}s"
    fi
}

# ----------------------------------------------------------------------
# `create-config <path>` - write an annotated default config file.
# ----------------------------------------------------------------------
cmd_create_config() {
    if [ $# -lt 1 ]; then
        errmsg "Usage: $SCRIPT_NAME create-config <path>"
        echo
        info "Suggested locations (any one works; first readable wins):"
        info "  /LINKS/default/my-appleRAID.conf        # your symlink-based location"
        info "  /usr/local/etc/my-appleRAID.conf        # system-wide"
        info "  ~/.my-appleRAID.conf                    # per-user"
        exit 1
    fi
    path="$1"
    if [ -e "$path" ]; then
        confirm "File $path already exists. Overwrite?" || die "Aborted."
    fi
    dir=$(dirname "$path")
    [ -d "$dir" ] || mkdir -p "$dir" || die "Cannot create directory $dir"

    cat > "$path" <<'EOF'
# ======================================================================
# my-appleRAID configuration file
# ======================================================================
# This file is sourced by /bin/dash. Syntax: KEY=value (no spaces around
# '='). Values with spaces must be quoted.  Lines starting with '#' are
# comments.
#
# Search path (first readable file wins):
#   $MY_APPLERAID_CONFIG  (env var, for testing)
#   /LINKS/default/my-appleRAID.conf
#   $HOME/.my-appleRAID.conf
#   /usr/local/etc/my-appleRAID.conf
#   /etc/my-appleRAID.conf
#
# Every key has a built-in default; you only need to set the ones you
# want to change.
#
# ----------------------------------------------------------------------
# DURATION SYNTAX (applies to *_INTERVAL and *_PERIOD keys)
# ----------------------------------------------------------------------
# All keys whose name ends in _INTERVAL or _PERIOD accept either a bare
# number (interpreted as seconds) or a value with a time-unit suffix:
#   60       -> 60 seconds
#   30s      -> 30 seconds
#   5m       -> 5 minutes  (300 s)
#   2h       -> 2 hours    (7200 s)
#   1d       -> 1 day      (86400 s)
#   1w       -> 1 week     (604800 s)
# Suffix is case-insensitive. The parser warns and falls back to 0 on
# invalid input (typos, unknown units).
# ======================================================================


# ======================================================================
# !!! REVIEW / SET THESE FIRST !!!
# ----------------------------------------------------------------------
# Without the three EMAIL_* keys below, problems are detected and logged
# but NO email is sent. The audible alarm still fires (if enabled), and
# the LOG_FILE still records everything, but you will NOT be notified
# remotely until EMAIL_TO has a real address AND EMAIL_SENDER points at
# a configured sendmail-compatible binary.
# ======================================================================

# Recipient. EMPTY (default) DISABLES EMAIL ENTIRELY.
# Set this to a real address before relying on the daemon for alerts.
EMAIL_TO=""

# From address. Must match what your SMTP relay allows (most relays
# reject mail whose envelope sender is not a domain they accept).
# Default below is a placeholder that will be rejected by every relay.
EMAIL_FROM="my-appleRAID@localhost"

# Path to (or bare name of) a sendmail-compatible sender. msmtp is
# recommended:
#   brew install msmtp
# Configure ~/.msmtprc with a working SMTP account before email will
# leave the host.
#
# A bare name (default below) is resolved via PATH; my-appleRAID's
# top-of-script block extends PATH to include /opt/homebrew/bin and
# /usr/local/bin so this works in the launchd daemon context too. Set
# to an absolute path here if you have multiple sender binaries and
# want to pin one explicitly.
EMAIL_SENDER="msmtp"

# Minimum time between emails for the SAME ongoing problem.
# Accepts duration suffixes (see top of file): 60, 60s, 5m, 2h, 1d, 1w.
# Default 4h gives 6 emails/day max per problem.
EMAIL_INTERVAL=4h


# --- RAID monitoring -------------------------------------------------

# Which RAID sets to SMART-monitor and status-check.
#   "all" / "auto"    -> every AppleRAID set on the system (synonyms)
#   "NameA,NameB"     -> comma-list of set names or UUIDs
MONITOR_SETS="all"

# RAID sets to subtract from MONITOR_SETS (comma-list of names/UUIDs).
# Useful when you want "all except this one scratch mirror".
MONITOR_SETS_EXCLUDE=""

# Which RAID sets MUST exist in 'diskutil appleRAID list'. When a
# required set is missing entirely (not just degraded), the daemon
# alerts. Degraded/Failed status is ALWAYS caught separately by the
# standard RAID check - this key only adds the "set vanished" case.
#
#   "all"              -> snapshot current sets as the baseline; alert
#                         if any of them later goes missing. Run
#                         'appleRAID baseline --sets' after deliberately
#                         adding or removing a RAID set.
#   "NameA,NameB"      -> explicit list; compared directly, no snapshot.
#   ""                 -> disabled (no presence check for sets).
REQUIRED_SETS="all"

# Master switch for REQUIRED_SETS. Set to "no" to disable the presence
# check entirely without losing the REQUIRED_SETS value.
ALERT_ON_MISSING_SET=yes

# Severity of a missing-set alert:
#   warn -> log + email (rate-limited), NO audible alarm
#   crit -> log + email + audible alarm (rate-limited)
MISSING_SET_SEVERITY=crit

# Debounce: how long a set must be missing before alerting.
# Thunderbolt enclosures can take 5-30 seconds to re-enumerate after
# sleep/wake, so a too-aggressive alert would fire falsely. 5m gives
# comfortable headroom; lower it if your attachments are more stable.
# Accepts duration suffixes (see top of file): 60, 5m, 2h, 1d.
MISSING_SET_GRACE_PERIOD=5m


# --- Disk monitoring -------------------------------------------------

# Which physical disks to run SMART checks against.
#   "auto"               -> members of monitored RAID sets. Good default:
#                           SMART on the drives you care about most
#                           without waking idle archive disks.
#   "all"                -> every whole physical disk attached (internal
#                           + external). Blanket coverage. Note: idle
#                           USB drives will spin up once per
#                           SMART_POLL_INTERVAL.
#   "disk2,disk3,..."    -> explicit list. Accepts bare numbers (3),
#                           names (disk3), or full paths (/dev/disk3).
#                           Partition suffixes (s2) are stripped.
MONITOR_DISKS="auto"

# Disks to subtract from MONITOR_DISKS (comma-list).
# Example: MONITOR_DISKS=all, MONITOR_DISKS_EXCLUDE="disk8"  -- monitor
# everything except the external scratch drive on disk8.
MONITOR_DISKS_EXCLUDE=""

# Which disks MUST be attached. When a required disk is missing, the
# daemon alerts (after MISSING_DISK_GRACE_PERIOD debounce).
#
#   "all"              -> snapshot currently-attached disks as the
#                         baseline; alert if any go missing later.
#                         Suitable for servers where drives are stable
#                         fixtures. Less suitable for laptops where USB
#                         drives come and go - you'd need to rebaseline
#                         after every unplug. Use an explicit list in
#                         that case.
#   "disk2,disk8"      -> explicit list; compared directly.
#   ""                 -> disabled.
#
# REQUIRED_DISKS entries are AUTOMATICALLY included in the SMART scope
# when present (you don't need to also list them in MONITOR_DISKS).
REQUIRED_DISKS="all"

# Master switch for REQUIRED_DISKS.
ALERT_ON_MISSING_DISK=yes

# Severity of a missing-disk alert: warn|crit
MISSING_DISK_SEVERITY=crit

# Debounce: how long a disk must be missing before alerting.
# Accepts duration suffixes.
MISSING_DISK_GRACE_PERIOD=5m


# --- Optional disk sets (SETs of GROUPs of DISKs) -------------------
#
# WHEN TO USE THIS:
#   This feature is for ROTATING EXTRA BACKUP DISK SETS - the standard
#   3-2-1-style offsite-backup workflow where you keep two (or more)
#   identical bundles of backup disks and physically rotate them
#   between "on-site, plugged in" and "off-site / in a safe / at
#   another location". You swap them on a cadence (weekly, monthly,
#   etc). You can run multiple independent rotations in parallel
#   (e.g. an off-site rotation AND a separate weekly archive rotation).
#
#   Without this feature, a swapped-out set would (a) trip the standard
#   "required disk missing" alert, and (b) you'd have no automated
#   confirmation that you actually plugged in the OTHER set after
#   pulling the first one. This feature handles both cases cleanly.
#
# THREE LEVELS:
#
#   DISK    one physical disk, identified by stable id (SN:/PART:/USB:/
#           VOL:) or bare disk-node name.
#   GROUP   a named bundle of disks (e.g. a mirror pair). Rule (a):
#           if ANY member of the group is currently present, ALL members
#           must be present together (no partial group attached).
#   SET     a named collection of GROUPs (one rotation pool). Rule (b):
#           within the set, AT LEAST ONE group must be fully present at
#           any time. Different SETs are independent.
#
# Members of any optional GROUP (in any SET) are EXCLUDED from
# REQUIRED_DISKS resolution, so swapping out a rotation disk does NOT
# also fire a stand-alone disk-missing alert. The optional-set checker
# is the authoritative source of truth for those disks' presence.
#
# CONFIG FORMAT: multi-line. Each non-empty, non-'#' line:
#
#     <Set>/<Group> = <disk-spec>, <disk-spec>, ...
#
# A line with no '/' (legacy v6 form "<name> = ...") is auto-promoted
# into the SET named 'default'. v6 semantics are preserved exactly.
#
# A disk-spec may be a tagged baseline id (preferred for rotation):
#
#     SN:<serial>     - ATA/NVMe serial. Stable across reboot/replug.
#     PART:<gpt-uuid> - GPT partition entry GUID. Stable, baked into
#                       partition table.
#     USB:<srl>:<bytes> - USB bridge serial + size in bytes.
#     VOL:<uuid>      - Volume UUID (last resort).
#
# ...or a bare disk-node form (disk7, /dev/disk7) - TRANSIENT, may
# match a different physical disk after replug. Run 'appleRAID disks'
# to discover stable ids; the SERIAL column (with -V) shows the raw
# serial that you'd write as 'SN:<serial>'.
#
# INTERACTIVE MANAGER: instead of hand-editing this section, run
# 'appleRAID baseline --optsets'. It lists currently-attached disks and
# disks in the baseline-but-missing list, lets you create / rename /
# delete sets and groups, assign disks via menu pick, and writes the
# result back into this config file atomically.
#
# EXAMPLE 1: a single rotation pool with two mirror pairs.
# OffsiteRotation lives in two halves: Pair1 on-site, Pair2 off-site.
# Once a week you swap them. The daemon enforces:
#   - within each pair, both disks must be present together (rule a);
#   - within OffsiteRotation, exactly one pair must be fully present
#     at any time (rule b).
#
#     OPTIONAL_DISK_SETS="
#     OffsiteRotation/Pair1 = SN:WD-AAA1, SN:WD-AAA2
#     OffsiteRotation/Pair2 = SN:WD-BBB1, SN:WD-BBB2
#     "
#
# EXAMPLE 2: two independent rotation pools (off-site rotation AND a
# separate quarterly archive). Each pool's rule (b) is checked
# independently - you must always have one OffsiteRotation pair AND
# one QuarterlyArchive disk plugged in.
#
#     OPTIONAL_DISK_SETS="
#     OffsiteRotation/Pair1 = SN:WD-AAA1, SN:WD-AAA2
#     OffsiteRotation/Pair2 = SN:WD-BBB1, SN:WD-BBB2
#     QuarterlyArchive/Q1 = SN:HGST-Q1
#     QuarterlyArchive/Q2 = SN:HGST-Q2
#     QuarterlyArchive/Q3 = SN:HGST-Q3
#     QuarterlyArchive/Q4 = SN:HGST-Q4
#     "
#
# Default empty -> feature disabled.
OPTIONAL_DISK_SETS=""

# Master switch for the optional-disk-set checker. "no" disables both
# rule (a) and rule (b) alerts without losing the OPTIONAL_DISK_SETS
# definition.
ALERT_ON_OPTIONAL_DISK_SETS=yes

# Severity of optional-set alerts (partial group, or no group fully
# present). warn -> log + email; crit -> log + email + audible alarm.
OPTIONAL_DISK_SET_SEVERITY=crit

# Debounce: how long a partial-group / no-group-fully-present condition
# must persist before alerting. Covers the swap window: while you are
# physically pulling group A and plugging in group B, both rules will
# briefly be violated. Accepts duration suffixes.
OPTIONAL_DISK_SET_GRACE_PERIOD=5m


# --- Auto-baseline ---------------------------------------------------
#
# When REQUIRED_SETS=all / REQUIRED_DISKS=all, the daemon uses baseline
# files to know which sets/disks are supposed to exist. These files can
# be updated manually (`appleRAID baseline`) or automatically by the
# five keys below. All default to "yes" to keep the baseline in lockstep
# with reality on a stable-hardware server.
#
# There are three trigger events across two subsystems:
#
#   SETS:   - ON_CREATE   fires when 'appleRAID create' succeeds
#           - ON_DESTROY  fires when 'appleRAID destroy' succeeds
#           - ON_HEALTH   fires during 'appleRAID health' poll when a
#                         new set has been observed continuously for
#                         AUTO_BASELINE_GRACE_PERIOD
#
#   DISKS:  - ON_HEALTH   fires during 'appleRAID health' poll when a
#                         new disk has been observed continuously for
#                         AUTO_BASELINE_GRACE_PERIOD
#                         (no CREATE/DESTROY commands exist for disks -
#                          macOS handles attach/detach itself, so only
#                          the health poll can observe disk changes)
#
# When a trigger fires AND the subsystem uses REQUIRED_*=all, the
# corresponding baseline file is regenerated from current system state.
# Items that have been intentionally removed are therefore automatically
# forgotten on the next matching event (e.g. destroying a set with
# AUTO_BASELINE_FOR_SETS_ON_DESTROY=yes also removes it from the
# baseline in the same step).
#
# Set any key to "no" to require manual 'appleRAID baseline' commands
# for the corresponding event.

AUTO_BASELINE_FOR_SETS_ON_CREATE=yes
AUTO_BASELINE_FOR_SETS_ON_DESTROY=yes
AUTO_BASELINE_FOR_SETS_ON_HEALTH=yes
AUTO_BASELINE_FOR_DISKS_ON_HEALTH=yes

# How long a new set/disk must be continuously present before the
# ON_HEALTH auto-baseliner adds it. This filters out test plug-ins,
# flaky USB hubs, and other transient attachments that you don't
# actually want permanently tracked.
#
# Accepts duration suffixes: 1h, 6h, 1d, 1w.
# Default 1d: a drive must stay attached for a full day before the
# daemon concludes it's a "keeper".
AUTO_BASELINE_GRACE_PERIOD=1d


# --- Thresholds ------------------------------------------------------

# Temperature alert thresholds in degrees Celsius.
# WD Gold / Red Pro rated operating range: 5-60C. Alert well before the
# ceiling so you can react (improve airflow, check fans, etc.).
TEMP_WARN_C=50
TEMP_CRIT_C=58

# Master enable for SMART attribute checking (health, temp, error counts).
# Set to "no" if you only want RAID set monitoring (disables temp alerts
# and attribute-based warnings too).
SMART_CHECK_ENABLED=yes


# --- AppleRAID AutoRebuild enforcement -------------------------------
#
# Apple's `diskutil appleRAID create` ships every new mirror with
# `Rebuild: manual` (AutoRebuild=0). Empirical real-disk testing
# confirms AutoRebuild is the ONLY knob that affects what happens
# when a transiently-missing member returns; SetTimeout has no
# observable effect on clean physical disconnects.
#
# DEFAULT_AUTO_REBUILD controls whether my-appleRAID enforces an
# AutoRebuild value on every set during create / health / list:
#
#   0   (default) enforce AutoRebuild=0 on every set. A returning member
#       stays 'Failed' until you manually run 'my-appleRAID repair'.
#       Pros: persistent visible alert (the Degraded state and the
#       Failed member are loudly obvious until you act); explicit
#       control over when the multi-hour rebuild runs.
#   1   force AutoRebuild=1. Returning members auto-rebuild without operator
#       action. The health daemon still emails on every transition
#       (Degraded onset, Rebuilding start, progress every 6h,
#       resolution back to Online), so visibility is preserved -
#       but the set self-heals if you don't act.
#   ""  (empty) disable enforcement entirely. The script reads and
#       displays AutoRebuild but never writes it. Manage by hand
#       per-set via `my-appleRAID autorebuild <set> on|off`.
#
# Default: 0.
DEFAULT_AUTO_REBUILD=0

# Re-email interval for an ongoing rebuild. Rebuilds last hours per
# TB on AppleRAID (no incremental resync), so periodic progress
# emails are useful. Default 21600 seconds = 6h = 4 emails/day.
# Set to a smaller value if you want denser progress reports, or
# to a value >= the typical rebuild duration to get only the
# start + completion emails.
REBUILD_EMAIL_INTERVAL=21600


# --- Audible alarm ---------------------------------------------------

# Master enable. "no" silences all audible alerts (email/log still work).
ALARM_ENABLED=yes

# Path to a sound file. macOS ships /System/Library/Sounds/*.aiff:
#   Basso.aiff (deep, urgent) - default
#   Funk.aiff / Glass.aiff / Hero.aiff / Ping.aiff / Sosumi.aiff ...
ALARM_SOUND="/System/Library/Sounds/Basso.aiff"

# Target volume (0.0 = silent, 1.0 = max).
ALARM_VOLUME=0.8

# How the script uses ALARM_VOLUME:
#   boost - only raise volume if current system volume is LOWER than
#           ALARM_VOLUME. Ensures audibility even if user muted. DEFAULT.
#   cap   - only lower volume if current is HIGHER than ALARM_VOLUME.
#           Prevents 3am full-blast if user had music at max.
#   set   - always set volume to exactly ALARM_VOLUME.
# In all cases, the previous system volume is restored after alarm.
ALARM_VOLUME_MODE=boost

# Minimum time between alarm playbacks for the SAME ongoing problem.
# Accepts duration suffixes (see top of file): 60, 60s, 5m, 2h, 1d, 1w.
# Set higher (e.g. 5m) if you find the every-minute alarm too aggressive.
ALARM_INTERVAL=1m


# --- SMART polling schedule -----------------------------------------

# How often to run SMART health + attribute checks.
# Accepts duration suffixes (see top of file): 60, 5m, 2h, 1d, 1w.
# Default 1d = once per day. Running more often wastes power (causes
# drive spin-ups on idle drives) without meaningful benefit - attribute
# changes unfold over hours/days, not seconds. For mostly-idle USB
# drives where every spin-up matters, 1w is a sensible alternative.
SMART_POLL_INTERVAL=1d

# SMART self-test schedules: "never" | "daily" | "weekly".
# Self-tests run IN THE BACKGROUND on the drive's own firmware - the
# drive remains accessible but performance is slightly reduced.
# Results land in the drive's firmware-resident self-test log (visible
# via 'smart <disk>' section 3/4, and used by 'smart <disk1> <disk2>'
# for comparative analysis).
#
#   short: ~2 minutes per drive. Quick electronics + small media
#          sample. Cost is negligible (a couple of percent CPU on the
#          drive controller, no host-side I/O).
#          Default: "daily". Cheap belt-and-braces backstop on top of
#          the daily attribute poll (SMART_POLL_INTERVAL), and it
#          keeps the per-drive self-test log freshly populated for
#          'smart <a> <b>' comparative analysis.
#
#   long:  full media scan. Duration scales LINEARLY with drive
#          capacity at a sustained read rate of ~200 MB/s. Rule of
#          thumb: ~1.4 hours per TB. Worked example:
#                 1 TB ->  ~1.4 h
#                 2 TB ->  ~2.8 h
#                 4 TB ->  ~5.5 h
#                 8 TB ->  ~11 h
#                10 TB ->  ~14 h
#                12 TB ->  ~17 h
#                14 TB ->  ~19 h
#                16 TB ->  ~22 h
#                18 TB ->  ~25 h
#                20 TB ->  ~28 h
#                22 TB ->  ~30 h
#                26 TB ->  ~36 h  (~1.5 days)
#                30 TB ->  ~42 h
#          On large modern drives a long test may take more than a day,
#          so "daily" makes no sense - the next test request is
#          rejected while the previous one is still running. Default
#          "weekly" gives room for the test to complete plus several
#          idle days. Rising bad-sector counts are caught within
#          hours by the daily attribute poll, so the long test is a
#          deep-scan backstop, not a primary detector.
SELFTEST_SHORT_SCHEDULE="daily"
SELFTEST_LONG_SCHEDULE="weekly"

# Hour of day (0-23) when scheduled self-tests should kick off.
# Pick a time when the drives are likely idle (backups finished, etc.).
SELFTEST_HOUR=3


# --- State & logging ------------------------------------------------

# Where the script keeps its state database and sentinel files.
# Must be writable by the user running `appleRAID health`.
STATE_DIR="/var/db/my-appleRAID"

# Log file. Set empty to log to stderr only (launchd will capture it).
LOG_FILE="/var/log/my-appleRAID.log"

# Verbosity: error | warn | info | debug
LOG_LEVEL=info


# --- LaunchDaemon installation (used by `install-daemon`) -----------

# Full path to the plist.
# The label (used internally by launchd and visible in 'launchctl list')
# is automatically derived from this filename - you do NOT set it
# separately. Example:
#   LAUNCHD_PLIST=".../eu.no-panic.my-appleRAID_health.plist"
#   -> label becomes  "eu.no-panic.my-appleRAID_health"
# Use reverse-DNS naming (yourdomain.tld.product_component) to avoid
# clashes with other launch items.
LAUNCHD_PLIST="/Library/LaunchDaemons/eu.no-panic.my-appleRAID_health.plist"

# Where launchd writes the daemon's stdout and stderr. These are the
# paths that end up inside the plist as StandardOutPath / StandardErrorPath,
# and are the destinations for anything the script prints *outside* the
# structured log (LOG_FILE). In practice: stdout stays empty, stderr
# captures any unexpected tracebacks or crash output.
#
# Must be writable by root (the daemon runs as root via launchd).
LAUNCHD_STDOUT_LOG="/var/log/my-appleRAID.launchd.out"
LAUNCHD_STDERR_LOG="/var/log/my-appleRAID.launchd.err"

# How often launchd should invoke `appleRAID health`.
# Accepts duration suffixes (see top of file): 60, 1m, 5m, etc.
# 1m = every minute. Cheap: RAID checks are fast; SMART is rate-limited
# internally by SMART_POLL_INTERVAL.
LAUNCHD_INTERVAL=1m
EOF

    chmod 644 "$path" 2>/dev/null || true
    ok "Wrote default config to: $path"
    echo
    warn "Email alerts are DISABLED until you set the variables below."
    warn "Without these, the launchd watchdog will detect problems but you"
    warn "will receive NO email notifications."
    echo
    info "Edit $path and set at minimum:"
    info "  EMAIL_TO       = \"you@example.com\"           # recipient (currently empty -> email off)"
    info "  EMAIL_FROM     = \"my-appleRAID@yourhost\"     # must match what your SMTP relay allows"
    info "  EMAIL_SENDER   = \"msmtp\"                     # default; needs 'brew install msmtp'"
    info "                                                # + ~/.msmtprc with a working SMTP account"
    echo
    info "Then verify with: $SCRIPT_NAME show-config"
    info "And test with:    $SCRIPT_NAME test-alerts"
}

# ----------------------------------------------------------------------
# `baseline` - snapshot currently-existing RAID sets and/or attached
# disks into the "expected" baseline used by REQUIRED_SETS=all /
# REQUIRED_DISKS=all. Run this after deliberately adding or removing a
# RAID set, or when you change your disk lineup.
#
# Does NOT affect SMART monitoring - SMART uses absolute thresholds,
# not a baseline.
# ----------------------------------------------------------------------
cmd_baseline() {
    cfg_load
    state_init

    # Build the bsd -> tagged-id cache ONCE for this run. baseline
    # walks attached disks several times (write-disks filter, optsets
    # rendering, Added/Removed annotation, '--show'), each of which
    # would otherwise call disk_baseline_id per disk and trip
    # system_profiler. Single init means single sweep. Trap cleans up.
    _diskid_cache_init
    trap '_diskid_cache_clear' EXIT INT TERM

    do_sets=1
    do_disks=1
    show_only=0
    do_optsets=0
    for a in "$@"; do
        case "$a" in
            --sets)    do_sets=1; do_disks=0; do_optsets=0 ;;
            --disks)   do_sets=0; do_disks=1; do_optsets=0 ;;
            --show)    show_only=1 ;;
            --optsets) do_sets=0; do_disks=0; do_optsets=1 ;;
            -h|--help)
                cat <<EOF
Usage: $SCRIPT_NAME baseline [--sets|--disks|--show|--optsets]

Snapshots the currently-existing RAID sets and/or attached disks into
the "expected baseline" used by REQUIRED_SETS=all / REQUIRED_DISKS=all,
or interactively manages OPTIONAL_DISK_SETS for rotating-backup
workflows.

  (no args)   Update both set and disk baselines.
  --sets      Update the RAID set baseline only.
  --disks     Update the disk baseline only.
  --show      Print the current baseline files without modifying them.
  --optsets   Interactive manager for OPTIONAL_DISK_SETS (SETs of
              GROUPs of DISKs - the rotating-backup feature). Lets you
              create/rename/delete named SETs and named GROUPs within
              them, and assign currently-attached or
              missing-from-baseline disks to a chosen Set/Group via
              menu pick. Writes the result back into the loaded
              config file atomically.

              Three-level model:
                DISK  - one physical disk (SN:/PART:/USB:/VOL: or diskN)
                GROUP - bundle of disks. Rule (a): if any member is
                        present, ALL must be present together.
                SET   - collection of groups (one rotation pool).
                        Rule (b): within the set, at least ONE group
                        must be fully present.
              Different SETs are independent (one rotation does not
              constrain another).

              Members of optional groups are excluded from
              REQUIRED_DISKS resolution, so a swapped-out rotation
              disk does not also fire a disk-missing alert.

Baseline files:
  $(baseline_sets_file)
  $(baseline_disks_file)
EOF
                return 0
                ;;
            *)
                die "Unknown baseline option: $a (try: --sets | --disks | --show | --optsets | --help)"
                ;;
        esac
    done

    if [ "$do_optsets" = "1" ]; then
        cmd_baseline_optsets
        return $?
    fi

    if [ "$show_only" = "1" ]; then
        step "Current baseline"
        f=$(baseline_sets_file)
        if [ -f "$f" ]; then
            info "RAID sets ($f):"
            sed 's/^/    /' "$f"
        else
            warn "No set baseline file yet: $f"
        fi
        echo
        f=$(baseline_disks_file)
        if [ -f "$f" ]; then
            info "Disks ($f):"
            sed 's/^/    /' "$f"
        else
            warn "No disk baseline file yet: $f"
        fi

        # ----------------------------------------------------------
        # Optional disk sets (read-only summary).
        # Show what 'health' will enforce: per-group rule (a), per-set
        # rule (b), plus the explicit list of disk specs that are
        # EXCLUDED from REQUIRED_DISKS resolution because they belong
        # to an optset.
        # ----------------------------------------------------------
        echo
        info "Optional disk sets (OPTIONAL_DISK_SETS in ${LOADED_CONFIG:-<no config>}):"
        if [ -z "${OPTIONAL_DISK_SETS:-}" ]; then
            echo "    (not configured)"
        else
            for _setn in $(optional_sets_set_names); do
                printf '    %sSet:%s %s\n' "${C_BOLD}" "${C_RESET}" "$_setn"
                for _grpn in $(optional_sets_groups_in "$_setn"); do
                    _ms=$(optional_set_group_members "$_setn" "$_grpn" \
                          | tr '\n' ',' | sed 's/,$//;s/,/, /g')
                    printf '      %s/%s = %s\n' "$_setn" "$_grpn" "$_ms"
                done
            done
            echo
            info "How 'health' / 'baseline' use these:"
            explain "  - Members of any optset GROUP are EXCLUDED from REQUIRED_DISKS"
            explain "    resolution; swapping a rotation disk OUT does not trigger"
            explain "    the standard 'required disk missing' alert."
            explain "  - Per GROUP (rule a): if any member is present, ALL members"
            explain "    must be present together (else: PARTIAL alert)."
            explain "  - Per SET (rule b): at least ONE group must be fully present"
            explain "    (else: 'no group fully present' alert)."
            explain "  - Different SETs are independent; rule (b) is checked per-set."
            echo
            info "Disk specs excluded from REQUIRED_DISKS (governed by optset rules):"
            optional_sets_all_specs | sed 's/^/    /'
        fi
        return 0
    fi

    if [ "$do_sets" = "1" ]; then
        step "Updating RAID set baseline"
        explain "Snapshotting names of all currently-existing RAID sets to:"
        explain "  $(baseline_sets_file)"
        # Capture the previous baseline so we can show what changed.
        _prev_sets=$(baseline_read_sets 2>/dev/null)
        baseline_write_sets
        _new_sets=$(baseline_read_sets 2>/dev/null)
        info "Baselined RAID sets:"
        echo "$_new_sets" | awk 'NF>0' | sed 's/^/    /'

        # Diff: what was added vs removed since the prior baseline.
        # Both lists are simple newline-separated names.
        _added_sets=$(printf '%s\n' "$_new_sets" "$_prev_sets" "$_prev_sets" \
            | awk 'NF>0' | sort | uniq -u)
        _removed_sets=$(printf '%s\n' "$_prev_sets" "$_new_sets" "$_new_sets" \
            | awk 'NF>0' | sort | uniq -u)
        echo
        if [ -n "$_added_sets" ]; then
            info "Added RAID sets (new since previous baseline):"
            echo "$_added_sets" | sed 's/^/    + /'
        fi
        if [ -n "$_removed_sets" ]; then
            info "Removed RAID sets (gone since previous baseline):"
            echo "$_removed_sets" | sed 's/^/    - /'
        fi
        if [ -z "$_added_sets" ] && [ -z "$_removed_sets" ]; then
            info "RAID set baseline unchanged."
        fi
    fi

    # Optional Disk Sets / Groups - shown between the RAID-set and
    # the plain-disk baselines so the output reads as a complete
    # picture of what the daemon will track. Read-only: the optsets
    # are stored in $LOADED_CONFIG (OPTIONAL_DISK_SETS), not in a
    # baseline file - edit them with 'baseline --optsets'.
    if [ "$do_disks" = "1" ] || [ "$do_sets" = "1" ]; then
        step "Optional Disk Sets / Groups baseline"
        if [ -z "${OPTIONAL_DISK_SETS:-}" ]; then
            explain "Empty. Define rotation pools with 'baseline --optsets'."
        else
            explain "Rules: (a) within a group: all members present together; (b) within a set: >=1 group fully present."
            explain "Read-only here. Source: OPTIONAL_DISK_SETS in ${LOADED_CONFIG:-<no config>} (edit via 'baseline --optsets')."
            for _setn in $(optional_sets_set_names); do
                printf '  %sSet:%s %s\n' "${C_BOLD}" "${C_RESET}" "$_setn"
                _any_full=0
                for _grpn in $(optional_sets_groups_in "$_setn"); do
                    _members=$(optional_set_group_members "$_setn" "$_grpn")
                    _total=$(printf '%s\n' "$_members" | awk 'NF>0' | wc -l | tr -d ' ')
                    _present=0
                    _line=""
                    for _spec in $_members; do
                        [ -n "$_spec" ] || continue
                        _bsd=$(optional_spec_to_bsd "$_spec" 2>/dev/null)
                        if [ -n "$_bsd" ]; then
                            _present=$((_present + 1))
                            _line="$_line ${_spec}->${_bsd}"
                        else
                            _line="$_line ${_spec}=MISSING"
                        fi
                    done
                    if [ "$_total" -gt 0 ] && [ "$_present" = "$_total" ]; then
                        _state="FULL"; _any_full=1
                    elif [ "$_present" -gt 0 ]; then
                        _state="PARTIAL"
                    else
                        _state="ABSENT"
                    fi
                    printf '    %-12s %-12s %s\n' \
                        "$_grpn" "${_state}(${_present}/${_total})" "${_line# }"
                done
                if [ "$_any_full" = "1" ]; then
                    printf '    %srule (b): OK%s\n' "${C_GREEN}" "${C_RESET}"
                else
                    printf '    %srule (b): VIOLATED%s\n' "${C_YELLOW}" "${C_RESET}"
                fi
            done
        fi
    fi

    if [ "$do_disks" = "1" ]; then
        step "Updating disk baseline"
        explain "Snapshotting attached disks (stable ids) to: $(baseline_disks_file)"
        explain "Optset members are filtered out - they're tracked by rules (a)+(b) above."
        # Capture the previous baseline file's data lines (full lines
        # including the bsd/size/model comment) so we can diff and show
        # the human-readable hint alongside each added/removed id.
        f=$(baseline_disks_file)
        _prev_disks_lines=""
        [ -f "$f" ] && _prev_disks_lines=$(awk 'NF>0 && !/^#/' "$f")
        _prev_disk_ids=$(echo "$_prev_disks_lines" | awk 'NF>0 {print $1}')

        baseline_write_disks

        _new_disks_lines=""
        [ -f "$f" ] && _new_disks_lines=$(awk 'NF>0 && !/^#/' "$f")
        _new_disk_ids=$(echo "$_new_disks_lines" | awk 'NF>0 {print $1}')

        info "Baselined disks (id, current node, size, model):"
        if [ -n "$_new_disks_lines" ]; then
            echo "$_new_disks_lines" | sed 's/^/    /'
        else
            echo "    (none - all currently-attached disks are governed by OPTIONAL_DISK_SETS)"
        fi

        # Diff: which ids are new, which are gone. We display the full
        # data line (including the bsd/size/model comment) for each, so
        # the user can see "what hardware" was added or lost without
        # cross-referencing.
        _added_ids=$(printf '%s\n' "$_new_disk_ids" "$_prev_disk_ids" "$_prev_disk_ids" \
            | awk 'NF>0' | sort | uniq -u)
        _removed_ids=$(printf '%s\n' "$_prev_disk_ids" "$_new_disk_ids" "$_new_disk_ids" \
            | awk 'NF>0' | sort | uniq -u)
        echo
        # Optset specs - used to split the Added/Removed lists into
        # "real change" vs "ignored, now governed by optset rules", so
        # disks that look like they vanished from baseline are clearly
        # labelled as still-monitored, not lost.
        _optspecs=""
        if [ -n "${OPTIONAL_DISK_SETS:-}" ]; then
            _optspecs=$(optional_sets_all_specs)
        fi

        # Currently-attached disks with a stable id (regardless of
        # optset filter) - lets us also surface "would-have-been-added
        # but skipped because they're in an optset".
        _attached_ids=""
        if [ -n "$_optspecs" ]; then
            _attached_ids=$(list_all_physical_disks | while IFS= read -r _d; do
                [ -n "$_d" ] || continue
                _id=$(disk_baseline_id "$_d" 2>/dev/null)
                [ -n "$_id" ] && echo "$_id"
            done)
        fi

        # Helper: look up Set/Group owning a given spec.
        _optset_owner_of() {
            for _s in $(optional_sets_set_names); do
                for _g in $(optional_sets_groups_in "$_s"); do
                    if optional_set_group_members "$_s" "$_g" \
                        | grep -qxF "$1"; then
                        echo "$_s/$_g"; return
                    fi
                done
            done
        }

        # Real Added (new, not in optset) - printed first, plain form.
        if [ -n "$_added_ids" ]; then
            info "Added disks (new since previous baseline):"
            echo "$_added_ids" | while IFS= read -r _id; do
                [ -n "$_id" ] || continue
                _line=$(echo "$_new_disks_lines" | awk -v id="$_id" '$1==id {print; exit}')
                printf '    + %s\n' "${_line:-$_id}"
            done
        fi

        # Added-but-IGNORED (currently attached, in optset, not in prev
        # baseline). These would have entered the baseline if not for
        # the optset filter - the user sees them so they know the
        # script noticed the new hardware but routed it to the optset.
        _added_optset=""
        if [ -n "$_attached_ids" ]; then
            for _id in $_attached_ids; do
                [ -n "$_id" ] || continue
                printf '%s\n' "$_optspecs" | grep -qxF "$_id" || continue
                if [ -n "$_prev_disk_ids" ] \
                   && printf '%s\n' "$_prev_disk_ids" | grep -qxF "$_id"; then
                    continue
                fi
                _added_optset=$(printf '%s\n%s' "$_added_optset" "$_id")
            done
            _added_optset=$(printf '%s' "$_added_optset" | awk 'NF>0')
        fi
        if [ -n "$_added_optset" ]; then
            info "Added disks (new since previous baseline) - but IGNORING them as they are part of sets:"
            echo "$_added_optset" | while IFS= read -r _id; do
                [ -n "$_id" ] || continue
                _own=$(_optset_owner_of "$_id")
                printf '    + %-41s   (governed by optset: %s)\n' "$_id" "${_own:-?}"
            done
        fi

        # Removed split into truly-gone vs ignored-because-optset.
        _removed_truly=""; _removed_optset=""
        for _id in $_removed_ids; do
            [ -n "$_id" ] || continue
            if [ -n "$_optspecs" ] && printf '%s\n' "$_optspecs" | grep -qxF "$_id"; then
                _removed_optset=$(printf '%s\n%s' "$_removed_optset" "$_id")
            else
                _removed_truly=$(printf '%s\n%s' "$_removed_truly" "$_id")
            fi
        done
        _removed_truly=$(printf '%s' "$_removed_truly" | awk 'NF>0')
        _removed_optset=$(printf '%s' "$_removed_optset" | awk 'NF>0')

        if [ -n "$_removed_truly" ]; then
            info "Removed disks (gone since previous baseline):"
            echo "$_removed_truly" | while IFS= read -r _id; do
                [ -n "$_id" ] || continue
                _line=$(echo "$_prev_disks_lines" | awk -v id="$_id" '$1==id {print; exit}')
                printf '    - %s\n' "${_line:-$_id}"
            done
        fi
        if [ -n "$_removed_optset" ]; then
            info "Removed disks (gone since previous baseline) - but IGNORING them as they are part of sets:"
            echo "$_removed_optset" | while IFS= read -r _id; do
                [ -n "$_id" ] || continue
                _line=$(echo "$_prev_disks_lines" | awk -v id="$_id" '$1==id {print; exit}')
                _own=$(_optset_owner_of "$_id")
                printf '    - %s   (governed by optset: %s)\n' "${_line:-$_id}" "${_own:-?}"
            done
        fi

        # "Real" changes = entries that affect the plain-required set
        # (truly added or truly removed). Optset-ignored entries are
        # informational only - the disks remain tracked, just by the
        # optset rules - so they don't count as a baseline update.
        if [ -z "$_added_ids" ] && [ -z "$_removed_truly" ]; then
            if [ -n "$_added_optset" ] || [ -n "$_removed_optset" ]; then
                info "Disk baseline: no real update (only optset-governed diffs above)."
            else
                info "Disk baseline unchanged."
            fi
        fi
    fi

    ok "Baseline check complete. (REQUIRED_*=all use the files above; OPTIONAL_DISK_SETS rules (a)+(b) use the config.)"
}

# ----------------------------------------------------------------------
# `baseline --optsets` - interactive OPTIONAL_DISK_SETS manager.
#
# Lets the user define named rotation groups and assign disks to them
# without hand-editing the config file. Operates on a session-local
# work file that mirrors the parsed OPTIONAL_DISK_SETS value as one
# "<group>|<spec>" line per (group, member) pair. On save, the work
# file is rendered back into a multi-line OPTIONAL_DISK_SETS="..."
# block and spliced into $LOADED_CONFIG (replacing any existing
# OPTIONAL_DISK_SETS assignment, single-line or multi-line).
# ----------------------------------------------------------------------

# Render the work file back into a shell value for OPTIONAL_DISK_SETS.
# Output: a multi-line "..." string. Each non-empty (set, group) emits
# "<set>/<group> = spec, spec, ..." line. Empty placeholder-only groups
# are excluded (they exist only as in-memory scaffolding mid-edit).
_optsets_render_value() {
    _wf="$1"
    [ -f "$_wf" ] || { printf '""\n'; return 0; }
    # Real (non-placeholder) tuples?
    if ! awk -F'|' 'NF>=3 && $3 != "__placeholder__" {f=1; exit} END{exit !f}' "$_wf"; then
        printf '""\n'; return 0
    fi
    printf '"\n'
    awk -F'|' 'NF>=3 && $3 != "__placeholder__" {
        key = $1 "|" $2
        if (!(seen[key]++)) order[++n] = key
        members[key] = (members[key] ? members[key] ", " $3 : $3)
    }
    END {
        for (i = 1; i <= n; i++) {
            split(order[i], a, "|")
            print a[1] "/" a[2] " = " members[order[i]]
        }
    }' "$_wf"
    printf '"\n'
}

# Sweep baseline-disks: remove any tagged-id whose disk is now a
# member of an optset (any group in any set). Those disks are
# governed by the optset rules; keeping them in the standard
# baseline-disks list would be confusing in `baseline --show` and
# noisy in baseline diffs (resolve_required_disks already filters
# them out at runtime, so behaviour doesn't change - this is a
# cleanup pass for clarity).
_optsets_clean_baseline() {
    _wf="$1"
    _bf=$(baseline_disks_file)
    [ -f "$_bf" ] || return 0
    _specs=$(mktemp "$STATE_DIR/.optsets-clean.XXXXXX") || return 0
    awk -F'|' 'NF>=3 && $3 != "__placeholder__" {print $3}' "$_wf" | sort -u > "$_specs"
    if [ ! -s "$_specs" ]; then rm -f "$_specs"; return 0; fi
    _new=$(mktemp "$STATE_DIR/.optsets-cleanout.XXXXXX") || { rm -f "$_specs"; return 0; }
    awk '
        NR==FNR { specs[$0]=1; next }
        /^[[:space:]]*#/ || NF==0 { print; next }
        !($1 in specs) { print }
    ' "$_specs" "$_bf" > "$_new"
    _old_n=$(awk 'NF>0 && !/^[[:space:]]*#/' "$_bf" | wc -l | tr -d ' ')
    _new_n=$(awk 'NF>0 && !/^[[:space:]]*#/' "$_new" | wc -l | tr -d ' ')
    _removed=$((_old_n - _new_n))
    if [ "$_removed" -gt 0 ]; then
        chmod --reference="$_bf" "$_new" 2>/dev/null \
            || chmod 0644 "$_new" 2>/dev/null || true
        if mv "$_new" "$_bf"; then
            ok "Removed $_removed disk(s) from baseline-disks (now governed by optset): $_bf"
        else
            rm -f "$_new"
            warn "Could not update $_bf"
        fi
    else
        rm -f "$_new"
    fi
    rm -f "$_specs"
}

# Splice a new OPTIONAL_DISK_SETS=<value> block into $LOADED_CONFIG,
# replacing any existing assignment (single-line OR multi-line quoted).
# Appends if not present. Writes atomically via a tmpfile next to the
# real config. Honors symlinks: edits the link target.
_optsets_save_to_config() {
    _new_value_file="$1"
    case "$LOADED_CONFIG" in
        ""|*'(none'*)
            errmsg "No config file is loaded; nothing to write to."
            errmsg "Create one first: $SCRIPT_NAME create-config <path>"
            return 1
            ;;
    esac
    _conf=$(readlink -f "$LOADED_CONFIG" 2>/dev/null || echo "$LOADED_CONFIG")
    if [ ! -w "$_conf" ]; then
        errmsg "Config file is not writable by uid=$(id -u): $_conf"
        errmsg "Re-run as root, or fix permissions, then try again."
        return 1
    fi
    _tmp=$(mktemp "$_conf.optset.XXXXXX") || { errmsg "mktemp failed"; return 1; }
    # Strip any existing OPTIONAL_DISK_SETS=... block (handles both
    # single-line and multi-line quoted forms).
    awk '
        BEGIN { skip = 0 }
        {
            if (skip) {
                if ($0 ~ /"/) skip = 0
                next
            }
            if ($0 ~ /^OPTIONAL_DISK_SETS=/) {
                # Single-line: closes on same line.
                if ($0 ~ /^OPTIONAL_DISK_SETS="[^"]*"[[:space:]]*$/) next
                # Single-line bare (unquoted, e.g. OPTIONAL_DISK_SETS=).
                if ($0 !~ /^OPTIONAL_DISK_SETS="/) next
                # Multi-line opening: skip until next line containing ".
                skip = 1
                next
            }
            print
        }
    ' "$_conf" > "$_tmp" || { rm -f "$_tmp"; errmsg "awk rewrite failed"; return 1; }
    # Append the new block (with a leading blank line for readability).
    {
        printf '\n# Updated by %s baseline --optsets on %s\n' "$SCRIPT_NAME" "$(now_iso 2>/dev/null || date)"
        printf 'OPTIONAL_DISK_SETS=%s' "$(cat "$_new_value_file")"
    } >> "$_tmp"
    # Preserve perms/ownership.
    chmod --reference="$_conf" "$_tmp" 2>/dev/null \
        || chmod 0644 "$_tmp" 2>/dev/null || true
    if mv "$_tmp" "$_conf"; then
        ok "Wrote OPTIONAL_DISK_SETS into: $_conf"
        return 0
    else
        rm -f "$_tmp"
        errmsg "atomic rename to $_conf failed"
        return 1
    fi
}

# Print the current state of the work file as a SET/GROUP tree, with
# presence tally per group; plus unassigned attached disks and
# missing-from-baseline disks the user can assign.
# Build the candidate cache. Format per line:
#     KIND|ID|NODE|SIZE|MODEL
# KIND is ATTACHED (currently plugged in, has a stable id) or MISSING
# (in baseline-disks but not currently attached). Order: attached
# first (declaration order from list_all_physical_disks), then
# missing (declaration order from the baseline file). Numbers used
# in the UI are 1-based row indices into this file and are stable
# for the whole session.
_optsets_build_cache() {
    _cache="$1"
    : > "$_cache"
    # Attached.
    list_all_physical_disks | while IFS= read -r _d; do
        [ -n "$_d" ] || continue
        _id=$(disk_baseline_id "$_d" 2>/dev/null)
        [ -n "$_id" ] || continue
        _info=$(diskutil info "/dev/$_d" 2>/dev/null)
        _model=$(printf '%s\n' "$_info" \
            | awk -F': +' '/Device \/ Media Name:/ {print $2; exit}' \
            | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        # "Disk Size: 16.0 TB (15999999999 Bytes) (...)". We want the
        # human form (first two whitespace-separated tokens after the
        # colon), e.g. "16.0 TB".
        _size=$(printf '%s\n' "$_info" \
            | awk -F': +' '/Disk Size:/ {print $2; exit}' \
            | awk '{print $1, $2}' \
            | sed 's/[[:space:]]*$//')
        printf 'ATTACHED|%s|/dev/%s|%s|%s\n' "$_id" "$_d" "${_size:-?}" "${_model:-?}" >> "$_cache"
    done
    # Missing-from-baseline. baseline_write_disks formats each line as
    #     <id>  # <bsd>  <size>  <model>
    # where <size> is "<num> <unit>" (two whitespace-separated tokens)
    # and <model> is the rest. Parse with awk.
    _bf=$(baseline_disks_file)
    if [ -f "$_bf" ]; then
        awk '
            NF>0 && !/^#/ {
                id = $1
                hidx = 0
                for (i = 2; i <= NF; i++) if ($i == "#") { hidx = i; break }
                if (hidx == 0 || hidx + 3 > NF) {
                    # Fallback: no parsable hint. Emit whole tail as model.
                    rest = ""
                    for (j = 2; j <= NF; j++) rest = rest (rest=="" ? "" : " ") $j
                    print id "|-|?|" rest
                    next
                }
                bsd = $(hidx + 1)
                size = $(hidx + 2) " " $(hidx + 3)
                model = ""
                for (j = hidx + 4; j <= NF; j++) model = (model == "" ? $j : model " " $j)
                if (model == "") model = "?"
                print id "|" bsd "|" size "|" model
            }
        ' "$_bf" | while IFS='|' read -r _id _bsd _size _model; do
            [ -n "$_id" ] || continue
            # Skip if we already listed it as ATTACHED (under any bsd).
            if grep -q "^ATTACHED|${_id}|" "$_cache" 2>/dev/null; then continue; fi
            # Confirm it's actually missing from current attachment.
            [ -z "$(disk_for_baseline_id "$_id" 2>/dev/null)" ] || continue
            printf 'MISSING|%s|-|%s|%s\n' "$_id" "${_size:-?}" "${_model:-?}" >> "$_cache"
        done
    fi
}

# Look up the (set/group) currently holding a given spec in the work
# file, or empty if unassigned. Excludes placeholders.
_optsets_assignment_of() {
    _wf="$1"; _spec="$2"
    awk -F'|' -v sp="$_spec" '$3==sp && $3!="__placeholder__" {print $1 "/" $2; exit}' "$_wf"
}

# Resolve a number from the cache to its tagged id (column 2). Empty
# if the number is out of range.
_optsets_id_for_num() {
    _cache="$1"; _n="$2"
    awk -F'|' -v n="$_n" 'NR==n {print $2; exit}' "$_cache"
}

# Render the SET/GROUP/STATE/MEMBERS table (4 columns, SET in column 1)
# plus the cached numbered disk list with per-row assignment status.
_optsets_show_state() {
    _wf="$1"; _cache="$2"
    echo
    step "Optional disk sets (working draft)"
    if ! awk 'NF>0' "$_wf" | head -n1 | grep -q .; then
        info "(no sets/groups defined yet)"
    else
        printf '  %-18s %-18s %-12s %s\n' "SET" "GROUP" "STATE" "MEMBERS"
        printf '  %-18s %-18s %-12s %s\n' "---" "-----" "-----" "-------"
        # Walk SET, then GROUPs within, in declaration order.
        _setlist=$(awk -F'|' 'NF>=3 && !seen[$1]++ {print $1}' "$_wf")
        echo "$_setlist" | while IFS= read -r _setn; do
            [ -n "$_setn" ] || continue
            _groups=$(awk -F'|' -v s="$_setn" '$1==s && !seen[$2]++ {print $2}' "$_wf")
            echo "$_groups" | while IFS= read -r _grpn; do
                [ -n "$_grpn" ] || continue
                _ms=$(awk -F'|' -v s="$_setn" -v g="$_grpn" '$1==s && $2==g && $3 != "__placeholder__" {print $3}' "$_wf" | tr '\n' ' ')
                if [ -z "$(printf '%s' "$_ms" | tr -d '[:space:]')" ]; then
                    printf '  %-18s %-18s %-12s %s\n' "$_setn" "$_grpn" "EMPTY(0/0)" "(no disks assigned yet)"
                    continue
                fi
                _total=0; _present=0; _line=""
                for _s in $_ms; do
                    _total=$((_total + 1))
                    _bsd=$(optional_spec_to_bsd "$_s" 2>/dev/null)
                    if [ -n "$_bsd" ]; then
                        _present=$((_present + 1))
                        _line="$_line ${_s}->${_bsd}"
                    else
                        _line="$_line ${_s}=MISSING"
                    fi
                done
                if [ "$_total" -gt 0 ] && [ "$_present" = "$_total" ]; then
                    _state="FULL"
                elif [ "$_present" -gt 0 ]; then
                    _state="PARTIAL"
                else
                    _state="ABSENT"
                fi
                printf '  %-18s %-18s %-12s %s\n' "$_setn" "$_grpn" "${_state}(${_present}/${_total})" "${_line# }"
            done
        done
    fi

    # Numbered disk list: ATTACHED first, then MISSING. Numbers are
    # stable for the whole session (the cache is built once at start).
    echo
    info "Disks (numbers stable; use them in 'a' / 'x' / disk-pick after 'c'):"
    if [ ! -s "$_cache" ]; then
        echo "  (no disks discovered)"
        return 0
    fi
    _i=0
    while IFS='|' read -r _kind _id _node _size _model; do
        [ -n "$_kind" ] || continue
        _i=$((_i + 1))
        _own=$(_optsets_assignment_of "$_wf" "$_id")
        if [ -n "$_own" ]; then
            _tag="in: $_own"
        else
            _tag="unassigned"
        fi
        # Columns: NUM) KIND ID NODE SIZE MODEL [tag]
        # ID width sized for the widest tagged form: "PART:" + 36-char
        # GPT GUID = 41 chars. SIZE is "<num> <unit>" e.g. "16.0 TB"
        # (8 chars max for sane disks). MODEL squashed to single
        # spaces and capped at 28 chars.
        _model_norm=$(printf '%s' "${_model:-?}" | tr -s '[:space:]' ' ')
        printf '  %3d) [%-8s] %-41s %-12s %-9s %-28.28s [%s]\n' \
            "$_i" "$_kind" "$_id" "$_node" "${_size:-?}" "$_model_norm" "$_tag"
    done < "$_cache"
}

# Interactive entry point.
cmd_baseline_optsets() {
    if [ ! -t 0 ] || [ ! -t 1 ]; then
        die "baseline --optsets is interactive; needs a TTY on stdin/stdout."
    fi
    _ensure_state_dir_writable
    _wf=$(mktemp "$STATE_DIR/.optsets-work.XXXXXX") \
        || die "mktemp failed in $STATE_DIR"
    _cache=$(mktemp "$STATE_DIR/.optsets-cache.XXXXXX") \
        || { rm -f "$_wf"; die "mktemp failed in $STATE_DIR"; }
    # On normal EXIT just clean up. On INT/TERM clean up AND exit:
    # otherwise the trap deletes the work files but control returns to
    # the menu loop, which then tries to awk a vanished file. Common
    # path: user Ctrl+C-s out of an interactive child (bash readline,
    # confirm, etc.) - the SIGINT hits both the child and us.
    trap 'rm -f "$_wf" "$_cache"' EXIT
    trap 'rm -f "$_wf" "$_cache"; trap - EXIT; exit 130' INT TERM

    # Seed the work file from the current OPTIONAL_DISK_SETS value.
    optional_sets_iter > "$_wf" 2>/dev/null || true
    # Build the candidate cache ONCE (expensive: smartctl, system_profiler).
    _optsets_build_cache "$_cache"

    step "Interactive OPTIONAL_DISK_SETS manager (SETs of GROUPs of DISKs)"
    explain "Loaded config: ${LOADED_CONFIG:-<none>}"
    explain "Changes are kept in memory until you 's'ave."
    explain "Per-group rule (a): if any member is present, ALL members must be."
    explain "Per-set rule (b): at least one group in the set must be fully present."
    explain "Paths are 'Set/Group' (e.g. OffsiteRotation/Pair1)."
    explain "Disk numbers shown below are STABLE across actions in this session."

    while :; do
        _optsets_show_state "$_wf" "$_cache"
        echo
        printf '%sActions:%s\n' "${C_BOLD}" "${C_RESET}"
        printf '  c) create a new group (Set/Group), then assign disks by number\n'
        printf '  r) rename a group or a whole set\n'
        printf '  d) delete a group or a whole set\n'
        printf '  a) add disks to an existing group (by number from list above)\n'
        printf '  x) remove disks from a group\n'
        printf '  R) rebuild disk cache (re-scan after a hardware change)\n'
        printf '  s) save and exit (writes to %s)\n' "${LOADED_CONFIG:-<none>}"
        printf '  q) quit without saving\n'
        printf '%sChoose [c/r/d/a/x/R/s/q]:%s ' "${C_YELLOW}" "${C_RESET}"
        if ! read -r _act; then
            echo; warn "EOF on input; quitting without saving."
            return 1
        fi
        case "$_act" in
            c|C) _optsets_action_create "$_wf" "$_cache" ;;
            r)   _optsets_action_rename "$_wf" ;;
            d|D) _optsets_action_delete "$_wf" ;;
            a|A) _optsets_action_add    "$_wf" "$_cache" ;;
            x|X) _optsets_action_remove "$_wf" ;;
            R)   info "Rebuilding disk cache..."
                 # Drop the bsd->id cache too so hardware changes are
                 # picked up on the next disk_baseline_id / for_id call.
                 _diskid_cache_clear
                 _diskid_cache_init
                 _optsets_build_cache "$_cache"
                 ok "Cache rebuilt." ;;
            s|S)
                _val=$(mktemp "$STATE_DIR/.optsets-val.XXXXXX") \
                    || { errmsg "mktemp failed"; continue; }
                _optsets_render_value "$_wf" > "$_val"
                if _optsets_save_to_config "$_val"; then
                    rm -f "$_val"
                    # Sweep baseline-disks: any disk that is now in an
                    # optset is no longer a "plain required disk", so
                    # remove it from the baseline file for clarity.
                    _optsets_clean_baseline "$_wf"
                    info "Re-run 'my-appleRAID disks' to confirm membership annotations."
                    return 0
                fi
                rm -f "$_val"
                ;;
            q|Q)
                if confirm "Discard all changes and quit?"; then
                    info "No changes written."
                    return 0
                fi
                ;;
            *) warn "Unknown action: '$_act'" ;;
        esac
    done
}

_optsets_prompt() {
    # $1=prompt label, sets _ANS to trimmed input (may be empty).
    printf '%s%s%s ' "${C_YELLOW}" "$1" "${C_RESET}"
    if ! read -r _ANS; then _ANS=""; return 1; fi
    _ANS=$(printf '%s' "$_ANS" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
}

# Prompt with a numbered candidate list (helps avoid typos and
# duplicate names by letting the user pick an existing entry by
# number rather than retyping it).
# $1 = prompt; $2... = candidate strings.
# Sets _ANS to the resolved value (or blank if nothing entered):
# - a numeric input picks the corresponding candidate
# - any other input is returned verbatim (intended for "new" names)
#
# Why a numbered list rather than readline TAB completion: dash's
# built-in `read` has no readline. We previously delegated to a
# `bash -i -c` subshell with TAB bound to dynamic-complete-history,
# but `bash -i` inside $(...) cannot reliably take over the user's
# controlling terminal for input on macOS - the subshell would hang
# silently with no echo. A numbered list works in pure dash and is
# arguably clearer anyway: the user sees every existing name AND
# can pick by single digit.
_optsets_prompt_completing() {
    _prompt="$1"; shift
    if [ "$#" -gt 0 ]; then
        info "Existing names (pick by number, or type a new name):"
        _i=0
        for _c in "$@"; do
            [ -n "$_c" ] || continue
            _i=$((_i + 1))
            printf '  %2d) %s\n' "$_i" "$_c"
        done
    fi
    _optsets_prompt "$_prompt"
    case "$_ANS" in
        '') return 0 ;;
        [0-9]*)
            # Numeric input - resolve to the Nth candidate.
            _idx="$_ANS"
            _i=0
            _resolved=""
            for _c in "$@"; do
                [ -n "$_c" ] || continue
                _i=$((_i + 1))
                if [ "$_i" = "$_idx" ]; then
                    _resolved="$_c"
                    break
                fi
            done
            if [ -n "$_resolved" ]; then
                _ANS="$_resolved"
                info "  -> $_ANS"
            else
                warn "No candidate at number $_idx; using literal '$_ANS' as a new name."
            fi
            ;;
    esac
    return 0
}

# List all (set, group) pairs in declaration order, numbered.
# Sets _PATHS to a newline-separated "set/group" list and prints
# them with numbers. Returns 1 if the work file is empty.
_optsets_list_paths() {
    _wf="$1"
    _PATHS=$(awk -F'|' 'NF>=3 && !seen[$1"|"$2]++ {print $1 "/" $2}' "$_wf")
    if [ -z "$_PATHS" ]; then return 1; fi
    _i=0
    echo "$_PATHS" | while IFS= read -r _p; do
        _i=$((_i+1)); printf '  %2d) %s\n' "$_i" "$_p"
    done
    return 0
}

# Resolve a user input to a "set/group" path. Accepts:
#   - a number from the list shown by _optsets_list_paths
#   - a literal "set/group" string
#   - a bare group name if exactly one group with that name exists
# Sets _PICK to the resolved "set/group" or empty.
_optsets_resolve_path() {
    _wf="$1"; _ans="$2"
    _PICK=""
    [ -n "$_ans" ] || return 1
    _all=$(awk -F'|' 'NF>=3 && !seen[$1"|"$2]++ {print $1 "/" $2}' "$_wf")
    case "$_ans" in
        [0-9]*)
            _PICK=$(echo "$_all" | awk -v n="$_ans" 'NR==n {print; exit}')
            ;;
        */*)
            if echo "$_all" | grep -qxF "$_ans"; then
                _PICK="$_ans"
            fi
            ;;
        *)
            # Bare group name: unique-match across all sets.
            _hits=$(echo "$_all" | awk -F'/' -v g="$_ans" '$2==g {print}')
            _hc=$(echo "$_hits" | awk 'NF>0' | wc -l | tr -d ' ')
            if [ "$_hc" = "1" ]; then
                _PICK=$(echo "$_hits" | head -n1)
            elif [ "$_hc" -gt 1 ]; then
                warn "Group name '$_ans' is ambiguous (matches: $(echo "$_hits" | tr '\n' ' '))."
                return 1
            fi
            ;;
    esac
    if [ -z "$_PICK" ]; then
        warn "No such set/group: '$_ans'"
        return 1
    fi
    return 0
}

_optsets_validate_name() {
    # $1 = candidate name; rejects empty / space / | / , / = / /.
    case "$1" in
        '') return 1 ;;
        *'|'*|*','*|*'='*|*'/'*|*' '*) return 1 ;;
    esac
    return 0
}

_optsets_action_create() {
    _wf="$1"; _cache="$2"

    # Show existing sets+groups so the user has a clear visual reference
    # for what already exists (helps avoid typos and duplicate set
    # names). Two-step prompt: SET first (with TAB-completion of
    # existing set names), then GROUP (with TAB-completion of existing
    # group names within that set, shown for awareness — duplicates
    # are rejected by validation below).
    _existing_sets=$(awk -F'|' 'NF>=3 && !seen[$1]++ {print $1}' "$_wf")
    if [ -n "$_existing_sets" ]; then
        info "Existing sets:"
        echo "$_existing_sets" | while IFS= read -r _s; do
            [ -n "$_s" ] || continue
            _gs=$(awk -F'|' -v s="$_s" '$1==s && !seen[$2]++ {print $2}' "$_wf" | paste -sd, -)
            printf '  - %s (groups: %s)\n' "$_s" "${_gs:-none}"
        done
    else
        info "No sets defined yet — pick any name (e.g. OffsiteRotation, WeeklyArchive)."
    fi

    # 1. Set name. With a numbered list of existing sets so the user
    # can reuse one by number (avoids typos / accidental duplicates).
    if [ -n "$_existing_sets" ]; then
        # shellcheck disable=SC2046  # word-splitting intended
        _optsets_prompt_completing \
            "Set name (number to reuse existing, or type a new name):" \
            $(echo "$_existing_sets")
    else
        _optsets_prompt "Set name (e.g. OffsiteRotation):"
    fi
    [ -n "$_ANS" ] || { warn "Empty set name; aborted."; return; }
    _setn="$_ANS"
    _optsets_validate_name "$_setn" \
        || { warn "Invalid set name (no space, '|', ',', '=', '/')."; return; }

    # 2. Group name. List this set's existing groups so the user
    # avoids name collisions. Loop until we get a fresh, valid name
    # (or empty input to abort) - rejecting a duplicate inline is
    # friendlier than bouncing back to the main menu and forcing a
    # re-entry of every step.
    _existing_groups=$(awk -F'|' -v s="$_setn" '$1==s && !seen[$2]++ {print $2}' "$_wf")
    if [ -n "$_existing_groups" ]; then
        info "Groups already in set '$_setn' (pick a name NOT in this list):"
        echo "$_existing_groups" | sed 's/^/  - /'
    else
        info "Set '$_setn' has no groups yet."
    fi
    _grpn=""
    while [ -z "$_grpn" ]; do
        _optsets_prompt "New group name in '$_setn' (must be fresh, e.g. Pair1; blank to cancel):"
        if [ -z "$_ANS" ]; then
            warn "Empty group name; aborted."
            return
        fi
        if ! _optsets_validate_name "$_ANS"; then
            warn "Invalid group name (no space, '|', ',', '=', '/'). Try again."
            continue
        fi
        if awk -F'|' -v s="$_setn" -v g="$_ANS" '$1==s && $2==g {f=1; exit} END{exit !f}' "$_wf"; then
            warn "Group '$_setn/$_ANS' already exists. Pick a different name."
            continue
        fi
        _grpn="$_ANS"
    done
    printf '%s|%s|__placeholder__\n' "$_setn" "$_grpn" >> "$_wf"
    ok "Created group '$_setn/$_grpn'."

    # Streamlined: chain immediately into disk assignment, using the
    # cached numbered list. Blank input keeps the empty group.
    _optsets_assign_disks "$_wf" "$_cache" "$_setn" "$_grpn" \
        "Assign disks to '$_setn/$_grpn' now (numbers from list, blank to skip):"
}

# Shared assignment routine. Reads space-separated numbers from the
# cache (or pasted free-form specs) and adds each to (set, group).
# Skips already-assigned ids (warns, with the existing path), and
# enforces "one home per disk" across all sets/groups.
_optsets_assign_disks() {
    _wf="$1"; _cache="$2"; _setn="$3"; _grpn="$4"; _prompt="$5"
    if [ ! -s "$_cache" ]; then
        warn "Disk cache is empty (no candidates). Use 'R' to rebuild."
        return
    fi
    _optsets_prompt "$_prompt"
    if [ -z "$_ANS" ]; then
        info "No disks assigned to '$_setn/$_grpn' yet."
        return
    fi
    # Accept commas, semicolons, and whitespace as separators so "10,11",
    # "10 11", "10; 11" all do the same thing.
    _ANS=$(printf '%s' "$_ANS" | tr ',;' '  ')
    _added=0
    for _tok in $_ANS; do
        case "$_tok" in
            [0-9]*) _id=$(_optsets_id_for_num "$_cache" "$_tok") ;;
            *)      _id="$_tok" ;;
        esac
        if [ -z "$_id" ]; then
            warn "Could not resolve '$_tok'"; continue
        fi
        # Drop placeholder for this (set, group) before appending real members.
        _tmp=$(mktemp "$STATE_DIR/.optsets-addg.XXXXXX") || continue
        awk -F'|' -v s="$_setn" -v g="$_grpn" '!($1==s && $2==g && $3=="__placeholder__")' "$_wf" > "$_tmp" \
            && mv "$_tmp" "$_wf"
        # Already in this exact group?
        if awk -F'|' -v s="$_setn" -v g="$_grpn" -v sp="$_id" '$1==s && $2==g && $3==sp {f=1; exit} END{exit !f}' "$_wf"; then
            warn "$_id already in '$_setn/$_grpn'; skipped."
            continue
        fi
        # In a DIFFERENT group? "Exactly one home per disk" — warn, skip.
        if awk -F'|' -v sp="$_id" '$3==sp && $3!="__placeholder__" {f=1; exit} END{exit !f}' "$_wf"; then
            _other=$(awk -F'|' -v sp="$_id" '$3==sp && $3!="__placeholder__" {print $1 "/" $2; exit}' "$_wf")
            warn "$_id is already in '$_other'; skipped (a disk lives in one group). Use 'x' to move it."
            continue
        fi
        printf '%s|%s|%s\n' "$_setn" "$_grpn" "$_id" >> "$_wf"
        ok "Added $_id to '$_setn/$_grpn'."
        _added=$((_added + 1))
    done
    [ "$_added" -gt 0 ] || warn "No disks added."
}

_optsets_action_rename() {
    _wf="$1"
    _optsets_prompt "Path to rename (Set or Set/Group; number from list or string):" || return
    [ -n "$_ANS" ] || { warn "Empty; aborted."; return; }

    # Determine if it refers to a SET (no slash) or a GROUP (has slash
    # or matches a numbered list entry).
    case "$_ANS" in
        */*|[0-9]*)
            _optsets_resolve_path "$_wf" "$_ANS" || return
            _oldset=$(printf '%s' "$_PICK" | sed 's|/.*||')
            _oldgrp=$(printf '%s' "$_PICK" | sed 's|^[^/]*/||')
            _optsets_prompt "New Set/Group name:" || return
            case "$_ANS" in
                */*) ;;
                *) warn "Need a Set/Group path."; return ;;
            esac
            _newset=$(printf '%s' "$_ANS" | sed 's|/.*||')
            _newgrp=$(printf '%s' "$_ANS" | sed 's|^[^/]*/||')
            _optsets_validate_name "$_newset" && _optsets_validate_name "$_newgrp" \
                || { warn "Invalid name."; return; }
            if awk -F'|' -v s="$_newset" -v g="$_newgrp" '$1==s && $2==g {f=1; exit} END{exit !f}' "$_wf"; then
                warn "Target '$_newset/$_newgrp' already exists."; return
            fi
            _tmp=$(mktemp "$STATE_DIR/.optsets-rn.XXXXXX") || { errmsg "mktemp failed"; return; }
            awk -F'|' -v os="$_oldset" -v og="$_oldgrp" -v ns="$_newset" -v ng="$_newgrp" \
                'BEGIN{OFS="|"} $1==os && $2==og {$1=ns; $2=ng} {print}' "$_wf" > "$_tmp" \
                && mv "$_tmp" "$_wf" \
                && ok "Renamed '$_oldset/$_oldgrp' -> '$_newset/$_newgrp'." \
                || { rm -f "$_tmp"; errmsg "rename failed"; }
            ;;
        *)
            # Rename a SET (affects all its groups).
            _oldset="$_ANS"
            if ! awk -F'|' -v s="$_oldset" '$1==s {f=1; exit} END{exit !f}' "$_wf"; then
                warn "No such set: '$_oldset'"; return
            fi
            _optsets_prompt "New set name:" || return
            _optsets_validate_name "$_ANS" || { warn "Invalid set name."; return; }
            if awk -F'|' -v s="$_ANS" '$1==s {f=1; exit} END{exit !f}' "$_wf"; then
                warn "Set '$_ANS' already exists; renames must not collide."; return
            fi
            _tmp=$(mktemp "$STATE_DIR/.optsets-rn.XXXXXX") || { errmsg "mktemp failed"; return; }
            awk -F'|' -v os="$_oldset" -v ns="$_ANS" \
                'BEGIN{OFS="|"} $1==os {$1=ns} {print}' "$_wf" > "$_tmp" \
                && mv "$_tmp" "$_wf" \
                && ok "Renamed set '$_oldset' -> '$_ANS' (all its groups moved)." \
                || { rm -f "$_tmp"; errmsg "rename failed"; }
            ;;
    esac
}

_optsets_action_delete() {
    _wf="$1"
    _optsets_prompt "Path to delete (Set or Set/Group; number from list or string):" || return
    [ -n "$_ANS" ] || { warn "Empty; aborted."; return; }
    case "$_ANS" in
        */*|[0-9]*)
            _optsets_resolve_path "$_wf" "$_ANS" || return
            _setn=$(printf '%s' "$_PICK" | sed 's|/.*||')
            _grpn=$(printf '%s' "$_PICK" | sed 's|^[^/]*/||')
            confirm "Delete group '$_setn/$_grpn' and unassign all its members?" || return
            _tmp=$(mktemp "$STATE_DIR/.optsets-del.XXXXXX") || { errmsg "mktemp failed"; return; }
            awk -F'|' -v s="$_setn" -v g="$_grpn" '!($1==s && $2==g)' "$_wf" > "$_tmp" \
                && mv "$_tmp" "$_wf" \
                && ok "Deleted group '$_setn/$_grpn'." \
                || { rm -f "$_tmp"; errmsg "delete failed"; }
            ;;
        *)
            _setn="$_ANS"
            if ! awk -F'|' -v s="$_setn" '$1==s {f=1; exit} END{exit !f}' "$_wf"; then
                warn "No such set: '$_setn'"; return
            fi
            confirm "Delete entire set '$_setn' (all its groups and members)?" || return
            _tmp=$(mktemp "$STATE_DIR/.optsets-del.XXXXXX") || { errmsg "mktemp failed"; return; }
            awk -F'|' -v s="$_setn" '$1!=s' "$_wf" > "$_tmp" \
                && mv "$_tmp" "$_wf" \
                && ok "Deleted set '$_setn'." \
                || { rm -f "$_tmp"; errmsg "delete failed"; }
            ;;
    esac
}

_optsets_action_add() {
    _wf="$1"; _cache="$2"
    info "Existing groups:"
    if ! _optsets_list_paths "$_wf"; then
        warn "No groups defined yet. Use 'c' to create one (Set/Group)."
        return
    fi
    _optsets_prompt "Add to which group (Set/Group, or number above):" || return
    _optsets_resolve_path "$_wf" "$_ANS" || return
    _setn=$(printf '%s' "$_PICK" | sed 's|/.*||')
    _grpn=$(printf '%s' "$_PICK" | sed 's|^[^/]*/||')
    _optsets_assign_disks "$_wf" "$_cache" "$_setn" "$_grpn" \
        "Pick disk numbers (space-separated; or paste a free-form spec):"
}

_optsets_action_remove() {
    _wf="$1"
    info "Existing groups:"
    if ! _optsets_list_paths "$_wf"; then
        warn "No groups defined yet."
        return
    fi
    _optsets_prompt "Remove from which group (Set/Group, or number above):" || return
    _optsets_resolve_path "$_wf" "$_ANS" || return
    _setn=$(printf '%s' "$_PICK" | sed 's|/.*||')
    _grpn=$(printf '%s' "$_PICK" | sed 's|^[^/]*/||')

    _ms=$(awk -F'|' -v s="$_setn" -v g="$_grpn" '$1==s && $2==g && $3!="__placeholder__" {print $3}' "$_wf")
    if [ -z "$_ms" ]; then
        warn "Group '$_setn/$_grpn' has no members."
        return
    fi
    info "Members of '$_setn/$_grpn':"
    _i=0
    echo "$_ms" | while IFS= read -r _s; do
        _i=$((_i+1)); printf '  %d) %s\n' "$_i" "$_s"
    done
    _optsets_prompt "Pick (numbers; comma, semicolon, or whitespace separated):"
    [ -n "$_ANS" ] || { warn "Nothing entered."; return; }
    _ANS=$(printf '%s' "$_ANS" | tr ',;' '  ')
    for _tok in $_ANS; do
        case "$_tok" in
            [0-9]*) _id=$(echo "$_ms" | awk -v n="$_tok" 'NR==n {print; exit}') ;;
            *)      _id="$_tok" ;;
        esac
        [ -n "$_id" ] || { warn "Could not resolve '$_tok'"; continue; }
        _tmp=$(mktemp "$STATE_DIR/.optsets-rm.XXXXXX") || continue
        awk -F'|' -v s="$_setn" -v g="$_grpn" -v sp="$_id" '!($1==s && $2==g && $3==sp)' "$_wf" > "$_tmp" \
            && mv "$_tmp" "$_wf" \
            && ok "Removed $_id from '$_setn/$_grpn'."
        # If the group is now empty, restore a placeholder so it stays visible.
        if ! awk -F'|' -v s="$_setn" -v g="$_grpn" '$1==s && $2==g && $3!="__placeholder__" {f=1; exit} END{exit !f}' "$_wf"; then
            printf '%s|%s|__placeholder__\n' "$_setn" "$_grpn" >> "$_wf"
        fi
    done
}

# ----------------------------------------------------------------------
# `install-daemon` / `uninstall-daemon` - launchd integration.
# ----------------------------------------------------------------------
cmd_install_daemon() {
    cfg_load
    plist="${LAUNCHD_PLIST}"
    label="${LAUNCHD_LABEL}"
    interval="${LAUNCHD_INTERVAL:-60}"
    stdout_log="${LAUNCHD_STDOUT_LOG:-/var/log/my-appleRAID.launchd.out}"
    stderr_log="${LAUNCHD_STDERR_LOG:-/var/log/my-appleRAID.launchd.err}"

    # Self path: the absolute path to this script, so the plist can call it.
    self=$(cd "$(dirname "$0")" && pwd)/$(basename "$0")

    step "LaunchDaemon installation plan"
    info "Plist path:   $plist"
    info "Label:        $label  (derived from plist filename)"
    info "Interval:     ${interval}s"
    info "Script path:  $self"
    info "Stdout log:   $stdout_log"
    info "Stderr log:   $stderr_log"
    echo

    # Render the desired plist into a tmpfile so we can compare it with
    # whatever is already on disk and only show the user what changed.
    new_tmp=$(mktemp -t my-appleRAID-plist-new.XXXXXX) \
        || die "mktemp failed for new plist"
    trap 'rm -f "$new_tmp"' EXIT INT TERM
    cat > "$new_tmp" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>$label</string>
  <key>ProgramArguments</key>
  <array>
    <string>$self</string>
    <string>health</string>
  </array>
  <key>StartInterval</key>
  <integer>$interval</integer>
  <key>RunAtLoad</key>
  <true/>
  <key>StandardOutPath</key>
  <string>$stdout_log</string>
  <key>StandardErrorPath</key>
  <string>$stderr_log</string>
</dict>
</plist>
EOF

    if [ -f "$plist" ]; then
        if cmp -s "$new_tmp" "$plist" 2>/dev/null; then
            ok "Existing plist is already up-to-date - no rewrite needed:"
            info "  $plist"
            echo
            confirm "Reload it anyway (unload + load via launchctl)?" || {
                rm -f "$new_tmp"
                trap - EXIT INT TERM
                info "Nothing changed. Done."
                return 0
            }
            # Skip the write; just reload below.
            do_write=0
        else
            warn "Existing plist found at: $plist"
            info "Diff (existing -> new) is shown below; only the differences will be applied:"
            echo
            # diff exits 1 when files differ. Suppress the non-zero
            # status so the script (under set -u) doesn't trip.
            diff -u "$plist" "$new_tmp" || true
            echo
            confirm "Apply these changes and reload (requires sudo)?" || die "Aborted."
            do_write=1
        fi
    else
        info "No existing plist at $plist - this is a fresh install."
        info "Full plist contents to be written:"
        echo
        sed 's/^/    /' "$new_tmp"
        echo
        confirm "Install and load this LaunchDaemon (requires sudo)?" || die "Aborted."
        do_write=1
    fi

    if [ "$do_write" = "1" ]; then
        # Write plist via sudo by piping the rendered tmpfile into a
        # root-owned 'cat'. Using cp would also work; this matches the
        # heredoc style of the rest of the script.
        run sudo sh -c "cat > '$plist'" < "$new_tmp" \
            || err 014 "writing the LaunchDaemon plist to $plist failed"
        run sudo chown root:wheel "$plist" \
            || err 015 "chown root:wheel $plist failed"
        run sudo chmod 644 "$plist" \
            || err 016 "chmod 644 $plist failed"
    fi

    rm -f "$new_tmp"
    trap - EXIT INT TERM

    # Reload: unload first if already registered, then bootstrap.
    if launchctl list "$label" >/dev/null 2>&1 \
        || sudo -n launchctl list "$label" >/dev/null 2>&1; then
        run sudo launchctl bootout system "$plist" 2>/dev/null \
            || run sudo launchctl unload "$plist" 2>/dev/null \
            || true
    fi
    run sudo launchctl bootstrap system "$plist" \
        || run sudo launchctl load -w "$plist" \
        || warn "Could not load the plist automatically. Reboot or run 'sudo launchctl bootstrap system $plist' manually."

    ok "LaunchDaemon installed and loaded."
    info "View logs:  tail -f $stderr_log ${LOG_FILE:-/var/log/my-appleRAID.log}"
    info "Status:     sudo launchctl list | grep $label"
}

# ----------------------------------------------------------------------
# `daemon-status` - show the health-monitoring daemon's state: plist
# file presence, launchd registration, last exit status, log activity,
# and whether the daemon can actually write to its state dir and log.
#
# Designed to answer "is it actually running properly?" in one place.
# Pure read-only: no sudo, no state changes.
# ----------------------------------------------------------------------
cmd_daemon_status() {
    cfg_load
    plist="${LAUNCHD_PLIST}"
    label="${LAUNCHD_LABEL}"

    step "appleRAID daemon status"
    info "Config file:   $LOADED_CONFIG"
    info "Plist path:    $plist"
    info "Launchd label: $label  (derived from plist filename)"
    info "Run interval:  ${LAUNCHD_INTERVAL}s ($(format_duration "$LAUNCHD_INTERVAL"))"
    echo

    # --- Check 1/8: plist file on disk -----------------------------
    step "Check 1/8: Plist file"
    if [ -f "$plist" ]; then
        mtime=$(stat -f '%Sm' -t '%Y-%m-%d %H:%M:%S' "$plist" 2>/dev/null)
        ok "Present. Last modified: $mtime"
    else
        errmsg "Plist file missing: $plist"
        warn "Run:  sudo $SCRIPT_NAME install-daemon"
        return 1
    fi
    echo

    # --- Check 2/8: plist content matches current config -----------
    step "Check 2/8: Plist content vs current config"
    # The plist embeds the absolute path of this script and the interval
    # value. If someone renamed the script or changed LAUNCHD_INTERVAL,
    # the on-disk plist is stale.
    self=$(cd "$(dirname "$0")" && pwd)/$(basename "$0")
    stale=0
    if ! grep -qF "<string>$self</string>" "$plist" 2>/dev/null; then
        warn "Plist references a DIFFERENT script path than this one:"
        warn "  This script: $self"
        warn "  In plist:    $(grep -A0 '<string>.*/appleRAID</string>' "$plist" 2>/dev/null | head -1 | sed 's/^[[:space:]]*//')"
        stale=1
    fi
    plist_interval=$(awk '
        /<key>StartInterval<\/key>/ { next_is_int=1; next }
        next_is_int && /<integer>/ {
            sub(/.*<integer>/,""); sub(/<\/integer>.*/,""); print; exit
        }
    ' "$plist" 2>/dev/null)
    if [ -n "$plist_interval" ] && [ "$plist_interval" != "$LAUNCHD_INTERVAL" ]; then
        warn "StartInterval in plist ($plist_interval) differs from config ($LAUNCHD_INTERVAL)"
        stale=1
    fi
    if [ "$stale" = "1" ]; then
        info "Re-run:  sudo $SCRIPT_NAME install-daemon    to regenerate the plist"
    else
        ok "Plist content matches current script + config."
    fi
    echo

    # --- Check 3/8: loaded in launchd ------------------------------
    step "Check 3/8: launchd registration"
    # 'launchctl list <label>' returns 0 if loaded, non-zero if not.
    # No sudo needed for a system-domain query read-only lookup.
    if launchctl list "$label" >/dev/null 2>&1; then
        ok "Loaded (launchctl list '$label' succeeds)."
    elif sudo -n launchctl list "$label" >/dev/null 2>&1; then
        ok "Loaded (visible via sudo)."
    else
        errmsg "NOT loaded in launchd."
        warn "Run:  sudo launchctl bootstrap system $plist"
        warn "Or:   sudo $SCRIPT_NAME install-daemon"
        # Continue with remaining checks anyway - the log / state info
        # is still useful even when not loaded.
    fi
    echo

    # --- Check 4/8: PID + last exit status -------------------------
    step "Check 4/8: Process + last exit status"
    # Try both userspace and (if available) sudo to read the job dict.
    out=$(launchctl list "$label" 2>/dev/null || sudo -n launchctl list "$label" 2>/dev/null)
    if [ -n "$out" ]; then
        pid=$(echo "$out" | awk -F'[=;]' '/"PID"/ {gsub(/[ \t]/, "", $2); print $2}')
        last_exit=$(echo "$out" | awk -F'[=;]' '/"LastExitStatus"/ {gsub(/[ \t]/, "", $2); print $2}')
        case "$pid" in
            ""|0) info "Not currently running (expected - launchd invokes it every ${LAUNCHD_INTERVAL}s)." ;;
            *)    info "Currently running as PID $pid" ;;
        esac
        case "$last_exit" in
            ""|0) ok "Last exit status: 0 (healthy)" ;;
            *)    warn "Last exit status: $last_exit (non-zero - check log)" ;;
        esac
    else
        warn "Could not read launchd job state (try: sudo $SCRIPT_NAME daemon-status)"
    fi
    echo

    # --- Check 5/8: log file -------------------------------------
    step "Check 5/8: Log file"
    if [ -n "${LOG_FILE:-}" ] && [ -f "$LOG_FILE" ]; then
        lmtime=$(stat -f '%m' "$LOG_FILE" 2>/dev/null)
        if [ -n "$lmtime" ]; then
            ago=$(( $(date +%s) - lmtime ))
            human=$(stat -f '%Sm' -t '%Y-%m-%d %H:%M:%S' "$LOG_FILE" 2>/dev/null)
            info "Log: $LOG_FILE"
            info "  Last write: $human (${ago}s ago)"
            # If the log hasn't been touched in >2x the interval, something's
            # probably wrong.
            threshold=$(( LAUNCHD_INTERVAL * 2 + 30 ))
            if [ "$ago" -gt "$threshold" ]; then
                warn "Log hasn't been written to in ${ago}s (interval is ${LAUNCHD_INTERVAL}s)."
                warn "The daemon may not be running. Check:"
                warn "  tail ${LAUNCHD_STDERR_LOG:-/var/log/my-appleRAID.launchd.err}"
            else
                ok "Log activity is recent."
            fi
        fi
        # Last few log lines for quick visual check.
        info "Last 3 log lines:"
        tail -3 "$LOG_FILE" 2>/dev/null | sed 's/^/    /'
    else
        warn "Log file not present or not configured: ${LOG_FILE:-<unset>}"
        info "  (launchd stderr/stdout logs may still exist at"
        info "   ${LAUNCHD_STDERR_LOG:-/var/log/my-appleRAID.launchd.err}"
        info "   ${LAUNCHD_STDOUT_LOG:-/var/log/my-appleRAID.launchd.out}"
        info "   - check those.)"
    fi
    echo

    # --- Check 6/8: launchd stderr (last errors) -------------------
    step "Check 6/8: Launchd stderr log"
    err_log="${LAUNCHD_STDERR_LOG:-/var/log/my-appleRAID.launchd.err}"
    if [ -f "$err_log" ]; then
        sz=$(stat -f '%z' "$err_log" 2>/dev/null)
        if [ "${sz:-0}" = "0" ]; then
            ok "Stderr log empty (no recent errors)."
        else
            warn "Stderr log has content ($sz bytes). Last 5 lines:"
            tail -5 "$err_log" 2>/dev/null | sed 's/^/    /'
        fi
    else
        info "No stderr log yet: $err_log"
    fi
    echo

    # --- Check 7/8: state dir writable -----------------------------
    step "Check 7/8: Writable paths"
    # The daemon runs as root via launchd, but if it were ever run
    # manually as a non-root user, the state dir may not be writable.
    # Check the *current* user's ability to touch these paths - a
    # best-effort diagnostic.
    if [ -d "$STATE_DIR" ]; then
        if [ -w "$STATE_DIR" ]; then
            ok "State dir writable by current user: $STATE_DIR"
        else
            warn "State dir NOT writable by current user: $STATE_DIR"
            info "  (Daemon runs as root via launchd, so this is probably fine."
            info "   But you won't be able to run 'appleRAID health' manually)"
        fi
    else
        warn "State dir does not exist: $STATE_DIR"
        info "  Will be auto-created on first daemon run."
    fi
    if [ -n "${LOG_FILE:-}" ]; then
        parent=$(dirname "$LOG_FILE")
        if [ -w "$parent" ]; then
            ok "Log directory writable by current user: $parent"
        else
            info "Log directory NOT writable by current user: $parent"
            info "  (Daemon runs as root via launchd, so this is probably fine.)"
        fi
    fi
    echo

    # --- Check 8/8: smartctl availability --------------------------
    # The daemon's SMART-checking pipeline is silent-failure-prone
    # when smartctl is missing. Call it out explicitly here so the
    # "all good" conclusion of daemon-status can never be misleading
    # when SMART is actually disabled for lack of tooling.
    step "Check 8/8: smartctl availability"
    if command -v smartctl >/dev/null 2>&1; then
        ok "smartctl is installed: $(command -v smartctl)"
        ok "  SMART monitoring is ACTIVE."
    else
        errmsg "smartctl is NOT INSTALLED."
        errmsg "  SMART monitoring is DISABLED."
        errmsg "  Temperature, pending/reallocated sectors, drive health -"
        errmsg "  NONE of these are being monitored. A failing drive could"
        errmsg "  go unnoticed until it causes RAID degradation or data loss."
        echo
        info "  Fix:  brew install smartmontools"
        info "  Or:   set SMART_CHECK_ENABLED=no in config to silence the warning."
    fi
    echo

    step "Quick actions"
    cat <<EOF
  Tail the log live:       tail -f ${LOG_FILE:-/var/log/my-appleRAID.log}
  Tail launchd stderr:     tail -f ${LAUNCHD_STDERR_LOG:-/var/log/my-appleRAID.launchd.err}
  Force an immediate run:  sudo launchctl kickstart -k system/$label
  Reload the plist:        sudo $SCRIPT_NAME uninstall-daemon && sudo $SCRIPT_NAME install-daemon
  Full health overview:    $SCRIPT_NAME report
EOF
}

cmd_uninstall_daemon() {
    cfg_load
    plist="${LAUNCHD_PLIST}"
    label="${LAUNCHD_LABEL}"
    step "Uninstalling LaunchDaemon"
    info "Plist: $plist"
    info "Label: $label"
    confirm "Unload and delete?" || die "Aborted."

    run sudo launchctl bootout system "$plist" 2>/dev/null \
        || run sudo launchctl unload "$plist" 2>/dev/null \
        || warn "launchctl unload failed (maybe not loaded)"
    run sudo rm -f "$plist" \
        || err 017 "removing the LaunchDaemon plist file $plist failed"
    ok "Uninstalled."
}

# ======================================================================
# SoftRAID detection + migration helpers
# ======================================================================

# Return whole-disk identifiers (diskN) that appear to be SoftRAID
# members, based on `diskutil info` content markers. Conservative:
# prefers false-negative over false-positive. Empty output when
# SoftRAID is not installed or no SoftRAID volumes exist.
list_softraid_disks() {
    list_all_physical_disks | while read -r d; do
        [ -n "$d" ] || continue
        if diskutil info "/dev/$d" 2>/dev/null | grep -qiE "SoftRAID"; then
            echo "$d"
            continue
        fi
        # Also probe partitions.
        diskutil list "/dev/$d" 2>/dev/null \
            | awk '/^ *[0-9]+:/ {print $NF}' \
            | while read -r part; do
                [ -n "$part" ] || continue
                if diskutil info "/dev/$part" 2>/dev/null | grep -qiE "SoftRAID"; then
                    echo "$d"
                    break
                fi
            done
    done | awk '!seen[$0]++'
}

# Enumerate SoftRAID VIRTUAL mirror devices - the whole-disks that the
# SoftRAID driver synthesizes from its physical members and that carry
# the user-visible volume name shown in SoftRAID.app (e.g. "2.OLD",
# "backup"). Identified by "SoftRAID_Media" in the Device/Media Name
# field of `diskutil info`. Note: `diskutil list` reports them as
# `(external, physical)`, not as virtual/synthesized - the SoftRAID
# kext makes them appear as regular whole-disks.
#
# Output: pipe-separated lines, one per mirror:
#   <diskN>|<volume-name>|<size-string>|<fs>|<mount-point-or-dash>|<size-bytes>
list_softraid_virtual_mirrors() {
    diskutil list 2>/dev/null \
        | awk '/^\/dev\/disk[0-9]+ / { sub(/^\/dev\//, "", $1); print $1 }' \
        | while read -r d; do
            [ -n "$d" ] || continue
            info=$(diskutil info "/dev/$d" 2>/dev/null) || continue
            case "$info" in
                *"SoftRAID_Media"*) ;;
                *) continue ;;
            esac
            whole=$(printf '%s\n' "$info" | awk -F': *' '/^ *Whole:/ {print $2; exit}')
            [ "$whole" = "Yes" ] || continue
            vol=$(printf '%s\n' "$info"  | awk -F': *' '/^ *Volume Name:/ {print $2; exit}')
            # Disk Size line: "  Disk Size:   16.0 TB (16000756740096 Bytes) ..."
            size_str=$(printf '%s\n' "$info" | awk -F': *' '/^ *Disk Size:/ {print $2; exit}' | awk -F'(' '{print $1}' | sed 's/ *$//')
            size_bytes=$(printf '%s\n' "$info" | awk -F'[()]' '/^ *Disk Size:/ {print $2; exit}' | awk '{print $1}')
            fs=$(printf '%s\n' "$info" | awk -F': *' '/^ *File System Personality:/ {print $2; exit}')
            [ -z "$fs" ] && fs=$(printf '%s\n' "$info" | awk -F': *' '/^ *Name \(User Visible\):/ {print $2; exit}')
            mp=$(printf '%s\n' "$info" | awk -F': *' '/^ *Mount Point:/ {print $2; exit}')

            # Some SoftRAID mirrors expose a GPT with a single data
            # partition (e.g. Apple_HFS on diskNs1) rather than a raw
            # filesystem directly on the whole disk. In that case the
            # whole-disk `Volume Name` reads "Not applicable..." - fall
            # through to the first data partition for the real name.
            case "$vol" in
                ""|"Not applicable"*)
                    part=$(diskutil list "/dev/$d" 2>/dev/null \
                        | awk '/^ *[1-9][0-9]*:/ {print $NF; exit}')
                    if [ -n "$part" ]; then
                        pinfo=$(diskutil info "/dev/$part" 2>/dev/null)
                        pvol=$(printf '%s\n' "$pinfo" | awk -F': *' '/^ *Volume Name:/ {print $2; exit}')
                        pfs=$(printf '%s\n'  "$pinfo" | awk -F': *' '/^ *File System Personality:/ {print $2; exit}')
                        pmp=$(printf '%s\n'  "$pinfo" | awk -F': *' '/^ *Mount Point:/ {print $2; exit}')
                        case "$pvol" in
                            ""|"Not applicable"*) ;;
                            *) vol="$pvol" ;;
                        esac
                        [ -n "$pfs" ] && fs="$pfs"
                        case "$pmp" in
                            ""|"Not applicable"*) ;;
                            *) mp="$pmp" ;;
                        esac
                    fi
                    ;;
            esac

            case "$mp"  in ""|"Not applicable"*) mp="-" ;; esac
            case "$vol" in ""|"Not applicable"*) vol="(unnamed)" ;; esac
            printf '%s|%s|%s|%s|%s|%s\n' "$d" "$vol" "${size_str:-?}" "${fs:-?}" "$mp" "${size_bytes:-0}"
        done
}

# Enumerate PHYSICAL SoftRAID member disks - the actual drives that back
# the virtual mirrors above. Detected by either:
#   (a) `diskutil info` mentioning "SoftRAID" (true when SoftRAID
#       metadata / secrets have NOT been removed), OR
#   (b) the presence of the distinctive SoftRAID data partition UUID
#       FA709C7E-65B1-4593-BFD5-E71D61DE9B02 in the disk's GPT (this
#       partition survives "Delete Secrets" and is the fingerprint
#       that remains on disks that were once SoftRAID members).
# Excludes virtual SoftRAID_Media mirror devices (which are also marked
# "physical" in `diskutil list`).
#
# The constant SOFTRAID_DATA_PARTITION_UUID below is the public GPT
# type UUID that SoftRAID assigns to member data partitions. It is
# stable across SoftRAID versions.
SOFTRAID_DATA_PARTITION_UUID="FA709C7E-65B1-4593-BFD5-E71D61DE9B02"

list_softraid_physical_members() {
    list_all_physical_disks | while read -r d; do
        [ -n "$d" ] || continue
        info=$(diskutil info "/dev/$d" 2>/dev/null) || continue
        # Skip virtual SoftRAID mirror devices.
        case "$info" in *"SoftRAID_Media"*) continue ;; esac

        # (a) SoftRAID header/metadata still present on whole disk.
        if printf '%s\n' "$info" | grep -qiE 'SoftRAID'; then
            echo "$d"; continue
        fi
        # (a') ... or on one of its partitions.
        found=""
        parts=$(diskutil list "/dev/$d" 2>/dev/null | awk '/^ *[0-9]+:/ {print $NF}')
        for part in $parts; do
            [ -n "$part" ] || continue
            if diskutil info "/dev/$part" 2>/dev/null | grep -qiE 'SoftRAID'; then
                found=1; break
            fi
        done
        if [ -n "$found" ]; then echo "$d"; continue; fi

        # (b) SoftRAID data partition UUID in the GPT layout.
        if diskutil list "/dev/$d" 2>/dev/null | grep -q "$SOFTRAID_DATA_PARTITION_UUID"; then
            echo "$d"; continue
        fi
    done | awk '!seen[$0]++'
}

# Given a physical SoftRAID member disk (diskN), return the volume name
# of the virtual mirror it most likely belongs to, by size-matching its
# data partition against the known virtual mirror sizes.
#
# Args:  $1=diskN  $2=output of list_softraid_virtual_mirrors
# Output: volume name, or "?" if no match, or "? (ambiguous: A, B)" if
#         multiple mirrors share the same size.
softraid_member_guess_volume() {
    d="$1"
    mirrors="$2"
    # Data-partition size in bytes (the FA709C7E partition).
    data_bytes=$(diskutil list -plist "/dev/$d" 2>/dev/null \
        | awk -v uuid="$SOFTRAID_DATA_PARTITION_UUID" '
            /<key>Content<\/key>/ {getline; if (index($0, uuid)) incontent=1}
            incontent && /<key>Size<\/key>/ {getline;
                gsub(/.*<integer>/, ""); gsub(/<\/integer>.*/, "");
                print; exit}
          ')
    if [ -z "$data_bytes" ] || [ "$data_bytes" = "0" ]; then
        # Fallback: whole-disk size (for disks without a visible data
        # partition, e.g. SoftRAID header intact, or GPT not exposing
        # the sizes via plist).
        data_bytes=$(disk_size_bytes "/dev/$d")
    fi
    [ -z "$data_bytes" ] && { echo "?"; return; }

    # Find mirrors whose size is within 1 GB of data_bytes (the data
    # partition is always slightly larger than the mirror due to
    # SoftRAID's reserved header).
    matches=$(printf '%s\n' "$mirrors" | awk -F'|' -v bytes="$data_bytes" '
        {
            # $6 = mirror size in bytes
            diff = bytes - $6
            if (diff < 0) diff = -diff
            if (diff < 1073741824) print $2   # 1 GiB tolerance
        }
    ')
    case "$(echo "$matches" | awk 'NF' | wc -l | tr -d ' ')" in
        0) echo "?" ;;
        1) echo "$matches" | awk 'NF {print; exit}' ;;
        *) printf '? (ambiguous: %s)' "$(echo "$matches" | awk 'NF' | paste -sd ',' - | sed 's/,/, /g')" ;;
    esac
}

# True if SoftRAID app or background daemon is currently running.
softraid_is_running() {
    pgrep -i -f "SoftRAID\\|softraidd" >/dev/null 2>&1
}

# True if the SoftRAID system extension / kext appears loaded.
softraid_extension_loaded() {
    if command -v systemextensionsctl >/dev/null 2>&1; then
        if systemextensionsctl list 2>/dev/null | grep -qi softraid; then
            return 0
        fi
    fi
    if command -v kextstat >/dev/null 2>&1; then
        if kextstat 2>/dev/null | grep -qi softraid; then
            return 0
        fi
    fi
    return 1
}

# ----------------------------------------------------------------------
# softraidtool wrappers - active SoftRAID-side teardown for migration.
# Used by cmd_migrate_softraid (probe + Step 5 execution) and cmd_release_softraid.
#
# These functions DO modify SoftRAID state (delete volumes, quickzero
# member disks to release them). They exist so that migrate-softraid can run end-to-end
# without the user having to do the SoftRAID-side cleanup by hand in
# SoftRAID.app, and so that the rare case of an unmigratable RAID-N
# volume can still be released via 'release-softraid'.
# ----------------------------------------------------------------------

# Path to the SoftRAIDTool CLI shipped by SoftRAID. Quote "$SOFTRAID_TOOL"
# at every call site - the path contains a literal space.
SOFTRAID_TOOL="/Library/Application Support/SoftRAID/SoftRAIDTool"

softraid_tool_available() {
    [ -x "$SOFTRAID_TOOL" ]
}

# Run softraidtool, capturing stdout+stderr; never let the caller die on
# softraidtool returning non-zero (callers branch on output).
softraid_tool() {
    "$SOFTRAID_TOOL" "$@" 2>&1
}

# Extract the first "  <key>: <value>" line from softraidtool info output.
_sr_info_field() {
    awk -v k="$1" '
        $0 ~ "^[[:space:]]*"k"[[:space:]]*:" {
            sub("^[[:space:]]*"k"[[:space:]]*:[[:space:]]*", "")
            print
            exit
        }
    '
}

# True if softraidtool reports "diskN" as a SoftRAID-controlled disk.
softraid_disk_is_member() {
    out=$(softraid_tool disk "$1" info 2>&1)
    case "$out" in
        *"is not a SoftRAID disk"*|*"could not find"*|*"unable to"*) return 1 ;;
    esac
    case "$out" in
        *"Driver Type:"*"SoftRAID"*|*"SoftRAID ID:"*) return 0 ;;
    esac
    return 1
}

# Newline-separated list of SoftRAID volume names that disk <bsd> belongs
# to (from the "Volumes on diskN:" section). Empty if none.
softraid_disk_volumes() {
    softraid_tool disk "$1" info 2>&1 | awk '
        /^Volumes on / {invol=1; next}
        invol && /^[[:space:]]*"/ {
            sub(/^[[:space:]]*"/, "")
            sub(/".*/, "")
            print
            next
        }
        invol && NF==0 {invol=0}
    '
}

# Volume RAID level normalised: raid0 / raid1 / raid4 / raid5 / raid10 /
# nonraid (lowercase, no spaces). Empty on miss.
softraid_volume_raid_level() {
    softraid_tool volume "$1" info 2>&1 \
        | _sr_info_field "RAID level" \
        | tr '[:upper:]' '[:lower:]' \
        | sed -e 's/[[:space:]]\{1,\}//g' -e 's/,.*//'
}

# True if Volume Safeguard is currently enabled.
softraid_volume_safeguard_enabled() {
    state=$(softraid_tool volume "$1" info 2>&1 | _sr_info_field "Volume Safeguard")
    case "$state" in
        enabled|Enabled|ENABLED) return 0 ;;
    esac
    return 1
}

# True if the volume is currently mounted somewhere.
softraid_volume_mounted() {
    mp=$(softraid_tool volume "$1" info 2>&1 | _sr_info_field "Mountpoint")
    case "$mp" in
        ""|"-"|"none"|"None"|"not mounted"*) return 1 ;;
    esac
    return 0
}

# BSD disk ids ("diskN") of every member of the named volume, in the
# order softraidtool prints them.
softraid_volume_member_disks() {
    softraid_tool volume "$1" info 2>&1 | awk '
        /^Disks used for this volume:/ {indisks=1; next}
        indisks && /^bsd disk:/        {next}
        indisks && /^disk[0-9]+/       {print $1; next}
        indisks && NF==0               {indisks=0}
    '
}

# True if softraidtool knows about a volume by this name. NOTE: this
# is intentionally permissive - softraidtool's CLI also resolves names
# of AppleRAID and plain (Apple Disk Utility) volumes, so any caller
# that intends to issue destructive commands MUST also call
# softraid_volume_is_softraid below to confirm it is actually a
# SoftRAID-managed volume before proceeding.
softraid_volume_exists() {
    out=$(softraid_tool volume "$1" info 2>&1)
    case "$out" in
        *"could not find"*|*"is not"*|*"unrecognized"*|*"error"*) return 1 ;;
    esac
    case "$out" in
        *"Mountpoint:"*|*"Total Bytes:"*) return 0 ;;
    esac
    return 1
}

# True ONLY if softraidtool reports the named volume is actually
# SoftRAID-managed (i.e. the info output contains 'Volume is SoftRAID').
# Anything else - AppleRAID, Apple Disk Utility, bootable, etc. - returns
# false. This is the safety gate for any command that would invoke
# 'softraidtool volume X delete' or 'softraidtool disk Y quickzero',
# both of which softraidtool will happily execute against AppleRAID
# member disks if asked, with catastrophic consequences.
softraid_volume_is_softraid() {
    out=$(softraid_tool volume "$1" info 2>&1)
    case "$out" in
        *"is not unique"*|*"could not find"*|*"is not "*) return 1 ;;
    esac
    case "$out" in
        *"Volume is SoftRAID"*) return 0 ;;
    esac
    return 1
}

# Convenience: extract the 'Volume is X' classification line for
# diagnostic output (e.g. 'AppleRAID', 'Apple Disk Utility', etc.).
softraid_volume_flavor() {
    softraid_tool volume "$1" info 2>&1 \
        | awk '/^Volume is / {sub(/^Volume is[[:space:]]*/,""); print; exit}'
}

# Orchestrate the SoftRAID-side release of one named volume:
#
#   1. (if Safeguard enabled)  volume <V> disablesafeguard
#   2. (if mounted)            volume <V> unmount
#   3.                         volume <V> delete
#   4. for each member disk:   disk <D> initialize
#   5. re-resolve each member's BSD id by serial (kernel may renumber)
#
# Args:
#   $1   volume name (as shown by softraidtool)
#   $2+  one or more "diskN" ids; serials are captured BEFORE
#        initialize so we can find them again afterwards
#
# Stdout: NEW BSD ids (one per line) in the same order as the input
# disks. Caller can capture and reassign dev1/dev2.
#
# On any failure: prints a clear error and dies. No partial-success
# return path - the cache invariant is "fully released or aborted".
softraid_release_volume() {
    vol="$1"; shift
    [ $# -ge 1 ] || die "softraid_release_volume: no member disks given"
    softraid_tool_available || die "SoftRAIDTool not found at: $SOFTRAID_TOOL"

    # Defense-in-depth safety gate. softraidtool resolves names of
    # AppleRAID and plain HFS volumes too; refuse anything that is
    # not actually 'Volume is SoftRAID' so we can never delete or
    # quickzero the wrong thing.
    if ! softraid_volume_is_softraid "$vol"; then
        flavor=$(softraid_volume_flavor "$vol")
        errmsg "Refusing to release: \"$vol\" is not a SoftRAID volume (softraidtool reports: ${flavor:-unknown})."
        return 1
    fi

    # The function emits two kinds of output:
    #   - VISIBLE PROGRESS: info/run/ok/warn -- normally to stdout
    #   - RESULT:           the new BSD ids, one per line, also stdout
    #
    # Callers wrap us in $(...) to capture the result, which would
    # also swallow the visible progress and any softraidtool error
    # printed on stdout. Run the body in a subshell with fd 1 and 2
    # swapped: progress (fd 1 -> 2) reaches the user's terminal; the
    # original stdout is preserved on fd 3 and used only for result
    # emission, so $(...) only captures the BSD ids.
    (
        exec 3>&1 1>&2

        if softraid_volume_safeguard_enabled "$vol"; then
            info "Volume \"$vol\" has Safeguard enabled - disabling first."
            run sudo "$SOFTRAID_TOOL" volume "$vol" disablesafeguard \
                || die "Failed to disable Safeguard on \"$vol\""
        fi

        if softraid_volume_mounted "$vol"; then
            info "Volume \"$vol\" is mounted - unmounting first."
            run sudo "$SOFTRAID_TOOL" volume "$vol" unmount \
                || warn "Volume unmount returned non-zero (delete will retry)."
        fi

        info "Deleting SoftRAID volume \"$vol\"."
        run sudo "$SOFTRAID_TOOL" volume "$vol" delete \
            || die "softraidtool volume \"$vol\" delete failed"

        for d in "$@"; do
            [ -n "$d" ] || continue
            # IMPORTANT: 'disk initialize' is the WRONG primitive here -
            # it re-initialises the disk as a FRESH SoftRAID-controlled
            # disk (assigns a new SoftRAID ID, keeps Driver Type=SoftRAID),
            # leaving the kext claiming the disk and synthesising a
            # phantom 'stuff A/B'-labelled mirror device.
            #
            # 'disk quickzero' writes zeros to the first and last 100
            # sectors, which clears the SoftRAID disk-level signature.
            # On the next probe the kext stops recognising the disk as
            # a SoftRAID member and releases it, so subsequent dd /
            # diskutil writes (used by do_auto_wipe) succeed.
            info "Releasing /dev/$d from SoftRAID (disk quickzero)."
            run sudo "$SOFTRAID_TOOL" disk "$d" quickzero \
                || die "softraidtool disk $d quickzero failed"
        done

        echo
        info "Verifying disks present after quickzero..."
        for d in "$@"; do
            [ -n "$d" ] || continue
            j=0
            while [ "$j" -lt 10 ]; do
                if diskutil info "/dev/$d" >/dev/null 2>&1; then
                    ok "/dev/$d present."
                    # The ONLY line written to fd 3 - the original
                    # stdout captured by the caller's $(...).
                    echo "$d" >&3
                    break
                fi
                sleep 1
                j=$((j + 1))
            done
            [ "$j" -lt 10 ] || die "/dev/$d not visible after initialize. Run '$SCRIPT_NAME disks' to inspect."
        done
    )
}

# ----------------------------------------------------------------------
# `uninstall-softraid` - pre-flight + post-flight checklist for
# removing SoftRAID. This command does NOT delete anything itself -
# use SoftRAID's own uninstaller (handles the system extension
# correctly) and AppCleaner (handles app bundle remnants).
# ----------------------------------------------------------------------
cmd_uninstall_softraid() {
    step "SoftRAID uninstall verification"
    explain "This command checks whether SoftRAID has been cleanly removed."
    explain "It does NOT delete anything itself - the right tools are:"
    explain "  1. SoftRAID.app -> SoftRAID menu -> Uninstall SoftRAID..."
    explain "  2. AppCleaner (drag the SoftRAID app into it for leftover files)"
    echo

    step "Check 1/3: SoftRAID volumes"
    sr_disks=$(list_softraid_disks)
    if [ -z "$sr_disks" ]; then
        ok "No SoftRAID volumes detected."
    else
        errmsg "SoftRAID membership still present on:"
        echo "$sr_disks" | sed 's|^|    /dev/|'
        warn "Migrate or delete these volumes BEFORE uninstalling SoftRAID."
        warn "Use: appleRAID migrate-softraid"
    fi
    echo

    step "Check 2/3: Running processes"
    if softraid_is_running; then
        warn "SoftRAID app or daemon is running. Quit it before uninstalling:"
        pgrep -l -f "SoftRAID\\|softraidd" 2>/dev/null | sed 's/^/    /'
    else
        ok "No SoftRAID processes running."
    fi
    echo

    step "Check 3/3: System extension / kext"
    if softraid_extension_loaded; then
        warn "SoftRAID system extension (or kext) is still registered."
        if command -v systemextensionsctl >/dev/null 2>&1; then
            systemextensionsctl list 2>/dev/null | grep -i softraid | sed 's/^/    /'
        fi
        info "This is removed by SoftRAID's own uninstaller + a reboot."
    else
        ok "No SoftRAID system extension / kext detected."
    fi
    echo

    step "Uninstall checklist (do these in order)"
    cat <<EOF
  1. Open SoftRAID.app
  2. SoftRAID menu -> "Uninstall SoftRAID..."
  3. Enter your admin password when prompted
  4. Reboot  (required for system-extension removal)
  5. After reboot, run AppCleaner and drop SoftRAID.app onto it
     to catch leftover preferences / caches / logs
  6. Re-run '$SCRIPT_NAME uninstall-softraid' to verify

This command does NOT delete anything itself.
EOF
}

# ----------------------------------------------------------------------
# `migrate-softraid` - guided, per-mirror migration from SoftRAID to
# AppleRAID. Intended to be run once per existing SoftRAID mirror.
#
# Flow:
#   1. List detected SoftRAID member disks, let the user pick a pair
#   2. Confirm the user has backed up the data
#   3. Walk through SoftRAID-side volume deletion + "delete secrets"
#      (which the user does inside SoftRAID.app, verified afterwards)
#   4. Wipe both disks (first+last 100 MB)
#   5. Create AppleRAID mirror
#
# This wraps existing primitives (wipe + create) around SoftRAID-
# specific steps. It does NOT mount SoftRAID volumes, manipulate
# SoftRAID's internal state, or touch the SoftRAID app - those are
# the user's responsibility.
# ----------------------------------------------------------------------
cmd_migrate_softraid() {
    # Strip global flags that may appear after the subcommand.
    eval "$(parse_global_flags "$@")"

    # Per-command help.
    for a in "$@"; do
        case "$a" in
            -h|--help)
                cat <<EOF
Usage: $SCRIPT_NAME migrate-softraid [volume]

Guided migration of ONE SoftRAID mirror to AppleRAID. The other mirrors
on this Mac keep working; run the command once per mirror.

Positional argument (optional):
  volume    Name of the SoftRAID volume (as shown in SoftRAID.app, e.g.
            "2.OLD"), or the BSD disk of its virtual mirror (e.g. disk10).
            When given, the two member disks and the new AppleRAID name
            are pre-filled from the size-matched physical members.
            When omitted: if only one SoftRAID volume is present it is
            auto-selected, otherwise you are prompted to pick one.
EOF
                return 0
                ;;
        esac
    done

    vol_arg=""
    if [ $# -ge 1 ]; then
        vol_arg="$1"
    fi

    step "Guided SoftRAID-to-AppleRAID migration (one mirror)"
    explain "This command walks you through migrating ONE SoftRAID mirror to"
    explain "AppleRAID. Run it once per mirror you want to convert. The other"
    explain "SoftRAID mirrors keep working throughout - you migrate one at a time."
    echo

    step "Step 1: Detect SoftRAID volumes and member disks"

    # (a) Virtual mirrors: the volumes a user sees in SoftRAID.app
    #     (e.g. "2.OLD", "backup"). Each is a whole virtual disk
    #     synthesized by the SoftRAID driver from two member disks.
    sr_mirrors=$(list_softraid_virtual_mirrors)
    if [ -n "$sr_mirrors" ]; then
        info "SoftRAID volumes exposed by the SoftRAID driver:"
        printf '%s\n' "$sr_mirrors" | while IFS='|' read -r vd vname vsize vfs vmp _vbytes; do
            printf '  /dev/%-7s  volume="%s"  size=%s  fs=%s  mount=%s\n' \
                "$vd" "$vname" "$vsize" "$vfs" "$vmp"
        done
        echo
    fi

    # (b) Physical member disks: the actual drives backing the mirrors.
    sr_disks=$(list_softraid_physical_members)
    if [ -z "$sr_disks" ] && [ -z "$sr_mirrors" ]; then
        warn "No SoftRAID volumes or member disks detected. Nothing to migrate."
        info "If you believe SoftRAID is present, verify manually with:"
        info "  diskutil info -all | grep -i softraid"
        info "  /Applications/SoftRAID.app/Contents/MacOS/SoftRAIDTool volume all info"
        return 0
    fi
    if [ -z "$sr_disks" ]; then
        warn "Virtual mirrors found but no physical members detected."
        warn "This usually means SoftRAID metadata has been fully removed while"
        warn "the mirrors are still mounted. Unmount them in SoftRAID.app first."
        echo
    else
        info "Physical disks that appear to be SoftRAID members:"
        echo "$sr_disks" | while read -r d; do
            [ -n "$d" ] || continue
            size=$(diskutil info "/dev/$d" 2>/dev/null | awk -F': *' '/Disk Size:/ {print $2; exit}' | awk -F'(' '{print $1}' | sed 's/ *$//')
            model=$(diskutil info "/dev/$d" 2>/dev/null | awk -F': *' '/Device \/ Media Name:/ {print $2; exit}')
            vol=$(softraid_member_guess_volume "$d" "$sr_mirrors")
            printf '  /dev/%-7s  size=%-10s  belongs_to=%-24s  model=%s\n' \
                "$d" "${size:-?}" "\"$vol\"" "${model:-?}"
        done
        echo
    fi
    warn "Detection is heuristic - verify with SoftRAID.app if in doubt."
    warn "belongs_to= is a size-match guess; ambiguous when multiple mirrors"
    warn "share the same size. Confirm in SoftRAID.app."
    echo

    # ------------------------------------------------------------------
    # Select a single SoftRAID volume to migrate. Matches by volume name
    # (e.g. "2.OLD") or by virtual-mirror BSD disk (e.g. disk10 / 10).
    # If no argument was given and multiple volumes exist, prompt.
    # If only one volume exists, auto-select.
    # The selected volume drives auto-detection of its two physical
    # members (by size match) and a default name for the new AppleRAID
    # mirror in Step 3.
    # ------------------------------------------------------------------
    selected_vol_name=""
    selected_mirror_line=""
    if [ -n "$sr_mirrors" ]; then
        if [ -n "$vol_arg" ]; then
            selected_mirror_line=$(printf '%s\n' "$sr_mirrors" | awk -F'|' -v v="$vol_arg" '
                $2 == v || $1 == v || ("disk" $1) == v || ("/dev/disk" $1) == v || ("/dev/" $1) == v {print; exit}
            ')
            [ -z "$selected_mirror_line" ] \
                && die "No SoftRAID volume matches '$vol_arg'. Use one of the names or disks listed above."
        else
            n_mirrors=$(printf '%s\n' "$sr_mirrors" | awk 'NF' | wc -l | tr -d ' ')
            if [ "$n_mirrors" -eq 1 ]; then
                selected_mirror_line="$sr_mirrors"
            elif [ "$n_mirrors" -gt 1 ]; then
                step "Select which SoftRAID volume to migrate"
                printf 'Enter volume name or disk (e.g. 2.OLD, disk10, 10): '
                read -r choice
                [ -z "$choice" ] && die "No selection made."
                selected_mirror_line=$(printf '%s\n' "$sr_mirrors" | awk -F'|' -v v="$choice" '
                    $2 == v || $1 == v || ("disk" $1) == v || ("/dev/disk" $1) == v || ("/dev/" $1) == v {print; exit}
                ')
                [ -z "$selected_mirror_line" ] \
                    && die "No SoftRAID volume matches '$choice'."
            fi
        fi
    fi

    auto_n1=""
    auto_n2=""
    if [ -n "$selected_mirror_line" ]; then
        selected_vol_name=$(echo "$selected_mirror_line" | awk -F'|' '{print $2}')
        selected_vol_disk=$(echo "$selected_mirror_line" | awk -F'|' '{print $1}')
        info "Selected SoftRAID volume: \"$selected_vol_name\" (/dev/$selected_vol_disk)"

        # Find physical members whose size-guessed volume matches.
        matching=$(echo "$sr_disks" | while read -r d; do
            [ -n "$d" ] || continue
            guessed=$(softraid_member_guess_volume "$d" "$sr_mirrors")
            if [ "$guessed" = "$selected_vol_name" ]; then
                echo "$d"
            fi
        done)
        n_match=$(echo "$matching" | awk 'NF' | wc -l | tr -d ' ')
        if [ "$n_match" -eq 2 ]; then
            auto_n1=$(echo "$matching" | awk 'NF {print; exit}' | sed 's/^disk//')
            auto_n2=$(echo "$matching" | awk 'NF' | sed -n '2p' | sed 's/^disk//')
            info "Auto-detected members: /dev/disk$auto_n1 + /dev/disk$auto_n2"
        elif [ "$n_match" -gt 2 ]; then
            warn "Size-match found $n_match possible members for \"$selected_vol_name\":"
            echo "$matching" | awk 'NF' | sed 's|^|    /dev/|'
            warn "You'll be asked to pick two manually in Step 3."
        else
            warn "Could not auto-detect physical members for \"$selected_vol_name\"."
            warn "You'll be asked to enter them manually in Step 3."
        fi
        echo
    fi

    step "Step 2: Pre-flight checklist"
    cat <<EOF
Before proceeding, confirm:
  [ ] You have backed up the mirror's data (migration is destructive)
  [ ] You have the two member disk numbers ready
  [ ] The OTHER SoftRAID mirrors on this Mac are still intact and will
      remain managed by SoftRAID during this migration

NOTE: SoftRAID-side cleanup (volume delete + member quickzero) is now
done automatically as part of Step 4's final plan - you no longer
have to do it manually in SoftRAID.app. You will get exactly ONE
confirmation prompt covering the entire destructive pipeline (SoftRAID
release + disk wipe + AppleRAID create); after that there are no
further prompts.
EOF
    echo
    confirm "All three items above are done?" || die "Aborted. Complete the checklist first."
    echo

    step "Step 3: Select the two disks"
    if [ -n "$auto_n1" ] && [ -n "$auto_n2" ]; then
        printf 'Disk NUMBER of first member [%s]: ' "$auto_n1"
        read -r n1
        [ -z "$n1" ] && n1="$auto_n1"
        printf 'Disk NUMBER of second member [%s]: ' "$auto_n2"
        read -r n2
        [ -z "$n2" ] && n2="$auto_n2"
    else
        printf 'Enter disk NUMBER of first member (e.g. 2): '
        read -r n1
        printf 'Enter disk NUMBER of second member (e.g. 3): '
        read -r n2
    fi
    if [ -z "$n1" ] || [ -z "$n2" ]; then
        die "Both disk numbers are required."
    fi
    [ "$n1" = "$n2" ] && die "Cannot mirror a disk to itself."

    dev1=$(resolve_disk "$n1") || die "Invalid: $n1"
    dev2=$(resolve_disk "$n2") || die "Invalid: $n2"

    if [ -n "$selected_vol_name" ] && [ "$selected_vol_name" != "(unnamed)" ]; then
        printf 'Name for the new AppleRAID mirror [%s]: ' "$selected_vol_name"
        read -r new_name
        [ -z "$new_name" ] && new_name="$selected_vol_name"
    else
        printf 'Enter a name for the new AppleRAID mirror (e.g. Mirror2): '
        read -r new_name
    fi
    [ -n "$new_name" ] || die "Name is required."
    echo

    # ------------------------------------------------------------------
    # SoftRAID state probe (silent). If the chosen disks are still
    # members of an active SoftRAID volume, we add the SoftRAID-side
    # teardown to the consolidated Step 4 plan. Asymmetric state, two
    # unrelated volumes, or a non-mirror RAID level abort here before
    # the user sees any plan. The probe runs softraidtool a few times
    # and can take a couple of seconds; surface that as a single info
    # line so it's not mistaken for a hang.
    # ------------------------------------------------------------------
    info "Probing SoftRAID state for selected disks (this may take a few seconds)..."
    bsd1=${dev1#/dev/}
    bsd2=${dev2#/dev/}
    sr_member1=no; sr_member2=no
    softraid_disk_is_member "$bsd1" && sr_member1=yes
    softraid_disk_is_member "$bsd2" && sr_member2=yes

    sr_release_needed=no
    sr_vol=""
    sr_disable_safeguard=no
    sr_unmount=no
    if [ "$sr_member1" = "yes" ] || [ "$sr_member2" = "yes" ]; then
        if [ "$sr_member1" != "$sr_member2" ]; then
            errmsg "Asymmetric SoftRAID state:"
            errmsg "  /dev/$bsd1 SoftRAID-controlled: $sr_member1"
            errmsg "  /dev/$bsd2 SoftRAID-controlled: $sr_member2"
            die "Both members must be in the same state. Inspect with: $SCRIPT_NAME disks"
        fi

        vol1=$(softraid_disk_volumes "$bsd1" | awk 'NF {print; exit}')
        vol2=$(softraid_disk_volumes "$bsd2" | awk 'NF {print; exit}')
        if [ -z "$vol1" ] || [ -z "$vol2" ]; then
            die "SoftRAID claims one of the disks but no volume name was found. Run: $SCRIPT_NAME disks"
        fi
        if [ "$vol1" != "$vol2" ]; then
            errmsg "/dev/$bsd1 belongs to SoftRAID volume \"$vol1\""
            errmsg "/dev/$bsd2 belongs to SoftRAID volume \"$vol2\""
            die "Cannot migrate two unrelated SoftRAID volumes in one run."
        fi
        sr_vol="$vol1"
        sr_level=$(softraid_volume_raid_level "$sr_vol")

        case "$sr_level" in
            raid1) ;;
            "")
                die "Could not determine RAID level for volume \"$sr_vol\". Inspect with:
    sudo \"$SOFTRAID_TOOL\" volume \"$sr_vol\" info"
                ;;
            *)
                errmsg "Volume \"$sr_vol\" is RAID level '$sr_level' - not a mirror."
                errmsg "'migrate-softraid' only supports RAID 1 (mirrors)."
                info "To just tear down a non-mirror SoftRAID volume (delete + quickzero"
                info "all its members) without creating an AppleRAID set, run:"
                info "    $SCRIPT_NAME release-softraid \"$sr_vol\""
                die "Aborted - non-mirror SoftRAID volume."
                ;;
        esac

        sr_release_needed=yes
        softraid_volume_safeguard_enabled "$sr_vol" && sr_disable_safeguard=yes
        softraid_volume_mounted "$sr_vol" && sr_unmount=yes
    fi

    # ------------------------------------------------------------------
    # Step 4: ONE consolidated plan + ONE confirmation. Lists every
    # destructive action that the rest of the run will perform, in the
    # exact order it will execute them - SoftRAID-side teardown (if
    # required), 100 MB wipes front + back of each disk, AppleRAID
    # mirror create. After 'yes' here there are no further prompts.
    # ------------------------------------------------------------------
    step "Step 4: Final plan (single confirmation)"
    info "About to perform the following pipeline:"
    plan_step=1
    if [ "$sr_release_needed" = "yes" ]; then
        info "  Release SoftRAID volume \"$sr_vol\":"
        if [ "$sr_disable_safeguard" = "yes" ]; then
            info "    $plan_step. softraidtool volume \"$sr_vol\" disablesafeguard"
            plan_step=$((plan_step + 1))
        fi
        if [ "$sr_unmount" = "yes" ]; then
            info "    $plan_step. softraidtool volume \"$sr_vol\" unmount"
            plan_step=$((plan_step + 1))
        fi
        info "    $plan_step. softraidtool volume \"$sr_vol\" delete           (DESTROYS the SoftRAID volume)"
        plan_step=$((plan_step + 1))
        info "    $plan_step. softraidtool disk $bsd1 quickzero               (releases disk from SoftRAID)"
        plan_step=$((plan_step + 1))
        info "    $plan_step. softraidtool disk $bsd2 quickzero               (releases disk from SoftRAID)"
        plan_step=$((plan_step + 1))
    fi
    info "  Build AppleRAID mirror:"
    info "    $plan_step. WIPE first + last 100 MB of $dev1"
    plan_step=$((plan_step + 1))
    info "    $plan_step. WIPE first + last 100 MB of $dev2"
    plan_step=$((plan_step + 1))
    info "    $plan_step. diskutil appleRAID create mirror \"$new_name\" APFS $dev1 $dev2"
    echo
    if [ "$sr_release_needed" = "yes" ]; then
        warn "DESTRUCTIVE: SoftRAID volume \"$sr_vol\" will be deleted, both disks repartitioned,"
        warn "             then registered as members of new AppleRAID mirror \"$new_name\"."
    else
        warn "DESTRUCTIVE: both disks will be repartitioned and registered as members of"
        warn "             new AppleRAID mirror \"$new_name\"."
    fi
    warn "This is the ONLY confirmation. Step 2 already confirmed the data is backed up."
    echo
    confirm "PROCEED with the entire pipeline?" || die "Aborted."
    echo

    # ------------------------------------------------------------------
    # Step 5: execute the plan top-to-bottom, no further prompts.
    # ------------------------------------------------------------------
    step "Step 5: Executing pipeline"
    if [ "$sr_release_needed" = "yes" ]; then
        new_bsds=$(softraid_release_volume "$sr_vol" "$bsd1" "$bsd2") \
            || die "SoftRAID release failed - see above for details."
        new_bsd1=$(printf '%s\n' "$new_bsds" | awk 'NF {print; exit}')
        new_bsd2=$(printf '%s\n' "$new_bsds" | awk 'NF' | sed -n '2p')
        [ -n "$new_bsd1" ] && [ -n "$new_bsd2" ] \
            || die "Could not re-resolve BSD ids after release. Got: $new_bsds"
        dev1="/dev/$new_bsd1"
        dev2="/dev/$new_bsd2"
        n1=${new_bsd1#disk}
        n2=${new_bsd2#disk}
        echo
        ok "SoftRAID side released. Continuing with /dev/$new_bsd1 + /dev/$new_bsd2."
        echo
    fi

    # cmd_create handles wipe + AppleRAID create. _PRECONFIRMED=1 tells
    # it to skip its own internal "PROCEED?" prompt so we honour the
    # single-confirmation contract from Step 4.
    _PRECONFIRMED=1 cmd_create "$new_name" "$n1" "$n2"

    echo
    ok "Migration complete for mirror '$new_name'."
    info "Next steps:"
    info "  - Restore data from backup into /Volumes/$new_name"
    info "  - Migrate remaining SoftRAID mirrors: re-run 'appleRAID migrate-softraid'"
    info "  - Once ALL mirrors are migrated, run 'appleRAID uninstall-softraid'"
    info "    for the final uninstall checklist."
}

# ----------------------------------------------------------------------
# `release-softraid` - tear down a single named SoftRAID volume without
# creating an AppleRAID set. Use this for non-mirror SoftRAID volumes
# (RAID 0/4/5/10), or when you just want to free the disks.
#
# Steps (all via softraidtool):
#   1. Disable Safeguard (if enabled)
#   2. Unmount the volume (if mounted)
#   3. Delete the volume
#   4. Quickzero each member disk (releases it from SoftRAID control)
#   5. Re-resolve BSD ids by serial and print the final mapping
# ----------------------------------------------------------------------
cmd_release_softraid() {
    eval "$(parse_global_flags "$@")"

    for a in "$@"; do
        case "$a" in
            -h|--help)
                cat <<EOF
Usage: $SCRIPT_NAME release-softraid <volume>

Tear down a single SoftRAID volume completely:
  1. Disable Safeguard (if enabled)
  2. Unmount the volume (if mounted)
  3. Delete the volume from SoftRAID
  4. Quickzero each member disk (releases it from SoftRAID's control)
  5. Print the final BSD ids of the released disks

This does NOT create an AppleRAID set on top - use 'create' for that, or
use 'migrate-softraid' for the integrated end-to-end flow on mirrors.

This IS the intended way to handle:
  - non-mirror SoftRAID volumes (RAID 0/4/5/10) that 'migrate-softraid'
    refuses to touch
  - any SoftRAID volume you simply want to dismantle

DESTRUCTIVE: the volume's data is gone after step 3. Confirm you have
a backup before running this.
EOF
                return 0
                ;;
        esac
    done

    [ $# -ge 1 ] || die "Usage: $SCRIPT_NAME release-softraid <volume>"
    vol="$1"

    softraid_tool_available || die "SoftRAIDTool not found at: $SOFTRAID_TOOL
SoftRAID does not appear to be installed."

    step "Release SoftRAID volume \"$vol\""

    if ! softraid_volume_exists "$vol"; then
        die "SoftRAID does not know a volume named \"$vol\". List volumes with:
    sudo \"$SOFTRAID_TOOL\" volume all info"
    fi

    # SAFETY GATE: softraidtool resolves AppleRAID and plain HFS volumes
    # by name too, and will happily 'delete' them or 'quickzero' their
    # member disks if asked. Refuse anything that is not 'Volume is
    # SoftRAID' - this protects an AppleRAID set or a regular volume
    # that happens to share its name with a (now-stale) SoftRAID label
    # from being torn down by accident.
    if ! softraid_volume_is_softraid "$vol"; then
        flavor=$(softraid_volume_flavor "$vol")
        errmsg "Volume \"$vol\" is NOT a SoftRAID volume."
        errmsg "softraidtool reports it as: ${flavor:-(unknown)}"
        errmsg "Refusing to run destructive teardown against a non-SoftRAID volume."
        info "If you meant a different SoftRAID volume, list them with:"
        info "    sudo \"$SOFTRAID_TOOL\" volume all info | grep -nE '^Info for \"|Volume is SoftRAID'"
        die "Aborted - safety check (not a SoftRAID volume)."
    fi

    level=$(softraid_volume_raid_level "$vol")
    members=$(softraid_volume_member_disks "$vol" | awk 'NF')
    n_members=$(printf '%s\n' "$members" | awk 'NF' | wc -l | tr -d ' ')

    info "Volume \"$vol\":"
    info "  RAID level: ${level:-?}"
    info "  Members ($n_members):"
    printf '%s\n' "$members" | awk 'NF' | sed 's|^|    /dev/|'
    if softraid_volume_safeguard_enabled "$vol"; then
        info "  Safeguard:  enabled (will be disabled first)"
    else
        info "  Safeguard:  disabled"
    fi
    if softraid_volume_mounted "$vol"; then
        mp=$(softraid_tool volume "$vol" info 2>&1 | _sr_info_field "Mountpoint")
        info "  Mounted:    yes ($mp - will be unmounted first)"
    else
        info "  Mounted:    no"
    fi
    echo

    [ "$n_members" -ge 1 ] || die "Volume \"$vol\" has no member disks."

    explain "About to:"
    if softraid_volume_safeguard_enabled "$vol"; then
        explain "  - softraidtool volume \"$vol\" disablesafeguard"
    fi
    if softraid_volume_mounted "$vol"; then
        explain "  - softraidtool volume \"$vol\" unmount"
    fi
    explain "  - softraidtool volume \"$vol\" delete    (DESTROYS the volume)"
    printf '%s\n' "$members" | awk 'NF' | while read -r d; do
        explain "  - softraidtool disk $d quickzero        (releases disk from SoftRAID)"
    done
    echo
    warn "DESTRUCTIVE: volume \"$vol\" and all its data will be gone."
    warn "Make sure you have a backup if the data still matters."
    echo
    confirm "Release SoftRAID volume \"$vol\"?" || die "Aborted."
    echo

    # Translate the newline-separated member list into positional args
    # for softraid_release_volume.
    set -- "$vol"
    while IFS= read -r d; do
        [ -n "$d" ] || continue
        set -- "$@" "$d"
    done <<EOF
$members
EOF
    new_bsds=$(softraid_release_volume "$@") \
        || die "SoftRAID release failed - see above."

    echo
    ok "Volume \"$vol\" released. Final disk lineup:"
    i=0
    while IFS= read -r d; do
        [ -n "$d" ] || continue
        i=$((i + 1))
        old=$(printf '%s\n' "$members" | awk -v n="$i" 'NF {if (++c==n) {print; exit}}')
        if [ -n "$old" ] && [ "$old" != "$d" ]; then
            info "  /dev/$old -> /dev/$d"
        else
            info "  /dev/$d (unchanged)"
        fi
    done <<EOF
$new_bsds
EOF
    echo
    info "Next steps (optional):"
    info "  - Inspect:    $SCRIPT_NAME disks"
    info "  - Wipe stale GPT/metadata: $SCRIPT_NAME wipe <N>"
    info "  - Build AppleRAID:         $SCRIPT_NAME create <name> <N1> <N2>"
}

# ======================================================================
# Human-readable health report
# ======================================================================

# ----------------------------------------------------------------------
# `report` - overview of everything the daemon currently thinks, in
# readable form. Pure read-only: doesn't trigger alerts, doesn't
# modify state.
# ----------------------------------------------------------------------
cmd_report() {
    cfg_load
    state_init 2>/dev/null || true

    step "appleRAID health report"
    info "Generated: $(now_iso)"
    info "Host:      $(hostname)"
    info "Config:    $LOADED_CONFIG"
    echo

    # --- RAID sets ---
    step "RAID sets"
    uuids=$(raid_list_uuids)
    if [ -z "$uuids" ]; then
        warn "No AppleRAID sets present."
    else
        for u in $uuids; do
            name=$(diskutil appleRAID list | awk -F': +' -v u="$u" '
                /^Name:/      { cur = $2; sub(/ +$/, "", cur) }
                /^Unique ID:/ { uuid = $2; sub(/ +$/, "", uuid); if (uuid == u) { print cur; exit } }
            ')
            st=$(raid_status "$u")
            dev=$(raid_uuid_to_device "$u")
            case "$st" in
                Online)   color="$C_GREEN" ;;
                Degraded) color="$C_YELLOW" ;;
                *)        color="$C_RED" ;;
            esac
            printf '  %-20s  %s%-12s%s  dev=/dev/%s\n' \
                "$name" "$color" "$st" "$C_RESET" "$dev"
            # Per-member line
            diskutil appleRAID list "$u" 2>/dev/null | awk '
                /^[0-9]+[ \t]+disk/ {
                    devnode = $2
                    status = ""
                    for (i = 4; i < NF; i++) {
                        status = (status == "" ? $i : status " " $i)
                    }
                    printf "      %-10s %s\n", devnode, status
                }
            '
        done
    fi
    echo

    # --- Required set/disk baselines ---
    step "Baselines (for REQUIRED_*=all presence checks)"
    f=$(baseline_sets_file)
    if [ -f "$f" ]; then
        info "Set baseline ($f):"
        baseline_read_sets | sed 's/^/    /'
    else
        warn "No set baseline file yet (will be auto-created on first health run)."
    fi
    f=$(baseline_disks_file)
    if [ -f "$f" ]; then
        info "Disk baseline ($f):"
        baseline_read_disks | sed 's/^/    /'
    else
        warn "No disk baseline file yet (will be auto-created on first health run)."
    fi
    echo

    # --- Active problems ---
    step "Active problems (state DB)"
    if [ ! -f "${STATE_FILE:-/nonexistent}" ]; then
        info "No state file yet (daemon hasn't run, or state dir not writable)."
    else
        hashes=$(state_list_hashes)
        if [ -z "$hashes" ]; then
            ok "No active problems recorded."
        else
            printf '  %-6s  %-20s  %s\n' "SEV" "FIRST SEEN" "SUMMARY"
            printf '  %-6s  %-20s  %s\n' "---" "----------" "-------"
            for h in $hashes; do
                sev=$(state_field "$h" 2)
                first=$(state_field "$h" 3)
                summary=$(state_field "$h" 6)
                case "$sev" in
                    crit) col="$C_RED" ;;
                    warn) col="$C_YELLOW" ;;
                    *)    col="" ;;
                esac
                printf '  %s%-6s%s  %-20s  %s\n' \
                    "$col" "$sev" "$C_RESET" "${first%%+*}" "$summary"
            done
        fi
    fi
    echo

    # --- Pending grace timers ---
    step "Pending grace timers"
    pending_found=0
    # Use shell expansion with guard to handle the "no match" case.
    for f in "${STATE_DIR}"/pending-*; do
        [ -f "$f" ] || continue
        pending_found=1
        nm=$(basename "$f" | sed 's/^pending-//')
        ts=$(cat "$f" 2>/dev/null)
        if [ -n "$ts" ]; then
            elapsed=$(( $(date +%s) - ts ))
            printf '  MISSING  %-25s  elapsed %ss\n' "$nm" "$elapsed"
        fi
    done
    for f in "${STATE_DIR}"/seen-*; do
        [ -f "$f" ] || continue
        pending_found=1
        nm=$(basename "$f" | sed 's/^seen-//')
        ts=$(cat "$f" 2>/dev/null)
        if [ -n "$ts" ]; then
            elapsed=$(( $(date +%s) - ts ))
            printf '  PRESENT  %-25s  elapsed %ss (auto-baseline pending)\n' "$nm" "$elapsed"
        fi
    done
    [ "$pending_found" = "0" ] && ok "No pending timers."
    echo

    # --- SMART polling ---
    step "SMART polling"
    if ! command -v smartctl >/dev/null 2>&1; then
        errmsg "smartctl is NOT INSTALLED - SMART checks are DISABLED."
        errmsg "  No temperature / sector / health monitoring is happening."
        errmsg "  Install with:  brew install smartmontools"
    else
        ok "smartctl is available: $(command -v smartctl)"
        f=$(smart_last_run_file)
        if [ -f "$f" ]; then
            last=$(cat "$f" 2>/dev/null)
            if [ -n "$last" ]; then
                ago=$(( $(date +%s) - last ))
                info "Last SMART poll:  $(date -r "$last" '+%Y-%m-%d %H:%M:%S')  (${ago}s ago)"
                info "Next scheduled:   every ${SMART_POLL_INTERVAL}s ($(format_duration "$SMART_POLL_INTERVAL"))"
            fi
        else
            info "SMART has not run yet."
        fi
    fi
    echo

    # --- SoftRAID status (informational) ---
    step "SoftRAID presence"
    if softraid_extension_loaded; then
        warn "SoftRAID system extension / kext is loaded."
    else
        ok "No SoftRAID extension / kext detected."
    fi
    sr=$(list_softraid_disks)
    if [ -n "$sr" ]; then
        warn "SoftRAID member disks still present:"
        echo "$sr" | sed 's|^|    /dev/|'
    else
        ok "No SoftRAID member disks detected."
    fi
}

# ======================================================================
# SMART USB/Thunderbolt bridge-type auto-detection with per-disk cache
# ======================================================================
# smartctl on macOS needs '-d <type>' for many USB/Thunderbolt bridges.
# Wrong type = empty/meaningless output. We probe the common types and
# cache the working value per (disk, drive-serial) pair, so a disk
# re-enumerating at a different /dev/diskN still uses its correct type
# but a different physical drive at the same diskN doesn't inherit a
# stale cached value.
#
# Cache file: $STATE_DIR/smart-dtype-cache
# Format:    diskN|serial-hash|dtype
# Values:    'native' | 'sat' | 'usbjmicron' | 'usbprolific' | 'usbsunplus' | 'nvme'
# ----------------------------------------------------------------------

smart_cache_file() { echo "${STATE_DIR}/smart-dtype-cache"; }

# Resolve a disk's stable identifier for use as "serial". Behavior
# depends on disk type:
#
#   Physical disks: tries, in order:
#     1. `diskutil info`   'Media Serial Number'     (macOS 11+)
#     2. `diskutil info`   'Device / Media Serial'   (some variants)
#     3. `smartctl -i`     'Serial Number'           (always works if SMART works)
#
#   Virtual / synthesized disks: no physical serial exists. Returns:
#     1. AppleRAID Set UUID     (for AppleRAID virtual devices)
#     2. Disk / Partition UUID  (for APFS containers / synthesized disks)
#     3. Volume UUID            (last resort - less stable)
#
# Empty output only when nothing at all can be determined. Returning
# the UUID for virtuals means the SERIAL column always has SOMETHING
# meaningful in it - blank would be wasted screen real estate for what
# is in fact a perfectly good stable identifier.
#
# We NEVER return a physical disk's Volume UUID - that's a filesystem
# identifier, not a drive identifier, and would change if the volume
# is reformatted.
disk_serial() {
    dev="/dev/${1#/dev/}"

    info_out=$(diskutil info "$dev" 2>/dev/null) || return 0

    # --- Virtual / synthesized disks ---
    # These have no physical serial, but they DO have stable identifiers
    # that belong in the SERIAL column: the RAID set UUID for AppleRAID
    # virtual devices, or the container/partition UUID for APFS / other
    # synthesized disks. Prefer the most specific / stable one available.
    _virt=$(echo "$info_out" | awk -F': +' '/Virtual:/ {print $2; exit}')
    if [ "$_virt" = "Yes" ]; then
        # AppleRAID Set UUID is most specific for RAID virtual devices.
        s=$(echo "$info_out" | awk -F': +' '/AppleRAID Set UUID:/ {print $2; exit}')
        s=$(printf '%s' "$s" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        if [ -n "$s" ]; then
            printf '%s' "$s"
            return 0
        fi
        # APFS container / synthesized disk: use Disk/Partition UUID.
        s=$(echo "$info_out" | awk -F': +' '/Disk \/ Partition UUID:/ {print $2; exit}')
        s=$(printf '%s' "$s" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        if [ -n "$s" ]; then
            printf '%s' "$s"
            return 0
        fi
        # Last-ditch for virtuals: Volume UUID (less stable - changes if
        # the volume is recreated - but better than nothing for display).
        s=$(echo "$info_out" | awk -F': +' '/Volume UUID:/ {print $2; exit}')
        s=$(printf '%s' "$s" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        if [ -n "$s" ]; then
            printf '%s' "$s"
            return 0
        fi
        return 0
    fi

    # --- Physical disks ---
    # Try diskutil's 'Media Serial Number' field first.
    s=$(echo "$info_out" | awk -F': +' '/Media Serial Number:/ {print $2; exit}')
    s=$(printf '%s' "$s" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    if [ -n "$s" ]; then
        printf '%s' "$s"
        return 0
    fi

    # Some diskutil variants use 'Device / Media Serial' (rare).
    s=$(echo "$info_out" | awk -F': +' '/Device \/ Media Serial/ {print $2; exit}')
    s=$(printf '%s' "$s" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    if [ -n "$s" ]; then
        printf '%s' "$s"
        return 0
    fi

    # Fallback: ask smartctl directly. This is the most reliable source
    # on macOS for drives behind SATA / USB bridges where diskutil omits
    # the field.
    #
    # NOTE: we intentionally do NOT use smart_cmd() here - that function
    # would call smart_dtype_for() -> disk_serial_hash() -> disk_serial()
    # -> infinite recursion. Instead we try a small static list of -d
    # types directly. This is only used for the SERIAL column display
    # and for first-time cache priming, so simplicity beats optimality.
    if command -v smartctl >/dev/null 2>&1; then
        for _dt in "" "-d sat" "-d usbjmicron" "-d usbprolific" "-d nvme"; do
            # shellcheck disable=SC2086  # intentional word-split on _dt
            s=$(smartctl -i $_dt "$dev" </dev/null 2>/dev/null \
                | awk -F': +' '/^Serial Number:/ {print $2; exit}')
            s=$(printf '%s' "$s" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
            if [ -n "$s" ]; then
                printf '%s' "$s"
                return 0
            fi
        done
    fi

    # No serial available.
    return 0
}

# Stable short hash of a disk's serial number (first 16 chars of SHA1).
# If we can't get the serial, return 'unknown' - still cacheable but
# not drive-movement-stable.
disk_serial_hash() {
    serial=$(disk_serial "$1")
    if [ -z "$serial" ]; then
        echo "unknown"
    else
        printf '%s' "$serial" | shasum | awk '{print substr($1,1,16)}'
    fi
}

# Look up cached -d type for this disk+serial. Empty if not cached
# OR if the cache file is unreadable (silent miss; not an error).
smart_dtype_lookup() {
    disk="$1"; serial_hash="$2"
    _ensure_state_dir_writable
    f=$(smart_cache_file)
    [ -f "$f" ] && [ -r "$f" ] || return 0
    awk -F'|' -v d="$disk" -v s="$serial_hash" '
        /^#/ { next }
        $1 == d && $2 == s { print $3; exit }
    ' "$f" 2>/dev/null
}

# Store -d type in cache (replaces any prior entry for same disk+serial).
# Soft-fails (with a warning) when STATE_DIR is unwritable - the
# probe loop will just re-run on the next invocation, so a missing
# cache only costs a few smartctl probes, not correctness.
smart_dtype_store() {
    disk="$1"; serial_hash="$2"; dtype="$3"
    _ensure_state_dir_writable
    f=$(smart_cache_file)
    if [ ! -f "$f" ]; then
        if ! {
            echo "# appleRAID smartctl -d type cache"
            echo "# Format: disk|serial_hash|dtype"
        } > "$f" 2>/dev/null; then
            log_warn "smart-dtype-cache: cannot create $f - skipping cache write"
            return 0
        fi
    fi
    tmp=$(mktemp "${f}.XXXXXX" 2>/dev/null) \
        || err 012 "mktemp for smart-dtype-cache failed at ${f}.XXXXXX"
    if ! awk -F'|' -v d="$disk" -v s="$serial_hash" '
        /^#/ { print; next }
        !($1 == d && $2 == s) { print }
    ' "$f" > "$tmp" 2>/dev/null; then
        rm -f "$tmp"
        err 013 "smart-dtype-cache rewrite (awk) failed for $f"
    fi
    printf '%s|%s|%s\n' "$disk" "$serial_hash" "$dtype" >> "$tmp" \
        || err 013 "smart-dtype-cache: append of new row failed"
    mv "$tmp" "$f" \
        || err 013 "smart-dtype-cache: atomic rename ${tmp} -> ${f} failed"
}

# Probe smartctl with the given -d type. Returns 0 if smartctl was
# able to retrieve attributes (indicating the type is correct).
smart_dtype_probe() {
    dev="$1"; dtype="$2"
    case "$dtype" in
        native) out=$(smartctl -A "$dev" 2>/dev/null) ;;
        *)      out=$(smartctl -A -d "$dtype" "$dev" 2>/dev/null) ;;
    esac
    # A working probe returns the attribute table header.
    echo "$out" | grep -qE '^ID#.*ATTRIBUTE_NAME|^SMART Attributes' 2>/dev/null
}

# Determine the correct -d type for a disk, caching the result.
# Returns the dtype on stdout ('native' | 'sat' | 'usbjmicron' | ...).
# Empty output if no type works (disk doesn't support SMART).
smart_dtype_for() {
    d="$1"
    dev="/dev/$d"
    sh=$(disk_serial_hash "$d")

    cached=$(smart_dtype_lookup "$d" "$sh")
    if [ -n "$cached" ]; then
        echo "$cached"
        return 0
    fi

    log_debug "Probing smartctl -d types for $dev (serial=$sh)"
    for candidate in native sat usbjmicron usbprolific usbsunplus nvme; do
        if smart_dtype_probe "$dev" "$candidate"; then
            log_info "Cached smartctl type for $d: $candidate"
            smart_dtype_store "$d" "$sh" "$candidate"
            echo "$candidate"
            return 0
        fi
    done
    log_warn "No smartctl -d type works for $dev - SMART unavailable on this disk"
    smart_dtype_store "$d" "$sh" "none"
    echo ""
}

# Helper: build the `smartctl` command-line prefix for a disk, using
# the cached dtype. Example usage in a caller:
#   $(smart_cmd "$d") -H /dev/$d
smart_cmd() {
    d="$1"
    t=$(smart_dtype_for "$d")
    case "$t" in
        ""|none) echo "smartctl" ;;
        native)  echo "smartctl" ;;
        *)       echo "smartctl -d $t" ;;
    esac
}

# Compact one-line SMART summary for a single whole-disk identifier
# (e.g. "disk7"). Designed to be called inline from cmd_status's per-
# member loop so the user doesn't have to run `smart <disk>` separately
# for each mirror member.
#
# Output examples:
#   SMART: OK  temp=36C  POH=63685h  realloc=0  pending=0  uncorr=0  crc=0
#   SMART: unavailable (smartctl not installed)
#   SMART: unsupported on this enclosure
#
# Non-zero killer attributes (5/197/198/199) are highlighted in red so
# they jump out in a status table. The dtype probe is cached via
# smart_dtype_for, so subsequent calls on the same enclosure are fast.
smart_summary_line() {
    d="$1"
    [ -n "$d" ] || { echo "SMART: (no device)"; return; }
    if ! command -v smartctl >/dev/null 2>&1; then
        echo "SMART: unavailable (smartctl not installed)"; return
    fi
    if ! diskutil info "/dev/$d" >/dev/null 2>&1; then
        echo "SMART: unavailable (/dev/$d not present)"; return
    fi
    dtype=$(smart_dtype_for "$d")
    if [ -z "$dtype" ] || [ "$dtype" = "none" ]; then
        echo "SMART: unsupported on this enclosure"; return
    fi
    sc=$(smart_cmd "$d")

    health=$($sc -H "/dev/$d" 2>/dev/null | awk -F': *' '
        /SMART overall-health/ { print $2; exit }
        /SMART Health Status/  { print $2; exit }')
    health=$(echo "$health" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    case "$health" in
        PASSED|OK)  hd="${C_GREEN}OK${C_RESET}" ;;
        '')         hd="?" ;;
        *)          hd="${C_RED}${health}${C_RESET}" ;;
    esac

    attrs=$($sc -A "/dev/$d" 2>/dev/null)
    poh=$(echo "$attrs" | awk '
        /^[[:space:]]*9[[:space:]]+Power_On_Hours/ {print $10; exit}
        /^Power On Hours:/                          {v=$NF; gsub(/,/,"",v); print v; exit}')
    temp=$(echo "$attrs" | awk '/^[[:space:]]*(194|190)[[:space:]]+Temperature/ {print $10; exit}')
    realloc=$(echo "$attrs" | awk '/^[[:space:]]*5[[:space:]]+Reallocated_Sector/ {print $10; exit}')
    pending=$(echo "$attrs" | awk '/^[[:space:]]*197[[:space:]]+Current_Pending/ {print $10; exit}')
    uncorr=$(echo  "$attrs" | awk '/^[[:space:]]*198[[:space:]]+Offline_Uncorr/  {print $10; exit}')
    crc=$(echo     "$attrs" | awk '/^[[:space:]]*199[[:space:]]+UDMA_CRC/        {print $10; exit}')

    fmt_kill() {
        # $1=label, $2=value (string). Empty => "?"; "0" => plain; non-zero => red.
        case "${2:-}" in
            "")    printf '%s=?' "$1" ;;
            0)     printf '%s=0' "$1" ;;
            *)     printf '%s%s=%s%s' "${C_RED}" "$1" "$2" "${C_RESET}" ;;
        esac
    }

    out="SMART: $hd"
    [ -n "$temp" ] && out="$out  temp=${temp}C"
    if [ -n "$poh" ]; then
        # POH (Power_On_Hours) is the canonical raw attribute; we
        # show it as both the raw value and a years-rounded AGE so
        # the user can read 'how old is this drive' at a glance
        # without doing the /8760 division in their head.
        age_y=$(awk -v h="$poh" 'BEGIN { printf "%.1f", h / 8760 }')
        out="$out  POH=${poh}h  age=${age_y}y"
    fi
    out="$out  $(fmt_kill realloc "$realloc")"
    out="$out  $(fmt_kill pending "$pending")"
    out="$out  $(fmt_kill uncorr  "$uncorr")"
    out="$out  $(fmt_kill crc     "$crc")"
    echo "$out"
}

# ----------------------------------------------------------------------
# SMART drill-down: print a comprehensive per-disk health readout.
# Used by `cmd_smart` (interactive standalone) and `cmd_health --disk`
# (drill-down mode of the daemon command). Read-only.
#
# Sections:
#   1. Overall health        (smartctl -H)
#   2. Pre-failure attrs     (smartctl -A) + non-zero "killer" highlight
#   3. Self-test log         (smartctl -l selftest)
#   4. Error log             (smartctl -l error)
#
# Argument: short disk name (e.g. "disk3"), no /dev/ prefix.
# Returns 0 on clean run, 1 if smartctl/diskutil cannot inspect the disk.
# ----------------------------------------------------------------------
_smart_drilldown_one() {
    d="$1"
    dev="/dev/$d"

    if ! command -v smartctl >/dev/null 2>&1; then
        die "smartctl not installed.  Fix:  brew install smartmontools"
    fi
    if ! diskutil info "$dev" >/dev/null 2>&1; then
        die "Device not found: $dev"
    fi

    # smart_dtype_for writes a cache file under $STATE_DIR. STATE_DIR is
    # only populated by cfg_load (or state_init's fallback), which the
    # daemon path always runs but our standalone callers (cmd_smart,
    # cmd_health --disk) do not. Load the config first, then ensure the
    # dir exists - falling back to /tmp if the configured location isn't
    # writable (avoids the empty-path 'cannot create' from mktemp).
    cfg_load
    if [ -z "${STATE_DIR:-}" ]; then
        STATE_DIR="/var/db/my-appleRAID"
    fi
    if ! mkdir -p "$STATE_DIR" 2>/dev/null; then
        STATE_DIR="/tmp/my-appleRAID"
        mkdir -p "$STATE_DIR" 2>/dev/null || true
    fi

    virt=$(diskutil info "$dev" 2>/dev/null | awk -F': *' '/Virtual:/ {print $2; exit}')
    if [ "$virt" = "Yes" ]; then
        die "$dev is a VIRTUAL device (RAID/APFS container) - has no SMART data of its own."
    fi

    # Resolve / cache the right -d type for this enclosure.
    dtype=$(smart_dtype_for "$d")
    if [ -z "$dtype" ] || [ "$dtype" = "none" ]; then
        die "$dev does not respond to SMART (no working -d type for this enclosure)."
    fi
    sc=$(smart_cmd "$d")

    # Header
    model=$(diskutil info "$dev" 2>/dev/null | awk -F': +' '/Device \/ Media Name:/ {print $2; exit}')
    [ -z "$model" ] && model=$(diskutil info "$dev" 2>/dev/null | awk -F': +' '/Media Name:/ {print $2; exit}')
    serial=$(disk_serial "$d")
    size=$(diskutil info "$dev" 2>/dev/null | awk -F': +' '
        /Disk Size:/  {print $2; exit}
        /Total Size:/ {print $2; exit}' | sed 's/ *(.*)//; s/[[:space:]]*$//')
    proto=$(diskutil info "$dev" 2>/dev/null | awk -F': +' '/Protocol:/ {print $2; exit}')

    step "SMART drill-down: $dev"
    printf '  %-10s %s\n' "Model:"    "${model:-?}"
    printf '  %-10s %s\n' "Serial:"   "${serial:-?}"
    printf '  %-10s %s\n' "Size:"     "${size:-?}"
    printf '  %-10s %s\n' "Protocol:" "${proto:-?}"
    printf '  %-10s %s\n' "Probe:"    "$sc"
    echo

    # 1. Overall health
    step "1/4: Overall health  (smartctl -H)"
    health_raw=$($sc -H "$dev" 2>/dev/null | awk -F': *' '
        /SMART overall-health/ {print $2; exit}
        /SMART Health Status/   {print $2; exit}')
    health_raw=$(echo "$health_raw" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    case "$health_raw" in
        PASSED|OK)  ok "Overall health: $health_raw" ;;
        '')         warn "Overall health: not reported by drive" ;;
        *)          err "Overall health: $health_raw" ;;
    esac
    echo

    # 2. Pre-failure attributes (full table + non-zero killer summary)
    step "2/4: Pre-failure attributes  (smartctl -A)"
    explain "Watch the RAW_VALUE column. Non-zero on these IDs is a red flag:"
    explain "  5 Reallocated  187 Reported_Uncorrect  197 Pending  198 Offline_Uncorrectable  199 UDMA_CRC"
    echo
    attrs=$($sc -A "$dev" 2>/dev/null)

    # Current Power_On_Hours - sections 3/4 use this to translate each
    # log entry's LifeTime(hours) into "X ago" + an approximate date.
    # Empty if the drive doesn't expose POH (rare).
    poh=$(echo "$attrs" | awk '
        /^[[:space:]]*9[[:space:]]+Power_On_Hours/ { print $10; exit }
        /^Power On Hours:/ { v=$NF; gsub(/,/, "", v); print v; exit }')

    if [ -z "$attrs" ]; then
        warn "Could not read SMART attributes."
    else
        echo "$attrs" | sed 's/^/  /'
        echo

        # ATA killers: numeric IDs 5/187/197/198/199 with non-zero RAW.
        ata_nonzero=$(echo "$attrs" | awk '
            /^[[:space:]]*(5|187|197|198|199)[[:space:]]+[A-Za-z]/ {
                if ($10+0 > 0) printf "    %3d %-26s RAW=%s\n", $1, $2, $10
            }')

        # NVMe critical fields.
        nvme_warn=$(echo "$attrs" | awk -F': *' '
            /Critical Warning/         { v=$2; gsub(/^ +| +$/,"",v); if (v != "" && v != "0x00") printf "    %s = %s\n", $1, v }
            /Media and Data Integrity/ { v=$2; gsub(/^ +| +$/,"",v); if (v+0 > 0) printf "    %s = %s\n", $1, v }
            /Unsafe Shutdowns/         { v=$2; gsub(/^ +| +$/,"",v); if (v+0 > 0) printf "    %s = %s\n", $1, v }
            /Available Spare:/         { v=$2; gsub(/^ +| +$/,"",v); n=v; gsub(/%/,"",n); if (n+0 < 100 && n != "") printf "    %s = %s\n", $1, v }')

        if [ -n "$ata_nonzero" ] || [ -n "$nvme_warn" ]; then
            errmsg "Pre-failure indicator(s) found:"
            [ -n "$ata_nonzero" ] && printf '%s\n' "$ata_nonzero"
            [ -n "$nvme_warn"   ] && printf '%s\n' "$nvme_warn"
        else
            ok "No pre-failure indicators (ATA killers / NVMe critical fields all clean)."
        fi
    fi
    echo

    # 3. Self-test log
    step "3/4: Self-test log  (smartctl -l selftest)"
    selftest=$($sc -l selftest "$dev" 2>/dev/null)
    if [ -z "$selftest" ]; then
        warn "Self-test log unreadable (some USB bridges hide it)."
    elif echo "$selftest" | grep -qE 'No self-tests have been logged|No Self-tests Logged'; then
        info "No self-tests have been logged on this drive yet."
        explain "Run one with:  sudo $sc -t short $dev    (~2 min)"
        explain "             or sudo $sc -t long  $dev    (hours, full surface)"
    else
        if [ -n "$poh" ]; then
            explain "Current Power_On_Hours: $poh - the AGE_AGO / APPROX_DATE columns are"
            explain "computed as (POH - LifeTime). Calendar-accurate when the drive is"
            explain "roughly always-on; underestimates the more the drive sleeps."
            echo
        else
            warn "Could not read Power_On_Hours - showing raw LifeTime only."
            echo
        fi
        echo "$selftest" \
          | sed -n '/Num.*Test_Description/,/^$/p' \
          | awk -v poh="$poh" '
            function age_label(d) {
                if (poh == "" || d == "" || d+0 < 0)  return "?"
                if (d < 72)         return d "h"
                if (d < 14*24)      return int(d/24) "d"
                if (d < 8*7*24)     return int(d/(7*24)) "w"
                if (d < 365*24)     return int(d/(30*24)) "mo"
                return sprintf("%.1fy", d/(365*24))
            }
            function age_date(d,    cmd, out) {
                if (poh == "" || d == "" || d+0 < 0)  return "?"
                cmd = "date -v -" d "H +%Y-%m-%d 2>/dev/null"
                out = "?"
                cmd | getline out
                close(cmd)
                if (out == "") out = "?"
                return out
            }
            /Num.*Test_Description.*LifeTime/ {
                gsub(/[[:space:]]+$/, "", $0)
                printf "  %s  %-7s  %s\n", $0, "AGE_AGO", "APPROX_DATE"
                next
            }
            /^# *[0-9]+/ {
                gsub(/[[:space:]]+$/, "", $0)
                lt = $(NF-1)
                if (lt ~ /^[0-9]+$/ && poh != "" && (poh+0) >= (lt+0)) {
                    d = poh - lt
                    printf "  %s  %-7s  %s\n", $0, age_label(d), age_date(d)
                } else {
                    printf "  %s  %-7s  %s\n", $0, "?", "?"
                }
                next
            }
            { print "  " $0 }
        '
        if echo "$selftest" | grep -qE 'Failed|Aborted_by_host|Interrupted|Completed: read failure'; then
            warn "Past self-test failure(s) above. LBA_of_first_error points to the bad sector."
        else
            ok "All logged self-tests completed without error."
        fi
    fi
    echo

    # 4. Error log (firmware-recorded uncorrectable errors)
    step "4/4: SMART error log  (smartctl -l error)"
    elog=$($sc -l error "$dev" 2>/dev/null)
    if [ -z "$elog" ]; then
        warn "Error log unreadable (some USB bridges hide it)."
    elif echo "$elog" | grep -qE 'No Errors Logged|No errors logged'; then
        ok "Error count: 0  (firmware has logged no errors)"
    else
        ec=$(echo "$elog" | awk -F': *' '
            /Error [Cc]ount:/         { print $2; exit }
            /Device Error Count:/     { print $2; exit }')
        ec=$(echo "$ec" | awk '{print $1}')
        if [ -n "$ec" ] && [ "$ec" = "0" ]; then
            ok "Error count: 0"
        elif [ -n "$ec" ]; then
            errmsg "Error count: $ec  (firmware-recorded errors - inspect below)"
            echo
            if [ -n "$poh" ]; then
                explain "Each 'power-on lifetime: N hours' line is annotated with how long ago"
                explain "that error happened (current Power_On_Hours: $poh)."
                echo
            fi
            echo "$elog" \
              | awk '/^Error [0-9]+/,/^$/' \
              | awk -v poh="$poh" '
                function age_label(d) {
                    if (poh == "" || d == "" || d+0 < 0)  return "?"
                    if (d < 72)         return d "h"
                    if (d < 14*24)      return int(d/24) "d"
                    if (d < 8*7*24)     return int(d/(7*24)) "w"
                    if (d < 365*24)     return int(d/(30*24)) "mo"
                    return sprintf("%.1fy", d/(365*24))
                }
                function age_date(d,    cmd, out) {
                    if (poh == "" || d == "" || d+0 < 0)  return "?"
                    cmd = "date -v -" d "H +%Y-%m-%d 2>/dev/null"
                    out = "?"
                    cmd | getline out
                    close(cmd)
                    if (out == "") out = "?"
                    return out
                }
                /lifetime: [0-9]+ hours/ {
                    if (match($0, /lifetime: [0-9]+ hours/)) {
                        seg = substr($0, RSTART, RLENGTH)
                        gsub(/[^0-9]/, "", seg)
                        lt = seg+0
                        if (poh != "" && lt > 0 && (poh+0) >= lt) {
                            d = (poh+0) - lt
                            print $0 "    -> ~" age_label(d) " ago / " age_date(d)
                            next
                        }
                    }
                    print
                    next
                }
                { print }
              ' | sed 's/^/  /' | head -120
        else
            warn "Could not parse error count - raw output:"
            echo "$elog" | sed 's/^/  /' | head -40
        fi
    fi
    echo

    # ------------------------------------------------------------------
    # Summary highlights. Mirrors the priority logic used by the 2-drive
    # comparison (_smart_compare_two), but reduced to a single-drive
    # verdict: HEALTHY / WATCH / RETIRE-CANDIDATE. Reuses $health_raw,
    # $attrs, $selftest, $elog, $poh already collected above.
    # ------------------------------------------------------------------
    step "Summary"

    # Helper: extract raw value of a numeric ATA attribute id from $attrs.
    _attr_raw_one() {
        echo "$attrs" | awk -v id="$1" '
            $1+0 == id+0 && $2 ~ /^[A-Za-z]/ { print $10; exit }'
    }

    # Age in years from POH (8766 h/y).
    age_y=""
    if [ -n "$poh" ] && [ "$poh" -gt 0 ] 2>/dev/null; then
        age_y=$(awk -v h="$poh" 'BEGIN { printf "%.1f", h/8766 }')
    fi

    # Killer attrs.
    s5=$(_attr_raw_one 5)
    s187=$(_attr_raw_one 187)
    s197=$(_attr_raw_one 197)
    s198=$(_attr_raw_one 198)
    s199=$(_attr_raw_one 199)
    s22=$(_attr_raw_one 22)

    # Self-test status: count + last result.
    st_count=0
    st_last=""
    st_failed=0
    if [ -n "$selftest" ] && ! echo "$selftest" | grep -qE 'No self-tests have been logged|No Self-tests Logged'; then
        st_count=$(echo "$selftest" | awk '/^# *[0-9]+/' | wc -l | awk '{print $1}')
        st_last=$(echo "$selftest" | awk '
            /^# *[0-9]+/ {
                line=$0
                # Status field is everything between Test_Description and Remaining
                # but smartctl prints fixed columns; field 5 ("Status") is reliable.
                gsub(/[[:space:]]+$/, "", line)
                print line
                exit
            }')
        if echo "$selftest" | grep -qE 'Failed|Completed: read failure|Completed: unknown failure|Completed: servo'; then
            st_failed=1
        fi
    fi

    # Error log count.
    err_n=""
    if [ -n "$elog" ] && ! echo "$elog" | grep -qE 'No Errors Logged|No errors logged'; then
        err_n=$(echo "$elog" | awk -F': *' '
            /Error [Cc]ount:/         { print $2; exit }
            /Device Error Count:/     { print $2; exit }' | awk '{print $1}')
    fi

    # Render highlights.
    printf '  %-22s %s\n' "Overall health:"  "${health_raw:-?}"
    if [ -n "$age_y" ]; then
        printf '  %-22s %s years  (POH=%sh)\n' "Age:" "$age_y" "$poh"
    fi
    if [ -n "$s5$s187$s197$s198" ]; then
        printf '  %-22s (any non-zero raw value = drive-level damage)\n' \
            "Killer attrs:"
        printf '    %-30s = %s\n'  "5   Reallocated_Sector_Ct"   "${s5:-?}"
        printf '    %-30s = %s\n'  "187 Reported_Uncorrect"      "${s187:-?}"
        printf '    %-30s = %s\n'  "197 Current_Pending_Sector"  "${s197:-?}"
        printf '    %-30s = %s\n'  "198 Offline_Uncorrectable"   "${s198:-?}"
    fi
    if [ -n "$s199" ]; then
        printf '  %-22s %s  (199 UDMA_CRC_Error_Count - cable/port noise, not a drive defect on its own)\n' \
            "UDMA_CRC:" "$s199"
    fi
    if [ -n "$s22" ] && [ "$s22" -gt 0 ] 2>/dev/null; then
        printf '  %-22s %s  (22 Helium_Level - 100=full, drops as gas escapes; <95 = retire)\n' \
            "Helium:" "$s22"
    fi
    if [ "$st_count" -gt 0 ] 2>/dev/null; then
        printf '  %-22s %s recorded; last: %s\n' \
            "Self-tests:" "$st_count" "${st_last:-?}"
    else
        printf '  %-22s none recorded yet\n' "Self-tests:"
    fi
    if [ -n "$err_n" ]; then
        printf '  %-22s %s\n' "Error log:" "$err_n"
    else
        printf '  %-22s 0\n' "Error log:"
    fi
    echo

    # Verdict logic (single drive). Priority matches _smart_compare_two.
    verdict_level=""   # "" / WATCH / RETIRE
    verdict_reason=""

    case "$health_raw" in
        PASSED|OK|"") :;;
        *) verdict_level="RETIRE"; verdict_reason="overall health '$health_raw' is not PASSED" ;;
    esac

    if [ -z "$verdict_level" ] && [ "$st_failed" = "1" ]; then
        verdict_level="RETIRE"
        verdict_reason="self-test failure recorded - real surface fault"
    fi

    if [ -z "$verdict_level" ]; then
        for v in "$s5" "$s197" "$s198"; do
            if [ -n "$v" ] && [ "$v" -gt 0 ] 2>/dev/null; then
                verdict_level="RETIRE"
                verdict_reason="killer attribute non-zero (5=${s5:-0} 197=${s197:-0} 198=${s198:-0}) - sector damage"
                break
            fi
        done
    fi

    if [ -z "$verdict_level" ] && [ -n "$err_n" ] && [ "$err_n" -gt 0 ] 2>/dev/null; then
        verdict_level="WATCH"
        verdict_reason="firmware-recorded error count = $err_n - inspect section 4 above"
    fi

    if [ -z "$verdict_level" ] && [ -n "$s187" ] && [ "$s187" -gt 0 ] 2>/dev/null; then
        verdict_level="WATCH"
        verdict_reason="Reported_Uncorrect (187) = $s187 - drive saw uncorrectable reads"
    fi

    if [ -z "$verdict_level" ] && [ -n "$s199" ] && [ "$s199" -gt 0 ] 2>/dev/null; then
        verdict_level="WATCH"
        verdict_reason="UDMA_CRC (199) = $s199 - check SATA cable / port (not a drive defect on its own)"
    fi

    if [ -z "$verdict_level" ] && [ -n "$age_y" ]; then
        # >7 years: WATCH; >10 years: still WATCH but stronger phrasing.
        age_int=${age_y%.*}
        if [ "$age_int" -ge 10 ] 2>/dev/null; then
            verdict_level="WATCH"
            verdict_reason="drive is ${age_y} years old - well past typical lifetime, plan replacement"
        elif [ "$age_int" -ge 7 ] 2>/dev/null; then
            verdict_level="WATCH"
            verdict_reason="drive is ${age_y} years old - approaching end of typical lifetime"
        fi
    fi

    if [ "$st_count" = "0" ]; then
        if [ -z "$verdict_level" ]; then
            verdict_level="WATCH"
            verdict_reason="no self-tests recorded - run 'sudo $sc -t short $dev' to populate the log"
        else
            verdict_reason="$verdict_reason; also: no self-tests recorded yet"
        fi
    fi

    case "$verdict_level" in
        RETIRE) errmsg "VERDICT: RETIRE-CANDIDATE - $verdict_reason" ;;
        WATCH)  warn   "VERDICT: WATCH - $verdict_reason" ;;
        *)      ok     "VERDICT: HEALTHY - no concerning indicators across health, killers, self-tests, error log, age." ;;
    esac
    echo

    step "Run a fresh self-test"
    explain "Short test:  sudo $sc -t short $dev   (~2 min, online; quick electronics + media sample)"
    explain "Long  test:  sudo $sc -t long  $dev   (hours, full surface scan)"
    explain "Results land in 'smart $d' section 3/4 once the test completes."
}

# ----------------------------------------------------------------------
# Side-by-side SMART comparison of two physical disks. Designed to
# answer 'which one would you discard'. Renders a per-attribute table,
# computes deltas, highlights the discriminating signals (the four
# 'killer' attributes 5/197/198/199; load-cycle wear; helium level;
# SMART overall-health), and ends with a one-line verdict.
#
# Methodology - a drive is the loser if ANY of these is true, in
# order of priority:
#   1) Overall health != PASSED
#   2) Any killer attribute (5/197/198/199) raw value > 0
#   3) Helium level (22) significantly lower
#   4) Load-cycle count (193) significantly higher (>= 20% delta)
#   5) Power-on-hours (9) significantly higher (>= 20% delta)
# Otherwise: 'no clear loser'.
# ----------------------------------------------------------------------
_smart_compare_two() {
    bsd_a="$1"; bsd_b="$2"
    devA="/dev/$bsd_a"
    devB="/dev/$bsd_b"

    if ! command -v smartctl >/dev/null 2>&1; then
        die "smartctl not installed.  Fix:  brew install smartmontools"
    fi
    diskutil info "$devA" >/dev/null 2>&1 || die "Device not found: $devA"
    diskutil info "$devB" >/dev/null 2>&1 || die "Device not found: $devB"

    cfg_load
    _ensure_state_dir_writable

    # Resolve smartctl command + dtype per disk.
    scA=$(smart_cmd "$bsd_a")
    scB=$(smart_cmd "$bsd_b")
    [ "$scA" = "smartctl" ] && [ -z "$(smart_dtype_for "$bsd_a")" ] \
        && die "/dev/$bsd_a does not respond to SMART (no working -d type)."
    [ "$scB" = "smartctl" ] && [ -z "$(smart_dtype_for "$bsd_b")" ] \
        && die "/dev/$bsd_b does not respond to SMART (no working -d type)."

    # Capture raw smartctl outputs.
    infoA=$($scA -i "$devA" 2>/dev/null)
    infoB=$($scB -i "$devB" 2>/dev/null)
    healthA_raw=$($scA -H "$devA" 2>/dev/null)
    healthB_raw=$($scB -H "$devB" 2>/dev/null)
    attrA=$($scA -A "$devA" 2>/dev/null)
    attrB=$($scB -A "$devB" 2>/dev/null)
    # SMART self-test log + error log are firmware-resident on the
    # drive itself - no external storage required. We pull them once
    # here and parse below; counts/last-result feed comparison rows.
    selftestA=$($scA -l selftest "$devA" 2>/dev/null)
    selftestB=$($scB -l selftest "$devB" 2>/dev/null)
    errlogA=$($scA -l error "$devA" 2>/dev/null)
    errlogB=$($scB -l error "$devB" 2>/dev/null)

    # Helpers for parsing.
    _info_field() {
        # $1 = info dump, $2 = label substring (e.g. "Device Model")
        echo "$1" | awk -F': *' -v lbl="$2" 'index($1, lbl) {
            sub(/^[[:space:]]+/, "", $2); sub(/[[:space:]]+$/, "", $2); print $2; exit
        }'
    }
    _attr_raw() {
        # $1 = attr dump, $2 = numeric attribute id
        # Returns the RAW_VALUE column (first numeric token in the
        # smartctl raw column). Empty if id is not present.
        echo "$1" | awk -v id="$2" '$1 == id {
            # raw is column 10 in the standard layout, but the value
            # may include a parenthesized note (e.g. "35 (Min/Max ...)").
            # Take the first numeric token.
            for (i = 10; i <= NF; i++) {
                if (match($i, /^[0-9]+$/)) { print $i; exit }
            }
            exit
        }'
    }
    _health_word() {
        # $1 = health dump
        echo "$1" | awk -F': *' '
            /SMART overall-health/ { print $NF; exit }
            /SMART Health Status/  { print $NF; exit }
        '
    }

    # Identity.
    modelA=$(_info_field "$infoA" "Device Model")
    [ -z "$modelA" ] && modelA=$(_info_field "$infoA" "Model Family")
    modelB=$(_info_field "$infoB" "Device Model")
    [ -z "$modelB" ] && modelB=$(_info_field "$infoB" "Model Family")
    serialA=$(_info_field "$infoA" "Serial Number")
    serialB=$(_info_field "$infoB" "Serial Number")
    healthA=$(_health_word "$healthA_raw"); healthA=${healthA:-?}
    healthB=$(_health_word "$healthB_raw"); healthB=${healthB:-?}

    step "SMART comparison: $devA  vs  $devB"
    info "Drive A: ${modelA:-?}  serial=${serialA:-?}  $devA"
    info "Drive B: ${modelB:-?}  serial=${serialB:-?}  $devB"

    # Age - read from attr 9. Used both for the in-table age row
    # AND by the verdict logic later, so compute here.
    pohA=$(_attr_raw "$attrA" 9)
    pohB=$(_attr_raw "$attrB" 9)
    ageA_y=""; ageB_y=""
    if [ -n "$pohA" ]; then
        ageA_y=$(awk -v h="$pohA" 'BEGIN { printf "%.2f", h / 8760 }')
    fi
    if [ -n "$pohB" ]; then
        ageB_y=$(awk -v h="$pohB" 'BEGIN { printf "%.2f", h / 8760 }')
    fi

    echo
    # Pre-header line: print the actual bsd names (e.g. 'disk7' /
    # 'disk8') directly above the 'Drive A' / 'Drive B' label columns,
    # so the user can see at a glance which physical disk each column
    # refers to without scrolling back up to the header block.
    printf '%-4s %-25s %12s %12s\n' \
        "" "" "$bsd_a" "$bsd_b"
    printf '%s%-4s %-25s %12s %12s   %s%s\n' \
        "${C_BOLD}" "ID" "Attribute" "Drive A" "Drive B" "Delta / note" "${C_RESET}"

    # Per-attribute rows. Format:
    #   ID  Name                       Drive A   Drive B    delta / note
    _row() {
        # $1 id, $2 label, $3 a, $4 b, $5 note
        printf '%-4s %-25s %12s %12s   %s\n' "$1" "$2" "${3:-?}" "${4:-?}" "$5"
    }

    # Top two rows: not actual SMART attributes, but values the user
    # always wants to see at the top of the comparison. ID column
    # uses '-' to flag them as derived/synthetic.
    health_note="ok (both)"
    case "$healthA" in PASSED|OK|"") :;; *)
        case "$healthB" in PASSED|OK|"") health_note="A '$healthA' - DISCARD A" ;;
                            *)            health_note="BOTH not PASSED" ;; esac ;;
    esac
    case "$healthB" in PASSED|OK|"") :;; *)
        case "$healthA" in PASSED|OK|"") health_note="B '$healthB' - DISCARD B" ;;
                            *)            health_note="BOTH not PASSED" ;; esac ;;
    esac
    _row "-" "Overall health" "$healthA" "$healthB" "$health_note"

    # Age (years) row. Delta computed from POH (more precision than
    # rounded years), but displayed as years for human readability.
    age_note=""
    if [ -n "$pohA" ] && [ -n "$pohB" ] \
       && [ "$pohA" -gt 0 ] 2>/dev/null && [ "$pohB" -gt 0 ] 2>/dev/null; then
        if [ "$pohA" -ge "$pohB" ]; then
            d=$(awk -v hi="$pohA" -v lo="$pohB" 'BEGIN { printf "%.0f", (hi - lo) * 100 / lo }')
            age_higher="A"
        else
            d=$(awk -v hi="$pohB" -v lo="$pohA" 'BEGIN { printf "%.0f", (hi - lo) * 100 / lo }')
            age_higher="B"
        fi
        if [ "$d" -ge 5 ] 2>/dev/null; then
            age_note="$age_higher older by ${d}%"
        else
            age_note="similar age"
        fi
    fi
    _row "-" "Age (years)" "${ageA_y:+${ageA_y}y}" "${ageB_y:+${ageB_y}y}" "$age_note"

    # ---- Error log + self-test log (firmware-resident) ----
    #
    # The drive's own firmware keeps two persistent logs that survive
    # reboots and travel with the disk:
    #   - error log    (smartctl -l error)    - actual command failures
    #   - self-test log (smartctl -l selftest) - results of every short
    #                                            and long self-test
    #
    # 'health' fires a long self-test weekly per SELFTEST_LONG_SCHEDULE,
    # so on a normally-monitored host these logs are populated and very
    # useful for the comparison: a drive with a 'Completed: read failure'
    # in its self-test log is a stronger discard signal than any
    # threshold delta on an attribute.
    #
    # Parse:
    #   _errlog_count(text) -> total errors recorded ('No Errors Logged'
    #                          maps to 0)
    #   _selftest_count(text) -> number of completed (any kind) entries
    #   _selftest_last(text) -> status of the most recent entry, e.g.
    #                          'Completed without error' or 'Completed:
    #                          read failure'
    _errlog_count() {
        # Look for either 'No Errors Logged' (-> 0) or
        # 'ATA Error Count: N' (-> N).
        echo "$1" | awk '
            /No Errors Logged/        { print 0; exit }
            /ATA Error Count:/        { for (i = 1; i <= NF; i++) if (match($i, /^[0-9]+$/)) { print $i; exit } exit }
            /Error logging capability:.*disabled/ { print "n/a"; exit }
        '
    }
    _selftest_count() {
        # Number of '# N  Description ...' rows.
        echo "$1" | awk '/^# +[0-9]+ +/ { c++ } END { print c+0 }'
    }
    _selftest_last() {
        # First entry under the header is the MOST RECENT (smartctl
        # prints them newest-first). Status is a multi-word column
        # between the description and the percentage-remaining.
        # Capture the whole line, then extract the status piece.
        echo "$1" | awk '
            /^# +1 +/ {
                # Drop "# N" and the description (1 or 2 words like
                # "Short offline" / "Extended offline" / "Conveyance
                # offline"). Easier to take the whole line and strip
                # the prefix + percentage onward.
                line = $0
                sub(/^# +[0-9]+ +(Short|Extended|Conveyance|Selective)( offline| captive)? +/, "", line)
                # Now line starts with the status (multi-word) and ends
                # with "  XX% LIFETIME LBA". Strip from the percentage
                # onward.
                sub(/[[:space:]]+[0-9]+% .*/, "", line)
                # Trim trailing whitespace.
                sub(/[[:space:]]+$/, "", line)
                print line
                exit
            }'
    }
    errA_n=$(_errlog_count "$errlogA")
    errB_n=$(_errlog_count "$errlogB")
    stcA_n=$(_selftest_count "$selftestA")
    stcB_n=$(_selftest_count "$selftestB")
    stlA=$(_selftest_last "$selftestA")
    stlB=$(_selftest_last "$selftestB")

    # Error-log row.
    err_note=""
    case "${errA_n:-?}" in
        0|n/a|"") a_err_bad=0 ;;
        *)
            if [ "$errA_n" -gt 0 ] 2>/dev/null; then a_err_bad=1; else a_err_bad=0; fi ;;
    esac
    case "${errB_n:-?}" in
        0|n/a|"") b_err_bad=0 ;;
        *)
            if [ "$errB_n" -gt 0 ] 2>/dev/null; then b_err_bad=1; else b_err_bad=0; fi ;;
    esac
    if [ "$a_err_bad" = "1" ] && [ "$b_err_bad" = "0" ]; then err_note="A has logged errors - DISCARD A"
    elif [ "$b_err_bad" = "1" ] && [ "$a_err_bad" = "0" ]; then err_note="B has logged errors - DISCARD B"
    elif [ "$a_err_bad" = "1" ] && [ "$b_err_bad" = "1" ]; then err_note="BOTH have logged errors"
    else err_note="ok (both)"
    fi
    _row "-" "Error log entries" "${errA_n:-?}" "${errB_n:-?}" "$err_note"

    # Self-test log rows: count + last result.
    _row "-" "Self-tests recorded" "${stcA_n:-0}" "${stcB_n:-0}" ""
    st_note=""
    case "$stlA" in
        ""|"-"|"Completed without error") a_st_bad=0 ;;
        *Aborted*|*"in progress"*)        a_st_bad=0 ;;
        *)                                a_st_bad=1 ;;
    esac
    case "$stlB" in
        ""|"-"|"Completed without error") b_st_bad=0 ;;
        *Aborted*|*"in progress"*)        b_st_bad=0 ;;
        *)                                b_st_bad=1 ;;
    esac
    if [ "$a_st_bad" = "1" ] && [ "$b_st_bad" = "0" ]; then st_note="A failure - DISCARD A"
    elif [ "$b_st_bad" = "1" ] && [ "$a_st_bad" = "0" ]; then st_note="B failure - DISCARD B"
    elif [ "$a_st_bad" = "1" ] && [ "$b_st_bad" = "1" ]; then st_note="BOTH failures"
    fi
    _row "-" "Last self-test" "${stlA:--}" "${stlB:--}" "$st_note"

    # Killer attributes - the three that genuinely point at drive
    # failure when non-zero: reallocated sectors, current pending,
    # offline uncorrectable. ANY non-zero == discard that drive.
    for spec in '5:Reallocated_Sector_Ct' \
                '197:Current_Pending_Sector' \
                '198:Offline_Uncorrectable'; do
        id=${spec%%:*}; name=${spec#*:}
        a=$(_attr_raw "$attrA" "$id")
        b=$(_attr_raw "$attrB" "$id")
        a_bad=0; b_bad=0
        [ -n "$a" ] && [ "$a" -gt 0 ] 2>/dev/null && a_bad=1
        [ -n "$b" ] && [ "$b" -gt 0 ] 2>/dev/null && b_bad=1
        note="ok (both)"
        if [ "$a_bad" = "1" ] && [ "$b_bad" = "0" ]; then note="A non-zero - DISCARD A"; fi
        if [ "$b_bad" = "1" ] && [ "$a_bad" = "0" ]; then note="B non-zero - DISCARD B"; fi
        if [ "$a_bad" = "1" ] && [ "$b_bad" = "1" ]; then note="BOTH non-zero - both suspect"; fi
        _row "$id" "$name" "$a" "$b" "$note"
    done

    # UDMA_CRC_Error_Count (199) is in the kill-zone of many SMART
    # tools, but on real hardware it's usually a SATA cable / port
    # / connector issue rather than a drive defect: the protocol
    # caught a bad transfer and retransmitted, so data integrity
    # is preserved. Show non-zero values with a 'cable check'
    # annotation rather than 'DISCARD', and treat it as a low-
    # priority verdict signal (after age + load cycles).
    a199=$(_attr_raw "$attrA" 199)
    b199=$(_attr_raw "$attrB" 199)
    a_bus_bad=0; b_bus_bad=0
    [ -n "$a199" ] && [ "$a199" -gt 0 ] 2>/dev/null && a_bus_bad=1
    [ -n "$b199" ] && [ "$b199" -gt 0 ] 2>/dev/null && b_bus_bad=1
    crc_note="ok (both)"
    if [ "$a_bus_bad" = "1" ] && [ "$b_bus_bad" = "0" ]; then crc_note="A non-zero - check A's SATA cable / port"; fi
    if [ "$b_bus_bad" = "1" ] && [ "$a_bus_bad" = "0" ]; then crc_note="B non-zero - check B's SATA cable / port"; fi
    if [ "$a_bus_bad" = "1" ] && [ "$b_bus_bad" = "1" ]; then crc_note="BOTH non-zero - check cabling on both"; fi
    _row 199 "UDMA_CRC_Error_Count" "$a199" "$b199" "$crc_note"

    # Wear / age signals with delta % computed.
    for spec in '4:Start_Stop_Count' \
                '12:Power_Cycle_Count' \
                '192:Power-Off_Retract_Count' \
                '193:Load_Cycle_Count' \
                '9:Power_On_Hours'; do
        id=${spec%%:*}; name=${spec#*:}
        a=$(_attr_raw "$attrA" "$id")
        b=$(_attr_raw "$attrB" "$id")
        delta_note=""
        if [ -n "$a" ] && [ -n "$b" ] && [ "$a" -gt 0 ] 2>/dev/null && [ "$b" -gt 0 ] 2>/dev/null; then
            # delta = (max - min) / min * 100
            if [ "$a" -ge "$b" ]; then
                delta=$(awk -v hi="$a" -v lo="$b" 'BEGIN { printf "%.0f", (hi - lo) * 100 / lo }')
                higher="A"
            else
                delta=$(awk -v hi="$b" -v lo="$a" 'BEGIN { printf "%.0f", (hi - lo) * 100 / lo }')
                higher="B"
            fi
            if [ "$delta" -ge 5 ] 2>/dev/null; then
                delta_note="$higher higher by ${delta}%"
            else
                delta_note="similar"
            fi
        fi
        _row "$id" "$name" "$a" "$b" "$delta_note"
    done

    # Helium level (HE-series). Lower is worse.
    heA=$(_attr_raw "$attrA" 22)
    heB=$(_attr_raw "$attrB" 22)
    he_note=""
    if [ -n "$heA" ] && [ -n "$heB" ]; then
        if [ "$heA" -lt "$heB" ] 2>/dev/null; then he_note="A lower - leak suspect"
        elif [ "$heB" -lt "$heA" ] 2>/dev/null; then he_note="B lower - leak suspect"
        else he_note="equal"
        fi
    fi
    _row 22 "Helium_Level" "$heA" "$heB" "$he_note"

    # Temperature.
    tA=$(_attr_raw "$attrA" 194)
    tB=$(_attr_raw "$attrB" 194)
    _row 194 "Temperature_Celsius" "$tA" "$tB" ""

    echo

    # Verdict logic.
    verdict=""
    reason=""

    # 1) Overall health.
    case "$healthA" in PASSED|OK|"") :;; *) verdict="A"; reason="overall health '$healthA' is not PASSED"; esac
    case "$healthB" in PASSED|OK|"") :;; *) [ -z "$verdict" ] && verdict="B" && reason="overall health '$healthB' is not PASSED";; esac

    # 2) Self-test failure on one only - VERY strong signal (the drive
    #    actually exercised its surface and reported a real fault).
    if [ -z "$verdict" ]; then
        if [ "$a_st_bad" = "1" ] && [ "$b_st_bad" = "0" ]; then
            verdict="A"; reason="self-test failure on A (last result: '$stlA') - real surface fault"
        elif [ "$b_st_bad" = "1" ] && [ "$a_st_bad" = "0" ]; then
            verdict="B"; reason="self-test failure on B (last result: '$stlB') - real surface fault"
        fi
    fi

    # 3) Error log entries on one only.
    if [ -z "$verdict" ]; then
        if [ "$a_err_bad" = "1" ] && [ "$b_err_bad" = "0" ]; then
            verdict="A"; reason="error log entries on A (count=$errA_n) - firmware-recorded command failures"
        elif [ "$b_err_bad" = "1" ] && [ "$a_err_bad" = "0" ]; then
            verdict="B"; reason="error log entries on B (count=$errB_n) - firmware-recorded command failures"
        fi
    fi

    # 4) Killer attrs 5/197/198 (sector-level drive damage). 199 is
    #    handled later as a low-priority hint because it's usually
    #    cable/port/connector noise rather than a drive defect.
    if [ -z "$verdict" ]; then
        for id in 5 197 198; do
            a=$(_attr_raw "$attrA" "$id")
            b=$(_attr_raw "$attrB" "$id")
            a_bad=0; b_bad=0
            [ -n "$a" ] && [ "$a" -gt 0 ] 2>/dev/null && a_bad=1
            [ -n "$b" ] && [ "$b" -gt 0 ] 2>/dev/null && b_bad=1
            if [ "$a_bad" = "1" ] && [ "$b_bad" = "0" ]; then
                verdict="A"; reason="attribute $id is non-zero on A only (raw=$a) - drive sector damage"; break
            fi
            if [ "$b_bad" = "1" ] && [ "$a_bad" = "0" ]; then
                verdict="B"; reason="attribute $id is non-zero on B only (raw=$b) - drive sector damage"; break
            fi
        done
    fi

    # 3) Helium level.
    if [ -z "$verdict" ] && [ -n "$heA" ] && [ -n "$heB" ]; then
        if [ "$heA" -lt "$heB" ] 2>/dev/null; then
            verdict="A"; reason="lower helium level (A=$heA vs B=$heB)"
        elif [ "$heB" -lt "$heA" ] 2>/dev/null; then
            verdict="B"; reason="lower helium level (B=$heB vs A=$heA)"
        fi
    fi

    # 4) Load cycle count delta >= 20%.
    if [ -z "$verdict" ]; then
        lA=$(_attr_raw "$attrA" 193)
        lB=$(_attr_raw "$attrB" 193)
        if [ -n "$lA" ] && [ -n "$lB" ] && [ "$lA" -gt 0 ] 2>/dev/null && [ "$lB" -gt 0 ] 2>/dev/null; then
            if [ "$lA" -ge "$lB" ]; then
                d=$(awk -v hi="$lA" -v lo="$lB" 'BEGIN { printf "%.0f", (hi - lo) * 100 / lo }')
                if [ "$d" -ge 20 ] 2>/dev/null; then
                    verdict="A"; reason="head-park wear: A has ${d}% more load cycles than B ($lA vs $lB)"
                fi
            else
                d=$(awk -v hi="$lB" -v lo="$lA" 'BEGIN { printf "%.0f", (hi - lo) * 100 / lo }')
                if [ "$d" -ge 20 ] 2>/dev/null; then
                    verdict="B"; reason="head-park wear: B has ${d}% more load cycles than A ($lB vs $lA)"
                fi
            fi
        fi
    fi

    # 5) Power-on hours delta >= 20%.
    if [ -z "$verdict" ] && [ -n "$pohA" ] && [ -n "$pohB" ] \
       && [ "$pohA" -gt 0 ] 2>/dev/null && [ "$pohB" -gt 0 ] 2>/dev/null; then
        if [ "$pohA" -ge "$pohB" ]; then
            d=$(awk -v hi="$pohA" -v lo="$pohB" 'BEGIN { printf "%.0f", (hi - lo) * 100 / lo }')
            if [ "$d" -ge 20 ] 2>/dev/null; then
                verdict="A"; reason="A is ${d}% older than B (POH $pohA vs $pohB)"
            fi
        else
            d=$(awk -v hi="$pohB" -v lo="$pohA" 'BEGIN { printf "%.0f", (hi - lo) * 100 / lo }')
            if [ "$d" -ge 20 ] 2>/dev/null; then
                verdict="B"; reason="B is ${d}% older than A (POH $pohB vs $pohA)"
            fi
        fi
    fi

    # 6) UDMA_CRC delta - lowest-priority tiebreaker. This is rarely a
    #    drive defect; it's typically a cable/port/connector issue.
    #    Only fire if NOTHING else differentiated the drives.
    if [ -z "$verdict" ] && [ "$a_bus_bad" = "1" ] && [ "$b_bus_bad" = "0" ]; then
        verdict="A"; reason="UDMA CRC errors on A ($a199) suggest cable/port issue on A's bus (verify cabling before retiring)"
    fi
    if [ -z "$verdict" ] && [ "$b_bus_bad" = "1" ] && [ "$a_bus_bad" = "0" ]; then
        verdict="B"; reason="UDMA CRC errors on B ($b199) suggest cable/port issue on B's bus (verify cabling before retiring)"
    fi

    if [ -n "$verdict" ]; then
        if [ "$verdict" = "A" ]; then
            warn "VERDICT: if you must retire one, prefer DRIVE A ($devA, ${modelA:-?})"
        else
            warn "VERDICT: if you must retire one, prefer DRIVE B ($devB, ${modelB:-?})"
        fi
        warn "  Reason: $reason"
    else
        info "VERDICT: no clear loser - both drives look healthy on the metrics compared."
        info "  Both passed killer attributes, helium, load cycles, and age delta thresholds."
    fi
    echo
    # Closing note. If both drives have at least one recorded self-test,
    # mention that we used those results in the comparison; otherwise
    # say what was used and what was skipped.
    if [ "${stcA_n:-0}" -gt 0 ] 2>/dev/null && [ "${stcB_n:-0}" -gt 0 ] 2>/dev/null; then
        explain "Note: comparison includes attributes + error log + self-test history"
        explain "(both drives have firmware-recorded self-tests; latest run on each is"
        explain "shown in the 'Last self-test' row). For the full dump on either drive,"
        explain "use '$SCRIPT_NAME smart <disk>'."
    else
        explain "Note: comparison includes attributes + error log; self-test history is"
        if [ "${stcA_n:-0}" = 0 ] && [ "${stcB_n:-0}" = 0 ]; then
            explain "  empty on BOTH drives (configure SELFTEST_LONG_SCHEDULE in the config"
            explain "  to have the daemon run periodic long self-tests; results survive"
            explain "  reboot in firmware-resident logs)."
        elif [ "${stcA_n:-0}" = 0 ]; then
            explain "  empty on Drive A (no self-tests have been run on this disk yet)."
        else
            explain "  empty on Drive B (no self-tests have been run on this disk yet)."
        fi
        explain "For the full dump on either drive, use '$SCRIPT_NAME smart <disk>'."
    fi
}

