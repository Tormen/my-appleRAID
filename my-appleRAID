# ----------------------------------------------------------------------
# Subcommand: list
# ----------------------------------------------------------------------
# ----------------------------------------------------------------------
# Row gatherers + formatters used by the compact 'list' summary.
#
# Pipe-delimited row schema (11 fields):
#   source | level_raw | state_raw | devnode | size_bytes | free_bytes
#          | mount     | fs        | name    | members    | flags
#
# - source = "Apple" or "Soft"
# - members = space-separated "diskN:CODE" pairs (CODE is one letter,
#   see member_state_legend below)
# - flags  = additional inline annotations (e.g. "SG" if SoftRAID
#   Safeguard is enabled). Empty when no flags apply.
#
# Apple rows are emitted with FS/free/mount empty - they need a follow-up
# diskutil lookup on the devnode (handled by appleraid_volume_info).
# Soft rows already carry every field from softraidtool.
# ----------------------------------------------------------------------

# Format raw bytes as "10.9 TB" / "5.18 GB" / "-".
fmt_bytes() {
    awk -v b="$1" 'BEGIN {
        if (b == "" || b+0 == 0) { print "-"; exit }
        if (b >= 1e12) { printf "%.1f TB\n", b/1e12; exit }
        if (b >= 1e9 ) { printf "%.1f GB\n", b/1e9 ; exit }
        if (b >= 1e6 ) { printf "%.1f MB\n", b/1e6 ; exit }
        printf "%d B\n", b
    }'
}

# AppleRAID Type -> short level
ar_level_short() {
    case "$1" in
        Mirror)              echo "R1" ;;
        Stripe|RAID0)        echo "R0" ;;
        Concat|Concatenated) echo "Cat" ;;
        *)                   echo "${1:-?}" ;;
    esac
}

# SoftRAID raid level (already lowercased+stripped) -> short
sr_level_short() {
    case "$1" in
        raid0)   echo "R0" ;;
        raid1)   echo "R1" ;;
        raid4)   echo "R4" ;;
        raid5)   echo "R5" ;;
        raid10)  echo "R10" ;;
        nonraid) echo "1x" ;;
        "")      echo "?" ;;
        *)       echo "$1" ;;
    esac
}

# AppleRAID member status -> single-letter code
ar_member_state_short() {
    case "$1" in
        Online)     echo "O" ;;
        Missing)    echo "M" ;;
        Spare)      echo "P" ;;
        Rebuilding) echo "R" ;;
        Failed)     echo "F" ;;
        Standby)    echo "S" ;;
        Offline)    echo "X" ;;
        *)          echo "?" ;;
    esac
}

# Look up FS / mount / free for a synthesized AppleRAID device node.
# AppleRAID-as-APFS exposes the FS/mount/free on the inner APFS volume,
# not on the synthesized container. Output: <fs>|<mount>|<free_bytes>
appleraid_volume_info() {
    raidnode="$1"
    [ -n "$raidnode" ] || { echo "-|-|"; return; }
    dinfo=$(diskutil info "/dev/$raidnode" 2>/dev/null) || { echo "-|-|"; return; }
    bundle=$(printf '%s\n' "$dinfo" | awk -F': *' '/^[[:space:]]*Type \(Bundle\):/ {print $2; exit}')
    case "$bundle" in
        apfs)
            # APFS-on-AppleRAID: the APFS layer creates a SEPARATE
            # synthesized disk (e.g. disk12) whose Physical Store is
            # the AppleRAID node (disk11). The mounted APFS volume
            # lives there as disk12s1, NOT under disk11. Walk the
            # full 'diskutil list' to find it.
            innervol=$(diskutil list 2>/dev/null | awk -v phys="$raidnode" '
                /^\/dev\/disk[0-9]+ \(synthesized\)/ { in_synth=1; found=0; next }
                /^\/dev\//                            { in_synth=0; found=0; next }
                in_synth && /Physical Store/ {
                    for (i=1; i<=NF; i++) {
                        s=$i; gsub(/,$/, "", s)
                        if (s == phys) { found=1 }
                    }
                    next
                }
                in_synth && found && /APFS Volume/ { print $NF; exit }
            ')
            if [ -n "$innervol" ]; then
                vinfo=$(diskutil info "/dev/$innervol" 2>/dev/null)
                mp=$(printf '%s\n' "$vinfo" | awk -F': *' '/^[[:space:]]*Mount Point:/ {print $2; exit}')
                free=$(free_bytes_for_mount "$mp")
                printf 'APFS|%s|%s\n' "${mp:--}" "${free:-}"
                return
            fi
            echo "APFS|-|"
            return
            ;;
    esac
    fs=$(printf '%s\n' "$dinfo" | awk -F': *' '/^[[:space:]]*File System Personality:/ {print $2; exit}')
    mp=$(printf '%s\n' "$dinfo" | awk -F': *' '/^[[:space:]]*Mount Point:/ {print $2; exit}')
    free=$(free_bytes_for_mount "$mp")
    printf '%s|%s|%s\n' "${fs:-?}" "${mp:--}" "${free:-}"
}

# Free space in bytes for a mount point. df is reliable across APFS,
# HFS+, etc. - 'diskutil info Volume Free Space:' is missing on APFS
# volumes, and 'Container Free Space:' is per-container, not per-volume.
free_bytes_for_mount() {
    mp="$1"
    [ -n "$mp" ] && [ "$mp" != "-" ] && [ -d "$mp" ] || return 0
    # df -k: 1024-byte blocks. Available column is the 4th in the
    # data row (POSIX layout, used by macOS df by default).
    df -k "$mp" 2>/dev/null | awk 'NR==2 {printf "%.0f\n", $4 * 1024; exit}'
}

# Gather AppleRAID rows. Outputs partial rows; fs/mount/free are
# resolved later in print_raid_summary via appleraid_volume_info.
gather_appleraid_rows() {
    command -v diskutil >/dev/null 2>&1 || return 0
    diskutil appleRAID list 2>/dev/null | awk '
        function flush() {
            if (have) {
                # Schema: source|level|state|devnode|size|free|mount|fs|name|members|flags|ar|rebuild_pct
                # Apple emits source(1) level(2) state(3) devnode(4) size(5)
                # then 3 empties (free/mount/fs) then name(9) members(10)
                # flags(11) auto_rebuild(12) rebuild_pct(13) -> 13 fields.
                printf "Apple|%s|%s|%s|%s||||%s|%s||%s|%s\n",
                       type, status, devnode, size, name, members, auto_rebuild, rebuild_pct
            }
            have=0; type=""; name=""; status=""; size=""; devnode=""
            members=""; auto_rebuild=""; rebuild_pct=""
            dash_count=0; in_members=0
        }
        /^=+$/ { flush(); next }
        /^Name:[[:space:]]/         { sub(/^Name:[[:space:]]*/,""); name=$0; have=1; next }
        /^Type:[[:space:]]/         { sub(/^Type:[[:space:]]*/,""); type=$0; next }
        /^Status:[[:space:]]/       { sub(/^Status:[[:space:]]*/,""); status=$0; next }
        /^Rebuild:[[:space:]]/      { sub(/^Rebuild:[[:space:]]*/,""); auto_rebuild=$0; next }
        /^Size:[[:space:]]/         {
            n=split($0,p,"(")
            if (n>=2) { gsub(/[^0-9]/,"",p[2]); size=p[2] }
            next
        }
        /^Device Node:[[:space:]]/  { sub(/^Device Node:[[:space:]]*/,""); devnode=$0; next }
        /^-+$/                      { dash_count++; if (have && dash_count==2) in_members=1; next }
        in_members && /^# +DevNode/ { next }
        in_members && /^[0-9]+[[:space:]]+disk/ {
            # Columns: # DevNode UUID Status Size
            # Status may be multi-word, e.g. "0% (rebuilding)" or "Online".
            # Reconstruct everything between $3 (UUID) and $NF (size-bytes)
            # as the per-member status.
            mstatus=""
            for (i=4; i<NF; i++) mstatus = (mstatus == "" ? $i : mstatus " " $i)
            # Capture overall rebuild progress (highest %) for the set.
            if (match(mstatus, /[0-9]+%/)) {
                pct = substr(mstatus, RSTART, RLENGTH)
                gsub(/%/, "", pct)
                if (rebuild_pct == "" || pct+0 > rebuild_pct+0) rebuild_pct = pct
            }
            # Member-state code: simplify multi-word status to a single
            # keyword we map to a letter in ar_member_state_short.
            mcode = "?"
            if (mstatus ~ /[Rr]ebuild/) mcode = "Rebuilding"
            else if (mstatus == "Online")   mcode = "Online"
            else if (mstatus == "Missing")  mcode = "Missing"
            else if (mstatus == "Spare")    mcode = "Spare"
            else if (mstatus == "Offline")  mcode = "Offline"
            else if (mstatus == "Failed")   mcode = "Failed"
            else if (mstatus == "Stale")    mcode = "Stale"
            else                            mcode = mstatus
            members = (members ? members " " : "") $2 ":" mcode
            next
        }
        END { flush() }
    '
}

# Gather SoftRAID rows. softraidtool reports ALL volumes on the host
# including non-SoftRAID ones (boot disk, plain HFS volumes); we only
# emit rows where "Volume is SoftRAID" was seen in the block.
gather_softraid_rows() {
    softraid_tool_available || return 0
    softraid_tool volume all info 2>/dev/null | awk '
        function flush() {
            if (in_block && is_sr) {
                printf "Soft|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s\n",
                       level, state, devnode, total, free, mp, fmt, name, members,
                       (sg ? "SG" : "")
            }
            in_block=0; is_sr=0
            level=""; state=""; fmt=""; total=""; free=""; mp=""; name=""
            devnode=""; members=""; sg=""; in_disks=0
        }
        /^Info for "/ {
            flush()
            line=$0
            sub(/^Info for "/,"",line); sub(/":$/,"",line); sub(/"$/,"",line)
            name=line
            in_block=1
            next
        }
        /Volume is SoftRAID/                  { is_sr=1; next }
        /^[[:space:]]*Mountpoint:/            { sub(/^[[:space:]]*Mountpoint:[[:space:]]*/,""); mp=$0; next }
        /^[[:space:]]*BSD disk:/              { sub(/^[[:space:]]*BSD disk:[[:space:]]*/,""); devnode=$0; next }
        /^[[:space:]]*Total Bytes:/           {
            n=split($0,p,"("); if (n>=2) { gsub(/[^0-9]/,"",p[2]); total=p[2] }
            next
        }
        /^[[:space:]]*Free Bytes:/            {
            n=split($0,p,"("); if (n>=2) { gsub(/[^0-9]/,"",p[2]); free=p[2] }
            next
        }
        /^[[:space:]]*Volume format:/         { sub(/^[[:space:]]*Volume format:[[:space:]]*/,""); fmt=$0; next }
        /^[[:space:]]*RAID level:/            {
            sub(/^[[:space:]]*RAID level:[[:space:]]*/,"")
            l=tolower($0); gsub(/[[:space:]]+/,"",l); sub(/,.*$/,"",l)
            level=l; next
        }
        /^[[:space:]]*Volume Safeguard:/      {
            sub(/^[[:space:]]*Volume Safeguard:[[:space:]]*/,"")
            if (tolower($0) ~ /^enabled/) sg=1
            next
        }
        /^[[:space:]]*Volume state:/          {
            sub(/^[[:space:]]*Volume state:[[:space:]]*/,"")
            sub(/,.*$/,"")
            state=$0; next
        }
        /^Disks used for this volume:/        { in_disks=1; next }
        in_disks && /^bsd disk:/              { next }
        in_disks && /^disk[0-9]+/             {
            mn=$1
            role="?"
            if ($0 ~ /primary disk/)        role="P"
            else if ($0 ~ /secondary disk/)  role="S"
            else if ($0 ~ /missing/)         role="M"
            else if ($0 ~ /offline/)         role="F"
            members = (members ? members " " : "") mn ":" role
            next
        }
        in_disks && NF==0                     { in_disks=0 }
        END { flush() }
    '
}

# Render one Apple row's level + member states from the raw schema row.
# Receives the row on stdin (single line). Outputs the rendered row.
_render_apple_row() {
    IFS='|' read -r src level state devnode size_b free_b mount fs name members flags ar rebuild_pct _rest
    short_level=$(ar_level_short "$level")
    # Resolve fs/mount/free from the synthesized RAID device node.
    info_line=$(appleraid_volume_info "$devnode")
    fs=$(printf '%s\n' "$info_line" | awk -F'|' '{print $1}')
    mount=$(printf '%s\n' "$info_line" | awk -F'|' '{print $2}')
    free_b=$(printf '%s\n' "$info_line" | awk -F'|' '{print $3}')
    short_members=""
    for m in $members; do
        mn=${m%%:*}; ms=${m#*:}
        sc=$(ar_member_state_short "$ms")
        short_members="${short_members:+$short_members }${mn}:${sc}"
    done
    size_str=$(fmt_bytes "$size_b")
    if [ -z "$mount" ] || [ "$mount" = "-" ]; then
        mount="-"
        free_str="n/a"
    else
        free_str=$(fmt_bytes "$free_b")
    fi
    [ -n "$fs" ] || fs="?"
    flags_str=""
    [ -n "$flags" ] && flags_str=" $flags"

    # Append rebuild progress to STATE while a rebuild is active.
    state_text="${state:--}"
    if [ -n "$rebuild_pct" ]; then
        state_text="${state} ${rebuild_pct}%"
    fi
    # Pre-pad state (width 13) BEFORE adding color escapes: %-Ns counts
    # escape bytes against the field width.
    state_padded=$(printf '%-13s' "$state_text")
    case "$state" in
        Online)             state_disp="${C_GREEN}${state_padded}${C_RESET}"  ;;
        Degraded)           state_disp="${C_YELLOW}${state_padded}${C_RESET}" ;;
        Failed|Offline)     state_disp="${C_RED}${state_padded}${C_RESET}"    ;;
        *)                  state_disp="$state_padded" ;;
    esac

    # AR column: AppleRAID's Rebuild policy. Lowercased + abbreviated to
    # "auto" / "manual" / "-" so the column is narrow.
    ar_text="-"
    case "$(printf '%s' "$ar" | tr '[:upper:]' '[:lower:]')" in
        automatic|auto|true|1|yes) ar_text="auto"   ;;
        manual|false|0|no)         ar_text="manual" ;;
    esac

    printf '%-22s AppleRAID  %-4s %s %-6s %-5s %-9s %-9s %-22s [%s]%s\n' \
        "$name" "$short_level" "$state_disp" "$ar_text" "$fs" "$size_str" "$free_str" "$mount" \
        "$short_members" "$flags_str"
}

_render_soft_row() {
    IFS='|' read -r src level state devnode size_b free_b mount fs name members flags _rest
    short_level=$(sr_level_short "$level")
    [ -n "$fs" ]    || fs="?"
    [ -n "$state" ] || state="-"
    size_str=$(fmt_bytes "$size_b")
    if [ -z "$mount" ] || [ "$mount" = "-" ]; then
        mount="-"
        free_str="n/a"
    else
        free_str=$(fmt_bytes "$free_b")
    fi
    flags_str=""
    [ -n "$flags" ] && flags_str=" $flags"
    # SoftRAID has its own rebuild policy (separate from AppleRAID's
    # AutoRebuild). Print "-" in the AR column to keep column
    # alignment with AppleRAID rows.
    state_padded=$(printf '%-13s' "$state")
    case "$state" in
        Online|Optimal)         state_disp="${C_GREEN}${state_padded}${C_RESET}"  ;;
        Degraded|Rebuilding)    state_disp="${C_YELLOW}${state_padded}${C_RESET}" ;;
        Failed|Offline|Missing) state_disp="${C_RED}${state_padded}${C_RESET}"    ;;
        *)                      state_disp="$state_padded" ;;
    esac
    printf '%-22s SoftRAID   %-4s %s %-6s %-5s %-9s %-9s %-22s [%s]%s\n' \
        "$name" "$short_level" "$state_disp" "-" "$fs" "$size_str" "$free_str" "$mount" \
        "$members" "$flags_str"
}

# Print the unified compact summary (the new default 'list' output).
print_raid_summary() {
    apple_rows=$(gather_appleraid_rows)
    soft_rows=$(gather_softraid_rows)

    if [ -z "$apple_rows" ] && [ -z "$soft_rows" ]; then
        info "No AppleRAID sets and no SoftRAID volumes found on this host."
        return
    fi

    printf '%s%-22s %-10s %-4s %-13s %-6s %-5s %-9s %-9s %-22s %s%s\n' \
        "${C_BOLD}" "NAME" "SOURCE" "LVL" "STATE" "AR" "FS" "SIZE" "FREE" "MOUNT" "[MEMBERS]" "${C_RESET}"

    if [ -n "$apple_rows" ]; then
        printf '%s\n' "$apple_rows" | while IFS= read -r row; do
            [ -n "$row" ] || continue
            printf '%s\n' "$row" | _render_apple_row
        done
    fi
    if [ -n "$soft_rows" ]; then
        printf '%s\n' "$soft_rows" | while IFS= read -r row; do
            [ -n "$row" ] || continue
            printf '%s\n' "$row" | _render_soft_row
        done
    fi

    n_apple=$(printf '%s\n' "$apple_rows" | awk 'NF' | wc -l | tr -d ' ')
    n_soft=$(printf '%s\n' "$soft_rows" | awk 'NF' | wc -l | tr -d ' ')
    n_apple_degraded=$(printf '%s\n' "$apple_rows" | awk -F'|' 'NF && $3 != "Online" {n++} END {print n+0}')
    n_soft_degraded=$(printf '%s\n' "$soft_rows" | awk -F'|' 'NF && $3 != "normal" {n++} END {print n+0}')

    echo
    explain "Member states: O=Online R=Rebuilding F=Failed S=Standby M=Missing P=Spare X=Offline ?=Unknown"
    explain "AR column: AppleRAID AutoRebuild policy (auto/manual). Flags: SG=Safeguard enabled (SoftRAID)."
    if softraid_tool_available; then
        printf 'Totals: %s AppleRAID set(s) (%s degraded), %s SoftRAID volume(s) (%s degraded).\n' \
            "${n_apple:-0}" "$n_apple_degraded" "${n_soft:-0}" "$n_soft_degraded"
    else
        printf 'Totals: %s AppleRAID set(s) (%s degraded). SoftRAID: not installed on this host.\n' \
            "${n_apple:-0}" "$n_apple_degraded"
    fi
}

# Verbose dump (the legacy 'list' output): full diskutil appleRAID list
# with a synthetic 'File System:' line injected per set.
cmd_list_verbose_dump() {
    step "AppleRAID sets - full diskutil output"
    explain "Command: diskutil appleRAID list (with 'File System:' line injected per set)."
    echo
    printf '%s$ diskutil appleRAID list%s\n' "${C_BOLD}" "${C_RESET}"
    diskutil appleRAID list 2>&1 | while IFS= read -r line; do
        printf '%s\n' "$line"
        case "$line" in
            "Device Node:"*)
                dev=$(printf '%s\n' "$line" | awk '{print $NF}')
                [ -n "$dev" ] || continue
                dinfo=$(diskutil info "/dev/$dev" 2>/dev/null) || continue
                fs=$(printf '%s\n' "$dinfo" | awk -F': *' '/^ *File System Personality:/ {print $2; exit}')
                if [ -z "$fs" ]; then
                    bundle=$(printf '%s\n' "$dinfo" | awk -F': *' '/^ *Type \(Bundle\):/ {print $2; exit}')
                    case "$bundle" in
                        apfs) fs="APFS Container" ;;
                        "")   ;;
                        *)    fs="$bundle" ;;
                    esac
                fi
                if [ -z "$fs" ]; then
                    fs=$(printf '%s\n' "$dinfo" | awk -F': *' '/^ *Name \(User Visible\):/ {print $2; exit}')
                fi
                [ -z "$fs" ] && fs="(none / unformatted)"
                printf 'File System:          %s\n' "$fs"
                ;;
        esac
    done
}

cmd_list() {
    eval "$(parse_global_flags "$@")"

    for a in "$@"; do
        case "$a" in
            -h|--help)
                cat <<EOF
Usage: $SCRIPT_NAME list [-V]

Print a compact one-line-per-RAID summary covering both AppleRAID sets
and SoftRAID volumes. Each row shows the source (AppleRAID/SoftRAID),
RAID level, state, filesystem, size + free, mount point, the volume
name, and inline member status codes.

  -V, --verbose    Also print the full 'diskutil appleRAID list' dump
                   FIRST (the legacy 'list' output), followed by the
                   compact summary.
EOF
                return 0
                ;;
        esac
    done

    # Load config so DEFAULT_AUTO_REBUILD (and other defaults) are available.
    cfg_load 2>/dev/null

    if [ "$VERBOSE" = "1" ] || [ "$DEBUG" = "1" ]; then
        cmd_list_verbose_dump
        echo
    fi

    # Enforce DEFAULT_AUTO_REBUILD on every visible set BEFORE gathering
    # the summary, so the AR column reflects post-enforcement state.
    # No-op (silent) if every set already matches the configured target,
    # or if DEFAULT_AUTO_REBUILD is empty.
    if [ -n "${DEFAULT_AUTO_REBUILD:-}" ]; then
        for u in $(raid_list_uuids 2>/dev/null); do
            enforce_default_ar_for_uuid "$u" >/dev/null 2>&1 || true
        done
    fi

    step "RAID summary"
    print_raid_summary
}

# ----------------------------------------------------------------------
# Subcommand: disks
# Detail levels (controlled by GLOBAL -V/-D flags):
#   (default)              compact one-liner: DEV LOC KIND SIZE MODEL ROLE
#   -V / --verbose         extended: adds SERIAL TEMP SMART ROT TRIM PROTOCOL
#                          (requires smartctl for TEMP / SMART / ROT)
#   -D / --debug           full 'diskutil list' output (every partition)
# ----------------------------------------------------------------------
cmd_disks() {
    # Strip global flags that may appear after the subcommand.
    eval "$(parse_global_flags "$@")"

    # Any non-flag positional args to disks are currently unsupported,
    # but we accept -h gracefully.
    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help)
                cat <<EOF
Usage: $SCRIPT_NAME disks [-V | -D]

Detail levels:
  (default)       compact: DEV LOC KIND SIZE MODEL ROLE
  -V, --verbose   extended: adds SERIAL TEMP SMART ROT TRIM PROTOCOL
                  (TEMP/SMART/ROT require smartctl)
  -D, --debug     full 'diskutil list' output (every partition/slice)
EOF
                return 0
                ;;
            *) warn "Unknown option: $1" ;;
        esac
        shift
    done

    if [ "$DEBUG" = "1" ]; then
        step "Listing all disks (full diskutil list)"
        explain "Command: diskutil list"
        explain "Shows every block device: physical, virtual (RAID, APFS), and synthesized."
        echo
        run diskutil list
        return 0
    fi

    if [ "$VERBOSE" = "1" ]; then
        step "Disks (extended)"
        explain "Use '$SCRIPT_NAME disks' for compact view, or '-D' for full 'diskutil list'."
        if ! command -v smartctl >/dev/null 2>&1; then
            warn "smartctl not installed - TEMP / SMART / ROT columns will be '-'"
            warn "  Fix:  brew install smartmontools"
        fi
    else
        step "Disks (compact)"
        explain "Use '$SCRIPT_NAME disks -V' for extended info, or '-D' for full 'diskutil list'."
    fi
    echo

    # Build a "disk -> RAID set name" lookup for the Role column.
    raid_map=$(diskutil appleRAID list 2>/dev/null | awk -F': +' '
        /^Name:/ { setname = $2; sub(/ +$/, "", setname) }
        /^[ ]*[0-9]+[ \t]+disk[0-9]+/ {
            nf = split($0, parts, /[ \t]+/)
            for (i = 1; i <= nf; i++) {
                if (parts[i] ~ /^disk[0-9]+(s[0-9]+)?$/) {
                    dev = parts[i]
                    sub(/s[0-9]+$/, "", dev)
                    print dev "|" setname
                    break
                }
            }
        }
    ')

    # Header
    if [ "$VERBOSE" = "1" ]; then
        printf '  %-8s %-9s %-4s %9s  %-24s  %-18s %5s %-6s %-4s %-4s %-10s %s\n' \
            "DEV" "LOC" "KIND" "SIZE" "MODEL" "SERIAL" "TEMP" "SMART" "ROT" "TRIM" "PROTOCOL" "ROLE"
        printf '  %-8s %-9s %-4s %9s  %-24s  %-18s %5s %-6s %-4s %-4s %-10s %s\n' \
            "---" "---" "----" "----" "-----" "------" "----" "-----" "---" "----" "--------" "----"
    else
        printf '  %-8s %-9s %-4s %9s  %-28s %s\n' \
            "DEV" "LOC" "KIND" "SIZE" "MODEL" "ROLE"
        printf '  %-8s %-9s %-4s %9s  %-28s %s\n' \
            "---" "---" "----" "----" "-----" "----"
    fi

    # Capture the disk list FIRST into a variable, then iterate with
    # a for-loop rather than a `while read`. This avoids the classic
    # POSIX hazard where subshells inside `while read -r d; do ... done`
    # inherit stdin from the enclosing pipe - commands like smartctl
    # consume the remaining input and truncate the loop.
    disks_list=$(diskutil list 2>/dev/null | awk '/^\/dev\/disk[0-9]+/ {
        sub(/:$/, "", $1)
        sub(/^\/dev\//, "", $1)
        print $1
    }')

    for d in $disks_list; do
        [ -n "$d" ] || continue
        dev="/dev/$d"
        info_out=$(diskutil info "$dev" 2>/dev/null) || continue

        size=$(echo "$info_out" | awk -F': +' '
            /Disk Size:/ { print $2; exit }
            /Total Size:/ { print $2; exit }
        ')
        size=$(echo "$size" | sed 's/ *(.*)//; s/[[:space:]]*$//')

        virtual=$(echo "$info_out"  | awk -F': +' '/Virtual:/      {print $2; exit}')
        solid=$(echo "$info_out"    | awk -F': +' '/Solid State:/  {print $2; exit}')
        protocol=$(echo "$info_out" | awk -F': +' '/Protocol:/     {print $2; exit}')
        if   [ "$virtual"  = "Yes" ];        then kind="virt"
        elif [ "$protocol" = "Disk Image" ]; then kind="img"
        elif [ "$solid"    = "Yes" ];        then kind="SSD"
        else                                       kind="HDD"
        fi

        loc=$(echo "$info_out" | awk -F': +' '/Device Location:/ {print $2; exit}')
        [ -z "$loc" ] && loc=$(echo "$info_out" | awk -F': +' '/Internal:/ {print ($2=="Yes"?"Internal":"External"); exit}')
        loc=$(echo "$loc" | awk '{print $1}')

        model=$(echo "$info_out" | awk -F': +' '/Device \/ Media Name:/ {print $2; exit}')
        [ -z "$model" ] && model=$(echo "$info_out" | awk -F': +' '/Media Name:/ {print $2; exit}')
        [ -z "$model" ] && model="-"

        role=""
        hit=$(printf '%s\n' "$raid_map" | awk -F'|' -v d="$d" '$1==d {print $2; exit}')
        if [ -n "$hit" ]; then
            role="RAID member ($hit)"
        else
            is_raid_virt=$(echo "$info_out" | awk -F': +' '/AppleRAID Set:/ {print "yes"; exit}')
            if [ "$is_raid_virt" = "yes" ]; then
                set_name=$(echo "$info_out" | awk -F': +' '/AppleRAID Set Name:/ {print $2; exit}')
                [ -z "$set_name" ] && set_name="RAID set"
                role="RAID virtual ($set_name)"
            else
                is_apfs=$(echo "$info_out" | awk -F': +' '/File System Personality:/ {print $2; exit}')
                case "$is_apfs" in
                    *APFS*) role="APFS" ;;
                    *)      role="-" ;;
                esac
            fi
        fi

        if [ "$VERBOSE" = "1" ]; then
            serial=$(disk_serial "$d")
            [ -z "$serial" ] && serial="-"
            serial=$(printf '%s' "$serial" | cut -c1-18)

            trim=$(echo "$info_out" | awk -F': +' '/TRIM Support:/ {print $2; exit}')
            case "$trim" in
                Yes) trim="yes" ;;
                No)  trim="no"  ;;
                *)   trim="-"   ;;
            esac

            proto_short=$(echo "$protocol" | cut -c1-10)
            [ -z "$proto_short" ] && proto_short="-"

            temp="-"; smart="-"; rot="-"
            if command -v smartctl >/dev/null 2>&1 && [ "$virtual" != "Yes" ]; then
                # IMPORTANT: every $(...) below inherits stdin from the
                # enclosing `while read -r d` loop's pipe. smartctl reads
                # stdin (it tries to open the device only, but the shell
                # still attaches stdin before exec), which CONSUMES the
                # remaining disk names and causes the loop to exit after
                # one iteration. Redirect stdin from /dev/null on every
                # call to prevent this.
                sc=$(smart_cmd "$d" </dev/null 2>/dev/null)
                [ -z "$sc" ] && sc="smartctl"
                attrs=$($sc -A "$dev" </dev/null 2>/dev/null)
                health_raw=$($sc -H "$dev" </dev/null 2>/dev/null | awk -F': *' '
                    /SMART overall-health/ { print $2; exit }
                    /SMART Health Status/  { print $2; exit }')
                health_raw=$(echo "$health_raw" | sed 's/^ *//;s/ *$//')
                case "$health_raw" in
                    PASSED|OK) smart="OK" ;;
                    '')        smart="-"  ;;
                    *)         smart="$(printf '%s' "$health_raw" | cut -c1-6)" ;;
                esac
                temp=$(echo "$attrs" | awk '
                    /^[[:space:]]*(194|190)[[:space:]]+Temperature/ { print $10 "C"; exit }
                ')
                [ -z "$temp" ] && temp="-"
                rot=$($sc -i "$dev" </dev/null 2>/dev/null | awk -F': +' '/Rotation Rate:/ {
                    gsub(/ *rpm.*/, "", $2); print $2; exit
                }')
                case "$rot" in
                    "")                       rot="-" ;;
                    "Solid State Device")     rot="SSD" ;;
                esac
            fi

            printf '  %-8s %-9s %-4s %9s  %-24.24s  %-18s %5s %-6s %-4s %-4s %-10s %s\n' \
                "$d" "${loc:-?}" "$kind" "$size" "$model" "$serial" "$temp" "$smart" "$rot" "$trim" "$proto_short" "$role"
        else
            model_c=$(printf '%s' "$model" | cut -c1-28)
            printf '  %-8s %-9s %-4s %9s  %-28s %s\n' \
                "$d" "${loc:-?}" "$kind" "$size" "$model_c" "$role"
        fi
    done
}

# ----------------------------------------------------------------------
# Subcommand: status (also accessible as 'info' - synonym in dispatch)
# ----------------------------------------------------------------------
# Behavior:
#   No arg, 0 sets   -> warn + exit 1
#   No arg, 1 set    -> auto-show that set's full status
#   No arg, 2+ sets  -> compact list (cmd_list output)
#   <name|uuid>      -> full status for that set (set-level header,
#                       members table with parent-disk info, AR +
#                       SetTimeout from ioreg, mount info)
#   -V               -> ALSO append the full 'diskutil appleRAID list'
#                       dump and 'diskutil info' on the synthesized
#                       virtual device.
cmd_status() {
    eval "$(parse_global_flags "$@")"

    arg=""
    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help)
                cat <<EOF
Usage: $SCRIPT_NAME status [<set>] [-V]
       $SCRIPT_NAME info   [<set>] [-V]    (synonym)

Show detailed status for one AppleRAID set: header (level, state,
AutoRebuild, SetTimeout, size, mount, free, FS, virtual device), plus
a per-member table (kernel state + parent physical disk info).

Without <set>:
  - 0 sets    : prints a warning, exits 1.
  - 1 set     : auto-shows that set's full status.
  - 2+ sets   : prints the compact 'list' summary (use 'status <set>'
                for the per-set drill-down).

With -V: appends the full 'diskutil appleRAID list' dump and the
'diskutil info' for the synthesized RAID device.
EOF
                return 0
                ;;
            -V|--verbose|-D|--debug) ;;
            -*) warn "Unknown option: $1" ;;
            *)  arg="$1" ;;
        esac
        shift
    done

    cfg_load 2>/dev/null

    if [ -z "$arg" ]; then
        n=$(raid_count)
        if [ "$n" -eq 0 ]; then
            warn "No AppleRAID sets found."
            return 1
        fi
        if [ "$n" -ge 2 ]; then
            cmd_list
            return 0
        fi
        SELECTED_UUID=$(raid_list_uuids | head -1)
    else
        uuid=""
        for u in $(raid_list_uuids); do
            [ "$u" = "$arg" ] && uuid="$u" && break
        done
        [ -z "$uuid" ] && uuid=$(raid_name_to_uuid "$arg")
        [ -z "$uuid" ] && die "No RAID set matches '$arg'."
        SELECTED_UUID="$uuid"
    fi

    UUID="$SELECTED_UUID"
    name=$(diskutil appleRAID list "$UUID" 2>/dev/null \
        | awk -F': +' '/^Name:/ {v=$2; sub(/[[:space:]]+$/,"",v); print v; exit}')

    step "Status of RAID set '$name' ($UUID)"

    # Set-level fields
    type_str=$(diskutil appleRAID list "$UUID" 2>/dev/null \
        | awk -F': +' '/^Type:/ {print $2; exit}' | sed 's/[[:space:]]*$//')
    state=$(raid_status "$UUID")
    size_str=$(diskutil appleRAID list "$UUID" 2>/dev/null \
        | awk -F': +' '/^Size:/ {print $2; exit}' | sed 's/ *(.*//; s/[[:space:]]*$//')
    dev=$(raid_uuid_to_device "$UUID")

    ar_raw=$(raid_ar_get "$UUID")
    case "$ar_raw" in
        1) ar_word="auto (1)"   ;;
        0) ar_word="manual (0)" ;;
        *) ar_word="?"          ;;
    esac
    st_secs=$(raid_st_get "$UUID")

    info_line=$(appleraid_volume_info "$dev")
    fs=$(printf '%s\n' "$info_line" | awk -F'|' '{print $1}')
    mount_pt=$(printf '%s\n' "$info_line" | awk -F'|' '{print $2}')
    free_b=$(printf '%s\n' "$info_line" | awk -F'|' '{print $3}')
    if [ -z "$mount_pt" ] || [ "$mount_pt" = "-" ]; then
        mount_pt="<not mounted>"
        free_str="n/a"
    else
        free_str=$(fmt_bytes "$free_b")
    fi
    [ -n "$fs" ] || fs="?"

    case "$state" in
        Online)   state_disp="${C_GREEN}${state}${C_RESET}"  ;;
        Degraded) state_disp="${C_YELLOW}${state}${C_RESET}" ;;
        *)        state_disp="${C_RED}${state:-?}${C_RESET}" ;;
    esac
    printf '  %-15s %s\n' "Level:"        "${type_str:-?}"
    printf '  %-15s %s\n' "State:"        "$state_disp"
    printf '  %-15s %s\n' "AutoRebuild:"  "$ar_word"
    printf '  %-15s %s%s\n' "SetTimeout:" "${st_secs:-?}" "s  (informational - changes have no observable runtime effect; see README)"
    printf '  %-15s %s\n' "Size:"         "${size_str:-?}"
    printf '  %-15s %s\n' "Mount:"        "$mount_pt"
    [ "$mount_pt" != "<not mounted>" ] && printf '  %-15s %s\n' "Free:" "$free_str"
    printf '  %-15s %s\n' "Volume FS:"    "$fs"
    printf '  %-15s /dev/%s\n' "RAID device:" "${dev:-?}"

    echo
    step "Members"
    diskutil appleRAID list "$UUID" 2>/dev/null | awk '
        BEGIN { found=0 }
        /^#[[:space:]]+DevNode/ { found=1; next }
        found && /^[0-9]+[[:space:]]+disk/ {
            n = split($0, p, /[[:space:]]+/)
            delete q; nq=0
            for (i=1; i<=n; i++) if (p[i] != "") { nq++; q[nq]=p[i] }
            if (nq < 5) next
            idx=q[1]; devnode=q[2]; muuid=q[3]
            status=q[4]
            for (i=5; i<=nq-1; i++) status = status " " q[i]
            size=q[nq]
            printf "%s|%s|%s|%s|%s\n", idx, devnode, muuid, status, size
        }
    ' | while IFS='|' read -r idx devnode muuid mstatus msize; do
        parent=$(echo "$devnode" | sed 's/s[0-9]*$//')
        pinfo=$(diskutil info "/dev/$parent" 2>/dev/null)
        model=$(echo "$pinfo" | awk -F': +' '/Device \/ Media Name:/ {print $2; exit}')
        [ -z "$model" ] && model=$(echo "$pinfo" | awk -F': +' '/Media Name:/ {print $2; exit}')
        loc=$(echo "$pinfo"   | awk -F': +' '/Device Location:/ {print $2; exit}')
        loc=$(echo "$loc"     | awk '{print $1}')
        psize=$(echo "$pinfo" | awk -F': +' '/Disk Size:/ {print $2; exit}' | sed 's/ *(.*//; s/[[:space:]]*$//')
        case "$mstatus" in
            Online)              ms="${C_GREEN}${mstatus}${C_RESET}"  ;;
            *[Rr]ebuild*)        ms="${C_YELLOW}${mstatus}${C_RESET}" ;;
            *)                   ms="${C_RED}${mstatus}${C_RESET}"    ;;
        esac
        printf '  [%s] %-9s %s  parent=/dev/%-7s loc=%-9s size=%-9s model=%s\n' \
            "$idx" "$devnode" "$ms" "$parent" "${loc:-?}" "${psize:-?}" "${model:-?}"
        # Inline SMART one-liner so the user doesn't need to invoke
        # 'smart <disk>' separately for each member.
        smart_line=$(smart_summary_line "$parent")
        [ -n "$smart_line" ] && printf '       %s\n' "$smart_line"
    done

    if [ "$VERBOSE" = "1" ]; then
        echo
        step "Verbose: full diskutil appleRAID list output"
        run diskutil appleRAID list "$UUID"
        if [ -n "$dev" ]; then
            echo
            step "Verbose: diskutil info /dev/$dev"
            run diskutil info "/dev/$dev"
        fi
    fi
}

# ----------------------------------------------------------------------
# Subcommand: watch
# ----------------------------------------------------------------------
cmd_watch() {
    if [ $# -ge 1 ]; then
        target="$1"
    else
        target=""
    fi
    info "Refreshing every 10 seconds. Press Ctrl-C to stop."
    sleep 1
    while true; do
        clear 2>/dev/null || printf '\033[2J\033[H'
        printf '%s[%s] AppleRAID status%s\n' "${C_BOLD}" "$(date '+%Y-%m-%d %H:%M:%S')" "${C_RESET}"
        echo
        if [ -n "$target" ]; then
            diskutil appleRAID list "$target" 2>&1 || diskutil appleRAID list 2>&1
        else
            diskutil appleRAID list 2>&1
        fi
        sleep 10
    done
}

# ----------------------------------------------------------------------
# Subcommand: blink
# ----------------------------------------------------------------------
# Pulse a disk's activity LED by repeatedly reading from it. macOS
# exposes no API to toggle an enclosure LED, so we generate read I/O
# instead and let the bus-activity LED do the blinking. This is the
# same trick SoftRAID's "Identify" button uses.
pick_physical_disk_interactively() {
    # $1 = verb shown in the prompt header ("blink", "eject", ...).
    _verb="${1:-pick}"

    # Enumerate whole disks (skip Virtual: AppleRAID/APFS containers).
    _disks=$(diskutil list 2>/dev/null | awk '/^\/dev\/disk[0-9]+/ {
        sub(/:$/, "", $1); sub(/^\/dev\//, "", $1); print $1
    }')

    _i=0
    _map=""
    {
        printf '%sPick a disk to %s:%s\n\n' "${C_BOLD}" "$_verb" "${C_RESET}"
        printf '  %3s  %-8s %-9s %-4s %9s  %s\n' "#" "DEV" "LOC" "KIND" "SIZE" "MODEL"
        printf '  %3s  %-8s %-9s %-4s %9s  %s\n' "-" "---" "---" "----" "----" "-----"
    } >&2

    for d in $_disks; do
        info_out=$(diskutil info "/dev/$d" 2>/dev/null) || continue
        virtual=$(echo "$info_out" | awk -F': +' '/Virtual:/ {print $2; exit}')
        [ "$virtual" = "Yes" ] && continue

        size=$(echo "$info_out" | awk -F': +' '
            /Disk Size:/ { print $2; exit }
            /Total Size:/ { print $2; exit }
        ' | sed 's/ *(.*)//; s/[[:space:]]*$//')

        solid=$(echo "$info_out"    | awk -F': +' '/Solid State:/  {print $2; exit}')
        protocol=$(echo "$info_out" | awk -F': +' '/Protocol:/     {print $2; exit}')
        if   [ "$protocol" = "Disk Image" ]; then kind="img"
        elif [ "$solid"    = "Yes" ];        then kind="SSD"
        else                                       kind="HDD"
        fi

        loc=$(echo "$info_out" | awk -F': +' '/Device Location:/ {print $2; exit}')
        [ -z "$loc" ] && loc=$(echo "$info_out" | awk -F': +' '/Internal:/ {print ($2=="Yes"?"Internal":"External"); exit}')
        loc=$(echo "$loc" | awk '{print $1}')

        model=$(echo "$info_out" | awk -F': +' '/Device \/ Media Name:/ {print $2; exit}')
        [ -z "$model" ] && model=$(echo "$info_out" | awk -F': +' '/Media Name:/ {print $2; exit}')
        [ -z "$model" ] && model="-"

        _i=$((_i + 1))
        _map="$_map$_i=$d
"
        printf '  %3d  %-8s %-9s %-4s %9s  %s\n' "$_i" "$d" "${loc:-?}" "$kind" "$size" "$model" >&2
    done

    if [ "$_i" -eq 0 ]; then
        err "No physical disks found."
        return 1
    fi

    {
        echo
        printf '%sChoice [1-%d, q to abort]:%s ' "${C_YELLOW}" "$_i" "${C_RESET}"
    } >&2
    read -r _choice || return 1
    case "$_choice" in
        q|Q|'')      err "Aborted."; return 1 ;;
        *[!0-9]*)    err "Invalid choice: $_choice"; return 1 ;;
    esac
    if [ "$_choice" -lt 1 ] || [ "$_choice" -gt "$_i" ]; then
        err "Invalid choice: $_choice (must be 1..$_i)"
        return 1
    fi

    _picked=$(printf '%s' "$_map" | awk -F= -v c="$_choice" '$1==c {print $2; exit}')
    [ -n "$_picked" ] || { err "Internal error resolving choice $_choice."; return 1; }
    echo "$_picked"
}

cmd_blink() {
    eval "$(parse_global_flags "$@")"

    arg=""
    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help)
                cat <<EOF
Usage: $SCRIPT_NAME blink [<disk>]

Pulse a disk's activity LED so you can identify which physical drive
(or which enclosure slot) maps to a given /dev/diskN before yanking
it for a swap or repair.

macOS has no API to toggle an enclosure LED directly, so this
generates read I/O on the disk and lets the bus-activity LED do the
blinking. Same trick SoftRAID's "Identify" button uses.

ARGUMENTS
  <disk>    Optional. Disk number (e.g. 3), short name (disk3) or
            full path (/dev/disk3). If omitted, you get an
            interactive picker listing all attached physical disks.

NOTES
  - Read-only. Will not touch data.
  - Reads from the raw device (/dev/rdiskN) for maximum throughput;
    requires sudo on modern macOS.
  - Pulses ~64 MiB read, then ~0.5 s idle, looping until you press
    Ctrl-C. The on/off pattern makes the blink obvious.
EOF
                return 0
                ;;
            -V|--verbose|-D|--debug) ;;
            -*) warn "Unknown option: $1" ;;
            *)  arg="$1" ;;
        esac
        shift
    done

    if [ -z "$arg" ]; then
        arg=$(pick_physical_disk_interactively "blink") || return 1
    fi

    dev=$(resolve_disk "$arg") || die "Invalid disk spec: $arg"
    assert_whole_disk "$dev"

    virt=$(diskutil info "$dev" 2>/dev/null | awk -F': *' '/Virtual:/ {print $2; exit}')
    if [ "$virt" = "Yes" ]; then
        die "$dev is a VIRTUAL device (RAID/APFS container) and has no LED of its own. Pick a physical disk."
    fi

    rdev="/dev/r${dev#/dev/}"

    step "Blinking $dev"
    describe_disk "$dev"
    explain "Read-only loop: reads ~64 MiB, idles ~0.5 s, repeats. Watch the"
    explain "drive's activity LED to identify which physical slot $dev is."
    explain "Press Ctrl-C to stop."
    echo

    # Trap so Ctrl-C exits cleanly instead of dumping a half-printed dd line.
    trap 'echo; ok "Blink stopped."; exit 0' INT TERM

    # Prime sudo once so the loop body doesn't trigger a re-prompt mid-pulse.
    if ! sudo -n true 2>/dev/null; then
        info "Reading $rdev requires sudo (cached for the rest of the loop)."
        sudo true || die "sudo authentication failed."
    fi

    pulse=0
    while :; do
        pulse=$((pulse + 1))
        printf '  pulse %d ...\r' "$pulse"
        if ! sudo dd if="$rdev" of=/dev/null bs=1m count=64 2>/dev/null; then
            echo
            die "Read failed on $rdev (disk disconnected?)"
        fi
        sleep 0.5
    done
}

# ----------------------------------------------------------------------
# Subcommand: eject
# ----------------------------------------------------------------------
# Spin down and power off a physical disk so it can be safely yanked.
# Designed as the natural follow-up to `blink`: blink to identify which
# slot a /dev/diskN is in, then eject it before pulling it.
cmd_eject() {
    eval "$(parse_global_flags "$@")"

    arg=""
    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help)
                cat <<EOF
Usage: $SCRIPT_NAME eject [<disk>]

Spin down and power off a physical disk so it can be safely
disconnected. Natural follow-up to '$SCRIPT_NAME blink': blink to
identify which physical slot a /dev/diskN is in, then eject it
before pulling it.

Unmounts every volume on the disk and runs 'diskutil eject', which
flushes caches and parks the heads.

ARGUMENTS
  <disk>    Optional. Disk number (e.g. 3), short name (disk3) or
            full path (/dev/disk3). If omitted, you get an
            interactive picker listing all attached physical disks.

NOTES
  - If the disk is a member of an online AppleRAID set, the set's
    kernel claim blocks 'diskutil eject'. You'll be shown a 3-step
    plan and one confirmation:
        1. unmount the disk
        2. diskutil appleRAID remove <member-uuid> <set-uuid>
           (set goes DEGRADED here)
        3. diskutil eject
    After swapping the disk, rebuild with: '$SCRIPT_NAME repair <set>'.
  - Internal disks are refused (would take down macOS).
  - Virtual devices (RAID/APFS containers) are refused; eject the
    backing physical disk instead.
EOF
                return 0
                ;;
            -V|--verbose|-D|--debug) ;;
            -*) warn "Unknown option: $1" ;;
            *)  arg="$1" ;;
        esac
        shift
    done

    if [ -z "$arg" ]; then
        arg=$(pick_physical_disk_interactively "eject") || return 1
    fi

    dev=$(resolve_disk "$arg") || die "Invalid disk spec: $arg"
    assert_whole_disk "$dev"
    short="${dev#/dev/}"

    virt=$(diskutil info "$dev" 2>/dev/null | awk -F': *' '/Virtual:/ {print $2; exit}')
    if [ "$virt" = "Yes" ]; then
        die "$dev is a VIRTUAL device (RAID/APFS container). Eject the backing physical disk instead."
    fi

    internal=$(diskutil info "$dev" 2>/dev/null | awk -F': *' '/Internal:/ {print $2; exit}')
    if [ "$internal" = "Yes" ]; then
        die "$dev is an INTERNAL disk - refusing to eject (would take down macOS)."
    fi

    # Detect if this disk is a member of an existing AppleRAID set, and
    # if so capture the set name + UUID, member UUID, and member partition
    # node (e.g. disk7s2). We need all four to call
    # 'diskutil appleRAID remove <member-uuid> <set-uuid>', which is the
    # only way to release the disk: AppleRAID claims members at the
    # kernel level so 'diskutil eject' fails while membership is live.
    raid_info=$(diskutil appleRAID list 2>/dev/null | awk -F': +' -v d="$short" '
        /^Name:/         { setname = $2; sub(/[[:space:]]+$/, "", setname) }
        /^Unique ID:/    { setuuid = $2; sub(/[[:space:]]+$/, "", setuuid) }
        /^[[:space:]]*[0-9]+[[:space:]]+disk[0-9]+/ {
            n = split($0, p, /[[:space:]]+/)
            j = 0
            for (i = 1; i <= n; i++) {
                if (p[i] != "") {
                    j++
                    if (j == 2) devnode = p[i]
                    if (j == 3) muuid   = p[i]
                }
            }
            base = devnode; sub(/s[0-9]+$/, "", base)
            if (base == d) {
                printf "%s|%s|%s|%s\n", setname, setuuid, muuid, devnode
                exit
            }
        }
    ')
    raid_set_name=$(   echo "$raid_info" | cut -d'|' -f1)
    raid_set_uuid=$(   echo "$raid_info" | cut -d'|' -f2)
    raid_member_uuid=$(echo "$raid_info" | cut -d'|' -f3)
    raid_member_part=$(echo "$raid_info" | cut -d'|' -f4)

    step "Eject plan for $dev"
    describe_disk "$dev"
    release_from_raid=0
    if [ -n "$raid_set_name" ]; then
        warn "$dev is a member of AppleRAID set '$raid_set_name'."
        warn "  Set UUID:    $raid_set_uuid"
        warn "  Member:      $raid_member_part  ($raid_member_uuid)"
        echo
        explain "AppleRAID claims member disks at the kernel level, so 'diskutil eject'"
        explain "fails while membership is live. To eject we must first release the"
        explain "disk from the set."
        echo
        explain "Plan if you confirm:"
        explain "  1. sudo diskutil unmountDisk force $dev"
        explain "  2. sudo diskutil appleRAID remove $raid_member_uuid $raid_set_uuid"
        explain "     (set '$raid_set_name' goes DEGRADED here)"
        explain "  3. diskutil eject $dev"
        explain ""
        explain "After swapping the disk, rebuild with:  $SCRIPT_NAME repair $raid_set_name"
        echo
        confirm "Eject $dev and degrade set '$raid_set_name'?" || die "Aborted."
        release_from_raid=1
    fi

    step "Unmounting $dev"
    run sudo diskutil unmountDisk force "$dev" \
        || warn "unmountDisk returned non-zero (may be already unmounted)"

    if [ "$release_from_raid" = "1" ]; then
        step "Removing $raid_member_part from AppleRAID set '$raid_set_name'"
        explain "'diskutil appleRAID remove <member-uuid> <set-uuid>' releases the disk"
        explain "from the kernel-level RAID claim. Set goes DEGRADED."
        if ! run sudo diskutil appleRAID remove "$raid_member_uuid" "$raid_set_uuid"; then
            err "appleRAID remove failed."
            explain "Possible reasons:"
            explain "  - The set is currently rebuilding; wait for it to finish."
            explain "  - macOS refused to remove the last viable member of the set."
            explain "  - The member UUID changed since this run started. Verify with:"
            explain "      diskutil appleRAID list $raid_set_uuid"
            exit 1
        fi
    fi

    step "Ejecting $dev"
    if run diskutil eject "$dev"; then
        ok "$dev ejected. Safe to disconnect."
        if [ "$release_from_raid" = "1" ]; then
            echo
            info "Set '$raid_set_name' is now DEGRADED."
            info "After connecting a replacement (or this same disk back),"
            info "rebuild with:  $SCRIPT_NAME repair $raid_set_name"
        fi
    else
        err "diskutil eject failed for $dev."
        explain "Possible reasons:"
        explain "  - A process is still holding files open on a volume on $dev."
        explain "    Try: lsof +D /Volumes/<name>  (or 'sudo lsof' for system processes)"
        if [ -n "$raid_set_name" ] && [ "$release_from_raid" != "1" ]; then
            explain "  - $dev is still a member of AppleRAID set '$raid_set_name'."
            explain "    Re-run '$SCRIPT_NAME eject $short' and confirm the release prompt."
        fi
        explain "  - The enclosure does not honor SCSI eject (some USB bridges)."
        explain "    The disk is unmounted but the device node will persist."
        explain "  - macOS refused due to a pending I/O operation. Wait a few seconds and retry."
        exit 1
    fi
}

# ----------------------------------------------------------------------
# Subcommand: smart
# ----------------------------------------------------------------------
# Comprehensive on-demand SMART drill-down for one disk: overall health,
# pre-failure attributes (with non-zero killer highlight), self-test
# history, and the firmware error log. Complements `health`, which is a
# recurring monitor that only alerts on threshold crossings - it never
# shows the firmware error/self-test logs and isn't designed for
# interactive per-disk inspection.
cmd_smart() {
    eval "$(parse_global_flags "$@")"

    arg=""
    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help)
                cat <<EOF
Usage: $SCRIPT_NAME smart [<disk>]

Detailed SMART health drill-down for one disk:

  1/4  Overall health           (smartctl -H)
  2/4  Pre-failure attributes   (smartctl -A) + non-zero killer summary
  3/4  Self-test log            (smartctl -l selftest)
  4/4  SMART error log          (smartctl -l error)

The error log and self-test log are exactly the data that answers
'was this drive ever in trouble in the past' - the firmware itself
remembers errors and test outcomes across reboots. Neither is shown
by '$SCRIPT_NAME health', which only alerts on the current value of
overall health, temperature, and the killer attributes.

ARGUMENTS
  <disk>    Optional. Disk number (e.g. 3), short name (disk3) or
            full path (/dev/disk3). If omitted, you get an
            interactive picker listing all attached physical disks.

NOTES
  - Read-only.
  - Auto-detects the right 'smartctl -d <type>' for USB/TB enclosures
    (cached in ~/.cache/my-appleRAID-smart-dtypes).
  - Refuses virtual devices (RAID/APFS containers - no SMART of their own).
  - Requires smartctl: brew install smartmontools
EOF
                return 0
                ;;
            -V|--verbose|-D|--debug) ;;
            -*) warn "Unknown option: $1" ;;
            *)  arg="$1" ;;
        esac
        shift
    done

    if [ -z "$arg" ]; then
        arg=$(pick_physical_disk_interactively "inspect (SMART)") || return 1
    fi

    dev=$(resolve_disk "$arg") || die "Invalid disk spec: $arg"
    assert_whole_disk "$dev"

    _smart_drilldown_one "${dev#/dev/}"
}

# ----------------------------------------------------------------------
# Subcommand: wipe
# ----------------------------------------------------------------------
# Zero first and last 100 MB of a whole disk.
cmd_wipe() {
    [ $# -ge 1 ] || die "Usage: $SCRIPT_NAME wipe <disk-number>"
    dev=$(resolve_disk "$1") || die "Invalid disk spec: $1"
    rdev="/dev/r${dev#/dev/}"

    assert_whole_disk "$dev"
    assert_safe_target "$dev"

    step "Wipe plan for $dev"
    describe_disk "$dev"
    explain "This will:"
    explain "  1. Unmount $dev and any partitions on it."
    explain "  2. Zero the first 100 MB (removes GPT + most RAID/filesystem headers)."
    explain "  3. Zero the last  100 MB (removes backup GPT and tail-stored metadata)."
    explain "  4. Verify both regions are zero."
    explain "Total wipe time: ~2-5 seconds (only 200 MB written, not the whole drive)."
    echo

    confirm "About to WIPE $dev. Continue?" || die "Aborted."

    size_bytes=$(disk_size_bytes "$dev")
    [ -n "$size_bytes" ] || die "Could not determine size of $dev"
    size_mb=$(( size_bytes / 1048576 ))
    seek_mb=$(( size_mb - 100 ))

    info "Disk size: $size_bytes bytes = $size_mb MiB; tail seek = $seek_mb MiB"

    step "Unmounting $dev"
    run sudo diskutil unmountDisk force "$dev" || warn "unmountDisk returned non-zero (may be already unmounted)"

    step "Zeroing first 100 MB of $dev"
    run sudo dd if=/dev/zero of="$rdev" bs=1m count=100 status=progress || die "First-100MB wipe failed"

    step "Zeroing last 100 MB of $dev"
    run sudo dd if=/dev/zero of="$rdev" bs=1m seek=$seek_mb count=100 status=progress || die "Last-100MB wipe failed"

    step "Verifying wipe"
    verify_wipe "$dev" || die "Verification failed"
    ok "Wipe complete and verified for $dev"
}

# Verify first and last 100 MB of a disk are all zero.
# Returns 0 on success, 1 on failure. Prints result.
verify_wipe() {
    dev="$1"
    rdev="/dev/r${dev#/dev/}"
    size_bytes=$(disk_size_bytes "$dev")
    [ -n "$size_bytes" ] || { err "Could not determine size of $dev"; return 1; }
    size_mb=$(( size_bytes / 1048576 ))
    skip_mb=$(( size_mb - 100 ))

    explain "Check 1/2: first 100 MB of $dev"
    show "sudo cmp -n 104857600 $rdev /dev/zero"
    if sudo cmp -n 104857600 "$rdev" /dev/zero >/dev/null 2>&1; then
        first="OK"
    else
        first="FAIL"
    fi

    explain "Check 2/2: last 100 MB of $dev (via dd skip=$skip_mb)"
    show "sudo dd if=$rdev bs=1m skip=$skip_mb count=100 | cmp -n 104857600 - /dev/zero"
    if sudo dd if="$rdev" bs=1m skip=$skip_mb count=100 2>/dev/null \
         | cmp -n 104857600 - /dev/zero >/dev/null 2>&1; then
        last="OK"
    else
        last="FAIL"
    fi

    printf '  first 100 MB: %s\n' "$first"
    printf '  last  100 MB: %s\n' "$last"

    [ "$first" = "OK" ] && [ "$last" = "OK" ]
}

cmd_verify_wipe() {
    [ $# -ge 1 ] || die "Usage: $SCRIPT_NAME verify-wipe <disk-number>"
    dev=$(resolve_disk "$1") || die "Invalid disk spec: $1"
    assert_whole_disk "$dev"
    step "Verifying wipe on $dev"
    if verify_wipe "$dev"; then
        ok "$dev is cleanly zeroed at both ends."
    else
        err "$dev still has non-zero data in first or last 100 MB."
        exit 1
    fi
}

# ----------------------------------------------------------------------
# Subcommand: create
# ----------------------------------------------------------------------
cmd_create() {
    [ $# -ge 3 ] || die "Usage: $SCRIPT_NAME create <name> <disk-num-1> <disk-num-2>"
    name="$1"
    dev1=$(resolve_disk "$2") || die "Invalid disk spec: $2"
    dev2=$(resolve_disk "$3") || die "Invalid disk spec: $3"

    [ "$dev1" = "$dev2" ] && die "Cannot mirror a disk to itself."

    assert_whole_disk "$dev1"
    assert_whole_disk "$dev2"
    assert_safe_target "$dev1"
    assert_safe_target "$dev2"

    step "Create AppleRAID mirror: $name"
    echo "  Member 1:"
    describe_disk "$dev1"
    echo "  Member 2:"
    describe_disk "$dev2"
    echo

    # Size sanity
    s1=$(disk_size_bytes "$dev1")
    s2=$(disk_size_bytes "$dev2")
    if [ -n "$s1" ] && [ -n "$s2" ] && [ "$s1" != "$s2" ]; then
        warn "Disks have different sizes ($s1 vs $s2 bytes). Mirror will use the smaller capacity."
    fi

    explain "This will:"
    explain "  1. WIPE both disks (first and last 100 MB) to remove stale metadata."
    explain "  2. Run 'diskutil appleRAID create mirror $name APFS $dev1 $dev2'."
    explain "  3. Show the resulting configuration."
    explain "The new mirror will appear as a virtual /dev/diskN device with an APFS volume named '$name'."
    echo

    if [ "${_PRECONFIRMED:-0}" = "1" ]; then
        info "Pre-confirmed by caller (e.g. migrate-softraid); skipping inner confirmation."
    else
        confirm "PROCEED? This erases BOTH disks." || die "Aborted."
    fi

    step "Wipe phase: $dev1"
    # Call wipe but auto-confirm by echoing yes into it -- cleaner to call internals directly.
    do_auto_wipe "$dev1"

    step "Wipe phase: $dev2"
    do_auto_wipe "$dev2"

    step "Creating mirror"
    explain "diskutil will:"
    explain "  - Partition each disk with GPT"
    explain "  - Create a ~200MB EFI partition, an Apple_RAID data partition, and an Apple_Boot helper"
    explain "  - Register the Apple_RAID partitions as mirror members"
    explain "  - Format the mirror as APFS and mount it at /Volumes/$name"
    echo
    run sudo diskutil appleRAID create mirror "$name" APFS "$dev1" "$dev2" \
        || die "diskutil appleRAID create failed"

    step "New RAID layout"
    run diskutil appleRAID list

    step "Full disk layout"
    run diskutil list

    ok "Mirror '$name' created successfully."

    # Load config (sets DEFAULT_AUTO_REBUILD, AUTO_BASELINE_*, etc.).
    cfg_load 2>/dev/null || true

    # Apply DEFAULT_AUTO_REBUILD policy to the new set. Apple's default
    # is AutoRebuild=0 (manual); our default config (DEFAULT_AUTO_REBUILD=1)
    # flips it to automatic right after creation, so a returning member
    # auto-rebuilds without operator intervention. Skipped if config
    # is empty.
    if [ -n "${DEFAULT_AUTO_REBUILD:-}" ]; then
        new_uuid=$(raid_name_to_uuid "$name")
        if [ -n "$new_uuid" ]; then
            step "Applying DEFAULT_AUTO_REBUILD=$DEFAULT_AUTO_REBUILD to '$name'"
            if enforce_default_ar_for_uuid "$new_uuid"; then
                ok "AutoRebuild set to ${DEFAULT_AUTO_REBUILD} on '$name'."
            else
                warn "Failed to set AutoRebuild=$DEFAULT_AUTO_REBUILD on '$name'."
                warn "You can retry manually:  $SCRIPT_NAME autorebuild $name on"
            fi
        fi
    fi

    # Auto-baseline hook: if the user has opted in (via config or by
    # default), add the new set to the baseline immediately so the
    # health daemon's REQUIRED_SETS=all check knows about it right away.
    if [ "${AUTO_BASELINE_FOR_SETS_ON_CREATE:-no}" = "yes" ]; then
        state_init 2>/dev/null || true
        baseline_write_sets
        info "auto-baseline: '$name' added to $(baseline_sets_file)"
    else
        info "tip: if you're using the health daemon with REQUIRED_SETS=all, run:"
        info "       $SCRIPT_NAME baseline --sets"
        info "     to include '$name' in the expected-set baseline."
    fi
}

# Non-interactive wipe used by 'create'. Assumes outer command has
# already obtained user confirmation.
do_auto_wipe() {
    dev="$1"
    rdev="/dev/r${dev#/dev/}"
    size_bytes=$(disk_size_bytes "$dev")
    size_mb=$(( size_bytes / 1048576 ))
    seek_mb=$(( size_mb - 100 ))

    run sudo diskutil unmountDisk force "$dev" || true
    run sudo dd if=/dev/zero of="$rdev" bs=1m count=100 status=progress \
        || die "First-100MB wipe of $dev failed"
    run sudo dd if=/dev/zero of="$rdev" bs=1m seek=$seek_mb count=100 status=progress \
        || die "Last-100MB wipe of $dev failed"
    verify_wipe "$dev" || die "Wipe verification failed for $dev"
    ok "$dev wiped and verified."
}

# ----------------------------------------------------------------------
# Educated guess for the replacement disk in `cmd_repair`.
#
# Inputs:
#   $1  target_size_bytes  size of the existing RAID member (replacement
#                          must be >= this)
#   $2  set_name           name of the RAID being repaired (so a
#                          previously-recognized returning member can be
#                          identified by 'role = RAID member (set_name)')
#
# Output (single line, pipe-separated):
#   <diskN>|<reason>
#
# Empty output if no good candidate exists.
#
# Scoring ladder (highest wins; ties broken by lowest disk number):
#   95  already a member of THIS set             - returning member that
#                                                   AppleRAID still has
#                                                   claimed (Stale/Spare/
#                                                   Failed); cmd_repair
#                                                   releases it via
#                                                   'appleRAID remove'
#                                                   before wipe + rebuild
#   80  free disk, exact size match              - "looks like a clean
#                                                   replacement of the
#                                                   right size"
#   60  free disk, larger than target            - "fits, with slack"
#
# Excluded outright: internal disks, virtual devices, members of OTHER
# RAID sets, and disks smaller than target_size_bytes.
#
# Cache-of-serials note: the smart_dtype_for cache stores
# disk|serial_hash|dtype. We use disk_serial / disk_serial_hash to surface
# the candidate's serial in the suggestion message so the user can verify
# "yes that's my disk", but the cache currently does NOT track which
# RAID a serial belonged to historically - that would be a useful future
# enhancement (cache RAID-member serials during health/list runs and
# match returning members by serial here).
# ----------------------------------------------------------------------
_repair_guess_replacement() {
    target_size="$1"
    selected_set_name="$2"

    # Build "disk -> set name" mapping for current RAIDs.
    raid_map=$(diskutil appleRAID list 2>/dev/null | awk -F': +' '
        /^Name:/ { setname = $2; sub(/[[:space:]]+$/, "", setname) }
        /^[[:space:]]*[0-9]+[[:space:]]+disk[0-9]+/ {
            n = split($0, p, /[[:space:]]+/)
            j = 0
            for (i = 1; i <= n; i++) {
                if (p[i] != "") { j++; if (j==2) { devnode = p[i]; break } }
            }
            base = devnode; sub(/s[0-9]+$/, "", base)
            print base "|" setname
        }
    ')

    disks=$(diskutil list 2>/dev/null | awk '/^\/dev\/disk[0-9]+/ {
        sub(/:$/, "", $1); sub(/^\/dev\//, "", $1); print $1
    }')

    best_disk=""
    best_score=0
    best_reason=""

    for d in $disks; do
        info_out=$(diskutil info "/dev/$d" 2>/dev/null) || continue
        virtual=$(echo "$info_out"  | awk -F': +' '/Virtual:/  {print $2; exit}')
        [ "$virtual" = "Yes" ] && continue
        internal=$(echo "$info_out" | awk -F': +' '/Internal:/ {print $2; exit}')
        [ "$internal" = "Yes" ] && continue

        size_bytes=$(disk_size_bytes "/dev/$d")
        size_bytes=$(printf '%s' "$size_bytes" | tr -dc '0-9')
        [ -n "$size_bytes" ] || continue

        if [ -n "$target_size" ] && [ "$target_size" -gt 0 ] 2>/dev/null \
           && [ "$size_bytes" -lt "$target_size" ] 2>/dev/null; then
            continue
        fi

        my_set=$(printf '%s\n' "$raid_map" \
                 | awk -F'|' -v d="$d" '$1==d {print $2; exit}')

        score=0; reason=""
        if [ -z "$my_set" ]; then
            if [ -n "$target_size" ] && [ "$size_bytes" = "$target_size" ]; then
                score=80; reason="exact size match, currently free"
            else
                score=60; reason="larger free disk"
            fi
        elif [ "$my_set" = "$selected_set_name" ]; then
            score=95; reason="returning member of '$selected_set_name'"
        else
            continue
        fi

        if [ "$score" -gt "$best_score" ]; then
            best_score="$score"
            best_disk="$d"
            best_reason="$reason"
        fi
    done

    [ -n "$best_disk" ] && echo "$best_disk|$best_reason"
}

# ----------------------------------------------------------------------
# Subcommand: repair (interactive guided)
# ----------------------------------------------------------------------
cmd_repair() {
    eval "$(parse_global_flags "$@")"
    if [ $# -ge 1 ]; then
        arg="$1"
        uuid=""
        for u in $(raid_list_uuids); do
            [ "$u" = "$arg" ] && uuid="$u" && break
        done
        [ -z "$uuid" ] && uuid=$(raid_name_to_uuid "$arg")
        [ -z "$uuid" ] && die "No RAID set matches '$arg'."
        SELECTED_UUID="$uuid"
    else
        pick_raid_set
    fi

    step "Interactive repair for RAID set $SELECTED_UUID"
    if [ "$VERBOSE" = "1" ]; then
        run diskutil appleRAID list "$SELECTED_UUID"
        echo
    fi

    st=$(raid_status "$SELECTED_UUID")
    case "$st" in
        Online)
            warn "Set status is Online. No repair is needed."
            confirm "Proceed anyway?" || return 0
            ;;
        Degraded)
            info "Set status is Degraded - repair is appropriate."
            ;;
        "")
            die "Could not determine set status. Aborting."
            ;;
        *)
            warn "Set status: $st (neither Online nor Degraded)."
            confirm "Proceed anyway?" || return 0
            ;;
    esac

    step "Step 1: identify the replacement disk"
    explain "Two scenarios:"
    explain ""
    explain "  A) The SAME drive was temporarily disconnected and has now returned."
    explain "     -> The drive likely still has the old Apple_RAID partition and metadata."
    explain "     -> We should WIPE it clean before re-adding, so repairMirror sees a fresh disk."
    explain ""
    explain "  B) A brand-new replacement drive of the same (or larger) capacity."
    explain "     -> We WIPE it (defensive; removes any leftover metadata from prior use)."
    explain "     -> We add it as the new member."
    explain ""
    explain "Either way, the operation is the same: wipe + repairMirror."
    echo
    # Use the compact 'disks' table for selection - the ROLE column makes
    # it obvious which disks are already RAID members vs free. With -V
    # cmd_disks itself shows the extended view (adds SERIAL/TEMP/SMART).
    cmd_disks
    echo

    # Compute target member size + set name for the educated guess.
    target_member_size=$(diskutil appleRAID list "$SELECTED_UUID" 2>/dev/null \
        | awk '/^[0-9]+[ \t]+disk/ {print $NF; exit}')
    target_set_name=$(diskutil appleRAID list "$SELECTED_UUID" 2>/dev/null \
        | awk -F': +' '/^Name:/ {v=$2; sub(/[[:space:]]+$/,"",v); print v; exit}')

    guess=""
    guess_reason=""
    if [ -n "$target_member_size" ]; then
        g=$(_repair_guess_replacement "$target_member_size" "$target_set_name")
        if [ -n "$g" ]; then
            guess=$(echo "$g" | cut -d'|' -f1)
            guess_reason=$(echo "$g" | cut -d'|' -f2-)
        fi
    fi

    if [ -n "$guess" ]; then
        guess_num="${guess#disk}"
        # Pull model + serial for display so the user can verify "yes
        # that's my disk" before pressing Enter.
        guess_model=$(diskutil info "/dev/$guess" 2>/dev/null \
            | awk -F': +' '/Device \/ Media Name:/ {print $2; exit}')
        guess_serial=$(disk_serial "$guess" 2>/dev/null)
        info "Suggested replacement: $guess  ($guess_reason)"
        [ -n "$guess_model" ]  && info "  model:  $guess_model"
        [ -n "$guess_serial" ] && info "  serial: $guess_serial"
        echo
        printf 'Enter the disk NUMBER of the replacement drive [Enter for %s]: ' "$guess_num"
    else
        printf 'Enter the disk NUMBER of the replacement drive (e.g. 3): '
    fi
    read -r disknum
    if [ -z "$disknum" ] && [ -n "$guess" ]; then
        disknum="$guess_num"
        info "Using suggested: $guess"
    fi
    [ -n "$disknum" ] || die "No disk number entered."
    dev=$(resolve_disk "$disknum") || die "Invalid disk spec: $disknum"
    assert_whole_disk "$dev"

    # Returning-member case: if the chosen disk is currently a member of
    # THIS set, branch on its MemberStatus:
    #   Online                 - nothing to repair, refuse loudly
    #   *Rebuild* / Rebuilding - rebuild already running, point to 'watch' and refuse
    #   Failed / Standby /
    #   Missing / Spare-Missing
    #   / anything else        - the legitimate stale-member case: explicitly
    #                            warn that AppleRAID has no incremental resync
    #                            so a FULL rebuild is required, then release
    #                            the kernel claim via 'appleRAID remove' so
    #                            assert_safe_target passes and repairMirror
    #                            can proceed.
    chosen_short="${dev#/dev/}"
    chosen_member_uuid=""
    chosen_member_part=""
    chosen_member_status=""
    if [ -n "$target_set_name" ]; then
        chosen_member_info=$(diskutil appleRAID list 2>/dev/null \
            | awk -F': +' -v sname="$target_set_name" -v d="$chosen_short" '
                /^Name:/      { setname = $2; sub(/[[:space:]]+$/, "", setname) }
                /^Unique ID:/ { setuuid = $2; sub(/[[:space:]]+$/, "", setuuid) }
                /^[[:space:]]*[0-9]+[[:space:]]+disk[0-9]+/ {
                    # Member line: index devnode uuid status... size-bytes.
                    # Status may be multi-word (e.g. "0% (rebuilding)"), so
                    # parse via clean non-empty token array.
                    nraw = split($0, p, /[[:space:]]+/)
                    delete q; nq = 0
                    for (i = 1; i <= nraw; i++) {
                        if (p[i] != "") { nq++; q[nq] = p[i] }
                    }
                    if (nq < 5) next
                    devnode = q[2]; muuid = q[3]
                    base = devnode; sub(/s[0-9]+$/, "", base)
                    if (base == d && setname == sname) {
                        status = q[4]
                        for (i = 5; i <= nq - 1; i++) status = status " " q[i]
                        printf "%s|%s|%s\n", muuid, devnode, status
                        exit
                    }
                }')
        if [ -n "$chosen_member_info" ]; then
            chosen_member_uuid=$(echo "$chosen_member_info"   | cut -d'|' -f1)
            chosen_member_part=$(echo "$chosen_member_info"   | cut -d'|' -f2)
            chosen_member_status=$(echo "$chosen_member_info" | cut -d'|' -f3-)

            case "$chosen_member_status" in
                Online)
                    err "$dev is currently an ONLINE member of set '$target_set_name'."
                    err "Nothing to repair on this disk - it's already part of an active mirror."
                    explain "Possible reasons:"
                    explain "  - You picked the wrong disk. Use '$SCRIPT_NAME disks' to find a free one."
                    explain "  - You meant the OTHER member of this set."
                    die "Aborted - active member."
                    ;;
                *[Rr]ebuild*)
                    err "$dev is currently REBUILDING as a member of '$target_set_name'"
                    err "  (status: $chosen_member_status)."
                    err "A rebuild is already running. Don't start another one."
                    explain "Watch progress:"
                    explain "    $SCRIPT_NAME watch $target_set_name"
                    explain "Wait for it to finish, then re-run repair only if it didn't recover."
                    die "Aborted - rebuild already in progress."
                    ;;
                *)
                    warn "$dev is currently a $chosen_member_status member of set '$target_set_name'"
                    warn "  ($chosen_member_part, member-uuid $chosen_member_uuid)."
                    echo
                    explain "AppleRAID has NO incremental resync (no write-intent bitmap), so"
                    explain "any re-add of this member triggers a FULL block-level rebuild."
                    explain "  Estimated time: ~14 hours per 10 TB at sustained ~200 MB/s."
                    explain "  The mirror stays mounted and usable during the rebuild."
                    explain ""
                    explain "AppleRAID still has the kernel claim on this slot, so we must"
                    explain "release it via 'diskutil appleRAID remove' before wiping and"
                    explain "calling repairMirror."
                    echo
                    confirm "Release $dev from '$target_set_name' and start a full rebuild?" \
                        || die "Aborted."
                    run sudo diskutil appleRAID remove "$chosen_member_uuid" "$SELECTED_UUID" \
                        || die "appleRAID remove failed - cannot proceed."
                    ok "Disk released from set."
                    echo
                    ;;
            esac
        fi
    fi

    assert_safe_target "$dev"

    step "Replacement disk details"
    describe_disk "$dev"
    echo

    # Size check vs RAID member size.
    # Member line format:
    #   <idx>  <devnode>  <uuid>  <status (1+ words)>  <size-bytes>
    # We can't rely on fixed column count because status may be multi-word
    # during rebuild (e.g. "1% (rebuilding)"). Use $1 digit + $NF as size.
    raid_member_size=$(diskutil appleRAID list "$SELECTED_UUID" 2>/dev/null \
        | awk '/^[0-9]+[ \t]+disk/ {print $NF; exit}')
    new_size=$(disk_size_bytes "$dev")
    if [ -n "$raid_member_size" ] && [ -n "$new_size" ]; then
        info "Existing member size: $raid_member_size bytes"
        info "Replacement size:     $new_size bytes"
        if [ "$new_size" -lt "$raid_member_size" ] 2>/dev/null; then
            err "Replacement is SMALLER than existing member. Cannot proceed."
            exit 1
        fi
    fi

    confirm "Wipe $dev and add it to RAID set $SELECTED_UUID?" || die "Aborted."

    step "Step 2: wipe replacement disk"
    do_auto_wipe "$dev"

    step "Step 3: add disk to mirror (repairMirror)"
    explain "'diskutil appleRAID repairMirror <set-uuid> <device>' will:"
    explain "  - Partition the new disk to match the existing member layout"
    explain "  - Add the Apple_RAID partition as a new mirror member"
    explain "  - Begin rebuilding data onto it"
    explain "The mirror stays mounted and usable during the rebuild (online rebuild)."
    echo
    run sudo diskutil appleRAID repairMirror "$SELECTED_UUID" "$dev" \
        || die "repairMirror failed"

    step "Step 4: post-repair status"
    run diskutil appleRAID list "$SELECTED_UUID"
    echo
    ok "Repair started. Monitor with:  $SCRIPT_NAME watch $SELECTED_UUID"
    info "Rebuild time depends on how much data is on the mirror."
    info "  - Empty mirror: seconds."
    info "  - Full 26 TB mirror at ~250 MB/s: ~24-30 hours."
}

# ----------------------------------------------------------------------
# Subcommand: test
# ----------------------------------------------------------------------
# Run T1..T5 on one RAID set UUID. Returns 0 if all tests pass, 1 if any
# test fails, and dies (exits) only on hard structural errors (no virtual
# device for the UUID, etc.) - those are bugs, not test failures.
_cmd_test_one_uuid() {
    SELECTED_UUID="$1"

    step "Testing RAID set $SELECTED_UUID"
    dev=$(raid_uuid_to_device "$SELECTED_UUID")
    [ -n "$dev" ] || die "Could not find virtual device for this RAID set."

    explain "Tests to run:"
    explain "  T1: RAID status must be 'Online'"
    explain "  T2: all members must be 'Online'"
    explain "  T3: virtual device /dev/$dev must exist"
    explain "  T4: APFS container on the RAID must be mounted"
    explain "  T5: write a small probe file and read it back (non-destructive)"
    echo

    fails=0

    # T1
    step "T1: overall RAID status"
    st=$(raid_status "$SELECTED_UUID")
    if [ "$st" = "Online" ]; then
        ok "Status: $st"
    else
        err "Status: $st (expected Online)"
        fails=$((fails + 1))
    fi

    # T2
    step "T2: member statuses"
    # Member line format (status may be multi-word during rebuild):
    #   <idx>  <devnode>  <uuid>  <status (1+ words)>  <size-bytes>
    # We extract everything between $3 (UUID) and $NF (size) as the status.
    bad_members=$(diskutil appleRAID list "$SELECTED_UUID" 2>/dev/null | awk '
        /^[0-9]+[ \t]+disk/ {
            devnode = $2
            status = ""
            for (i = 4; i < NF; i++) {
                status = (status == "" ? $i : status " " $i)
            }
            if (status != "Online") {
                print devnode " (" status ")"
            }
        }
    ')
    if [ -z "$bad_members" ]; then
        ok "All members are Online."
    else
        err "Non-Online members found:"
        echo "$bad_members" | sed 's/^/    /'
        fails=$((fails + 1))
    fi

    # T3
    step "T3: virtual device /dev/$dev exists"
    if [ -b "/dev/$dev" ] || diskutil info "/dev/$dev" >/dev/null 2>&1; then
        ok "/dev/$dev is present."
    else
        err "/dev/$dev not found."
        fails=$((fails + 1))
    fi

    # T4
    step "T4: find and check mount point"
    # The virtual disk itself isn't directly mounted (it holds an APFS container);
    # the APFS volume inside it is. Walk diskutil list to find the synthesized
    # APFS container whose Physical Store is our RAID virtual device, then find
    # the APFS Volume(s) inside that container.
    #
    # diskutil list layout (relevant portion):
    #   /dev/disk14 (synthesized):
    #      #:                  TYPE NAME              SIZE     IDENTIFIER
    #      0:  APFS Container Scheme -               +26.0 TB  disk14
    #                          Physical Store disk4
    #      1:      APFS Volume BackupGold             872 KB   disk14s1
    #
    # The identifier is always the LAST field on the line.
    apfs_vol=$(diskutil list | awk -v phys="$dev" '
        /^\/dev\/disk[0-9]+ \(synthesized\)/ { in_synth=1; found=0; next }
        /^\/dev\//                           { in_synth=0; found=0; next }
        in_synth && /Physical Store/ {
            for (i=1; i<=NF; i++) if ($i == phys) { found=1 }
            next
        }
        in_synth && found && /APFS Volume/ { print $NF; exit }
    ')
    mp=""
    if [ -n "$apfs_vol" ]; then
        mp=$(diskutil info "/dev/$apfs_vol" 2>/dev/null \
             | awk -F': *' '/Mount Point:/ {print $2; exit}')
    fi
    if [ -n "$mp" ] && [ -d "$mp" ]; then
        ok "APFS volume /dev/$apfs_vol is mounted at: $mp"
    else
        warn "No mounted APFS volume found on RAID set; skipping T5."
        [ -n "$apfs_vol" ] && warn "  (Found APFS volume /dev/$apfs_vol but no mount point.)"
        mp=""
    fi

    # T5
    if [ -n "$mp" ]; then
        step "T5: write/read probe"
        probe="$mp/.appleRAID-test-$$-$(date +%s)"
        payload="appleRAID self-test $(date) $$"
        explain "Writing probe file: $probe"
        if printf '%s\n' "$payload" > "$probe" 2>/dev/null; then
            readback=$(cat "$probe" 2>/dev/null)
            if [ "$readback" = "$payload" ]; then
                ok "Write-then-read succeeded and content matches."
            else
                err "Readback mismatch!"
                fails=$((fails + 1))
            fi
            rm -f "$probe"
        else
            err "Could not write probe file to $probe (permissions? disk full?)"
            fails=$((fails + 1))
        fi
    fi

    echo
    if [ $fails -eq 0 ]; then
        ok "All tests passed."
        return 0
    else
        err "$fails test(s) failed."
        return 1
    fi
}

cmd_test() {
    eval "$(parse_global_flags "$@")"

    test_all=0
    arg=""
    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help)
                cat <<EOF
Usage: $SCRIPT_NAME test [--all | <name|uuid>]

Run non-destructive tests on a RAID set:
  T1: overall RAID status is 'Online'
  T2: every member is 'Online'
  T3: virtual device exists
  T4: APFS volume on the RAID is mounted
  T5: write/read probe to the mounted volume

ARGUMENTS
  <name|uuid>   Test the named RAID set.
  --all         Test every AppleRAID set on the system. Continues
                through failures and exits non-zero if ANY set fails.
                Mutually exclusive with <name|uuid>.
  (omitted)     Interactive picker.
EOF
                return 0
                ;;
            --all) test_all=1 ;;
            -V|--verbose|-D|--debug) ;;
            -*) warn "Unknown option: $1" ;;
            *)  arg="$1" ;;
        esac
        shift
    done

    if [ "$test_all" = "1" ] && [ -n "$arg" ]; then
        die "--all and a RAID set argument are mutually exclusive."
    fi

    if [ "$test_all" = "1" ]; then
        _uuids=$(raid_list_uuids)
        [ -n "$_uuids" ] || die "No AppleRAID sets found."

        _total=0
        _failed=""
        for _u in $_uuids; do
            _total=$((_total + 1))
            if ! _cmd_test_one_uuid "$_u"; then
                _name=$(diskutil appleRAID list "$_u" 2>/dev/null \
                        | awk -F': +' '/^Name:/ {print $2; exit}')
                _failed="$_failed${_failed:+
}$_u${_name:+ ($_name)}"
            fi
        done

        echo
        step "Aggregate test summary"
        if [ -z "$_failed" ]; then
            ok "All $_total RAID set(s) passed."
            return 0
        else
            _nfail=$(printf '%s\n' "$_failed" | grep -c .)
            err "$_nfail of $_total RAID set(s) failed:"
            printf '%s\n' "$_failed" | sed 's/^/    - /'
            exit 1
        fi
    fi

    if [ -n "$arg" ]; then
        uuid=""
        for u in $(raid_list_uuids); do
            [ "$u" = "$arg" ] && uuid="$u" && break
        done
        [ -z "$uuid" ] && uuid=$(raid_name_to_uuid "$arg")
        [ -z "$uuid" ] && die "No RAID set matches '$arg'."
        SELECTED_UUID="$uuid"
    else
        pick_raid_set
    fi

    _cmd_test_one_uuid "$SELECTED_UUID" || exit 1
}

# ----------------------------------------------------------------------
# Subcommand: autorebuild
# ----------------------------------------------------------------------
# Manage AppleRAID's `AutoRebuild` (a.k.a. `Rebuild:` in `diskutil
# appleRAID list`) per set. With AutoRebuild=automatic, a returning
# member after a transient disconnect auto-rebuilds without operator
# intervention. With manual, a returning member sits in `Failed` until
# you run `repair`.
#
# Usage:
#   autorebuild                    explainer + table of all sets with their AutoRebuild policy
#   autorebuild <set>              show current state for one set;
#                                  prompt yes/no to flip
#   autorebuild <set> on|off       non-interactive flip
#
# (`SetTimeout` is intentionally NOT manageable via this command -
# empirical testing on real disks shows it has no observable effect on
# physical-disconnect behavior. See README "Empirically-verified
# AppleRAID behavior" section. SetTimeout is displayed read-only in
# `status`.)
cmd_autorebuild() {
    eval "$(parse_global_flags "$@")"

    arg_set=""
    arg_mode=""
    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help)
                cat <<EOF
Usage: $SCRIPT_NAME autorebuild [<set>] [on|off]

  (no args)             Print an explainer about AutoRebuild + show every
                        set's current AutoRebuild setting. No prompts, read-only.
  <set>                 Show the named set's current AutoRebuild; prompt yes/no to
                        flip it. Requires sudo for the update.
  <set> on              Set AutoRebuild=automatic non-interactively.
  <set> off             Set AutoRebuild=manual non-interactively.

<set> can be a UUID or the set's name.

Trade-off:
  Empirical real-disk testing shows AutoRebuild is the ONLY knob that
  controls what happens when a temporarily-missing member returns.
    on  (automatic) - kernel auto-rebuilds (Failed -> Rebuilding ->
                      Online). Full block-by-block rebuild; hours per
                      TB. The set self-heals; the health daemon still
                      emails on every transition + every 6h during
                      the rebuild, so you don't lose visibility.
    off (manual)    - returning member stays Failed; you must manually
                      run '$SCRIPT_NAME repair' (which does the same
                      full rebuild, just at your discretion). Persistent
                      visible Degraded+Failed state until you act.

The script's default is OFF (DEFAULT_AUTO_REBUILD=0) - hard-alert
behavior. Flip to ON if you'd rather have silent self-healing while
trusting the daemon's emails to surface incidents.

Note: SetTimeout (also a per-set parameter) has NO observable runtime
effect for clean physical disconnects on the enclosures we tested. It
is intentionally not managed by this command. Apple's default is 30s;
see '$SCRIPT_NAME status <set>' for the current value.
EOF
                return 0
                ;;
            -V|--verbose|-D|--debug) ;;
            on|off|ON|OFF) arg_mode="$1" ;;
            -*) warn "Unknown option: $1" ;;
            *)
                if [ -z "$arg_set" ]; then arg_set="$1"
                else warn "Unexpected extra arg: $1"; fi
                ;;
        esac
        shift
    done

    cfg_load 2>/dev/null

    # No-args mode: explainer + table of all sets.
    if [ -z "$arg_set" ]; then
        cat <<'EOF'

=== AutoRebuild explainer ===

AppleRAID has TWO per-set parameters: AutoRebuild and SetTimeout.

* AutoRebuild (this command):
    automatic (1) - When a temporarily-missing member returns, the
                    kernel auto-starts a FULL rebuild on it. The
                    member transitions Failed -> Rebuilding -> Online.
                    Takes hours per TB (block-by-block; AppleRAID
                    has no incremental resync mechanism).
    manual    (0) - The returning member stays in 'Failed' status
                    until you run '$SCRIPT_NAME repair' manually.

* SetTimeout (NOT managed by this command, displayed in 'status'):
    The kernel's "patience window" before declaring a missing member
    failed. Apple's default is 30s. EMPIRICAL FINDING: changing this
    has NO observable effect on clean physical disconnects of the
    enclosures we've tested - the kernel transitions to Degraded
    immediately and a returning member is treated as failed
    regardless of how long it was missing. We don't write this field.

The script's DEFAULT_AUTO_REBUILD config controls automatic enforcement
of AutoRebuild on every set the script touches (create / health / list
calls). Default value: 0 (force AutoRebuild=manual; you get a hard, persistent
alert when a member fails - the set stays Degraded with a Failed
member visibly until you run 'repair'). Flip to 1 if you'd rather
the kernel auto-rebuild silently; the health daemon will still
email on every transition and every 6h during the rebuild.

EOF
        # Table of every set with current AutoRebuild.
        printf '%s%-22s %-8s %-36s %-12s%s\n' \
            "${C_BOLD}" "NAME" "STATUS" "UUID" "AutoRebuild" "${C_RESET}"
        for u in $(raid_list_uuids 2>/dev/null); do
            n=$(diskutil appleRAID list "$u" 2>/dev/null \
                | awk -F': +' '/^Name:/ {v=$2; sub(/[[:space:]]+$/,"",v); print v; exit}')
            st=$(raid_status "$u")
            ar_raw=$(raid_ar_get "$u")
            case "$ar_raw" in
                1) ar="auto"   ;;
                0) ar="manual" ;;
                *) ar="?"      ;;
            esac
            printf '  %-22s %-8s %-36s %-12s\n' "$n" "$st" "$u" "$ar"
        done
        echo
        if [ -n "${DEFAULT_AUTO_REBUILD:-}" ]; then
            info "Effective DEFAULT_AUTO_REBUILD config: $DEFAULT_AUTO_REBUILD (sets that drift will be re-applied on next list/health run)."
        else
            info "DEFAULT_AUTO_REBUILD is empty - no automatic enforcement; sets will keep whatever AutoRebuild value they have."
        fi
        return 0
    fi

    # Resolve set arg to UUID.
    uuid=""
    for u in $(raid_list_uuids); do
        [ "$u" = "$arg_set" ] && uuid="$u" && break
    done
    [ -z "$uuid" ] && uuid=$(raid_name_to_uuid "$arg_set")
    [ -z "$uuid" ] && die "No RAID set matches '$arg_set'."
    name=$(diskutil appleRAID list "$uuid" 2>/dev/null \
        | awk -F': +' '/^Name:/ {v=$2; sub(/[[:space:]]+$/,"",v); print v; exit}')

    cur=$(raid_ar_get "$uuid")
    cur_word="manual"
    [ "$cur" = "1" ] && cur_word="auto"

    # Per-set mode without explicit on/off: show + prompt.
    if [ -z "$arg_mode" ]; then
        step "AutoRebuild for set '$name' ($uuid)"
        info "Current value: $cur_word ($cur)"
        echo
        if [ "$cur_word" = "manual" ]; then
            confirm "Switch to AUTOMATIC (recommended)?" || { info "No change."; return 0; }
            arg_mode="on"
        else
            confirm "Switch to MANUAL?" || { info "No change."; return 0; }
            arg_mode="off"
        fi
    fi

    # Apply the requested change.
    case "$(printf '%s' "$arg_mode" | tr '[:upper:]' '[:lower:]')" in
        on)  target=1; word="automatic" ;;
        off) target=0; word="manual"    ;;
        *)   die "Unknown mode '$arg_mode' (expected on or off)" ;;
    esac

    if [ "$cur" = "$target" ]; then
        ok "AutoRebuild already $word on '$name'. No change."
        return 0
    fi

    step "Setting AutoRebuild=$word on '$name'"
    if run sudo diskutil appleRAID update AutoRebuild "$target" "$uuid"; then
        new=$(raid_ar_get "$uuid")
        new_word="manual"
        [ "$new" = "1" ] && new_word="auto"
        if [ "$new" = "$target" ]; then
            ok "AutoRebuild is now $word on '$name'."
        else
            warn "diskutil reported success but ioreg shows AutoRebuild=$new_word."
        fi
    else
        die "Failed to set AutoRebuild=$word on '$name'."
    fi
}

# ----------------------------------------------------------------------
# Subcommand: rename
# ----------------------------------------------------------------------
# Renames a RAID set's "Name:" field (as shown in `diskutil appleRAID list`).
#
# Uses the undocumented `diskutil appleRAID update SetName <new> <uuid>` key.
# The documented update keys are only AutoRebuild and SetTimeout, but SetName
# is accepted by macOS (verified on Darwin 25.x). No sudo required; ownership
# of the RAID set is sufficient.
#
# Does NOT rename the file system volume inside the RAID (e.g. the APFS
# volume at /Volumes/<name>). Those are independent names; rename the
# mounted volume separately with `diskutil rename <mountpoint> <new>`
# if you want them to match.
cmd_rename() {
    # Strip global flags that may appear after the subcommand.
    eval "$(parse_global_flags "$@")"

    # Handle per-command help explicitly, BEFORE positional parsing -
    # otherwise `rename --help` would be interpreted as a new name
    # and rename the auto-selected set to the literal string "--help".
    for a in "$@"; do
        case "$a" in
            -h|--help)
                cat <<EOF
Usage: $SCRIPT_NAME rename [name|uuid] <new-name> [--raid-only]
       $SCRIPT_NAME rename <new-name>              # picks the set interactively

Renames a RAID set's "Name:" field (as shown in 'diskutil appleRAID list').
Non-destructive; no sudo required.

By default also renames mounted volume(s) backed by this RAID:
   - if volume name == old RAID name (in sync) -> renamed automatically
   - if volume name == new RAID name           -> already done; skipped
   - if volume name diverges from both         -> asks interactively
                                                  (yes/no per volume)

Options:
   --raid-only     Rename only the RAID set; never touch volume names.

Rationale: 'diskutil appleRAID create mirror <name> APFS ...' sets BOTH
the RAID set name and the created volume name to <name>, so the symmetric
operation for rename is to update both when they still agree.
EOF
                return 0
                ;;
        esac
    done

    # Parse --raid-only flag out of positional args (preserve spaces in others).
    raid_only=no
    new_args=""
    for a in "$@"; do
        case "$a" in
            --raid-only) raid_only=yes ;;
            *) new_args="$new_args${new_args:+ }$(printf '%s' "$a" | sed "s/'/'\\\\''/g; s/^/'/; s/$/'/")" ;;
        esac
    done
    eval "set -- $new_args"

    if [ $# -lt 1 ]; then
        die "Usage: $SCRIPT_NAME rename [name|uuid] <new-name> [--raid-only]"
    fi

    if [ $# -ge 2 ]; then
        arg="$1"
        new_name="$2"
        uuid=""
        for u in $(raid_list_uuids); do
            [ "$u" = "$arg" ] && uuid="$u" && break
        done
        [ -z "$uuid" ] && uuid=$(raid_name_to_uuid "$arg")
        [ -z "$uuid" ] && die "No RAID set matches '$arg'."
        SELECTED_UUID="$uuid"
    else
        new_name="$1"
        pick_raid_set
    fi

    # Validate new name: non-empty, not a flag, no leading/trailing space.
    if [ -z "$new_name" ]; then
        die "New name must not be empty."
    fi
    case "$new_name" in
        -*) die "New name must not start with '-' (looks like a flag): '$new_name'. Use -- to separate if intentional, or quote the name." ;;
        ' '*|*' ') die "New name must not start or end with whitespace: '$new_name'" ;;
    esac

    # Get current name for the log.
    old_name=$(diskutil appleRAID list 2>/dev/null | awk -F': +' -v u="$SELECTED_UUID" '
        /^Name:/      { cur = $2; sub(/ +$/, "", cur) }
        /^Unique ID:/ { uuid = $2; sub(/ +$/, "", uuid); if (uuid == u) { print cur; exit } }
    ')

    if [ "$old_name" = "$new_name" ]; then
        info "RAID set $SELECTED_UUID is already named '$new_name'; nothing to do."
        return 0
    fi

    # Reject collision with an existing set.
    collision=$(raid_name_to_uuid "$new_name")
    if [ -n "$collision" ] && [ "$collision" != "$SELECTED_UUID" ]; then
        die "Another RAID set is already named '$new_name' (uuid=$collision)."
    fi

    step "RENAME RAID set $SELECTED_UUID: '$old_name' -> '$new_name'"
    if [ "$raid_only" = "yes" ]; then
        info "Mode: --raid-only (volume names will not be touched)."
    else
        info "Mode: dual rename (RAID set + matching mounted volume(s))."
    fi

    run diskutil appleRAID update SetName "$new_name" "$SELECTED_UUID" \
        || die "RAID rename failed"

    ok "RAID set $SELECTED_UUID renamed: '$old_name' -> '$new_name'."

    # ------------------------------------------------------------------
    # Volume rename pass.
    # The RAID's Name field and the file-system volume name(s) are
    # independent: 'diskutil appleRAID create mirror <n> APFS ...' sets
    # both, but later 'diskutil rename' may touch only one. So:
    #   - volume name == old_name  -> they were in sync; rename automatically
    #   - volume name == new_name  -> already in sync with the new name; skip
    #   - anything else (diverged) -> ask interactively
    # ------------------------------------------------------------------
    if [ "$raid_only" != "yes" ]; then
        raid_dev=$(raid_uuid_to_device "$SELECTED_UUID")
        if [ -z "$raid_dev" ]; then
            warn "Could not resolve device node for RAID $SELECTED_UUID; skipping volume scan."
        else
            step "Scanning volumes backed by /dev/$raid_dev"
            vols=$(list_volumes_on_raid "$raid_dev")
            if [ -z "$vols" ]; then
                info "No mounted volumes found on /dev/$raid_dev — nothing to rename."
            else
                printf '%s\n' "$vols" | while IFS='|' read -r vdev vname vmp; do
                    [ -n "$vdev" ] || continue
                    info "Volume: /dev/$vdev  name='$vname'  mount='$vmp'"
                    if [ "$vname" = "$new_name" ]; then
                        info "  -> already named '$new_name'; nothing to do."
                        continue
                    fi
                    if [ "$vname" = "$old_name" ]; then
                        info "  -> in sync with old RAID name; renaming volume to '$new_name'."
                        run diskutil rename "/dev/$vdev" "$new_name" \
                            || warn "  Volume rename failed for /dev/$vdev (continuing)."
                        continue
                    fi
                    warn "  -> name diverges from RAID (volume='$vname', old RAID='$old_name')."
                    # while-loop is fed by a pipe, so use /dev/tty for the
                    # interactive prompt (otherwise confirm's read would
                    # consume the next volume line from the pipe).
                    # If no tty is available (e.g. ssh without -t), default
                    # to safe-skip and tell the user how to control behavior.
                    # Note: '[ -r /dev/tty ]' lies under ssh-without-tty
                    # (file exists but open() fails), so actually attempt
                    # the open in a subshell.
                    if ! ( : < /dev/tty ) 2>/dev/null; then
                        info "  -> non-interactive (no /dev/tty); leaving volume unchanged."
                        info "     Use 'ssh -t' to enable the prompt, --raid-only to suppress it,"
                        info "     or rename manually: diskutil rename /dev/$vdev <new-name>"
                    elif confirm "  Rename this volume to '$new_name' as well?" < /dev/tty; then
                        run diskutil rename "/dev/$vdev" "$new_name" \
                            || warn "  Volume rename failed for /dev/$vdev (continuing)."
                    else
                        info "  -> leaving volume name '$vname' unchanged."
                        info "     (Manual: diskutil rename /dev/$vdev <new-name>)"
                    fi
                done
            fi
        fi
    fi

    step "Post-rename state"
    run diskutil appleRAID list "$SELECTED_UUID"

    # Keep baseline in sync if REQUIRED_SETS=all / auto-baseline is on.
    # Without this, the health daemon would alert for a missing set
    # (the old name disappeared) and an unexpected set (the new name appeared).
    cfg_load 2>/dev/null || true
    if [ "${AUTO_BASELINE_FOR_SETS_ON_CREATE:-no}" = "yes" ] \
       || [ "${AUTO_BASELINE_FOR_SETS_ON_DESTROY:-no}" = "yes" ]; then
        state_init 2>/dev/null || true
        baseline_write_sets
        info "auto-baseline: $(baseline_sets_file) updated (name changed)"
    else
        info "tip: if you're using the health daemon with REQUIRED_SETS=all, run:"
        info "       $SCRIPT_NAME baseline --sets"
        info "     so the daemon picks up the new name."
    fi
}

# ----------------------------------------------------------------------
# Subcommand: destroy
# ----------------------------------------------------------------------
cmd_destroy() {
    if [ $# -ge 1 ]; then
        arg="$1"
        uuid=""
        for u in $(raid_list_uuids); do
            [ "$u" = "$arg" ] && uuid="$u" && break
        done
        [ -z "$uuid" ] && uuid=$(raid_name_to_uuid "$arg")
        [ -z "$uuid" ] && die "No RAID set matches '$arg'."
        SELECTED_UUID="$uuid"
    else
        pick_raid_set
    fi

    step "DESTROY RAID set $SELECTED_UUID"
    run diskutil appleRAID list "$SELECTED_UUID"
    echo
    warn "This will delete the RAID set and make the data inaccessible."
    warn "The member disks will become plain disks again (you can reformat/reuse them)."
    echo

    confirm "First confirmation: destroy this RAID set?" || die "Aborted."
    confirm "SECOND confirmation: are you ABSOLUTELY sure?" || die "Aborted."

    step "Deleting RAID set"
    run sudo diskutil appleRAID delete "$SELECTED_UUID" \
        || die "RAID deletion failed"

    step "Post-destroy state"
    run diskutil appleRAID list || true
    run diskutil list

    ok "RAID set $SELECTED_UUID destroyed."

    cfg_load 2>/dev/null || true
    if [ "${AUTO_BASELINE_FOR_SETS_ON_DESTROY:-no}" = "yes" ]; then
        state_init 2>/dev/null || true
        # Re-snapshot whatever sets remain - the destroyed one is now gone
        # from `diskutil appleRAID list`, so baseline_write_sets will
        # simply not include it.
        baseline_write_sets
        info "auto-baseline: $(baseline_sets_file) updated (destroyed set removed)"
    else
        info "tip: if you're using the health daemon with REQUIRED_SETS=all, run:"
        info "       $SCRIPT_NAME baseline --sets"
        info "     so the daemon stops alerting about the removed set."
    fi
}

# ----------------------------------------------------------------------
# Zsh completion installer (transparently managed from within the script,
# same pattern as my-plex). Runs on every invocation; idempotent: writes
# nothing if the on-disk file already has the current content.
# ----------------------------------------------------------------------
install_zsh_completions() {
    # Best-effort - never let this fail the run.
    [ -n "${HOME:-}" ] || return 0
    # We install into $HOME/.zsh/completions regardless of EUID. On
    # hosts where the tool is genuinely used as root (e.g. ada), root's
    # interactive shell IS the shell that needs the completion, and
    # /var/root is the right place. On a normal sudo-from-user setup
    # the file lands in /var/root only for that invocation, then a
    # subsequent non-sudo run installs the user's own copy too -
    # that's fine, they're independent files.

    _comp_dir="$HOME/.zsh/completions"
    _comp_file="$_comp_dir/_my-appleRAID"

    _tmp=$(mktemp 2>/dev/null) || return 0
    cat >"$_tmp" <<'COMPLETION_EOF'
#compdef my-appleRAID

_my-appleRAID() {
    local context state line
    typeset -A opt_args

    local -a commands
    commands=(
        'list:List all AppleRAID sets and their members'
        'disks:One line per disk'
        'info:Show detailed info for a RAID set'
        'status:Short status summary (Online / Degraded / ...)'
        'watch:Live-refreshing status'
        'blink:Pulse a disk activity LED to identify the physical drive'
        'eject:Spin down + power off a physical disk so it can be safely disconnected'
        'smart:Detailed SMART drill-down for one disk (history + error log + self-tests)'
        'wipe:Zero first + last 100 MB of /dev/diskN'
        'verify-wipe:Check that first + last 100 MB are zeros'
        'create:Create a new mirror from two disk numbers'
        'repair:Interactive guided repair of a degraded set'
        'test:Run non-destructive tests on a RAID set'
        'destroy:Delete a RAID set (data loss)'
        'rename:Rename a RAID set'
        'autorebuild:Manage AppleRAID AutoRebuild policy (per set)'
        'health:Run a monitoring pass'
        'show-config:Print effective config values'
        'create-config:Write annotated default config to <path>'
        'baseline:Snapshot current sets/disks as expected baseline'
        'report:Human-readable health summary (read-only)'
        'test-alerts:Exercise every alerting channel'
        'install-daemon:Install the LaunchDaemon plist'
        'uninstall-daemon:Unload and remove the LaunchDaemon'
        'daemon-status:Diagnose the daemon'
        'migrate-softraid:Migrate ONE SoftRAID mirror to AppleRAID (auto-releases SoftRAID side)'
        'release-softraid:Tear down a SoftRAID volume without creating an AppleRAID set'
        'uninstall-softraid:Pre/post-flight verification for SoftRAID removal'
        'help:Show help (use help <command> for details)'
    )

    local -a global_opts
    global_opts=(
        '(-V --verbose)'{-V,--verbose}'[Show more detail]'
        '(-D --debug)'{-D,--debug}'[Even more detail; implies -V + set -x]'
        '(-h --help)'{-h,--help}'[Show help]'
    )

    _arguments -s : \
        $global_opts \
        '1: :->cmd' \
        '*::arg:->args'

    case "$state" in
        cmd)
            _describe 'command' commands
            ;;
        args)
            case "$line[1]" in
                help|--help|-h)
                    _describe 'help topic' commands
                    ;;
                info|status|watch|destroy|rename|repair)
                    _message 'RAID set name or UUID'
                    ;;
                autorebuild)
                    _arguments \
                        '1: :_message "RAID set name or UUID (or omit for explainer + table)"' \
                        '2: :(on off)'
                    ;;
                test)
                    _arguments \
                        '--all[Test every AppleRAID set; non-zero exit if any fail]' \
                        '*: :_message "RAID set name or UUID"'
                    ;;
                migrate-softraid|release-softraid)
                    _message 'SoftRAID volume name'
                    ;;
                wipe|verify-wipe|blink|eject|smart)
                    _message 'disk number (e.g. 3 for /dev/disk3)'
                    ;;
                create)
                    _message 'name <N1> <N2>'
                    ;;
                create-config)
                    _files
                    ;;
                health)
                    _arguments \
                        '--dry-run[Perform checks, no alerts]' \
                        '--once[Bypass rate limits (testing)]' \
                        '-v[Debug logging for this run]' \
                        '--disk[SMART drill-down for one disk (skip daemon pass)]:disk number:'
                    ;;
                baseline)
                    _arguments \
                        '--sets[Only update set baseline]' \
                        '--disks[Only update disk baseline]' \
                        '--show[Print current baselines only]'
                    ;;
                *)
                    _files
                    ;;
            esac
            ;;
    esac
}

_my-appleRAID "$@"
COMPLETION_EOF

    # Idempotent: only update if content changed.
    _changed=0
    if [ -r "$_comp_file" ] && cmp -s "$_tmp" "$_comp_file" 2>/dev/null; then
        rm -f "$_tmp"
    else
        mkdir -p "$_comp_dir" 2>/dev/null || { rm -f "$_tmp"; return 0; }
        mv "$_tmp" "$_comp_file" 2>/dev/null || { rm -f "$_tmp"; return 0; }
        _changed=1
    fi
    # mktemp creates files at mode 600; compinit's security check then
    # refuses to load them. Match the conventional 644 used by other
    # completion files (e.g. _my-plex). Detect a stale 600 leftover
    # from earlier versions and treat that as 'changed' too, so the
    # zcompdump rebuild below kicks in.
    if [ -r "$_comp_file" ]; then
        case "$(stat -f '%Lp' "$_comp_file" 2>/dev/null)" in
            644) ;;
            *)   chmod 644 "$_comp_file" 2>/dev/null && _changed=1 ;;
        esac
    fi

    # When the completion file was created or updated, invalidate the
    # compinit dump so the next shell rebuilds it - otherwise zsh
    # keeps reusing the stale cache and the new file is ignored.
    if [ "$_changed" = "1" ]; then
        rm -f "$HOME"/.zcompdump* 2>/dev/null || true
    fi

    # Patch ~/.zshrc to add the fpath entry, but only once.
    _zshrc="$HOME/.zshrc"
    [ -f "$_zshrc" ] || return 0
    if grep -q '\.zsh/completions' "$_zshrc" 2>/dev/null; then
        return 0
    fi

    # If oh-my-zsh is loaded, insert fpath BEFORE the source line so
    # compinit (run by oh-my-zsh) picks up the new path. Otherwise
    # append fpath + compinit at the end.
    if grep -q 'oh-my-zsh\.sh' "$_zshrc" 2>/dev/null; then
        _tmp_rc=$(mktemp 2>/dev/null) || return 0
        awk -v cdir="$_comp_dir" '
            !inserted && /oh-my-zsh\.sh/ {
                print "# my-appleRAID zsh completions"
                print "fpath=(" cdir " $fpath)"
                inserted=1
            }
            { print }
        ' "$_zshrc" >"$_tmp_rc" 2>/dev/null \
            && mv "$_tmp_rc" "$_zshrc" 2>/dev/null
        rm -f "$_tmp_rc"
    else
        {
            printf '\n# my-appleRAID zsh completions\n'
            printf 'fpath=(%s $fpath)\n' "$_comp_dir"
            printf 'autoload -Uz compinit && compinit\n'
        } >>"$_zshrc" 2>/dev/null || true
    fi
}

# ----------------------------------------------------------------------
# Main dispatch
# ----------------------------------------------------------------------
main() {
    preflight

    # Global flags (-V/--verbose, -D/--debug) can appear before OR after
    # the subcommand name. Strip them here; subcommands also re-parse
    # their own argv via parse_global_flags so both positions work.
    eval "$(parse_global_flags "$@")"

    # Enable shell tracing AFTER flag parsing so the parser itself
    # doesn't pollute the trace output. PS4 adds a line-number prefix
    # so each traced line shows where it lives in the script.
    if [ "$DEBUG" = "1" ]; then
        PS4='+[L${LINENO}] '
        export PS4
        set -x
    fi

    if [ $# -lt 1 ]; then
        cmd_help
        exit 0
    fi

    cmd="$1"
    shift

    case "$cmd" in
        help|--help|-h|-\?) cmd_help ;;
        list)               cmd_list "$@" ;;
        disks)              cmd_disks "$@" ;;
