# ----------------------------------------------------------------------
# Subcommand: list
# ----------------------------------------------------------------------
cmd_list() {
    step "Listing AppleRAID sets"
    explain "Command: diskutil appleRAID list"
    explain "Shows all AppleRAID sets (mirrors, stripes, concats) and each member's status."
    explain "An extra 'File System:' line is injected per set, derived from"
    explain "diskutil info on the set's virtual device node."
    echo
    printf '%s$ diskutil appleRAID list%s\n' "${C_BOLD}" "${C_RESET}"
    diskutil appleRAID list 2>&1 | while IFS= read -r line; do
        printf '%s\n' "$line"
        case "$line" in
            "Device Node:"*)
                dev=$(printf '%s\n' "$line" | awk '{print $NF}')
                [ -n "$dev" ] || continue
                dinfo=$(diskutil info "/dev/$dev" 2>/dev/null) || continue
                fs=$(printf '%s\n' "$dinfo" | awk -F': *' '/^ *File System Personality:/ {print $2; exit}')
                # APFS-as-RAID has no FS Personality but Type (Bundle)=apfs.
                if [ -z "$fs" ]; then
                    bundle=$(printf '%s\n' "$dinfo" | awk -F': *' '/^ *Type \(Bundle\):/ {print $2; exit}')
                    case "$bundle" in
                        apfs) fs="APFS Container" ;;
                        "")   ;;
                        *)    fs="$bundle" ;;
                    esac
                fi
                # Fall through to the "Name (User Visible)" friendly name.
                if [ -z "$fs" ]; then
                    fs=$(printf '%s\n' "$dinfo" | awk -F': *' '/^ *Name \(User Visible\):/ {print $2; exit}')
                fi
                [ -z "$fs" ] && fs="(none / unformatted)"
                printf 'File System:          %s\n' "$fs"
                ;;
        esac
    done
}

# ----------------------------------------------------------------------
# Subcommand: disks
# Detail levels (controlled by GLOBAL -V/-D flags):
#   (default)              compact one-liner: DEV LOC KIND SIZE MODEL ROLE
#   -V / --verbose         extended: adds SERIAL TEMP SMART ROT TRIM PROTOCOL
#                          (requires smartctl for TEMP / SMART / ROT)
#   -D / --debug           full 'diskutil list' output (every partition)
# ----------------------------------------------------------------------
cmd_disks() {
    # Strip global flags that may appear after the subcommand.
    eval "$(parse_global_flags "$@")"

    # Any non-flag positional args to disks are currently unsupported,
    # but we accept -h gracefully.
    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help)
                cat <<EOF
Usage: $SCRIPT_NAME disks [-V | -D]

Detail levels:
  (default)       compact: DEV LOC KIND SIZE MODEL ROLE
  -V, --verbose   extended: adds SERIAL TEMP SMART ROT TRIM PROTOCOL
                  (TEMP/SMART/ROT require smartctl)
  -D, --debug     full 'diskutil list' output (every partition/slice)
EOF
                return 0
                ;;
            *) warn "Unknown option: $1" ;;
        esac
        shift
    done

    if [ "$DEBUG" = "1" ]; then
        step "Listing all disks (full diskutil list)"
        explain "Command: diskutil list"
        explain "Shows every block device: physical, virtual (RAID, APFS), and synthesized."
        echo
        run diskutil list
        return 0
    fi

    if [ "$VERBOSE" = "1" ]; then
        step "Disks (extended)"
        explain "Use '$SCRIPT_NAME disks' for compact view, or '-D' for full 'diskutil list'."
        if ! command -v smartctl >/dev/null 2>&1; then
            warn "smartctl not installed - TEMP / SMART / ROT columns will be '-'"
            warn "  Fix:  brew install smartmontools"
        fi
    else
        step "Disks (compact)"
        explain "Use '$SCRIPT_NAME disks -V' for extended info, or '-D' for full 'diskutil list'."
    fi
    echo

    # Build a "disk -> RAID set name" lookup for the Role column.
    raid_map=$(diskutil appleRAID list 2>/dev/null | awk -F': +' '
        /^Name:/ { setname = $2; sub(/ +$/, "", setname) }
        /^[ ]*[0-9]+[ \t]+disk[0-9]+/ {
            nf = split($0, parts, /[ \t]+/)
            for (i = 1; i <= nf; i++) {
                if (parts[i] ~ /^disk[0-9]+(s[0-9]+)?$/) {
                    dev = parts[i]
                    sub(/s[0-9]+$/, "", dev)
                    print dev "|" setname
                    break
                }
            }
        }
    ')

    # Header
    if [ "$VERBOSE" = "1" ]; then
        printf '  %-8s %-9s %-4s %9s  %-24s  %-18s %5s %-6s %-4s %-4s %-10s %s\n' \
            "DEV" "LOC" "KIND" "SIZE" "MODEL" "SERIAL" "TEMP" "SMART" "ROT" "TRIM" "PROTOCOL" "ROLE"
        printf '  %-8s %-9s %-4s %9s  %-24s  %-18s %5s %-6s %-4s %-4s %-10s %s\n' \
            "---" "---" "----" "----" "-----" "------" "----" "-----" "---" "----" "--------" "----"
    else
        printf '  %-8s %-9s %-4s %9s  %-28s %s\n' \
            "DEV" "LOC" "KIND" "SIZE" "MODEL" "ROLE"
        printf '  %-8s %-9s %-4s %9s  %-28s %s\n' \
            "---" "---" "----" "----" "-----" "----"
    fi

    # Capture the disk list FIRST into a variable, then iterate with
    # a for-loop rather than a `while read`. This avoids the classic
    # POSIX hazard where subshells inside `while read -r d; do ... done`
    # inherit stdin from the enclosing pipe - commands like smartctl
    # consume the remaining input and truncate the loop.
    disks_list=$(diskutil list 2>/dev/null | awk '/^\/dev\/disk[0-9]+/ {
        sub(/:$/, "", $1)
        sub(/^\/dev\//, "", $1)
        print $1
    }')

    for d in $disks_list; do
        [ -n "$d" ] || continue
        dev="/dev/$d"
        info_out=$(diskutil info "$dev" 2>/dev/null) || continue

        size=$(echo "$info_out" | awk -F': +' '
            /Disk Size:/ { print $2; exit }
            /Total Size:/ { print $2; exit }
        ')
        size=$(echo "$size" | sed 's/ *(.*)//; s/[[:space:]]*$//')

        virtual=$(echo "$info_out"  | awk -F': +' '/Virtual:/      {print $2; exit}')
        solid=$(echo "$info_out"    | awk -F': +' '/Solid State:/  {print $2; exit}')
        protocol=$(echo "$info_out" | awk -F': +' '/Protocol:/     {print $2; exit}')
        if   [ "$virtual"  = "Yes" ];        then kind="virt"
        elif [ "$protocol" = "Disk Image" ]; then kind="img"
        elif [ "$solid"    = "Yes" ];        then kind="SSD"
        else                                       kind="HDD"
        fi

        loc=$(echo "$info_out" | awk -F': +' '/Device Location:/ {print $2; exit}')
        [ -z "$loc" ] && loc=$(echo "$info_out" | awk -F': +' '/Internal:/ {print ($2=="Yes"?"Internal":"External"); exit}')
        loc=$(echo "$loc" | awk '{print $1}')

        model=$(echo "$info_out" | awk -F': +' '/Device \/ Media Name:/ {print $2; exit}')
        [ -z "$model" ] && model=$(echo "$info_out" | awk -F': +' '/Media Name:/ {print $2; exit}')
        [ -z "$model" ] && model="-"

        role=""
        hit=$(printf '%s\n' "$raid_map" | awk -F'|' -v d="$d" '$1==d {print $2; exit}')
        if [ -n "$hit" ]; then
            role="RAID member ($hit)"
        else
            is_raid_virt=$(echo "$info_out" | awk -F': +' '/AppleRAID Set:/ {print "yes"; exit}')
            if [ "$is_raid_virt" = "yes" ]; then
                set_name=$(echo "$info_out" | awk -F': +' '/AppleRAID Set Name:/ {print $2; exit}')
                [ -z "$set_name" ] && set_name="RAID set"
                role="RAID virtual ($set_name)"
            else
                is_apfs=$(echo "$info_out" | awk -F': +' '/File System Personality:/ {print $2; exit}')
                case "$is_apfs" in
                    *APFS*) role="APFS" ;;
                    *)      role="-" ;;
                esac
            fi
        fi

        if [ "$VERBOSE" = "1" ]; then
            serial=$(disk_serial "$d")
            [ -z "$serial" ] && serial="-"
            serial=$(printf '%s' "$serial" | cut -c1-18)

            trim=$(echo "$info_out" | awk -F': +' '/TRIM Support:/ {print $2; exit}')
            case "$trim" in
                Yes) trim="yes" ;;
                No)  trim="no"  ;;
                *)   trim="-"   ;;
            esac

            proto_short=$(echo "$protocol" | cut -c1-10)
            [ -z "$proto_short" ] && proto_short="-"

            temp="-"; smart="-"; rot="-"
            if command -v smartctl >/dev/null 2>&1 && [ "$virtual" != "Yes" ]; then
                # IMPORTANT: every $(...) below inherits stdin from the
                # enclosing `while read -r d` loop's pipe. smartctl reads
                # stdin (it tries to open the device only, but the shell
                # still attaches stdin before exec), which CONSUMES the
                # remaining disk names and causes the loop to exit after
                # one iteration. Redirect stdin from /dev/null on every
                # call to prevent this.
                sc=$(smart_cmd "$d" </dev/null 2>/dev/null)
                [ -z "$sc" ] && sc="smartctl"
                attrs=$($sc -A "$dev" </dev/null 2>/dev/null)
                health_raw=$($sc -H "$dev" </dev/null 2>/dev/null | awk -F': *' '
                    /SMART overall-health/ { print $2; exit }
                    /SMART Health Status/  { print $2; exit }')
                health_raw=$(echo "$health_raw" | sed 's/^ *//;s/ *$//')
                case "$health_raw" in
                    PASSED|OK) smart="OK" ;;
                    '')        smart="-"  ;;
                    *)         smart="$(printf '%s' "$health_raw" | cut -c1-6)" ;;
                esac
                temp=$(echo "$attrs" | awk '
                    /^[[:space:]]*(194|190)[[:space:]]+Temperature/ { print $10 "C"; exit }
                ')
                [ -z "$temp" ] && temp="-"
                rot=$($sc -i "$dev" </dev/null 2>/dev/null | awk -F': +' '/Rotation Rate:/ {
                    gsub(/ *rpm.*/, "", $2); print $2; exit
                }')
                case "$rot" in
                    "")                       rot="-" ;;
                    "Solid State Device")     rot="SSD" ;;
                esac
            fi

            printf '  %-8s %-9s %-4s %9s  %-24.24s  %-18s %5s %-6s %-4s %-4s %-10s %s\n' \
                "$d" "${loc:-?}" "$kind" "$size" "$model" "$serial" "$temp" "$smart" "$rot" "$trim" "$proto_short" "$role"
        else
            model_c=$(printf '%s' "$model" | cut -c1-28)
            printf '  %-8s %-9s %-4s %9s  %-28s %s\n' \
                "$d" "${loc:-?}" "$kind" "$size" "$model_c" "$role"
        fi
    done
}

# ----------------------------------------------------------------------
# Subcommand: info
# ----------------------------------------------------------------------
cmd_info() {
    if [ $# -ge 1 ]; then
        arg="$1"
        # Try as UUID first, then as name.
        uuid=""
        for u in $(raid_list_uuids); do
            [ "$u" = "$arg" ] && uuid="$u" && break
        done
        [ -z "$uuid" ] && uuid=$(raid_name_to_uuid "$arg")
        [ -z "$uuid" ] && die "No RAID set matches '$arg'."
        SELECTED_UUID="$uuid"
    else
        pick_raid_set
    fi

    step "RAID set details: $SELECTED_UUID"
    dev=$(raid_uuid_to_device "$SELECTED_UUID")

    explain "Command: diskutil appleRAID list <uuid>"
    echo
    run diskutil appleRAID list "$SELECTED_UUID"

    if [ -n "$dev" ]; then
        echo
        step "Virtual device backing the RAID set: /dev/$dev"
        explain "Command: diskutil info /dev/$dev"
        echo
        run diskutil info "/dev/$dev"
    fi
}

# ----------------------------------------------------------------------
# Subcommand: status
# ----------------------------------------------------------------------
cmd_status() {
    if [ $# -ge 1 ]; then
        arg="$1"
        uuid=""
        for u in $(raid_list_uuids); do
            [ "$u" = "$arg" ] && uuid="$u" && break
        done
        [ -z "$uuid" ] && uuid=$(raid_name_to_uuid "$arg")
        [ -z "$uuid" ] && die "No RAID set matches '$arg'."
        uuids="$uuid"
    else
        uuids=$(raid_list_uuids)
    fi

    if [ -z "$uuids" ]; then
        warn "No AppleRAID sets found."
        return 1
    fi

    step "AppleRAID status summary"
    for u in $uuids; do
        name=$(diskutil appleRAID list | awk -F': +' -v u="$u" '
            /^Name:/      { cur = $2; sub(/ +$/, "", cur) }
            /^Unique ID:/ { uuid = $2; sub(/ +$/, "", uuid); if (uuid == u) { print cur; exit } }
        ')
        st=$(raid_status "$u")
        dev=$(raid_uuid_to_device "$u")
        case "$st" in
            Online)    color="$C_GREEN" ;;
            Degraded)  color="$C_YELLOW" ;;
            *)         color="$C_RED" ;;
        esac
        printf '  %-20s  %s%-12s%s  uuid=%s  dev=/dev/%s\n' \
            "$name" "$color" "$st" "$C_RESET" "$u" "$dev"
    done
}

# ----------------------------------------------------------------------
# Subcommand: watch
# ----------------------------------------------------------------------
cmd_watch() {
    if [ $# -ge 1 ]; then
        target="$1"
    else
        target=""
    fi
    info "Refreshing every 10 seconds. Press Ctrl-C to stop."
    sleep 1
    while true; do
        clear 2>/dev/null || printf '\033[2J\033[H'
        printf '%s[%s] AppleRAID status%s\n' "${C_BOLD}" "$(date '+%Y-%m-%d %H:%M:%S')" "${C_RESET}"
        echo
        if [ -n "$target" ]; then
            diskutil appleRAID list "$target" 2>&1 || diskutil appleRAID list 2>&1
        else
            diskutil appleRAID list 2>&1
        fi
        sleep 10
    done
}

# ----------------------------------------------------------------------
# Subcommand: wipe
# ----------------------------------------------------------------------
# Zero first and last 100 MB of a whole disk.
cmd_wipe() {
    [ $# -ge 1 ] || die "Usage: $SCRIPT_NAME wipe <disk-number>"
    dev=$(resolve_disk "$1") || die "Invalid disk spec: $1"
    rdev="/dev/r${dev#/dev/}"

    assert_whole_disk "$dev"
    assert_safe_target "$dev"

    step "Wipe plan for $dev"
    describe_disk "$dev"
    explain "This will:"
    explain "  1. Unmount $dev and any partitions on it."
    explain "  2. Zero the first 100 MB (removes GPT + most RAID/filesystem headers)."
    explain "  3. Zero the last  100 MB (removes backup GPT and tail-stored metadata)."
    explain "  4. Verify both regions are zero."
    explain "Total wipe time: ~2-5 seconds (only 200 MB written, not the whole drive)."
    echo

    confirm "About to WIPE $dev. Continue?" || die "Aborted."

    size_bytes=$(disk_size_bytes "$dev")
    [ -n "$size_bytes" ] || die "Could not determine size of $dev"
    size_mb=$(( size_bytes / 1048576 ))
    seek_mb=$(( size_mb - 100 ))

    info "Disk size: $size_bytes bytes = $size_mb MiB; tail seek = $seek_mb MiB"

    step "Unmounting $dev"
    run sudo diskutil unmountDisk force "$dev" || warn "unmountDisk returned non-zero (may be already unmounted)"

    step "Zeroing first 100 MB of $dev"
    run sudo dd if=/dev/zero of="$rdev" bs=1m count=100 status=progress || die "First-100MB wipe failed"

    step "Zeroing last 100 MB of $dev"
    run sudo dd if=/dev/zero of="$rdev" bs=1m seek=$seek_mb count=100 status=progress || die "Last-100MB wipe failed"

    step "Verifying wipe"
    verify_wipe "$dev" || die "Verification failed"
    ok "Wipe complete and verified for $dev"
}

# Verify first and last 100 MB of a disk are all zero.
# Returns 0 on success, 1 on failure. Prints result.
verify_wipe() {
    dev="$1"
    rdev="/dev/r${dev#/dev/}"
    size_bytes=$(disk_size_bytes "$dev")
    [ -n "$size_bytes" ] || { err "Could not determine size of $dev"; return 1; }
    size_mb=$(( size_bytes / 1048576 ))
    skip_mb=$(( size_mb - 100 ))

    explain "Check 1/2: first 100 MB of $dev"
    show "sudo cmp -n 104857600 $rdev /dev/zero"
    if sudo cmp -n 104857600 "$rdev" /dev/zero >/dev/null 2>&1; then
        first="OK"
    else
        first="FAIL"
    fi

    explain "Check 2/2: last 100 MB of $dev (via dd skip=$skip_mb)"
    show "sudo dd if=$rdev bs=1m skip=$skip_mb count=100 | cmp -n 104857600 - /dev/zero"
    if sudo dd if="$rdev" bs=1m skip=$skip_mb count=100 2>/dev/null \
         | cmp -n 104857600 - /dev/zero >/dev/null 2>&1; then
        last="OK"
    else
        last="FAIL"
    fi

    printf '  first 100 MB: %s\n' "$first"
    printf '  last  100 MB: %s\n' "$last"

    [ "$first" = "OK" ] && [ "$last" = "OK" ]
}

cmd_verify_wipe() {
    [ $# -ge 1 ] || die "Usage: $SCRIPT_NAME verify-wipe <disk-number>"
    dev=$(resolve_disk "$1") || die "Invalid disk spec: $1"
    assert_whole_disk "$dev"
    step "Verifying wipe on $dev"
    if verify_wipe "$dev"; then
        ok "$dev is cleanly zeroed at both ends."
    else
        err "$dev still has non-zero data in first or last 100 MB."
        exit 1
    fi
}

# ----------------------------------------------------------------------
# Subcommand: create
# ----------------------------------------------------------------------
cmd_create() {
    [ $# -ge 3 ] || die "Usage: $SCRIPT_NAME create <name> <disk-num-1> <disk-num-2>"
    name="$1"
    dev1=$(resolve_disk "$2") || die "Invalid disk spec: $2"
    dev2=$(resolve_disk "$3") || die "Invalid disk spec: $3"

    [ "$dev1" = "$dev2" ] && die "Cannot mirror a disk to itself."

    assert_whole_disk "$dev1"
    assert_whole_disk "$dev2"
    assert_safe_target "$dev1"
    assert_safe_target "$dev2"

    step "Create AppleRAID mirror: $name"
    echo "  Member 1:"
    describe_disk "$dev1"
    echo "  Member 2:"
    describe_disk "$dev2"
    echo

    # Size sanity
    s1=$(disk_size_bytes "$dev1")
    s2=$(disk_size_bytes "$dev2")
    if [ -n "$s1" ] && [ -n "$s2" ] && [ "$s1" != "$s2" ]; then
        warn "Disks have different sizes ($s1 vs $s2 bytes). Mirror will use the smaller capacity."
    fi

    explain "This will:"
    explain "  1. WIPE both disks (first and last 100 MB) to remove stale metadata."
    explain "  2. Run 'diskutil appleRAID create mirror $name APFS $dev1 $dev2'."
    explain "  3. Show the resulting configuration."
    explain "The new mirror will appear as a virtual /dev/diskN device with an APFS volume named '$name'."
    echo

    confirm "PROCEED? This erases BOTH disks." || die "Aborted."

    step "Wipe phase: $dev1"
    # Call wipe but auto-confirm by echoing yes into it -- cleaner to call internals directly.
    do_auto_wipe "$dev1"

    step "Wipe phase: $dev2"
    do_auto_wipe "$dev2"

    step "Creating mirror"
    explain "diskutil will:"
    explain "  - Partition each disk with GPT"
    explain "  - Create a ~200MB EFI partition, an Apple_RAID data partition, and an Apple_Boot helper"
    explain "  - Register the Apple_RAID partitions as mirror members"
    explain "  - Format the mirror as APFS and mount it at /Volumes/$name"
    echo
    run sudo diskutil appleRAID create mirror "$name" APFS "$dev1" "$dev2" \
        || die "diskutil appleRAID create failed"

    step "New RAID layout"
    run diskutil appleRAID list

    step "Full disk layout"
    run diskutil list

    ok "Mirror '$name' created successfully."

    # Auto-baseline hook: if the user has opted in (via config or by
    # default), add the new set to the baseline immediately so the
    # health daemon's REQUIRED_SETS=all check knows about it right away.
    cfg_load 2>/dev/null || true
    if [ "${AUTO_BASELINE_FOR_SETS_ON_CREATE:-no}" = "yes" ]; then
        state_init 2>/dev/null || true
        baseline_write_sets
        info "auto-baseline: '$name' added to $(baseline_sets_file)"
    else
        info "tip: if you're using the health daemon with REQUIRED_SETS=all, run:"
        info "       $SCRIPT_NAME baseline --sets"
        info "     to include '$name' in the expected-set baseline."
    fi
}

# Non-interactive wipe used by 'create'. Assumes outer command has
# already obtained user confirmation.
do_auto_wipe() {
    dev="$1"
    rdev="/dev/r${dev#/dev/}"
    size_bytes=$(disk_size_bytes "$dev")
    size_mb=$(( size_bytes / 1048576 ))
    seek_mb=$(( size_mb - 100 ))

    run sudo diskutil unmountDisk force "$dev" || true
    run sudo dd if=/dev/zero of="$rdev" bs=1m count=100 status=progress \
        || die "First-100MB wipe of $dev failed"
    run sudo dd if=/dev/zero of="$rdev" bs=1m seek=$seek_mb count=100 status=progress \
        || die "Last-100MB wipe of $dev failed"
    verify_wipe "$dev" || die "Wipe verification failed for $dev"
    ok "$dev wiped and verified."
}

# ----------------------------------------------------------------------
# Subcommand: repair (interactive guided)
# ----------------------------------------------------------------------
cmd_repair() {
    if [ $# -ge 1 ]; then
        arg="$1"
        uuid=""
        for u in $(raid_list_uuids); do
            [ "$u" = "$arg" ] && uuid="$u" && break
        done
        [ -z "$uuid" ] && uuid=$(raid_name_to_uuid "$arg")
        [ -z "$uuid" ] && die "No RAID set matches '$arg'."
        SELECTED_UUID="$uuid"
    else
        pick_raid_set
    fi

    step "Interactive repair for RAID set $SELECTED_UUID"
    run diskutil appleRAID list "$SELECTED_UUID"
    echo

    st=$(raid_status "$SELECTED_UUID")
    case "$st" in
        Online)
            warn "Set status is Online. No repair is needed."
            confirm "Proceed anyway?" || return 0
            ;;
        Degraded)
            info "Set status is Degraded - repair is appropriate."
            ;;
        "")
            die "Could not determine set status. Aborting."
            ;;
        *)
            warn "Set status: $st (neither Online nor Degraded)."
            confirm "Proceed anyway?" || return 0
            ;;
    esac

    step "Step 1: identify the replacement disk"
    explain "Two scenarios:"
    explain ""
    explain "  A) The SAME drive was temporarily disconnected and has now returned."
    explain "     -> The drive likely still has the old Apple_RAID partition and metadata."
    explain "     -> We should WIPE it clean before re-adding, so repairMirror sees a fresh disk."
    explain ""
    explain "  B) A brand-new replacement drive of the same (or larger) capacity."
    explain "     -> We WIPE it (defensive; removes any leftover metadata from prior use)."
    explain "     -> We add it as the new member."
    explain ""
    explain "Either way, the operation is the same: wipe + repairMirror."
    echo
    info "Current disks on the system:"
    run diskutil list | awk '/^\/dev\/disk[0-9]+ \(external/,/^$/'
    echo
    printf 'Enter the disk NUMBER of the replacement drive (e.g. 3): '
    read -r disknum
    [ -n "$disknum" ] || die "No disk number entered."
    dev=$(resolve_disk "$disknum") || die "Invalid disk spec: $disknum"
    assert_whole_disk "$dev"
    assert_safe_target "$dev"

    step "Replacement disk details"
    describe_disk "$dev"
    echo

    # Size check vs RAID member size.
    # Member line format:
    #   <idx>  <devnode>  <uuid>  <status (1+ words)>  <size-bytes>
    # We can't rely on fixed column count because status may be multi-word
    # during rebuild (e.g. "1% (rebuilding)"). Use $1 digit + $NF as size.
    raid_member_size=$(diskutil appleRAID list "$SELECTED_UUID" 2>/dev/null \
        | awk '/^[0-9]+[ \t]+disk/ {print $NF; exit}')
    new_size=$(disk_size_bytes "$dev")
    if [ -n "$raid_member_size" ] && [ -n "$new_size" ]; then
        info "Existing member size: $raid_member_size bytes"
        info "Replacement size:     $new_size bytes"
        if [ "$new_size" -lt "$raid_member_size" ] 2>/dev/null; then
            err "Replacement is SMALLER than existing member. Cannot proceed."
            exit 1
        fi
    fi

    confirm "Wipe $dev and add it to RAID set $SELECTED_UUID?" || die "Aborted."

    step "Step 2: wipe replacement disk"
    do_auto_wipe "$dev"

    step "Step 3: add disk to mirror (repairMirror)"
    explain "'diskutil appleRAID repairMirror <set-uuid> <device>' will:"
    explain "  - Partition the new disk to match the existing member layout"
    explain "  - Add the Apple_RAID partition as a new mirror member"
    explain "  - Begin rebuilding data onto it"
    explain "The mirror stays mounted and usable during the rebuild (online rebuild)."
    echo
    run sudo diskutil appleRAID repairMirror "$SELECTED_UUID" "$dev" \
        || die "repairMirror failed"

    step "Step 4: post-repair status"
    run diskutil appleRAID list "$SELECTED_UUID"
    echo
    ok "Repair started. Monitor with:  $SCRIPT_NAME watch $SELECTED_UUID"
    info "Rebuild time depends on how much data is on the mirror."
    info "  - Empty mirror: seconds."
    info "  - Full 26 TB mirror at ~250 MB/s: ~24-30 hours."
}

# ----------------------------------------------------------------------
# Subcommand: test
# ----------------------------------------------------------------------
cmd_test() {
    if [ $# -ge 1 ]; then
        arg="$1"
        uuid=""
        for u in $(raid_list_uuids); do
            [ "$u" = "$arg" ] && uuid="$u" && break
        done
        [ -z "$uuid" ] && uuid=$(raid_name_to_uuid "$arg")
        [ -z "$uuid" ] && die "No RAID set matches '$arg'."
        SELECTED_UUID="$uuid"
    else
        pick_raid_set
    fi

    step "Testing RAID set $SELECTED_UUID"
    dev=$(raid_uuid_to_device "$SELECTED_UUID")
    [ -n "$dev" ] || die "Could not find virtual device for this RAID set."

    explain "Tests to run:"
    explain "  T1: RAID status must be 'Online'"
    explain "  T2: all members must be 'Online'"
    explain "  T3: virtual device /dev/$dev must exist"
    explain "  T4: APFS container on the RAID must be mounted"
    explain "  T5: write a small probe file and read it back (non-destructive)"
    echo

    fails=0

    # T1
    step "T1: overall RAID status"
    st=$(raid_status "$SELECTED_UUID")
    if [ "$st" = "Online" ]; then
        ok "Status: $st"
    else
        err "Status: $st (expected Online)"
        fails=$((fails + 1))
    fi

    # T2
    step "T2: member statuses"
    # Member line format (status may be multi-word during rebuild):
    #   <idx>  <devnode>  <uuid>  <status (1+ words)>  <size-bytes>
    # We extract everything between $3 (UUID) and $NF (size) as the status.
    bad_members=$(diskutil appleRAID list "$SELECTED_UUID" 2>/dev/null | awk '
        /^[0-9]+[ \t]+disk/ {
            devnode = $2
            status = ""
            for (i = 4; i < NF; i++) {
                status = (status == "" ? $i : status " " $i)
            }
            if (status != "Online") {
                print devnode " (" status ")"
            }
        }
    ')
    if [ -z "$bad_members" ]; then
        ok "All members are Online."
    else
        err "Non-Online members found:"
        echo "$bad_members" | sed 's/^/    /'
        fails=$((fails + 1))
    fi

    # T3
    step "T3: virtual device /dev/$dev exists"
    if [ -b "/dev/$dev" ] || diskutil info "/dev/$dev" >/dev/null 2>&1; then
        ok "/dev/$dev is present."
    else
        err "/dev/$dev not found."
        fails=$((fails + 1))
    fi

    # T4
    step "T4: find and check mount point"
    # The virtual disk itself isn't directly mounted (it holds an APFS container);
    # the APFS volume inside it is. Walk diskutil list to find the synthesized
    # APFS container whose Physical Store is our RAID virtual device, then find
    # the APFS Volume(s) inside that container.
    #
    # diskutil list layout (relevant portion):
    #   /dev/disk14 (synthesized):
    #      #:                  TYPE NAME              SIZE     IDENTIFIER
    #      0:  APFS Container Scheme -               +26.0 TB  disk14
    #                          Physical Store disk4
    #      1:      APFS Volume BackupGold             872 KB   disk14s1
    #
    # The identifier is always the LAST field on the line.
    apfs_vol=$(diskutil list | awk -v phys="$dev" '
        /^\/dev\/disk[0-9]+ \(synthesized\)/ { in_synth=1; found=0; next }
        /^\/dev\//                           { in_synth=0; found=0; next }
        in_synth && /Physical Store/ {
            for (i=1; i<=NF; i++) if ($i == phys) { found=1 }
            next
        }
        in_synth && found && /APFS Volume/ { print $NF; exit }
    ')
    mp=""
    if [ -n "$apfs_vol" ]; then
        mp=$(diskutil info "/dev/$apfs_vol" 2>/dev/null \
             | awk -F': *' '/Mount Point:/ {print $2; exit}')
    fi
    if [ -n "$mp" ] && [ -d "$mp" ]; then
        ok "APFS volume /dev/$apfs_vol is mounted at: $mp"
    else
        warn "No mounted APFS volume found on RAID set; skipping T5."
        [ -n "$apfs_vol" ] && warn "  (Found APFS volume /dev/$apfs_vol but no mount point.)"
        mp=""
    fi

    # T5
    if [ -n "$mp" ]; then
        step "T5: write/read probe"
        probe="$mp/.appleRAID-test-$$-$(date +%s)"
        payload="appleRAID self-test $(date) $$"
        explain "Writing probe file: $probe"
        if printf '%s\n' "$payload" > "$probe" 2>/dev/null; then
            readback=$(cat "$probe" 2>/dev/null)
            if [ "$readback" = "$payload" ]; then
                ok "Write-then-read succeeded and content matches."
            else
                err "Readback mismatch!"
                fails=$((fails + 1))
            fi
            rm -f "$probe"
        else
            err "Could not write probe file to $probe (permissions? disk full?)"
            fails=$((fails + 1))
        fi
    fi

    echo
    if [ $fails -eq 0 ]; then
        ok "All tests passed."
    else
        err "$fails test(s) failed."
        exit 1
    fi
}

# ----------------------------------------------------------------------
# Subcommand: rename
# ----------------------------------------------------------------------
# Renames a RAID set's "Name:" field (as shown in `diskutil appleRAID list`).
#
# Uses the undocumented `diskutil appleRAID update SetName <new> <uuid>` key.
# The documented update keys are only AutoRebuild and SetTimeout, but SetName
# is accepted by macOS (verified on Darwin 25.x). No sudo required; ownership
# of the RAID set is sufficient.
#
# Does NOT rename the file system volume inside the RAID (e.g. the APFS
# volume at /Volumes/<name>). Those are independent names; rename the
# mounted volume separately with `diskutil rename <mountpoint> <new>`
# if you want them to match.
cmd_rename() {
    # Strip global flags that may appear after the subcommand.
    eval "$(parse_global_flags "$@")"

    # Handle per-command help explicitly, BEFORE positional parsing -
    # otherwise `rename --help` would be interpreted as a new name
    # and rename the auto-selected set to the literal string "--help".
    for a in "$@"; do
        case "$a" in
            -h|--help)
                cat <<EOF
Usage: $SCRIPT_NAME rename [name|uuid] <new-name> [--raid-only]
       $SCRIPT_NAME rename <new-name>              # picks the set interactively

Renames a RAID set's "Name:" field (as shown in 'diskutil appleRAID list').
Non-destructive; no sudo required.

By default also renames mounted volume(s) backed by this RAID:
   - if volume name == old RAID name (in sync) -> renamed automatically
   - if volume name == new RAID name           -> already done; skipped
   - if volume name diverges from both         -> asks interactively
                                                  (yes/no per volume)

Options:
   --raid-only     Rename only the RAID set; never touch volume names.

Rationale: 'diskutil appleRAID create mirror <name> APFS ...' sets BOTH
the RAID set name and the created volume name to <name>, so the symmetric
operation for rename is to update both when they still agree.
EOF
                return 0
                ;;
        esac
    done

    # Parse --raid-only flag out of positional args (preserve spaces in others).
    raid_only=no
    new_args=""
    for a in "$@"; do
        case "$a" in
            --raid-only) raid_only=yes ;;
            *) new_args="$new_args${new_args:+ }$(printf '%s' "$a" | sed "s/'/'\\\\''/g; s/^/'/; s/$/'/")" ;;
        esac
    done
    eval "set -- $new_args"

    if [ $# -lt 1 ]; then
        die "Usage: $SCRIPT_NAME rename [name|uuid] <new-name> [--raid-only]"
    fi

    if [ $# -ge 2 ]; then
        arg="$1"
        new_name="$2"
        uuid=""
        for u in $(raid_list_uuids); do
            [ "$u" = "$arg" ] && uuid="$u" && break
        done
        [ -z "$uuid" ] && uuid=$(raid_name_to_uuid "$arg")
        [ -z "$uuid" ] && die "No RAID set matches '$arg'."
        SELECTED_UUID="$uuid"
    else
        new_name="$1"
        pick_raid_set
    fi

    # Validate new name: non-empty, not a flag, no leading/trailing space.
    if [ -z "$new_name" ]; then
        die "New name must not be empty."
    fi
    case "$new_name" in
        -*) die "New name must not start with '-' (looks like a flag): '$new_name'. Use -- to separate if intentional, or quote the name." ;;
        ' '*|*' ') die "New name must not start or end with whitespace: '$new_name'" ;;
    esac

    # Get current name for the log.
    old_name=$(diskutil appleRAID list 2>/dev/null | awk -F': +' -v u="$SELECTED_UUID" '
        /^Name:/      { cur = $2; sub(/ +$/, "", cur) }
        /^Unique ID:/ { uuid = $2; sub(/ +$/, "", uuid); if (uuid == u) { print cur; exit } }
    ')

    if [ "$old_name" = "$new_name" ]; then
        info "RAID set $SELECTED_UUID is already named '$new_name'; nothing to do."
        return 0
    fi

    # Reject collision with an existing set.
    collision=$(raid_name_to_uuid "$new_name")
    if [ -n "$collision" ] && [ "$collision" != "$SELECTED_UUID" ]; then
        die "Another RAID set is already named '$new_name' (uuid=$collision)."
    fi

    step "RENAME RAID set $SELECTED_UUID: '$old_name' -> '$new_name'"
    if [ "$raid_only" = "yes" ]; then
        info "Mode: --raid-only (volume names will not be touched)."
    else
        info "Mode: dual rename (RAID set + matching mounted volume(s))."
    fi

    run diskutil appleRAID update SetName "$new_name" "$SELECTED_UUID" \
        || die "RAID rename failed"

    ok "RAID set $SELECTED_UUID renamed: '$old_name' -> '$new_name'."

    # ------------------------------------------------------------------
    # Volume rename pass.
    # The RAID's Name field and the file-system volume name(s) are
    # independent: 'diskutil appleRAID create mirror <n> APFS ...' sets
    # both, but later 'diskutil rename' may touch only one. So:
    #   - volume name == old_name  -> they were in sync; rename automatically
    #   - volume name == new_name  -> already in sync with the new name; skip
    #   - anything else (diverged) -> ask interactively
    # ------------------------------------------------------------------
    if [ "$raid_only" != "yes" ]; then
        raid_dev=$(raid_uuid_to_device "$SELECTED_UUID")
        if [ -z "$raid_dev" ]; then
            warn "Could not resolve device node for RAID $SELECTED_UUID; skipping volume scan."
        else
            step "Scanning volumes backed by /dev/$raid_dev"
            vols=$(list_volumes_on_raid "$raid_dev")
            if [ -z "$vols" ]; then
                info "No mounted volumes found on /dev/$raid_dev — nothing to rename."
            else
                printf '%s\n' "$vols" | while IFS='|' read -r vdev vname vmp; do
                    [ -n "$vdev" ] || continue
                    info "Volume: /dev/$vdev  name='$vname'  mount='$vmp'"
                    if [ "$vname" = "$new_name" ]; then
                        info "  -> already named '$new_name'; nothing to do."
                        continue
                    fi
                    if [ "$vname" = "$old_name" ]; then
                        info "  -> in sync with old RAID name; renaming volume to '$new_name'."
                        run diskutil rename "/dev/$vdev" "$new_name" \
                            || warn "  Volume rename failed for /dev/$vdev (continuing)."
                        continue
                    fi
                    warn "  -> name diverges from RAID (volume='$vname', old RAID='$old_name')."
                    # while-loop is fed by a pipe, so use /dev/tty for the
                    # interactive prompt (otherwise confirm's read would
                    # consume the next volume line from the pipe).
                    # If no tty is available (e.g. ssh without -t), default
                    # to safe-skip and tell the user how to control behavior.
                    # Note: '[ -r /dev/tty ]' lies under ssh-without-tty
                    # (file exists but open() fails), so actually attempt
                    # the open in a subshell.
                    if ! ( : < /dev/tty ) 2>/dev/null; then
                        info "  -> non-interactive (no /dev/tty); leaving volume unchanged."
                        info "     Use 'ssh -t' to enable the prompt, --raid-only to suppress it,"
                        info "     or rename manually: diskutil rename /dev/$vdev <new-name>"
                    elif confirm "  Rename this volume to '$new_name' as well?" < /dev/tty; then
                        run diskutil rename "/dev/$vdev" "$new_name" \
                            || warn "  Volume rename failed for /dev/$vdev (continuing)."
                    else
                        info "  -> leaving volume name '$vname' unchanged."
                        info "     (Manual: diskutil rename /dev/$vdev <new-name>)"
                    fi
                done
            fi
        fi
    fi

    step "Post-rename state"
    run diskutil appleRAID list "$SELECTED_UUID"

    # Keep baseline in sync if REQUIRED_SETS=all / auto-baseline is on.
    # Without this, the health daemon would alert for a missing set
    # (the old name disappeared) and an unexpected set (the new name appeared).
    cfg_load 2>/dev/null || true
    if [ "${AUTO_BASELINE_FOR_SETS_ON_CREATE:-no}" = "yes" ] \
       || [ "${AUTO_BASELINE_FOR_SETS_ON_DESTROY:-no}" = "yes" ]; then
        state_init 2>/dev/null || true
        baseline_write_sets
        info "auto-baseline: $(baseline_sets_file) updated (name changed)"
    else
        info "tip: if you're using the health daemon with REQUIRED_SETS=all, run:"
        info "       $SCRIPT_NAME baseline --sets"
        info "     so the daemon picks up the new name."
    fi
}

# ----------------------------------------------------------------------
# Subcommand: destroy
# ----------------------------------------------------------------------
cmd_destroy() {
    if [ $# -ge 1 ]; then
        arg="$1"
        uuid=""
        for u in $(raid_list_uuids); do
            [ "$u" = "$arg" ] && uuid="$u" && break
        done
        [ -z "$uuid" ] && uuid=$(raid_name_to_uuid "$arg")
        [ -z "$uuid" ] && die "No RAID set matches '$arg'."
        SELECTED_UUID="$uuid"
    else
        pick_raid_set
    fi

    step "DESTROY RAID set $SELECTED_UUID"
    run diskutil appleRAID list "$SELECTED_UUID"
    echo
    warn "This will delete the RAID set and make the data inaccessible."
    warn "The member disks will become plain disks again (you can reformat/reuse them)."
    echo

    confirm "First confirmation: destroy this RAID set?" || die "Aborted."
    confirm "SECOND confirmation: are you ABSOLUTELY sure?" || die "Aborted."

    step "Deleting RAID set"
    run sudo diskutil appleRAID delete "$SELECTED_UUID" \
        || die "RAID deletion failed"

    step "Post-destroy state"
    run diskutil appleRAID list || true
    run diskutil list

    ok "RAID set $SELECTED_UUID destroyed."

    cfg_load 2>/dev/null || true
    if [ "${AUTO_BASELINE_FOR_SETS_ON_DESTROY:-no}" = "yes" ]; then
        state_init 2>/dev/null || true
        # Re-snapshot whatever sets remain - the destroyed one is now gone
        # from `diskutil appleRAID list`, so baseline_write_sets will
        # simply not include it.
        baseline_write_sets
        info "auto-baseline: $(baseline_sets_file) updated (destroyed set removed)"
    else
        info "tip: if you're using the health daemon with REQUIRED_SETS=all, run:"
        info "       $SCRIPT_NAME baseline --sets"
        info "     so the daemon stops alerting about the removed set."
    fi
}

# ----------------------------------------------------------------------
# Main dispatch
# ----------------------------------------------------------------------
main() {
    preflight

    # Global flags (-V/--verbose, -D/--debug) can appear before OR after
    # the subcommand name. Strip them here; subcommands also re-parse
    # their own argv via parse_global_flags so both positions work.
    eval "$(parse_global_flags "$@")"

    # Enable shell tracing AFTER flag parsing so the parser itself
    # doesn't pollute the trace output.
    if [ "$DEBUG" = "1" ]; then
        set -x
    fi

    if [ $# -lt 1 ]; then
        cmd_help
        exit 0
    fi

    cmd="$1"
    shift

    case "$cmd" in
        help|--help|-h|-\?) cmd_help ;;
        list)               cmd_list "$@" ;;
        disks)              cmd_disks "$@" ;;
        info)               cmd_info "$@" ;;
        status)             cmd_status "$@" ;;
        watch)              cmd_watch "$@" ;;
        wipe)               cmd_wipe "$@" ;;
        verify-wipe)        cmd_verify_wipe "$@" ;;
        create)             cmd_create "$@" ;;
        repair)             cmd_repair "$@" ;;
        test)               cmd_test "$@" ;;
        destroy)            cmd_destroy "$@" ;;
        rename)             cmd_rename "$@" ;;
        health)             cmd_health "$@" ;;
        show-config)        cmd_show_config "$@" ;;
        create-config)      cmd_create_config "$@" ;;
        baseline)           cmd_baseline "$@" ;;
        report)             cmd_report "$@" ;;
        test-alerts)        cmd_test_alerts "$@" ;;
        install-daemon)     cmd_install_daemon "$@" ;;
        uninstall-daemon)   cmd_uninstall_daemon "$@" ;;
        daemon-status)      cmd_daemon_status "$@" ;;
        migrate-softraid)   cmd_migrate_softraid "$@" ;;
        uninstall-softraid) cmd_uninstall_softraid "$@" ;;
        *)
            err "Unknown command: $cmd"
            echo
            cmd_help
            exit 2
            ;;
    esac
}

main "$@"
