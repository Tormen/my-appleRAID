# ----------------------------------------------------------------------
# Subcommand: info
# ----------------------------------------------------------------------
cmd_info() {
    if [ $# -ge 1 ]; then
        arg="$1"
        # Try as UUID first, then as name.
        uuid=""
        for u in $(raid_list_uuids); do
            [ "$u" = "$arg" ] && uuid="$u" && break
        done
        [ -z "$uuid" ] && uuid=$(raid_name_to_uuid "$arg")
        [ -z "$uuid" ] && die "No RAID set matches '$arg'."
        SELECTED_UUID="$uuid"
    else
        pick_raid_set
    fi

    step "RAID set details: $SELECTED_UUID"
    dev=$(raid_uuid_to_device "$SELECTED_UUID")

    explain "Command: diskutil appleRAID list <uuid>"
    echo
    run diskutil appleRAID list "$SELECTED_UUID"

    if [ -n "$dev" ]; then
        echo
        step "Virtual device backing the RAID set: /dev/$dev"
        explain "Command: diskutil info /dev/$dev"
        echo
        run diskutil info "/dev/$dev"
    fi
}

# ----------------------------------------------------------------------
# Subcommand: status
# ----------------------------------------------------------------------
cmd_status() {
    if [ $# -ge 1 ]; then
        arg="$1"
        uuid=""
        for u in $(raid_list_uuids); do
            [ "$u" = "$arg" ] && uuid="$u" && break
        done
        [ -z "$uuid" ] && uuid=$(raid_name_to_uuid "$arg")
        [ -z "$uuid" ] && die "No RAID set matches '$arg'."
        uuids="$uuid"
    else
        uuids=$(raid_list_uuids)
    fi

    if [ -z "$uuids" ]; then
        warn "No AppleRAID sets found."
        return 1
    fi

    step "AppleRAID status summary"
    for u in $uuids; do
        name=$(diskutil appleRAID list | awk -v u="$u" '
            /^Name:/      { cur = $2 }
            /^Unique ID:/ { if ($3 == u) { print cur; exit } }
        ')
        st=$(raid_status "$u")
        dev=$(raid_uuid_to_device "$u")
        case "$st" in
            Online)    color="$C_GREEN" ;;
            Degraded)  color="$C_YELLOW" ;;
            *)         color="$C_RED" ;;
        esac
        printf '  %-20s  %s%-12s%s  uuid=%s  dev=/dev/%s\n' \
            "$name" "$color" "$st" "$C_RESET" "$u" "$dev"
    done
}

# ----------------------------------------------------------------------
# Subcommand: watch
# ----------------------------------------------------------------------
cmd_watch() {
    if [ $# -ge 1 ]; then
        target="$1"
    else
        target=""
    fi
    info "Refreshing every 10 seconds. Press Ctrl-C to stop."
    sleep 1
    while true; do
        clear 2>/dev/null || printf '\033[2J\033[H'
        printf '%s[%s] AppleRAID status%s\n' "${C_BOLD}" "$(date '+%Y-%m-%d %H:%M:%S')" "${C_RESET}"
        echo
        if [ -n "$target" ]; then
            diskutil appleRAID list "$target" 2>&1 || diskutil appleRAID list 2>&1
        else
            diskutil appleRAID list 2>&1
        fi
        sleep 10
    done
}

# ----------------------------------------------------------------------
# Subcommand: wipe
# ----------------------------------------------------------------------
# Zero first and last 100 MB of a whole disk.
cmd_wipe() {
    [ $# -ge 1 ] || die "Usage: $SCRIPT_NAME wipe <disk-number>"
    dev=$(resolve_disk "$1") || die "Invalid disk spec: $1"
    rdev="/dev/r${dev#/dev/}"

    assert_whole_disk "$dev"

    step "Wipe plan for $dev"
    describe_disk "$dev"
    explain "This will:"
    explain "  1. Unmount $dev and any partitions on it."
    explain "  2. Zero the first 100 MB (removes GPT + most RAID/filesystem headers)."
    explain "  3. Zero the last  100 MB (removes backup GPT and tail-stored metadata)."
    explain "  4. Verify both regions are zero."
    explain "Total wipe time: ~2-5 seconds (only 200 MB written, not the whole drive)."
    echo

    confirm "About to WIPE $dev. Continue?" || die "Aborted."

    size_bytes=$(disk_size_bytes "$dev")
    [ -n "$size_bytes" ] || die "Could not determine size of $dev"
    size_mb=$(( size_bytes / 1048576 ))
    seek_mb=$(( size_mb - 100 ))

    info "Disk size: $size_bytes bytes = $size_mb MiB; tail seek = $seek_mb MiB"

    step "Unmounting $dev"
    run sudo diskutil unmountDisk force "$dev" || warn "unmountDisk returned non-zero (may be already unmounted)"

    step "Zeroing first 100 MB of $dev"
    run sudo dd if=/dev/zero of="$rdev" bs=1m count=100 status=progress || die "First-100MB wipe failed"

    step "Zeroing last 100 MB of $dev"
    run sudo dd if=/dev/zero of="$rdev" bs=1m seek=$seek_mb count=100 status=progress || die "Last-100MB wipe failed"

    step "Verifying wipe"
    verify_wipe "$dev" || die "Verification failed"
    ok "Wipe complete and verified for $dev"
}

# Verify first and last 100 MB of a disk are all zero.
# Returns 0 on success, 1 on failure. Prints result.
verify_wipe() {
    dev="$1"
    rdev="/dev/r${dev#/dev/}"
    size_bytes=$(disk_size_bytes "$dev")
    [ -n "$size_bytes" ] || { err "Could not determine size of $dev"; return 1; }
    size_mb=$(( size_bytes / 1048576 ))
    skip_mb=$(( size_mb - 100 ))

    explain "Check 1/2: first 100 MB of $dev"
    show "sudo cmp -n 104857600 $rdev /dev/zero"
    if sudo cmp -n 104857600 "$rdev" /dev/zero >/dev/null 2>&1; then
        first="OK"
    else
        first="FAIL"
    fi

    explain "Check 2/2: last 100 MB of $dev (via dd skip=$skip_mb)"
    show "sudo dd if=$rdev bs=1m skip=$skip_mb count=100 | cmp -n 104857600 - /dev/zero"
    if sudo dd if="$rdev" bs=1m skip=$skip_mb count=100 2>/dev/null \
         | cmp -n 104857600 - /dev/zero >/dev/null 2>&1; then
        last="OK"
    else
        last="FAIL"
    fi

    printf '  first 100 MB: %s\n' "$first"
    printf '  last  100 MB: %s\n' "$last"

    [ "$first" = "OK" ] && [ "$last" = "OK" ]
}

cmd_verify_wipe() {
    [ $# -ge 1 ] || die "Usage: $SCRIPT_NAME verify-wipe <disk-number>"
    dev=$(resolve_disk "$1") || die "Invalid disk spec: $1"
    assert_whole_disk "$dev"
    step "Verifying wipe on $dev"
    if verify_wipe "$dev"; then
        ok "$dev is cleanly zeroed at both ends."
    else
        err "$dev still has non-zero data in first or last 100 MB."
        exit 1
    fi
}

# ----------------------------------------------------------------------
# Subcommand: create
# ----------------------------------------------------------------------
cmd_create() {
    [ $# -ge 3 ] || die "Usage: $SCRIPT_NAME create <name> <disk-num-1> <disk-num-2>"
    name="$1"
    dev1=$(resolve_disk "$2") || die "Invalid disk spec: $2"
    dev2=$(resolve_disk "$3") || die "Invalid disk spec: $3"

    [ "$dev1" = "$dev2" ] && die "Cannot mirror a disk to itself."

    assert_whole_disk "$dev1"
    assert_whole_disk "$dev2"

    step "Create AppleRAID mirror: $name"
    echo "  Member 1:"
    describe_disk "$dev1"
    echo "  Member 2:"
    describe_disk "$dev2"
    echo

    # Size sanity
    s1=$(disk_size_bytes "$dev1")
    s2=$(disk_size_bytes "$dev2")
    if [ -n "$s1" ] && [ -n "$s2" ] && [ "$s1" != "$s2" ]; then
        warn "Disks have different sizes ($s1 vs $s2 bytes). Mirror will use the smaller capacity."
    fi

    explain "This will:"
    explain "  1. WIPE both disks (first and last 100 MB) to remove stale metadata."
    explain "  2. Run 'diskutil appleRAID create mirror $name APFS $dev1 $dev2'."
    explain "  3. Show the resulting configuration."
    explain "The new mirror will appear as a virtual /dev/diskN device with an APFS volume named '$name'."
    echo

    confirm "PROCEED? This erases BOTH disks." || die "Aborted."

    step "Wipe phase: $dev1"
    # Call wipe but auto-confirm by echoing yes into it -- cleaner to call internals directly.
    do_auto_wipe "$dev1"

    step "Wipe phase: $dev2"
    do_auto_wipe "$dev2"

    step "Creating mirror"
    explain "diskutil will:"
    explain "  - Partition each disk with GPT"
    explain "  - Create a ~200MB EFI partition, an Apple_RAID data partition, and an Apple_Boot helper"
    explain "  - Register the Apple_RAID partitions as mirror members"
    explain "  - Format the mirror as APFS and mount it at /Volumes/$name"
    echo
    run sudo diskutil appleRAID create mirror "$name" APFS "$dev1" "$dev2" \
        || die "diskutil appleRAID create failed"

    step "New RAID layout"
    run diskutil appleRAID list

    step "Full disk layout"
    run diskutil list

    ok "Mirror '$name' created successfully."
}

# Non-interactive wipe used by 'create'. Assumes outer command has
# already obtained user confirmation.
do_auto_wipe() {
    dev="$1"
    rdev="/dev/r${dev#/dev/}"
    size_bytes=$(disk_size_bytes "$dev")
    size_mb=$(( size_bytes / 1048576 ))
    seek_mb=$(( size_mb - 100 ))

    run sudo diskutil unmountDisk force "$dev" || true
    run sudo dd if=/dev/zero of="$rdev" bs=1m count=100 status=progress \
        || die "First-100MB wipe of $dev failed"
    run sudo dd if=/dev/zero of="$rdev" bs=1m seek=$seek_mb count=100 status=progress \
        || die "Last-100MB wipe of $dev failed"
    verify_wipe "$dev" || die "Wipe verification failed for $dev"
    ok "$dev wiped and verified."
}

# ----------------------------------------------------------------------
# Subcommand: repair (interactive guided)
# ----------------------------------------------------------------------
cmd_repair() {
    if [ $# -ge 1 ]; then
        arg="$1"
        uuid=""
        for u in $(raid_list_uuids); do
            [ "$u" = "$arg" ] && uuid="$u" && break
        done
        [ -z "$uuid" ] && uuid=$(raid_name_to_uuid "$arg")
        [ -z "$uuid" ] && die "No RAID set matches '$arg'."
        SELECTED_UUID="$uuid"
    else
        pick_raid_set
    fi

    step "Interactive repair for RAID set $SELECTED_UUID"
    run diskutil appleRAID list "$SELECTED_UUID"
    echo

    st=$(raid_status "$SELECTED_UUID")
    case "$st" in
        Online)
            warn "Set status is Online. No repair is needed."
            confirm "Proceed anyway?" || return 0
            ;;
        Degraded)
            info "Set status is Degraded - repair is appropriate."
            ;;
        "")
            die "Could not determine set status. Aborting."
            ;;
        *)
            warn "Set status: $st (neither Online nor Degraded)."
            confirm "Proceed anyway?" || return 0
            ;;
    esac

    step "Step 1: identify the replacement disk"
    explain "Two scenarios:"
    explain ""
    explain "  A) The SAME drive was temporarily disconnected and has now returned."
    explain "     -> The drive likely still has the old Apple_RAID partition and metadata."
    explain "     -> We should WIPE it clean before re-adding, so repairMirror sees a fresh disk."
    explain ""
    explain "  B) A brand-new replacement drive of the same (or larger) capacity."
    explain "     -> We WIPE it (defensive; removes any leftover metadata from prior use)."
    explain "     -> We add it as the new member."
    explain ""
    explain "Either way, the operation is the same: wipe + repairMirror."
    echo
    info "Current disks on the system:"
    run diskutil list | awk '/^\/dev\/disk[0-9]+ \(external/,/^$/'
    echo
    printf 'Enter the disk NUMBER of the replacement drive (e.g. 3): '
    read -r disknum
    [ -n "$disknum" ] || die "No disk number entered."
    dev=$(resolve_disk "$disknum") || die "Invalid disk spec: $disknum"
    assert_whole_disk "$dev"

    step "Replacement disk details"
    describe_disk "$dev"
    echo

    # Size check vs RAID member size.
    raid_member_size=$(diskutil appleRAID list "$SELECTED_UUID" 2>/dev/null \
        | awk '/^#/{seen=1;next} seen && NF>=5 {print $5; exit}')
    new_size=$(disk_size_bytes "$dev")
    if [ -n "$raid_member_size" ] && [ -n "$new_size" ]; then
        info "Existing member size: $raid_member_size bytes"
        info "Replacement size:     $new_size bytes"
        if [ "$new_size" -lt "$raid_member_size" ] 2>/dev/null; then
            err "Replacement is SMALLER than existing member. Cannot proceed."
            exit 1
        fi
    fi

    confirm "Wipe $dev and add it to RAID set $SELECTED_UUID?" || die "Aborted."

    step "Step 2: wipe replacement disk"
    do_auto_wipe "$dev"

    step "Step 3: add disk to mirror (repairMirror)"
    explain "'diskutil appleRAID repairMirror <set-uuid> <device>' will:"
    explain "  - Partition the new disk to match the existing member layout"
    explain "  - Add the Apple_RAID partition as a new mirror member"
    explain "  - Begin rebuilding data onto it"
    explain "The mirror stays mounted and usable during the rebuild (online rebuild)."
    echo
    run sudo diskutil appleRAID repairMirror "$SELECTED_UUID" "$dev" \
        || die "repairMirror failed"

    step "Step 4: post-repair status"
    run diskutil appleRAID list "$SELECTED_UUID"
    echo
    ok "Repair started. Monitor with:  $SCRIPT_NAME watch $SELECTED_UUID"
    info "Rebuild time depends on how much data is on the mirror."
    info "  - Empty mirror: seconds."
    info "  - Full 26 TB mirror at ~250 MB/s: ~24-30 hours."
}

