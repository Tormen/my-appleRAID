# ----------------------------------------------------------------------
# Subcommand: help
# ----------------------------------------------------------------------

# Print the section of cmd_help that documents a single subcommand.
# Used as the --help fallback in main() for subcommands that don't have
# their own per-command --help block. Returns 1 if the topic isn't
# found in cmd_help (so main() can fall back to the global cmd_help).
#
# The COMMANDS section of cmd_help is structured as:
#   2-space indent + topic name [+ args]
#                               (continuation lines, deeper indent)
#   2-space indent + NEXT topic name ...
# We strip ANSI colors before matching so this works regardless of
# terminal type.
show_subcmd_help() {
    _topic="$1"
    cmd_help 2>/dev/null | awk -v t="$_topic" '
        function strip(s) { gsub(/\x1b\[[0-9;]*m/, "", s); return s }
        BEGIN { capture = 0; found = 0 }
        {
            line = strip($0)
            # Topic line: starts with exactly 2 spaces + the topic
            # followed by a space, comma, EOL, or "[".
            if (line ~ "^  " t "([ ,[]|$)") {
                capture = 1; found = 1
                print
                next
            }
            # New topic header (2-space indent + alpha, NOT continuation
            # which uses 28+ spaces) ends the block we are capturing.
            if (capture && line ~ /^  [a-zA-Z]/ && line !~ /^   / ) {
                exit
            }
            # Top-level section header (no leading space, capital letter)
            # ends the block.
            if (capture && line ~ /^[A-Z]/) {
                exit
            }
            if (capture) print
        }
        END { if (!found) exit 1 }
    '
}

# Compute the displayed version string. Starts from the embedded
# SCRIPT_VERSION constant (which tracks the latest git tag); if the
# script lives in a git checkout, append a dev-build suffix from
# `git describe --tags --dirty` so users can tell a working-copy
# build apart from a clean tagged release. Fails silently on systems
# without git or outside any repo - in that case the bare embedded
# version is shown.
script_version_string() {
    _v="$SCRIPT_VERSION"
    _sha=""
    # SCRIPT_COMMIT (baked at stamp-version time) is AUTHORITATIVE
    # when set. The runtime `git rev-parse` fallback is ONLY used
    # when SCRIPT_COMMIT is empty. Earlier code consulted git
    # unconditionally, which fired in any checkout the script's
    # directory happened to be inside (e.g. an unrelated config repo
    # on ada) and overwrote the bake with a wrong sha plus '-dirty'.
    if [ -n "${SCRIPT_COMMIT:-}" ]; then
        _sha="$SCRIPT_COMMIT"
    elif command -v git >/dev/null 2>&1; then
        _here=$(cd "$(dirname "$0")" 2>/dev/null && pwd)
        if [ -n "$_here" ] && cd "$_here" 2>/dev/null \
                && git rev-parse --short HEAD >/dev/null 2>&1; then
            _git_sha=$(git rev-parse --short HEAD 2>/dev/null)
            if [ -n "$_git_sha" ]; then
                if ! git diff --quiet 2>/dev/null \
                   || ! git diff --cached --quiet 2>/dev/null; then
                    _git_sha="${_git_sha}-dirty"
                fi
                _sha="$_git_sha"
            fi
        fi
    fi
    [ -n "$_sha" ] && _v="$_v ($_sha)"
    echo "$_v"
}

# 'stamp-version' updates the SCRIPT_COMMIT line in place to the
# current HEAD short sha, then amends the last commit if SCRIPT_COMMIT
# actually changed. The amend is necessary to keep the in-tree script
# self-consistent: SCRIPT_COMMIT points at the commit it lives in.
# Run this as the last step before deploying to ada / any host that
# lacks a git checkout. Idempotent: a no-op if already in sync.
cmd_stamp_version() {
    _here=$(cd "$(dirname "$0")" 2>/dev/null && pwd)
    [ -n "$_here" ] || die "Cannot resolve script directory."
    cd "$_here" || die "Cannot cd to $_here"
    command -v git >/dev/null 2>&1 || die "git not found on PATH"
    git rev-parse --show-toplevel >/dev/null 2>&1 \
        || die "Not in a git repo (script dir: $_here)"
    _self="$_here/$(basename "$0")"
    [ -f "$_self" ] || die "Cannot locate self at: $_self"

    # Refuse to stamp if the working copy has uncommitted changes
    # OTHER than the SCRIPT_COMMIT line itself - we don't want to
    # silently fold in unrelated edits via --amend.
    _other_dirty=$(git diff --name-only -- ':!*' 2>/dev/null \
                 | grep -v "^$(basename "$0")$" || true)
    _self_dirty=$(git diff --name-only -- "$(basename "$0")" 2>/dev/null)
    if [ -n "$_other_dirty" ]; then
        errmsg "Working copy has uncommitted changes in OTHER files:"
        printf '%s\n' "$_other_dirty" | sed 's/^/  /'
        die "Commit or stash those first, then re-run stamp-version."
    fi

    _new_sha=$(git rev-parse --short HEAD)
    _cur_sha=$(awk -F'"' '/^SCRIPT_COMMIT=/ {print $2; exit}' "$_self")
    if [ "$_new_sha" = "$_cur_sha" ]; then
        ok "SCRIPT_COMMIT already matches HEAD ($_new_sha); nothing to do."
        return 0
    fi
    info "Stamping SCRIPT_COMMIT: '$_cur_sha' -> '$_new_sha'"
    # macOS BSD sed: -i requires an extension argument. Use ''.
    sed -i '' "s|^SCRIPT_COMMIT=\"[^\"]*\"|SCRIPT_COMMIT=\"$_new_sha\"|" "$_self" \
        || die "sed -i failed on $_self"

    if git diff --quiet -- "$(basename "$0")"; then
        ok "No change after sed; the file already had '$_new_sha'."
        return 0
    fi

    info "Amending HEAD to include the SCRIPT_COMMIT update."
    run git add "$_self" \
        && run git commit --amend --no-edit --no-verify \
        || die "git amend failed"

    _final_sha=$(git rev-parse --short HEAD)
    ok "Stamped. SCRIPT_COMMIT='$_new_sha'; HEAD is now '$_final_sha'."
    info "Note: amend rewrote HEAD's sha, so SCRIPT_COMMIT lags HEAD by 1."
    info "This is mathematically unavoidable (a commit's sha depends on"
    info "its content, which includes SCRIPT_COMMIT). Re-running stamp-"
    info "version would just produce another off-by-one. Tag at the new"
    info "HEAD; on a deployed copy, --version shows: <tag> ($_new_sha),"
    info "the sha of the tag's PARENT. Run 'git log $_new_sha..HEAD'"
    info "to confirm the only difference is the bake itself."
}

cmd_version() {
    _v=$(script_version_string)
    printf '%s%s%s %s\n' "${C_BOLD}" "$SCRIPT_NAME" "${C_RESET}" "$_v"
    printf '%s\n' "$SCRIPT_COPYRIGHT"
    printf 'License: %s\n' "$SCRIPT_LICENSE_SHORT"
    printf '         %s\n' "$SCRIPT_LICENSE_URL"
    printf '\n'
    printf 'This is free software: you are free to redistribute and modify it\n'
    printf 'under the terms of the GNU General Public License as published by\n'
    printf 'the Free Software Foundation, either version 3 of the License or\n'
    printf '(at your option) any later version.\n'
    printf '\n'
    printf 'This program comes with %sABSOLUTELY NO WARRANTY%s.\n' "${C_BOLD}" "${C_RESET}"
    printf 'Derivative works MUST be released under a compatible copyleft\n'
    printf 'license (this is the "copyleft" obligation of the GPL).\n'
}

cmd_help() {
    cat <<EOF
${C_BOLD}${SCRIPT_NAME}${C_RESET} $(script_version_string) - The Swiss Army knife for disks and RAIDs on macOS
                 (AppleRAID + SoftRAID interop, SMART, launchd watchdog)

${C_BOLD}USAGE${C_RESET}
  ${SCRIPT_NAME} [-V | -D] <command> [arguments]
  ${SCRIPT_NAME} <command> [-V | -D] [arguments]

${C_BOLD}GLOBAL OPTIONS${C_RESET} (accepted before OR after the command name)
  ${C_CYAN}-V${C_RESET}, ${C_CYAN}--verbose${C_RESET}            Show more detail. Sets LOG_LEVEL=debug.
                              Per-command: extended views where applicable.
  ${C_CYAN}-D${C_RESET}, ${C_CYAN}--debug${C_RESET}              Even more detail. Implies -V, plus shell
                              tracing (set -x with line-number prefix:
                              '+[L1234] cmd ...') and raw internal dumps.

${C_BOLD}COMMANDS${C_RESET}
  ${C_CYAN}list${C_RESET}                        Compact one-line-per-RAID summary covering both
                              AppleRAID sets AND SoftRAID volumes (level,
                              state, FS, size+free, mount, members).
                                -V    Show full 'diskutil appleRAID list'
                                      dump first, then the compact summary.
  ${C_CYAN}disks${C_RESET}                       One line per disk.
                                (default)  compact: DEV LOC KIND SIZE MODEL ROLE
                                -V         extended: adds SERIAL TEMP SMART
                                           ROT TRIM PROTOCOL
                                -D         full 'diskutil list' output
  ${C_CYAN}info${C_RESET} [name|uuid] [-V]       Synonym for 'status'.
  ${C_CYAN}create${C_RESET} <name> <N1> <N2> [--force]
                              Create a new APFS mirror from two disk NUMBERS
                              (e.g. '${SCRIPT_NAME} create BackupGold 2 3').
                              Pre-wipes a disk (first + last 100 MB) ONLY when
                              SoftRAID metadata is detected on it (auto, per
                              disk - SoftRAID's signature is sticky and
                              'diskutil appleRAID create' will not clear it).
                              For other disks, no pre-wipe; diskutil repartitions
                              them as part of normal create.
                                --force  Release the target disk(s) from any
                                         AppleRAID set that currently claims
                                         them. Per disk: 'remove' the member
                                         (set stays Degraded with surviving
                                         members), or 'delete' the entire set
                                         only if all of its members are among
                                         the targets. Confirms before any
                                         destructive action.
  ${C_CYAN}blink${C_RESET} [<disk>]                Pulse a disk's activity LED so you can
                              identify which physical drive (or enclosure
                              slot) maps to a /dev/diskN before yanking it.
                              Generates read-only I/O - same trick SoftRAID's
                              "Identify" button uses. Without an argument,
                              shows an interactive picker. Ctrl-C to stop.
  ${C_CYAN}eject${C_RESET} [<disk>] [--release]   Unmount + STANDBY IMMEDIATE (smartctl spin-down)
                              + diskutil eject, so the disk can be
                              safely disconnected. Without an
                              argument, shows an interactive picker.
                              For an active RAID member, plain eject
                              REFUSES (the kernel claim blocks it). Pass
                              --release to ALSO break it from the set
                              (DESTRUCTIVE: set goes Degraded).
